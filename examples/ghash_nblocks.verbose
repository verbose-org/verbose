@verbose 0.1.0

concept GhashState
  @intention: "GHASH fold state: accumulator Y + subkey H (16 bytes each) + block count, counter, which, hex data"
  @source: invoices.intent:1
  fields:
    y0 : number [0, 255]
    y1 : number [0, 255]
    y2 : number [0, 255]
    y3 : number [0, 255]
    y4 : number [0, 255]
    y5 : number [0, 255]
    y6 : number [0, 255]
    y7 : number [0, 255]
    y8 : number [0, 255]
    y9 : number [0, 255]
    y10 : number [0, 255]
    y11 : number [0, 255]
    y12 : number [0, 255]
    y13 : number [0, 255]
    y14 : number [0, 255]
    y15 : number [0, 255]
    h0 : number [0, 255]
    h1 : number [0, 255]
    h2 : number [0, 255]
    h3 : number [0, 255]
    h4 : number [0, 255]
    h5 : number [0, 255]
    h6 : number [0, 255]
    h7 : number [0, 255]
    h8 : number [0, 255]
    h9 : number [0, 255]
    h10 : number [0, 255]
    h11 : number [0, 255]
    h12 : number [0, 255]
    h13 : number [0, 255]
    h14 : number [0, 255]
    h15 : number [0, 255]
    nblocks : number [0, 64]
    i : number [0, 64]
    which : number [0, 15]
    data : text


rule ghash_fold
  @intention: "GHASH over N 16-byte blocks (hex data): Y=0; for each block B: Y=(Y xor B)*H. Returns byte which of Y"
  @source: invoices.intent:1
  input:
    s : GhashState
  output:
    out : number
  logic:
    let bidx = if s.i == 0 then 0 else s.nblocks - s.i
    let off = bidx * 32
    let hc_hi0 = byte_at(s.data, off + 0)
    let hc_lo0 = byte_at(s.data, off + 1)
    let hv_hi0 = if hc_hi0 <= 57 then hc_hi0 - 48 else bor(hc_hi0, 32) - 87
    let hv_lo0 = if hc_lo0 <= 57 then hc_lo0 - 48 else bor(hc_lo0, 32) - 87
    let blk0 = 16 * hv_hi0 + hv_lo0
    let hc_hi1 = byte_at(s.data, off + 2)
    let hc_lo1 = byte_at(s.data, off + 3)
    let hv_hi1 = if hc_hi1 <= 57 then hc_hi1 - 48 else bor(hc_hi1, 32) - 87
    let hv_lo1 = if hc_lo1 <= 57 then hc_lo1 - 48 else bor(hc_lo1, 32) - 87
    let blk1 = 16 * hv_hi1 + hv_lo1
    let hc_hi2 = byte_at(s.data, off + 4)
    let hc_lo2 = byte_at(s.data, off + 5)
    let hv_hi2 = if hc_hi2 <= 57 then hc_hi2 - 48 else bor(hc_hi2, 32) - 87
    let hv_lo2 = if hc_lo2 <= 57 then hc_lo2 - 48 else bor(hc_lo2, 32) - 87
    let blk2 = 16 * hv_hi2 + hv_lo2
    let hc_hi3 = byte_at(s.data, off + 6)
    let hc_lo3 = byte_at(s.data, off + 7)
    let hv_hi3 = if hc_hi3 <= 57 then hc_hi3 - 48 else bor(hc_hi3, 32) - 87
    let hv_lo3 = if hc_lo3 <= 57 then hc_lo3 - 48 else bor(hc_lo3, 32) - 87
    let blk3 = 16 * hv_hi3 + hv_lo3
    let hc_hi4 = byte_at(s.data, off + 8)
    let hc_lo4 = byte_at(s.data, off + 9)
    let hv_hi4 = if hc_hi4 <= 57 then hc_hi4 - 48 else bor(hc_hi4, 32) - 87
    let hv_lo4 = if hc_lo4 <= 57 then hc_lo4 - 48 else bor(hc_lo4, 32) - 87
    let blk4 = 16 * hv_hi4 + hv_lo4
    let hc_hi5 = byte_at(s.data, off + 10)
    let hc_lo5 = byte_at(s.data, off + 11)
    let hv_hi5 = if hc_hi5 <= 57 then hc_hi5 - 48 else bor(hc_hi5, 32) - 87
    let hv_lo5 = if hc_lo5 <= 57 then hc_lo5 - 48 else bor(hc_lo5, 32) - 87
    let blk5 = 16 * hv_hi5 + hv_lo5
    let hc_hi6 = byte_at(s.data, off + 12)
    let hc_lo6 = byte_at(s.data, off + 13)
    let hv_hi6 = if hc_hi6 <= 57 then hc_hi6 - 48 else bor(hc_hi6, 32) - 87
    let hv_lo6 = if hc_lo6 <= 57 then hc_lo6 - 48 else bor(hc_lo6, 32) - 87
    let blk6 = 16 * hv_hi6 + hv_lo6
    let hc_hi7 = byte_at(s.data, off + 14)
    let hc_lo7 = byte_at(s.data, off + 15)
    let hv_hi7 = if hc_hi7 <= 57 then hc_hi7 - 48 else bor(hc_hi7, 32) - 87
    let hv_lo7 = if hc_lo7 <= 57 then hc_lo7 - 48 else bor(hc_lo7, 32) - 87
    let blk7 = 16 * hv_hi7 + hv_lo7
    let hc_hi8 = byte_at(s.data, off + 16)
    let hc_lo8 = byte_at(s.data, off + 17)
    let hv_hi8 = if hc_hi8 <= 57 then hc_hi8 - 48 else bor(hc_hi8, 32) - 87
    let hv_lo8 = if hc_lo8 <= 57 then hc_lo8 - 48 else bor(hc_lo8, 32) - 87
    let blk8 = 16 * hv_hi8 + hv_lo8
    let hc_hi9 = byte_at(s.data, off + 18)
    let hc_lo9 = byte_at(s.data, off + 19)
    let hv_hi9 = if hc_hi9 <= 57 then hc_hi9 - 48 else bor(hc_hi9, 32) - 87
    let hv_lo9 = if hc_lo9 <= 57 then hc_lo9 - 48 else bor(hc_lo9, 32) - 87
    let blk9 = 16 * hv_hi9 + hv_lo9
    let hc_hi10 = byte_at(s.data, off + 20)
    let hc_lo10 = byte_at(s.data, off + 21)
    let hv_hi10 = if hc_hi10 <= 57 then hc_hi10 - 48 else bor(hc_hi10, 32) - 87
    let hv_lo10 = if hc_lo10 <= 57 then hc_lo10 - 48 else bor(hc_lo10, 32) - 87
    let blk10 = 16 * hv_hi10 + hv_lo10
    let hc_hi11 = byte_at(s.data, off + 22)
    let hc_lo11 = byte_at(s.data, off + 23)
    let hv_hi11 = if hc_hi11 <= 57 then hc_hi11 - 48 else bor(hc_hi11, 32) - 87
    let hv_lo11 = if hc_lo11 <= 57 then hc_lo11 - 48 else bor(hc_lo11, 32) - 87
    let blk11 = 16 * hv_hi11 + hv_lo11
    let hc_hi12 = byte_at(s.data, off + 24)
    let hc_lo12 = byte_at(s.data, off + 25)
    let hv_hi12 = if hc_hi12 <= 57 then hc_hi12 - 48 else bor(hc_hi12, 32) - 87
    let hv_lo12 = if hc_lo12 <= 57 then hc_lo12 - 48 else bor(hc_lo12, 32) - 87
    let blk12 = 16 * hv_hi12 + hv_lo12
    let hc_hi13 = byte_at(s.data, off + 26)
    let hc_lo13 = byte_at(s.data, off + 27)
    let hv_hi13 = if hc_hi13 <= 57 then hc_hi13 - 48 else bor(hc_hi13, 32) - 87
    let hv_lo13 = if hc_lo13 <= 57 then hc_lo13 - 48 else bor(hc_lo13, 32) - 87
    let blk13 = 16 * hv_hi13 + hv_lo13
    let hc_hi14 = byte_at(s.data, off + 28)
    let hc_lo14 = byte_at(s.data, off + 29)
    let hv_hi14 = if hc_hi14 <= 57 then hc_hi14 - 48 else bor(hc_hi14, 32) - 87
    let hv_lo14 = if hc_lo14 <= 57 then hc_lo14 - 48 else bor(hc_lo14, 32) - 87
    let blk14 = 16 * hv_hi14 + hv_lo14
    let hc_hi15 = byte_at(s.data, off + 30)
    let hc_lo15 = byte_at(s.data, off + 31)
    let hv_hi15 = if hc_hi15 <= 57 then hc_hi15 - 48 else bor(hc_hi15, 32) - 87
    let hv_lo15 = if hc_lo15 <= 57 then hc_lo15 - 48 else bor(hc_lo15, 32) - 87
    let blk15 = 16 * hv_hi15 + hv_lo15
    let t0 = bxor(s.y0, blk0)
    let t1 = bxor(s.y1, blk1)
    let t2 = bxor(s.y2, blk2)
    let t3 = bxor(s.y3, blk3)
    let t4 = bxor(s.y4, blk4)
    let t5 = bxor(s.y5, blk5)
    let t6 = bxor(s.y6, blk6)
    let t7 = bxor(s.y7, blk7)
    let t8 = bxor(s.y8, blk8)
    let t9 = bxor(s.y9, blk9)
    let t10 = bxor(s.y10, blk10)
    let t11 = bxor(s.y11, blk11)
    let t12 = bxor(s.y12, blk12)
    let t13 = bxor(s.y13, blk13)
    let t14 = bxor(s.y14, blk14)
    let t15 = bxor(s.y15, blk15)
    let g_ym0 = if band(s.h0, 128) > 0 then 255 else 0
    let g_z0_0 = bxor(0, band(t0, g_ym0))
    let g_z0_1 = bxor(0, band(t1, g_ym0))
    let g_z0_2 = bxor(0, band(t2, g_ym0))
    let g_z0_3 = bxor(0, band(t3, g_ym0))
    let g_z0_4 = bxor(0, band(t4, g_ym0))
    let g_z0_5 = bxor(0, band(t5, g_ym0))
    let g_z0_6 = bxor(0, band(t6, g_ym0))
    let g_z0_7 = bxor(0, band(t7, g_ym0))
    let g_z0_8 = bxor(0, band(t8, g_ym0))
    let g_z0_9 = bxor(0, band(t9, g_ym0))
    let g_z0_10 = bxor(0, band(t10, g_ym0))
    let g_z0_11 = bxor(0, band(t11, g_ym0))
    let g_z0_12 = bxor(0, band(t12, g_ym0))
    let g_z0_13 = bxor(0, band(t13, g_ym0))
    let g_z0_14 = bxor(0, band(t14, g_ym0))
    let g_z0_15 = bxor(0, band(t15, g_ym0))
    let g_vl0 = band(t15, 1)
    let g_vm0 = if g_vl0 > 0 then 225 else 0
    let g_v0_0 = bxor(shr(t0, 1), g_vm0)
    let g_v0_1 = bor(shr(t1, 1), shl(band(t0, 1), 7))
    let g_v0_2 = bor(shr(t2, 1), shl(band(t1, 1), 7))
    let g_v0_3 = bor(shr(t3, 1), shl(band(t2, 1), 7))
    let g_v0_4 = bor(shr(t4, 1), shl(band(t3, 1), 7))
    let g_v0_5 = bor(shr(t5, 1), shl(band(t4, 1), 7))
    let g_v0_6 = bor(shr(t6, 1), shl(band(t5, 1), 7))
    let g_v0_7 = bor(shr(t7, 1), shl(band(t6, 1), 7))
    let g_v0_8 = bor(shr(t8, 1), shl(band(t7, 1), 7))
    let g_v0_9 = bor(shr(t9, 1), shl(band(t8, 1), 7))
    let g_v0_10 = bor(shr(t10, 1), shl(band(t9, 1), 7))
    let g_v0_11 = bor(shr(t11, 1), shl(band(t10, 1), 7))
    let g_v0_12 = bor(shr(t12, 1), shl(band(t11, 1), 7))
    let g_v0_13 = bor(shr(t13, 1), shl(band(t12, 1), 7))
    let g_v0_14 = bor(shr(t14, 1), shl(band(t13, 1), 7))
    let g_v0_15 = bor(shr(t15, 1), shl(band(t14, 1), 7))
    let g_ym1 = if band(s.h0, 64) > 0 then 255 else 0
    let g_z1_0 = bxor(g_z0_0, band(g_v0_0, g_ym1))
    let g_z1_1 = bxor(g_z0_1, band(g_v0_1, g_ym1))
    let g_z1_2 = bxor(g_z0_2, band(g_v0_2, g_ym1))
    let g_z1_3 = bxor(g_z0_3, band(g_v0_3, g_ym1))
    let g_z1_4 = bxor(g_z0_4, band(g_v0_4, g_ym1))
    let g_z1_5 = bxor(g_z0_5, band(g_v0_5, g_ym1))
    let g_z1_6 = bxor(g_z0_6, band(g_v0_6, g_ym1))
    let g_z1_7 = bxor(g_z0_7, band(g_v0_7, g_ym1))
    let g_z1_8 = bxor(g_z0_8, band(g_v0_8, g_ym1))
    let g_z1_9 = bxor(g_z0_9, band(g_v0_9, g_ym1))
    let g_z1_10 = bxor(g_z0_10, band(g_v0_10, g_ym1))
    let g_z1_11 = bxor(g_z0_11, band(g_v0_11, g_ym1))
    let g_z1_12 = bxor(g_z0_12, band(g_v0_12, g_ym1))
    let g_z1_13 = bxor(g_z0_13, band(g_v0_13, g_ym1))
    let g_z1_14 = bxor(g_z0_14, band(g_v0_14, g_ym1))
    let g_z1_15 = bxor(g_z0_15, band(g_v0_15, g_ym1))
    let g_vl1 = band(g_v0_15, 1)
    let g_vm1 = if g_vl1 > 0 then 225 else 0
    let g_v1_0 = bxor(shr(g_v0_0, 1), g_vm1)
    let g_v1_1 = bor(shr(g_v0_1, 1), shl(band(g_v0_0, 1), 7))
    let g_v1_2 = bor(shr(g_v0_2, 1), shl(band(g_v0_1, 1), 7))
    let g_v1_3 = bor(shr(g_v0_3, 1), shl(band(g_v0_2, 1), 7))
    let g_v1_4 = bor(shr(g_v0_4, 1), shl(band(g_v0_3, 1), 7))
    let g_v1_5 = bor(shr(g_v0_5, 1), shl(band(g_v0_4, 1), 7))
    let g_v1_6 = bor(shr(g_v0_6, 1), shl(band(g_v0_5, 1), 7))
    let g_v1_7 = bor(shr(g_v0_7, 1), shl(band(g_v0_6, 1), 7))
    let g_v1_8 = bor(shr(g_v0_8, 1), shl(band(g_v0_7, 1), 7))
    let g_v1_9 = bor(shr(g_v0_9, 1), shl(band(g_v0_8, 1), 7))
    let g_v1_10 = bor(shr(g_v0_10, 1), shl(band(g_v0_9, 1), 7))
    let g_v1_11 = bor(shr(g_v0_11, 1), shl(band(g_v0_10, 1), 7))
    let g_v1_12 = bor(shr(g_v0_12, 1), shl(band(g_v0_11, 1), 7))
    let g_v1_13 = bor(shr(g_v0_13, 1), shl(band(g_v0_12, 1), 7))
    let g_v1_14 = bor(shr(g_v0_14, 1), shl(band(g_v0_13, 1), 7))
    let g_v1_15 = bor(shr(g_v0_15, 1), shl(band(g_v0_14, 1), 7))
    let g_ym2 = if band(s.h0, 32) > 0 then 255 else 0
    let g_z2_0 = bxor(g_z1_0, band(g_v1_0, g_ym2))
    let g_z2_1 = bxor(g_z1_1, band(g_v1_1, g_ym2))
    let g_z2_2 = bxor(g_z1_2, band(g_v1_2, g_ym2))
    let g_z2_3 = bxor(g_z1_3, band(g_v1_3, g_ym2))
    let g_z2_4 = bxor(g_z1_4, band(g_v1_4, g_ym2))
    let g_z2_5 = bxor(g_z1_5, band(g_v1_5, g_ym2))
    let g_z2_6 = bxor(g_z1_6, band(g_v1_6, g_ym2))
    let g_z2_7 = bxor(g_z1_7, band(g_v1_7, g_ym2))
    let g_z2_8 = bxor(g_z1_8, band(g_v1_8, g_ym2))
    let g_z2_9 = bxor(g_z1_9, band(g_v1_9, g_ym2))
    let g_z2_10 = bxor(g_z1_10, band(g_v1_10, g_ym2))
    let g_z2_11 = bxor(g_z1_11, band(g_v1_11, g_ym2))
    let g_z2_12 = bxor(g_z1_12, band(g_v1_12, g_ym2))
    let g_z2_13 = bxor(g_z1_13, band(g_v1_13, g_ym2))
    let g_z2_14 = bxor(g_z1_14, band(g_v1_14, g_ym2))
    let g_z2_15 = bxor(g_z1_15, band(g_v1_15, g_ym2))
    let g_vl2 = band(g_v1_15, 1)
    let g_vm2 = if g_vl2 > 0 then 225 else 0
    let g_v2_0 = bxor(shr(g_v1_0, 1), g_vm2)
    let g_v2_1 = bor(shr(g_v1_1, 1), shl(band(g_v1_0, 1), 7))
    let g_v2_2 = bor(shr(g_v1_2, 1), shl(band(g_v1_1, 1), 7))
    let g_v2_3 = bor(shr(g_v1_3, 1), shl(band(g_v1_2, 1), 7))
    let g_v2_4 = bor(shr(g_v1_4, 1), shl(band(g_v1_3, 1), 7))
    let g_v2_5 = bor(shr(g_v1_5, 1), shl(band(g_v1_4, 1), 7))
    let g_v2_6 = bor(shr(g_v1_6, 1), shl(band(g_v1_5, 1), 7))
    let g_v2_7 = bor(shr(g_v1_7, 1), shl(band(g_v1_6, 1), 7))
    let g_v2_8 = bor(shr(g_v1_8, 1), shl(band(g_v1_7, 1), 7))
    let g_v2_9 = bor(shr(g_v1_9, 1), shl(band(g_v1_8, 1), 7))
    let g_v2_10 = bor(shr(g_v1_10, 1), shl(band(g_v1_9, 1), 7))
    let g_v2_11 = bor(shr(g_v1_11, 1), shl(band(g_v1_10, 1), 7))
    let g_v2_12 = bor(shr(g_v1_12, 1), shl(band(g_v1_11, 1), 7))
    let g_v2_13 = bor(shr(g_v1_13, 1), shl(band(g_v1_12, 1), 7))
    let g_v2_14 = bor(shr(g_v1_14, 1), shl(band(g_v1_13, 1), 7))
    let g_v2_15 = bor(shr(g_v1_15, 1), shl(band(g_v1_14, 1), 7))
    let g_ym3 = if band(s.h0, 16) > 0 then 255 else 0
    let g_z3_0 = bxor(g_z2_0, band(g_v2_0, g_ym3))
    let g_z3_1 = bxor(g_z2_1, band(g_v2_1, g_ym3))
    let g_z3_2 = bxor(g_z2_2, band(g_v2_2, g_ym3))
    let g_z3_3 = bxor(g_z2_3, band(g_v2_3, g_ym3))
    let g_z3_4 = bxor(g_z2_4, band(g_v2_4, g_ym3))
    let g_z3_5 = bxor(g_z2_5, band(g_v2_5, g_ym3))
    let g_z3_6 = bxor(g_z2_6, band(g_v2_6, g_ym3))
    let g_z3_7 = bxor(g_z2_7, band(g_v2_7, g_ym3))
    let g_z3_8 = bxor(g_z2_8, band(g_v2_8, g_ym3))
    let g_z3_9 = bxor(g_z2_9, band(g_v2_9, g_ym3))
    let g_z3_10 = bxor(g_z2_10, band(g_v2_10, g_ym3))
    let g_z3_11 = bxor(g_z2_11, band(g_v2_11, g_ym3))
    let g_z3_12 = bxor(g_z2_12, band(g_v2_12, g_ym3))
    let g_z3_13 = bxor(g_z2_13, band(g_v2_13, g_ym3))
    let g_z3_14 = bxor(g_z2_14, band(g_v2_14, g_ym3))
    let g_z3_15 = bxor(g_z2_15, band(g_v2_15, g_ym3))
    let g_vl3 = band(g_v2_15, 1)
    let g_vm3 = if g_vl3 > 0 then 225 else 0
    let g_v3_0 = bxor(shr(g_v2_0, 1), g_vm3)
    let g_v3_1 = bor(shr(g_v2_1, 1), shl(band(g_v2_0, 1), 7))
    let g_v3_2 = bor(shr(g_v2_2, 1), shl(band(g_v2_1, 1), 7))
    let g_v3_3 = bor(shr(g_v2_3, 1), shl(band(g_v2_2, 1), 7))
    let g_v3_4 = bor(shr(g_v2_4, 1), shl(band(g_v2_3, 1), 7))
    let g_v3_5 = bor(shr(g_v2_5, 1), shl(band(g_v2_4, 1), 7))
    let g_v3_6 = bor(shr(g_v2_6, 1), shl(band(g_v2_5, 1), 7))
    let g_v3_7 = bor(shr(g_v2_7, 1), shl(band(g_v2_6, 1), 7))
    let g_v3_8 = bor(shr(g_v2_8, 1), shl(band(g_v2_7, 1), 7))
    let g_v3_9 = bor(shr(g_v2_9, 1), shl(band(g_v2_8, 1), 7))
    let g_v3_10 = bor(shr(g_v2_10, 1), shl(band(g_v2_9, 1), 7))
    let g_v3_11 = bor(shr(g_v2_11, 1), shl(band(g_v2_10, 1), 7))
    let g_v3_12 = bor(shr(g_v2_12, 1), shl(band(g_v2_11, 1), 7))
    let g_v3_13 = bor(shr(g_v2_13, 1), shl(band(g_v2_12, 1), 7))
    let g_v3_14 = bor(shr(g_v2_14, 1), shl(band(g_v2_13, 1), 7))
    let g_v3_15 = bor(shr(g_v2_15, 1), shl(band(g_v2_14, 1), 7))
    let g_ym4 = if band(s.h0, 8) > 0 then 255 else 0
    let g_z4_0 = bxor(g_z3_0, band(g_v3_0, g_ym4))
    let g_z4_1 = bxor(g_z3_1, band(g_v3_1, g_ym4))
    let g_z4_2 = bxor(g_z3_2, band(g_v3_2, g_ym4))
    let g_z4_3 = bxor(g_z3_3, band(g_v3_3, g_ym4))
    let g_z4_4 = bxor(g_z3_4, band(g_v3_4, g_ym4))
    let g_z4_5 = bxor(g_z3_5, band(g_v3_5, g_ym4))
