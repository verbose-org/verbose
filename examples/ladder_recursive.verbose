    let csx_b3 = bxor(s.x3_3, csx_t3)
    let csx_t4 = band(csx_mask, bxor(s.x2_4, s.x3_4))
    let csx_a4 = bxor(s.x2_4, csx_t4)
    let csx_b4 = bxor(s.x3_4, csx_t4)
    let csx_t5 = band(csx_mask, bxor(s.x2_5, s.x3_5))
    let csx_a5 = bxor(s.x2_5, csx_t5)
    let csx_b5 = bxor(s.x3_5, csx_t5)
    let csx_t6 = band(csx_mask, bxor(s.x2_6, s.x3_6))
    let csx_a6 = bxor(s.x2_6, csx_t6)
    let csx_b6 = bxor(s.x3_6, csx_t6)
    let csx_t7 = band(csx_mask, bxor(s.x2_7, s.x3_7))
