rule ladder
  @intention: "X25519 Montgomery ladder: 255 recursive steps with cswap + clamped scalar bit; returns limb which of final (x2|z2)"
  @source: invoices.intent:1
  input:
    s : LadderState
  output:
    out : number
  logic:
    let idx = if s.i == 0 then 0 else s.i - 1
    let b_B = shr(idx, 3)
    let b_pos = shl(b_B, 1)
    let b_hi = byte_at(s.scalar, b_pos)
    let b_lo = byte_at(s.scalar, b_pos + 1)
    let b_hv = if b_hi <= 57 then b_hi - 48 else bor(b_hi, 32) - 87
    let b_lv = if b_lo <= 57 then b_lo - 48 else bor(b_lo, 32) - 87
    let b_byte = 16 * b_hv + b_lv
    let b_raw = band(shr(b_byte, band(idx, 7)), 1)
    let b_bit = if idx < 3 then 0 else if idx == 254 then 1 else b_raw
    let sw = bxor(s.swap, b_bit)
    let csx_mask = 0 - sw
    let csx_t0 = band(csx_mask, bxor(s.x2_0, s.x3_0))
    let csx_a0 = bxor(s.x2_0, csx_t0)
    let csx_b0 = bxor(s.x3_0, csx_t0)
    let csx_t1 = band(csx_mask, bxor(s.x2_1, s.x3_1))
