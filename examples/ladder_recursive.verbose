    let csx_a8 = bxor(s.x2_8, csx_t8)
    let csx_b8 = bxor(s.x3_8, csx_t8)
    let csx_t9 = band(csx_mask, bxor(s.x2_9, s.x3_9))
    let csx_a9 = bxor(s.x2_9, csx_t9)
    let csx_b9 = bxor(s.x3_9, csx_t9)
    let csz_mask = 0 - sw
    let csz_t0 = band(csz_mask, bxor(s.z2_0, s.z3_0))
    let csz_a0 = bxor(s.z2_0, csz_t0)
    let csz_b0 = bxor(s.z3_0, csz_t0)
    let csz_t1 = band(csz_mask, bxor(s.z2_1, s.z3_1))
    let csz_a1 = bxor(s.z2_1, csz_t1)
    let csz_b1 = bxor(s.z3_1, csz_t1)
    let csz_t2 = band(csz_mask, bxor(s.z2_2, s.z3_2))
    let csz_a2 = bxor(s.z2_2, csz_t2)
    let csz_b2 = bxor(s.z3_2, csz_t2)
    let csz_t3 = band(csz_mask, bxor(s.z2_3, s.z3_3))
    let csz_a3 = bxor(s.z2_3, csz_t3)
    let csz_b3 = bxor(s.z3_3, csz_t3)
    let csz_t4 = band(csz_mask, bxor(s.z2_4, s.z3_4))
    let csz_a4 = bxor(s.z2_4, csz_t4)
    let csz_b4 = bxor(s.z3_4, csz_t4)
