    let w0_lv2 = if w0_l2 <= 57 then w0_l2 - 48 else bor(w0_l2, 32) - 87
    let w0_b2 = 16 * w0_hv2 + w0_lv2
    let w0_h3 = byte_at(s.data, boff + 6)
    let w0_l3 = byte_at(s.data, boff + 7)
    let w0_hv3 = if w0_h3 <= 57 then w0_h3 - 48 else bor(w0_h3, 32) - 87
    let w0_lv3 = if w0_l3 <= 57 then w0_l3 - 48 else bor(w0_l3, 32) - 87
    let w0_b3 = 16 * w0_hv3 + w0_lv3
    let w0_h4 = byte_at(s.data, boff + 8)
    let w0_l4 = byte_at(s.data, boff + 9)
    let w0_hv4 = if w0_h4 <= 57 then w0_h4 - 48 else bor(w0_h4, 32) - 87
    let w0_lv4 = if w0_l4 <= 57 then w0_l4 - 48 else bor(w0_l4, 32) - 87
    let w0_b4 = 16 * w0_hv4 + w0_lv4
    let w0_h5 = byte_at(s.data, boff + 10)
    let w0_l5 = byte_at(s.data, boff + 11)
    let w0_hv5 = if w0_h5 <= 57 then w0_h5 - 48 else bor(w0_h5, 32) - 87
    let w0_lv5 = if w0_l5 <= 57 then w0_l5 - 48 else bor(w0_l5, 32) - 87
    let w0_b5 = 16 * w0_hv5 + w0_lv5
    let w0_h6 = byte_at(s.data, boff + 12)
    let w0_l6 = byte_at(s.data, boff + 13)
    let w0_hv6 = if w0_h6 <= 57 then w0_h6 - 48 else bor(w0_h6, 32) - 87
    let w0_lv6 = if w0_l6 <= 57 then w0_l6 - 48 else bor(w0_l6, 32) - 87
    let w0_b6 = 16 * w0_hv6 + w0_lv6
