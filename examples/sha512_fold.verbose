    let w0_lv7 = if w0_l7 <= 57 then w0_l7 - 48 else bor(w0_l7, 32) - 87
    let w0_b7 = 16 * w0_hv7 + w0_lv7
    let w0 = bor(bor(bor(bor(bor(bor(bor(w0_b7, shl(w0_b0, 56)), shl(w0_b1, 48)), shl(w0_b2, 40)), shl(w0_b3, 32)), shl(w0_b4, 24)), shl(w0_b5, 16)), shl(w0_b6, 8))
    let w1_h0 = byte_at(s.data, boff + 16)
    let w1_l0 = byte_at(s.data, boff + 17)
    let w1_hv0 = if w1_h0 <= 57 then w1_h0 - 48 else bor(w1_h0, 32) - 87
    let w1_lv0 = if w1_l0 <= 57 then w1_l0 - 48 else bor(w1_l0, 32) - 87
    let w1_b0 = 16 * w1_hv0 + w1_lv0
