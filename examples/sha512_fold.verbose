    let w2_hv2 = if w2_h2 <= 57 then w2_h2 - 48 else bor(w2_h2, 32) - 87
    let w2_lv2 = if w2_l2 <= 57 then w2_l2 - 48 else bor(w2_l2, 32) - 87
    let w2_b2 = 16 * w2_hv2 + w2_lv2
    let w2_h3 = byte_at(s.data, boff + 38)
    let w2_l3 = byte_at(s.data, boff + 39)
    let w2_hv3 = if w2_h3 <= 57 then w2_h3 - 48 else bor(w2_h3, 32) - 87
    let w2_lv3 = if w2_l3 <= 57 then w2_l3 - 48 else bor(w2_l3, 32) - 87
    let w2_b3 = 16 * w2_hv3 + w2_lv3
    let w2_h4 = byte_at(s.data, boff + 40)
