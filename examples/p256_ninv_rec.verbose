@verbose 0.1.0

concept P256NinvState
  @intention: "P-256 k^-1 mod n state: Montgomery accumulator result (10 limbs r0..r9) + invariant Montgomery base z=k (10 limbs z0..z9) + bit counter j + which output byte + 64-hex-char big-endian exponent n-2"
  @source: invoices.intent:1
  fields:
    r0 : number [0, 67108863]
    r1 : number [0, 67108863]
    r2 : number [0, 67108863]
    r3 : number [0, 67108863]
    r4 : number [0, 67108863]
    r5 : number [0, 67108863]
    r6 : number [0, 67108863]
    r7 : number [0, 67108863]
    r8 : number [0, 67108863]
    r9 : number [0, 67108863]
    z0 : number [0, 67108863]
    z1 : number [0, 67108863]
    z2 : number [0, 67108863]
    z3 : number [0, 67108863]
    z4 : number [0, 67108863]
    z5 : number [0, 67108863]
    z6 : number [0, 67108863]
    z7 : number [0, 67108863]
    z8 : number [0, 67108863]
    z9 : number [0, 67108863]
    j : number [0, 256]
    which : number [0, 31]
    exp : text


rule p256_ninv_rec
  @intention: "modular inverse k^-1 mod n (P-256 group order) via Fermat z^(n-2), recursive MSB-first square-and-multiply over 256 exponent bits (decreasing j); accumulator + base in Montgomery (CIOS); base case un-lifts and serializes big-endian, returns byte which"
  @source: invoices.intent:1
  input:
    s : P256NinvState
  output:
    out : number
  logic:
    let pos = if s.j == 0 then 0 else s.j - 1
    let byte_be = 31 - shr(pos, 3)
    let bpos = band(pos, 7)
    let hpos = shl(byte_be, 1)
    let hc = byte_at(s.exp, hpos)
    let lc = byte_at(s.exp, hpos + 1)
    let hv = if hc <= 57 then hc - 48 else bor(hc, 32) - 87
    let lv = if lc <= 57 then lc - 48 else bor(lc, 32) - 87
    let bytev = 16 * hv + lv
    let bit = band(shr(bytev, bpos), 1)
    let sq_v_0_0 = 0 + (s.r0 * s.r0) + 0
    let sq_t_0_0 = band(sq_v_0_0, 67108863)
    let sq_cc_0_0 = shr(sq_v_0_0, 26)
    let sq_v_0_1 = 0 + (s.r0 * s.r1) + sq_cc_0_0
    let sq_t_0_1 = band(sq_v_0_1, 67108863)
    let sq_cc_0_1 = shr(sq_v_0_1, 26)
    let sq_v_0_2 = 0 + (s.r0 * s.r2) + sq_cc_0_1
    let sq_t_0_2 = band(sq_v_0_2, 67108863)
    let sq_cc_0_2 = shr(sq_v_0_2, 26)
    let sq_v_0_3 = 0 + (s.r0 * s.r3) + sq_cc_0_2
    let sq_t_0_3 = band(sq_v_0_3, 67108863)
    let sq_cc_0_3 = shr(sq_v_0_3, 26)
    let sq_v_0_4 = 0 + (s.r0 * s.r4) + sq_cc_0_3
    let sq_t_0_4 = band(sq_v_0_4, 67108863)
    let sq_cc_0_4 = shr(sq_v_0_4, 26)
    let sq_v_0_5 = 0 + (s.r0 * s.r5) + sq_cc_0_4
    let sq_t_0_5 = band(sq_v_0_5, 67108863)
    let sq_cc_0_5 = shr(sq_v_0_5, 26)
    let sq_v_0_6 = 0 + (s.r0 * s.r6) + sq_cc_0_5
    let sq_t_0_6 = band(sq_v_0_6, 67108863)
    let sq_cc_0_6 = shr(sq_v_0_6, 26)
    let sq_v_0_7 = 0 + (s.r0 * s.r7) + sq_cc_0_6
    let sq_t_0_7 = band(sq_v_0_7, 67108863)
    let sq_cc_0_7 = shr(sq_v_0_7, 26)
    let sq_v_0_8 = 0 + (s.r0 * s.r8) + sq_cc_0_7
    let sq_t_0_8 = band(sq_v_0_8, 67108863)
    let sq_cc_0_8 = shr(sq_v_0_8, 26)
    let sq_v_0_9 = 0 + (s.r0 * s.r9) + sq_cc_0_8
    let sq_t_0_9 = band(sq_v_0_9, 67108863)
    let sq_cc_0_9 = shr(sq_v_0_9, 26)
    let sq_vN_0 = 0 + sq_cc_0_9
    let sq_tN_0 = band(sq_vN_0, 67108863)
    let sq_tN1_0 = shr(sq_vN_0, 26)
    let sq_m_0 = band((sq_t_0_0 * 33602639), 67108863)
    let sq_rc_0_0 = shr(sq_t_0_0 + (sq_m_0 * 6497617), 26)
