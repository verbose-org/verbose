    let add_yx2_s0_4 = add_yx2_a5 + add_yx2_c0_4
    let add_yx2_c0_5 = shr(add_yx2_s0_4, 25)
    let add_yx2_lo0_5 = band(add_yx2_s0_4, 33554431)
    let add_yx2_s0_5 = add_yx2_a6 + add_yx2_c0_5
    let add_yx2_c0_6 = shr(add_yx2_s0_5, 26)
    let add_yx2_lo0_6 = band(add_yx2_s0_5, 67108863)
    let add_yx2_s0_6 = add_yx2_a7 + add_yx2_c0_6
    let add_yx2_c0_7 = shr(add_yx2_s0_6, 25)
    let add_yx2_lo0_7 = band(add_yx2_s0_6, 33554431)
