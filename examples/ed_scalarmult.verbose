rule ed_scalarmult
  @intention: "Ed25519 scalar mult [scalar]P by double-and-add over 256 bits (LSB-first); returns limb which of accumulator Q (X|Y|Z|T)"
  @source: invoices.intent:1
  input:
    s : EdScalarState
  output:
    out : number
  logic:
    let bi = 256 - s.j
    let bidx = shr(bi, 3)
    let bpos = band(bi, 7)
    let hpos = shl(bidx, 1)
    let hc = byte_at(s.scalar, hpos)
    let lc = byte_at(s.scalar, hpos + 1)
    let hv = if hc <= 57 then hc - 48 else bor(hc, 32) - 87
    let lv = if lc <= 57 then lc - 48 else bor(lc, 32) - 87
    let bytev = 16 * hv + lv
    let bit = band(shr(bytev, bpos), 1)
    let mask = 0 - bit
    let add_yx1_a0 = s.qy0 + 134217690 - s.qx0
    let add_yx1_a1 = s.qy1 + 67108862 - s.qx1
    let add_yx1_a2 = s.qy2 + 134217726 - s.qx2
    let add_yx1_a3 = s.qy3 + 67108862 - s.qx3
    let add_yx1_a4 = s.qy4 + 134217726 - s.qx4
    let add_yx1_a5 = s.qy5 + 67108862 - s.qx5
    let add_yx1_a6 = s.qy6 + 134217726 - s.qx6
    let add_yx1_a7 = s.qy7 + 67108862 - s.qx7
    let add_yx1_a8 = s.qy8 + 134217726 - s.qx8
    let add_yx1_a9 = s.qy9 + 67108862 - s.qx9
    let add_yx1_c0_0 = shr(add_yx1_a0, 26)
    let add_yx1_lo0_0 = band(add_yx1_a0, 67108863)
    let add_yx1_s0_0 = add_yx1_a1 + add_yx1_c0_0
    let add_yx1_c0_1 = shr(add_yx1_s0_0, 25)
    let add_yx1_lo0_1 = band(add_yx1_s0_0, 33554431)
    let add_yx1_s0_1 = add_yx1_a2 + add_yx1_c0_1
    let add_yx1_c0_2 = shr(add_yx1_s0_1, 26)
    let add_yx1_lo0_2 = band(add_yx1_s0_1, 67108863)
    let add_yx1_s0_2 = add_yx1_a3 + add_yx1_c0_2
    let add_yx1_c0_3 = shr(add_yx1_s0_2, 25)
    let add_yx1_lo0_3 = band(add_yx1_s0_2, 33554431)
    let add_yx1_s0_3 = add_yx1_a4 + add_yx1_c0_3
    let add_yx1_c0_4 = shr(add_yx1_s0_3, 26)
    let add_yx1_lo0_4 = band(add_yx1_s0_3, 67108863)
    let add_yx1_s0_4 = add_yx1_a5 + add_yx1_c0_4
    let add_yx1_c0_5 = shr(add_yx1_s0_4, 25)
    let add_yx1_lo0_5 = band(add_yx1_s0_4, 33554431)
    let add_yx1_s0_5 = add_yx1_a6 + add_yx1_c0_5
    let add_yx1_c0_6 = shr(add_yx1_s0_5, 26)
    let add_yx1_lo0_6 = band(add_yx1_s0_5, 67108863)
    let add_yx1_s0_6 = add_yx1_a7 + add_yx1_c0_6
    let add_yx1_c0_7 = shr(add_yx1_s0_6, 25)
    let add_yx1_lo0_7 = band(add_yx1_s0_6, 33554431)
    let add_yx1_s0_7 = add_yx1_a8 + add_yx1_c0_7
