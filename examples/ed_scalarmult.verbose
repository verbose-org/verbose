    let add_yx1_lo0_9 = band(add_yx1_s0_8, 33554431)
    let add_yx1_w0 = add_yx1_lo0_0 + 19 * add_yx1_c0_9
    let add_yx1_c1_0 = shr(add_yx1_w0, 26)
    let add_yx1_lo1_0 = band(add_yx1_w0, 67108863)
    let add_yx1_s1_0 = add_yx1_lo0_1 + add_yx1_c1_0
