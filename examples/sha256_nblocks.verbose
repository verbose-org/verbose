@verbose 0.1.0

concept Source
  @intention: "input message (up to 2 blocks) + which 32-bit word to return"
  @source: sha256_nblocks.intent:1
  fields:
    source : text [..503]
    which : number [0, 7]

concept Idx
  @intention: "round/W index 0..63"
  @source: sha256_nblocks.intent:1
  fields:
    i : number [0, 63]

concept WordAndShift
  @intention: "word + shift count"
  @source: sha256_nblocks.intent:1
  fields:
    x : number [0, 4294967295]
    n : number [0, 31]

concept OneWord
  @intention: "single 32-bit word"
  @source: sha256_nblocks.intent:1
  fields:
    x : number [0, 4294967295]

concept ThreeWords
  @intention: "three 32-bit words"
  @source: sha256_nblocks.intent:1
  fields:
    x : number [0, 4294967295]
    y : number [0, 4294967295]
    z : number [0, 4294967295]

concept PaddedByte
  @intention: "i-th byte of the SHA-256 padded message (multi-block aware)"
  @source: sha256_nblocks.intent:1
  fields:
    source : text [..503]
    len : number [0, 503]
    n_blocks : number [1, 8]
    block_idx : number [0, 7]
    pos : number [0, 63]

concept WordInit
  @intention: "i-th initial W value (0..15) of the block_idx-th block"
  @source: sha256_nblocks.intent:1
  fields:
    source : text [..503]
    len : number [0, 503]
    n_blocks : number [1, 8]
    block_idx : number [0, 7]
    i : number [0, 15]

concept State
  @intention: "compression working state for one block"
  @source: sha256_nblocks.intent:1
  fields:
    a : number [0, 4294967295]
    b : number [0, 4294967295]
    c : number [0, 4294967295]
    d : number [0, 4294967295]
    e : number [0, 4294967295]
    f : number [0, 4294967295]
    g : number [0, 4294967295]
    h : number [0, 4294967295]
    w0 : number [0, 4294967295]
    w1 : number [0, 4294967295]
    w2 : number [0, 4294967295]
    w3 : number [0, 4294967295]
    w4 : number [0, 4294967295]
    w5 : number [0, 4294967295]
    w6 : number [0, 4294967295]
    w7 : number [0, 4294967295]
    w8 : number [0, 4294967295]
    w9 : number [0, 4294967295]
    w10 : number [0, 4294967295]
    w11 : number [0, 4294967295]
    w12 : number [0, 4294967295]
    w13 : number [0, 4294967295]
    w14 : number [0, 4294967295]
    w15 : number [0, 4294967295]
    round : number [0, 64]
    which : number [0, 7]

concept Outer
  @intention: "multi-block iteration state: source + running hash + block index"
  @source: sha256_nblocks.intent:1
  fields:
    source : text [..503]
    len : number [0, 503]
    n_blocks : number [1, 8]
    h0 : number [0, 4294967295]
    h1 : number [0, 4294967295]
    h2 : number [0, 4294967295]
    h3 : number [0, 4294967295]
    h4 : number [0, 4294967295]
    h5 : number [0, 4294967295]
    h6 : number [0, 4294967295]
    h7 : number [0, 4294967295]
    block_idx : number [0, 8]
    which : number [0, 7]


rule rotr32
  @intention: "rotate right by n bits"
  @source: sha256_nblocks.intent:2
  input:
    w : WordAndShift
  output:
    out : number
  logic:
    out = band(bor(shr(w.x, w.n), shl(w.x, 32 - w.n)), 4294967295)
  proofs:
    purity:
      reads : [w.x, w.n]
      calls : []
    termination:
      bound : 10


rule ch
  @intention: "ch primitive"
  @source: sha256_nblocks.intent:2
  input:
    t : ThreeWords
  output:
    out : number
  logic:
    out = band(bxor(band(t.x, t.y), band(bnot(t.x), t.z)), 4294967295)
  proofs:
    purity:
      reads : [t.x, t.y, t.z]
      calls : []
    termination:
      bound : 10


rule maj
  @intention: "maj primitive"
  @source: sha256_nblocks.intent:2
  input:
    t : ThreeWords
  output:
    out : number
  logic:
    out = band(bxor(bxor(band(t.x, t.y), band(t.x, t.z)), band(t.y, t.z)), 4294967295)
  proofs:
    purity:
      reads : [t.x, t.y, t.z]
      calls : []
    termination:
      bound : 10


rule big_sigma0
  @intention: "big sigma 0"
  @source: sha256_nblocks.intent:2
  input:
    w : OneWord
  output:
    out : number
  logic:
    let r2  = rotr32(WordAndShift { x: w.x, n: 2 })
    let r13 = rotr32(WordAndShift { x: w.x, n: 13 })
    let r22 = rotr32(WordAndShift { x: w.x, n: 22 })
    out = band(bxor(bxor(r2, r13), r22), 4294967295)
  proofs:
    purity:
      reads : [w.x]
      calls : [rotr32]
    termination:
      bound : 20


rule big_sigma1
  @intention: "big sigma 1"
  @source: sha256_nblocks.intent:2
  input:
    w : OneWord
  output:
    out : number
  logic:
    let r6  = rotr32(WordAndShift { x: w.x, n: 6 })
    let r11 = rotr32(WordAndShift { x: w.x, n: 11 })
    let r25 = rotr32(WordAndShift { x: w.x, n: 25 })
    out = band(bxor(bxor(r6, r11), r25), 4294967295)
  proofs:
    purity:
      reads : [w.x]
      calls : [rotr32]
    termination:
      bound : 20


rule small_sigma0
  @intention: "small sigma 0"
  @source: sha256_nblocks.intent:2
  input:
    w : OneWord
  output:
    out : number
  logic:
    let r7  = rotr32(WordAndShift { x: w.x, n: 7 })
    let r18 = rotr32(WordAndShift { x: w.x, n: 18 })
    out = band(bxor(bxor(r7, r18), shr(w.x, 3)), 4294967295)
  proofs:
    purity:
      reads : [w.x]
      calls : [rotr32]
    termination:
      bound : 20


rule small_sigma1
  @intention: "small sigma 1"
  @source: sha256_nblocks.intent:2
  input:
    w : OneWord
  output:
    out : number
  logic:
    let r17 = rotr32(WordAndShift { x: w.x, n: 17 })
    let r19 = rotr32(WordAndShift { x: w.x, n: 19 })
    out = band(bxor(bxor(r17, r19), shr(w.x, 10)), 4294967295)
  proofs:
    purity:
      reads : [w.x]
      calls : [rotr32]
    termination:
      bound : 20


rule k_const
  @intention: "K[i]"
  @source: sha256_nblocks.intent:2
  input:
    idx : Idx
  output:
    out : number
  logic:
    out = if idx.i == 0 then 1116352408
      else if idx.i == 1 then 1899447441
      else if idx.i == 2 then 3049323471
      else if idx.i == 3 then 3921009573
      else if idx.i == 4 then 961987163
      else if idx.i == 5 then 1508970993
      else if idx.i == 6 then 2453635748
      else if idx.i == 7 then 2870763221
      else if idx.i == 8 then 3624381080
      else if idx.i == 9 then 310598401
      else if idx.i == 10 then 607225278
