@verbose 0.1.0

concept GfInput
  @intention: "two 128-bit field elements X, Y (16 bytes each, big-endian) + which output byte"
  @source: ghash_mul.intent:1
  fields:
    x0 : number [0, 255]
    x1 : number [0, 255]
    x2 : number [0, 255]
    x3 : number [0, 255]
    x4 : number [0, 255]
    x5 : number [0, 255]
    x6 : number [0, 255]
    x7 : number [0, 255]
    x8 : number [0, 255]
    x9 : number [0, 255]
    x10 : number [0, 255]
    x11 : number [0, 255]
    x12 : number [0, 255]
    x13 : number [0, 255]
    x14 : number [0, 255]
    x15 : number [0, 255]
    y0 : number [0, 255]
    y1 : number [0, 255]
    y2 : number [0, 255]
    y3 : number [0, 255]
    y4 : number [0, 255]
    y5 : number [0, 255]
    y6 : number [0, 255]
    y7 : number [0, 255]
    y8 : number [0, 255]
    y9 : number [0, 255]
    y10 : number [0, 255]
    y11 : number [0, 255]
    y12 : number [0, 255]
    y13 : number [0, 255]
    y14 : number [0, 255]
    y15 : number [0, 255]
    which : number [0, 15]


rule gf128_mul
  @intention: "GF(2^128) multiply under the GCM reduction polynomial (NIST SP 800-38D Alg. 1); returns byte `which` of X*Y"
  @source: ghash_mul.intent:2
  input:
    g : GfInput
  output:
    out : number
  logic:
    let ym0 = if band(g.y0, 128) > 0 then 255 else 0
    let z0_0 = bxor(0, band(g.x0, ym0))
    let z0_1 = bxor(0, band(g.x1, ym0))
    let z0_2 = bxor(0, band(g.x2, ym0))
    let z0_3 = bxor(0, band(g.x3, ym0))
    let z0_4 = bxor(0, band(g.x4, ym0))
    let z0_5 = bxor(0, band(g.x5, ym0))
    let z0_6 = bxor(0, band(g.x6, ym0))
    let z0_7 = bxor(0, band(g.x7, ym0))
    let z0_8 = bxor(0, band(g.x8, ym0))
    let z0_9 = bxor(0, band(g.x9, ym0))
    let z0_10 = bxor(0, band(g.x10, ym0))
    let z0_11 = bxor(0, band(g.x11, ym0))
    let z0_12 = bxor(0, band(g.x12, ym0))
    let z0_13 = bxor(0, band(g.x13, ym0))
    let z0_14 = bxor(0, band(g.x14, ym0))
    let z0_15 = bxor(0, band(g.x15, ym0))
    let vl0 = band(g.x15, 1)
    let vm0 = if vl0 > 0 then 225 else 0
    let v0_0 = bxor(shr(g.x0, 1), vm0)
    let v0_1 = bor(shr(g.x1, 1), shl(band(g.x0, 1), 7))
    let v0_2 = bor(shr(g.x2, 1), shl(band(g.x1, 1), 7))
    let v0_3 = bor(shr(g.x3, 1), shl(band(g.x2, 1), 7))
    let v0_4 = bor(shr(g.x4, 1), shl(band(g.x3, 1), 7))
    let v0_5 = bor(shr(g.x5, 1), shl(band(g.x4, 1), 7))
    let v0_6 = bor(shr(g.x6, 1), shl(band(g.x5, 1), 7))
    let v0_7 = bor(shr(g.x7, 1), shl(band(g.x6, 1), 7))
    let v0_8 = bor(shr(g.x8, 1), shl(band(g.x7, 1), 7))
    let v0_9 = bor(shr(g.x9, 1), shl(band(g.x8, 1), 7))
    let v0_10 = bor(shr(g.x10, 1), shl(band(g.x9, 1), 7))
    let v0_11 = bor(shr(g.x11, 1), shl(band(g.x10, 1), 7))
    let v0_12 = bor(shr(g.x12, 1), shl(band(g.x11, 1), 7))
    let v0_13 = bor(shr(g.x13, 1), shl(band(g.x12, 1), 7))
    let v0_14 = bor(shr(g.x14, 1), shl(band(g.x13, 1), 7))
    let v0_15 = bor(shr(g.x15, 1), shl(band(g.x14, 1), 7))
    let ym1 = if band(g.y0, 64) > 0 then 255 else 0
    let z1_0 = bxor(z0_0, band(v0_0, ym1))
    let z1_1 = bxor(z0_1, band(v0_1, ym1))
    let z1_2 = bxor(z0_2, band(v0_2, ym1))
    let z1_3 = bxor(z0_3, band(v0_3, ym1))
    let z1_4 = bxor(z0_4, band(v0_4, ym1))
    let z1_5 = bxor(z0_5, band(v0_5, ym1))
    let z1_6 = bxor(z0_6, band(v0_6, ym1))
    let z1_7 = bxor(z0_7, band(v0_7, ym1))
    let z1_8 = bxor(z0_8, band(v0_8, ym1))
    let z1_9 = bxor(z0_9, band(v0_9, ym1))
    let z1_10 = bxor(z0_10, band(v0_10, ym1))
    let z1_11 = bxor(z0_11, band(v0_11, ym1))
    let z1_12 = bxor(z0_12, band(v0_12, ym1))
    let z1_13 = bxor(z0_13, band(v0_13, ym1))
    let z1_14 = bxor(z0_14, band(v0_14, ym1))
    let z1_15 = bxor(z0_15, band(v0_15, ym1))
    let vl1 = band(v0_15, 1)
    let vm1 = if vl1 > 0 then 225 else 0
    let v1_0 = bxor(shr(v0_0, 1), vm1)
