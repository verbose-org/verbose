    let v2_11 = bor(shr(v1_11, 1), shl(band(v1_10, 1), 7))
    let v2_12 = bor(shr(v1_12, 1), shl(band(v1_11, 1), 7))
    let v2_13 = bor(shr(v1_13, 1), shl(band(v1_12, 1), 7))
    let v2_14 = bor(shr(v1_14, 1), shl(band(v1_13, 1), 7))
    let v2_15 = bor(shr(v1_15, 1), shl(band(v1_14, 1), 7))
    let ym3 = if band(g.y0, 16) > 0 then 255 else 0
    let z3_0 = bxor(z2_0, band(v2_0, ym3))
    let z3_1 = bxor(z2_1, band(v2_1, ym3))
    let z3_2 = bxor(z2_2, band(v2_2, ym3))
