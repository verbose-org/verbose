    let v1_5 = bor(shr(v0_5, 1), shl(band(v0_4, 1), 7))
    let v1_6 = bor(shr(v0_6, 1), shl(band(v0_5, 1), 7))
    let v1_7 = bor(shr(v0_7, 1), shl(band(v0_6, 1), 7))
    let v1_8 = bor(shr(v0_8, 1), shl(band(v0_7, 1), 7))
    let v1_9 = bor(shr(v0_9, 1), shl(band(v0_8, 1), 7))
    let v1_10 = bor(shr(v0_10, 1), shl(band(v0_9, 1), 7))
    let v1_11 = bor(shr(v0_11, 1), shl(band(v0_10, 1), 7))
