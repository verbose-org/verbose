    let m0_v4_8 = bor(shr(m0_v3_8, 1), shl(band(m0_v3_7, 1), 7))
    let m0_v4_9 = bor(shr(m0_v3_9, 1), shl(band(m0_v3_8, 1), 7))
    let m0_v4_10 = bor(shr(m0_v3_10, 1), shl(band(m0_v3_9, 1), 7))
