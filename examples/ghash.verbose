    let m0_z2_4 = bxor(m0_z1_4, band(m0_v1_4, m0_ym2))
    let m0_z2_5 = bxor(m0_z1_5, band(m0_v1_5, m0_ym2))
    let m0_z2_6 = bxor(m0_z1_6, band(m0_v1_6, m0_ym2))
    let m0_z2_7 = bxor(m0_z1_7, band(m0_v1_7, m0_ym2))
    let m0_z2_8 = bxor(m0_z1_8, band(m0_v1_8, m0_ym2))
    let m0_z2_9 = bxor(m0_z1_9, band(m0_v1_9, m0_ym2))
    let m0_z2_10 = bxor(m0_z1_10, band(m0_v1_10, m0_ym2))
    let m0_z2_11 = bxor(m0_z1_11, band(m0_v1_11, m0_ym2))
    let m0_z2_12 = bxor(m0_z1_12, band(m0_v1_12, m0_ym2))
    let m0_z2_13 = bxor(m0_z1_13, band(m0_v1_13, m0_ym2))
    let m0_z2_14 = bxor(m0_z1_14, band(m0_v1_14, m0_ym2))
    let m0_z2_15 = bxor(m0_z1_15, band(m0_v1_15, m0_ym2))
    let m0_vl2 = band(m0_v1_15, 1)
    let m0_vm2 = if m0_vl2 > 0 then 225 else 0
    let m0_v2_0 = bxor(shr(m0_v1_0, 1), m0_vm2)
    let m0_v2_1 = bor(shr(m0_v1_1, 1), shl(band(m0_v1_0, 1), 7))
    let m0_v2_2 = bor(shr(m0_v1_2, 1), shl(band(m0_v1_1, 1), 7))
    let m0_v2_3 = bor(shr(m0_v1_3, 1), shl(band(m0_v1_2, 1), 7))
    let m0_v2_4 = bor(shr(m0_v1_4, 1), shl(band(m0_v1_3, 1), 7))
    let m0_v2_5 = bor(shr(m0_v1_5, 1), shl(band(m0_v1_4, 1), 7))
    let m0_v2_6 = bor(shr(m0_v1_6, 1), shl(band(m0_v1_5, 1), 7))
    let m0_v2_7 = bor(shr(m0_v1_7, 1), shl(band(m0_v1_6, 1), 7))
    let m0_v2_8 = bor(shr(m0_v1_8, 1), shl(band(m0_v1_7, 1), 7))
    let m0_v2_9 = bor(shr(m0_v1_9, 1), shl(band(m0_v1_8, 1), 7))
    let m0_v2_10 = bor(shr(m0_v1_10, 1), shl(band(m0_v1_9, 1), 7))
    let m0_v2_11 = bor(shr(m0_v1_11, 1), shl(band(m0_v1_10, 1), 7))
    let m0_v2_12 = bor(shr(m0_v1_12, 1), shl(band(m0_v1_11, 1), 7))
    let m0_v2_13 = bor(shr(m0_v1_13, 1), shl(band(m0_v1_12, 1), 7))
    let m0_v2_14 = bor(shr(m0_v1_14, 1), shl(band(m0_v1_13, 1), 7))
    let m0_v2_15 = bor(shr(m0_v1_15, 1), shl(band(m0_v1_14, 1), 7))
    let m0_ym3 = if band(g.h0, 16) > 0 then 255 else 0
    let m0_z3_0 = bxor(m0_z2_0, band(m0_v2_0, m0_ym3))
    let m0_z3_1 = bxor(m0_z2_1, band(m0_v2_1, m0_ym3))
    let m0_z3_2 = bxor(m0_z2_2, band(m0_v2_2, m0_ym3))
    let m0_z3_3 = bxor(m0_z2_3, band(m0_v2_3, m0_ym3))
    let m0_z3_4 = bxor(m0_z2_4, band(m0_v2_4, m0_ym3))
    let m0_z3_5 = bxor(m0_z2_5, band(m0_v2_5, m0_ym3))
    let m0_z3_6 = bxor(m0_z2_6, band(m0_v2_6, m0_ym3))
    let m0_z3_7 = bxor(m0_z2_7, band(m0_v2_7, m0_ym3))
    let m0_z3_8 = bxor(m0_z2_8, band(m0_v2_8, m0_ym3))
    let m0_z3_9 = bxor(m0_z2_9, band(m0_v2_9, m0_ym3))
    let m0_z3_10 = bxor(m0_z2_10, band(m0_v2_10, m0_ym3))
    let m0_z3_11 = bxor(m0_z2_11, band(m0_v2_11, m0_ym3))
    let m0_z3_12 = bxor(m0_z2_12, band(m0_v2_12, m0_ym3))
    let m0_z3_13 = bxor(m0_z2_13, band(m0_v2_13, m0_ym3))
    let m0_z3_14 = bxor(m0_z2_14, band(m0_v2_14, m0_ym3))
    let m0_z3_15 = bxor(m0_z2_15, band(m0_v2_15, m0_ym3))
    let m0_vl3 = band(m0_v2_15, 1)
    let m0_vm3 = if m0_vl3 > 0 then 225 else 0
    let m0_v3_0 = bxor(shr(m0_v2_0, 1), m0_vm3)
    let m0_v3_1 = bor(shr(m0_v2_1, 1), shl(band(m0_v2_0, 1), 7))
    let m0_v3_2 = bor(shr(m0_v2_2, 1), shl(band(m0_v2_1, 1), 7))
    let m0_v3_3 = bor(shr(m0_v2_3, 1), shl(band(m0_v2_2, 1), 7))
    let m0_v3_4 = bor(shr(m0_v2_4, 1), shl(band(m0_v2_3, 1), 7))
    let m0_v3_5 = bor(shr(m0_v2_5, 1), shl(band(m0_v2_4, 1), 7))
    let m0_v3_6 = bor(shr(m0_v2_6, 1), shl(band(m0_v2_5, 1), 7))
    let m0_v3_7 = bor(shr(m0_v2_7, 1), shl(band(m0_v2_6, 1), 7))
