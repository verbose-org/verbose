    let m0_v1_10 = bor(shr(m0_v0_10, 1), shl(band(m0_v0_9, 1), 7))
    let m0_v1_11 = bor(shr(m0_v0_11, 1), shl(band(m0_v0_10, 1), 7))
    let m0_v1_12 = bor(shr(m0_v0_12, 1), shl(band(m0_v0_11, 1), 7))
    let m0_v1_13 = bor(shr(m0_v0_13, 1), shl(band(m0_v0_12, 1), 7))
    let m0_v1_14 = bor(shr(m0_v0_14, 1), shl(band(m0_v0_13, 1), 7))
    let m0_v1_15 = bor(shr(m0_v0_15, 1), shl(band(m0_v0_14, 1), 7))
    let m0_ym2 = if band(g.h0, 32) > 0 then 255 else 0
