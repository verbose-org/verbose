@verbose 0.1.0

concept GhashInput
  @intention: "hash subkey H + two 16-byte blocks (ciphertext block, length block) + which output byte"
  @source: ghash.intent:1
  fields:
    h0 : number [0, 255]
    h1 : number [0, 255]
    h2 : number [0, 255]
    h3 : number [0, 255]
    h4 : number [0, 255]
    h5 : number [0, 255]
    h6 : number [0, 255]
    h7 : number [0, 255]
    h8 : number [0, 255]
    h9 : number [0, 255]
    h10 : number [0, 255]
    h11 : number [0, 255]
    h12 : number [0, 255]
    h13 : number [0, 255]
    h14 : number [0, 255]
    h15 : number [0, 255]
    blk0_0 : number [0, 255]
    blk0_1 : number [0, 255]
    blk0_2 : number [0, 255]
    blk0_3 : number [0, 255]
    blk0_4 : number [0, 255]
    blk0_5 : number [0, 255]
    blk0_6 : number [0, 255]
    blk0_7 : number [0, 255]
    blk0_8 : number [0, 255]
    blk0_9 : number [0, 255]
    blk0_10 : number [0, 255]
    blk0_11 : number [0, 255]
    blk0_12 : number [0, 255]
    blk0_13 : number [0, 255]
    blk0_14 : number [0, 255]
    blk0_15 : number [0, 255]
    blk1_0 : number [0, 255]
    blk1_1 : number [0, 255]
    blk1_2 : number [0, 255]
    blk1_3 : number [0, 255]
    blk1_4 : number [0, 255]
    blk1_5 : number [0, 255]
    blk1_6 : number [0, 255]
    blk1_7 : number [0, 255]
    blk1_8 : number [0, 255]
    blk1_9 : number [0, 255]
    blk1_10 : number [0, 255]
    blk1_11 : number [0, 255]
    blk1_12 : number [0, 255]
    blk1_13 : number [0, 255]
    blk1_14 : number [0, 255]
    blk1_15 : number [0, 255]
    which : number [0, 15]


rule ghash
  @intention: "GHASH over 2 blocks: Y=((blk0*H) xor blk1)*H under the GCM field; returns byte `which`"
  @source: ghash.intent:2
  input:
    g : GhashInput
  output:
    out : number
  logic:
    let m0_ym0 = if band(g.h0, 128) > 0 then 255 else 0
    let m0_z0_0 = bxor(0, band(g.blk0_0, m0_ym0))
    let m0_z0_1 = bxor(0, band(g.blk0_1, m0_ym0))
    let m0_z0_2 = bxor(0, band(g.blk0_2, m0_ym0))
    let m0_z0_3 = bxor(0, band(g.blk0_3, m0_ym0))
    let m0_z0_4 = bxor(0, band(g.blk0_4, m0_ym0))
    let m0_z0_5 = bxor(0, band(g.blk0_5, m0_ym0))
    let m0_z0_6 = bxor(0, band(g.blk0_6, m0_ym0))
    let m0_z0_7 = bxor(0, band(g.blk0_7, m0_ym0))
    let m0_z0_8 = bxor(0, band(g.blk0_8, m0_ym0))
    let m0_z0_9 = bxor(0, band(g.blk0_9, m0_ym0))
    let m0_z0_10 = bxor(0, band(g.blk0_10, m0_ym0))
    let m0_z0_11 = bxor(0, band(g.blk0_11, m0_ym0))
    let m0_z0_12 = bxor(0, band(g.blk0_12, m0_ym0))
    let m0_z0_13 = bxor(0, band(g.blk0_13, m0_ym0))
    let m0_z0_14 = bxor(0, band(g.blk0_14, m0_ym0))
    let m0_z0_15 = bxor(0, band(g.blk0_15, m0_ym0))
    let m0_vl0 = band(g.blk0_15, 1)
    let m0_vm0 = if m0_vl0 > 0 then 225 else 0
    let m0_v0_0 = bxor(shr(g.blk0_0, 1), m0_vm0)
    let m0_v0_1 = bor(shr(g.blk0_1, 1), shl(band(g.blk0_0, 1), 7))
    let m0_v0_2 = bor(shr(g.blk0_2, 1), shl(band(g.blk0_1, 1), 7))
    let m0_v0_3 = bor(shr(g.blk0_3, 1), shl(band(g.blk0_2, 1), 7))
    let m0_v0_4 = bor(shr(g.blk0_4, 1), shl(band(g.blk0_3, 1), 7))
    let m0_v0_5 = bor(shr(g.blk0_5, 1), shl(band(g.blk0_4, 1), 7))
    let m0_v0_6 = bor(shr(g.blk0_6, 1), shl(band(g.blk0_5, 1), 7))
    let m0_v0_7 = bor(shr(g.blk0_7, 1), shl(band(g.blk0_6, 1), 7))
    let m0_v0_8 = bor(shr(g.blk0_8, 1), shl(band(g.blk0_7, 1), 7))
    let m0_v0_9 = bor(shr(g.blk0_9, 1), shl(band(g.blk0_8, 1), 7))
    let m0_v0_10 = bor(shr(g.blk0_10, 1), shl(band(g.blk0_9, 1), 7))
    let m0_v0_11 = bor(shr(g.blk0_11, 1), shl(band(g.blk0_10, 1), 7))
    let m0_v0_12 = bor(shr(g.blk0_12, 1), shl(band(g.blk0_11, 1), 7))
    let m0_v0_13 = bor(shr(g.blk0_13, 1), shl(band(g.blk0_12, 1), 7))
    let m0_v0_14 = bor(shr(g.blk0_14, 1), shl(band(g.blk0_13, 1), 7))
    let m0_v0_15 = bor(shr(g.blk0_15, 1), shl(band(g.blk0_14, 1), 7))
    let m0_ym1 = if band(g.h0, 64) > 0 then 255 else 0
    let m0_z1_0 = bxor(m0_z0_0, band(m0_v0_0, m0_ym1))
    let m0_z1_1 = bxor(m0_z0_1, band(m0_v0_1, m0_ym1))
    let m0_z1_2 = bxor(m0_z0_2, band(m0_v0_2, m0_ym1))
    let m0_z1_3 = bxor(m0_z0_3, band(m0_v0_3, m0_ym1))
    let m0_z1_4 = bxor(m0_z0_4, band(m0_v0_4, m0_ym1))
    let m0_z1_5 = bxor(m0_z0_5, band(m0_v0_5, m0_ym1))
    let m0_z1_6 = bxor(m0_z0_6, band(m0_v0_6, m0_ym1))
    let m0_z1_7 = bxor(m0_z0_7, band(m0_v0_7, m0_ym1))
    let m0_z1_8 = bxor(m0_z0_8, band(m0_v0_8, m0_ym1))
    let m0_z1_9 = bxor(m0_z0_9, band(m0_v0_9, m0_ym1))
    let m0_z1_10 = bxor(m0_z0_10, band(m0_v0_10, m0_ym1))
    let m0_z1_11 = bxor(m0_z0_11, band(m0_v0_11, m0_ym1))
    let m0_z1_12 = bxor(m0_z0_12, band(m0_v0_12, m0_ym1))
    let m0_z1_13 = bxor(m0_z0_13, band(m0_v0_13, m0_ym1))
    let m0_z1_14 = bxor(m0_z0_14, band(m0_v0_14, m0_ym1))
    let m0_z1_15 = bxor(m0_z0_15, band(m0_v0_15, m0_ym1))
    let m0_vl1 = band(m0_v0_15, 1)
    let m0_vm1 = if m0_vl1 > 0 then 225 else 0
    let m0_v1_0 = bxor(shr(m0_v0_0, 1), m0_vm1)
    let m0_v1_1 = bor(shr(m0_v0_1, 1), shl(band(m0_v0_0, 1), 7))
    let m0_v1_2 = bor(shr(m0_v0_2, 1), shl(band(m0_v0_1, 1), 7))
    let m0_v1_3 = bor(shr(m0_v0_3, 1), shl(band(m0_v0_2, 1), 7))
    let m0_v1_4 = bor(shr(m0_v0_4, 1), shl(band(m0_v0_3, 1), 7))
    let m0_v1_5 = bor(shr(m0_v0_5, 1), shl(band(m0_v0_4, 1), 7))
    let m0_v1_6 = bor(shr(m0_v0_6, 1), shl(band(m0_v0_5, 1), 7))
    let m0_v1_7 = bor(shr(m0_v0_7, 1), shl(band(m0_v0_6, 1), 7))
