    let inv_z2_a4 = (g.z0 * g.z4) + 2 * (g.z1 * g.z3) + (g.z2 * g.z2) + 2 * (g.z3 * g.z1) + (g.z4 * g.z0) + 38 * (g.z5 * g.z9) + 19 * (g.z6 * g.z8) + 38 * (g.z7 * g.z7) + 19 * (g.z8 * g.z6) + 38 * (g.z9 * g.z5)
