@verbose 0.1.0

concept EdPoint
  @intention: "Edwards point X,Y,Z (extended coords, T unused for affine) as 30 limbs + which output limb (0..19)"
  @source: invoices.intent:1
  fields:
    x0 : number [0, 67108863]
    x1 : number [0, 67108863]
    x2 : number [0, 67108863]
    x3 : number [0, 67108863]
    x4 : number [0, 67108863]
    x5 : number [0, 67108863]
    x6 : number [0, 67108863]
    x7 : number [0, 67108863]
    x8 : number [0, 67108863]
    x9 : number [0, 67108863]
    y0 : number [0, 67108863]
