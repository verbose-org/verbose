    let m_v_0_7 = 0 + (g.a0 * g.b7) + m_cc_0_6
    let m_t_0_7 = band(m_v_0_7, 67108863)
    let m_cc_0_7 = shr(m_v_0_7, 26)
    let m_v_0_8 = 0 + (g.a0 * g.b8) + m_cc_0_7
    let m_t_0_8 = band(m_v_0_8, 67108863)
