    let add_Z1Z1_cc_0_6 = shr(add_Z1Z1_v_0_6, 26)
    let add_Z1Z1_v_0_7 = 0 + (s.qz0 * s.qz7) + add_Z1Z1_cc_0_6
    let add_Z1Z1_t_0_7 = band(add_Z1Z1_v_0_7, 67108863)
    let add_Z1Z1_cc_0_7 = shr(add_Z1Z1_v_0_7, 26)
    let add_Z1Z1_v_0_8 = 0 + (s.qz0 * s.qz8) + add_Z1Z1_cc_0_7
    let add_Z1Z1_t_0_8 = band(add_Z1Z1_v_0_8, 67108863)
    let add_Z1Z1_cc_0_8 = shr(add_Z1Z1_v_0_8, 26)
    let add_Z1Z1_v_0_9 = 0 + (s.qz0 * s.qz9) + add_Z1Z1_cc_0_8
    let add_Z1Z1_t_0_9 = band(add_Z1Z1_v_0_9, 67108863)
    let add_Z1Z1_cc_0_9 = shr(add_Z1Z1_v_0_9, 26)
    let add_Z1Z1_vN_0 = 0 + add_Z1Z1_cc_0_9
    let add_Z1Z1_tN_0 = band(add_Z1Z1_vN_0, 67108863)
    let add_Z1Z1_tN1_0 = shr(add_Z1Z1_vN_0, 26)
    let add_Z1Z1_m_0 = band((add_Z1Z1_t_0_0 * 1), 67108863)
    let add_Z1Z1_rc_0_0 = shr(add_Z1Z1_t_0_0 + (add_Z1Z1_m_0 * 67108863), 26)
