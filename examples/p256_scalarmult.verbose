    let add_Z1Z1_cc_1_2 = shr(add_Z1Z1_v_1_2, 26)
    let add_Z1Z1_v_1_3 = add_Z1Z1_rt_0_4 + (s.qz1 * s.qz3) + add_Z1Z1_cc_1_2
