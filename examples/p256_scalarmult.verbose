    let add_Z1Z1_t_0_3 = band(add_Z1Z1_v_0_3, 67108863)
    let add_Z1Z1_cc_0_3 = shr(add_Z1Z1_v_0_3, 26)
    let add_Z1Z1_v_0_4 = 0 + (s.qz0 * s.qz4) + add_Z1Z1_cc_0_3
    let add_Z1Z1_t_0_4 = band(add_Z1Z1_v_0_4, 67108863)
    let add_Z1Z1_cc_0_4 = shr(add_Z1Z1_v_0_4, 26)
    let add_Z1Z1_v_0_5 = 0 + (s.qz0 * s.qz5) + add_Z1Z1_cc_0_4
    let add_Z1Z1_t_0_5 = band(add_Z1Z1_v_0_5, 67108863)
