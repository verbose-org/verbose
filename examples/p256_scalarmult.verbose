rule p256_scalarmult
  @intention: "P-256 scalar mult [scalar]P by double-and-add over 256 bits (LSB-first, big-endian scalar); incomplete-add safe via infinity flag; returns limb which of Jacobian accumulator Q (X|Y|Z)"
  @source: invoices.intent:1
  input:
    s : P256ScalarState
  output:
    out : number
  logic:
    let pos = if s.j == 0 then 0 else 256 - s.j
    let byte_be = 31 - shr(pos, 3)
    let bpos = band(pos, 7)
    let hpos = shl(byte_be, 1)
    let hc = byte_at(s.scalar, hpos)
    let lc = byte_at(s.scalar, hpos + 1)
    let hv = if hc <= 57 then hc - 48 else bor(hc, 32) - 87
    let lv = if lc <= 57 then lc - 48 else bor(lc, 32) - 87
    let bytev = 16 * hv + lv
    let bit = band(shr(bytev, bpos), 1)
    let add_Z1Z1_v_0_0 = 0 + (s.qz0 * s.qz0) + 0
    let add_Z1Z1_t_0_0 = band(add_Z1Z1_v_0_0, 67108863)
    let add_Z1Z1_cc_0_0 = shr(add_Z1Z1_v_0_0, 26)
    let add_Z1Z1_v_0_1 = 0 + (s.qz0 * s.qz1) + add_Z1Z1_cc_0_0
    let add_Z1Z1_t_0_1 = band(add_Z1Z1_v_0_1, 67108863)
    let add_Z1Z1_cc_0_1 = shr(add_Z1Z1_v_0_1, 26)
    let add_Z1Z1_v_0_2 = 0 + (s.qz0 * s.qz2) + add_Z1Z1_cc_0_1
