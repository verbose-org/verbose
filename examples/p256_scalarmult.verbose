    let add_Z1Z1_cc_1_0 = shr(add_Z1Z1_v_1_0, 26)
    let add_Z1Z1_v_1_1 = add_Z1Z1_rt_0_2 + (s.qz1 * s.qz1) + add_Z1Z1_cc_1_0
    let add_Z1Z1_t_1_1 = band(add_Z1Z1_v_1_1, 67108863)
    let add_Z1Z1_cc_1_1 = shr(add_Z1Z1_v_1_1, 26)
    let add_Z1Z1_v_1_2 = add_Z1Z1_rt_0_3 + (s.qz1 * s.qz2) + add_Z1Z1_cc_1_1
