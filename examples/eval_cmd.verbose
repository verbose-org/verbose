@verbose 0.1.0

concept ScanState
  @intention: "Scanner position"
  @source: eval_cmd.intent:1
  fields:
    source : text [..256]
    pos : number [0, 256]

concept DigitScan
  @intention: "Digit scanner with accumulator"
  @source: eval_cmd.intent:1
  fields:
    source : text [..256]
    pos : number [0, 256]
    acc : number [0, 999999]


rule skip_spaces
  @intention: "Advance past spaces"
  @source: eval_cmd.intent:2
  input:
    s : ScanState
  output:
    out : number
  logic:
    let len = length(s.source)
    out = if s.pos >= len then s.pos else if byte_at(s.source, s.pos) == 32 then skip_spaces(ScanState { source: s.source, pos: s.pos + 1 }) else s.pos
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : [skip_spaces]
    termination:
      bound : 256
      increasing : pos


rule word_length
  @intention: "Count consecutive lowercase letters"
  @source: eval_cmd.intent:2
  input:
    s : ScanState
  output:
    out : number
  logic:
    let len = length(s.source)
    out = if s.pos >= len then 0 else if byte_at(s.source, s.pos) >= 97 and byte_at(s.source, s.pos) <= 122 then 1 + word_length(ScanState { source: s.source, pos: s.pos + 1 }) else 0
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : [word_length]
    termination:
      bound : 256
      increasing : pos


rule scan_digits
  @intention: "Accumulate decimal digits"
  @source: eval_cmd.intent:2
  input:
    d : DigitScan
  output:
    out : number
  logic:
    let len = length(d.source)
    out = if d.pos >= len then d.acc else if byte_at(d.source, d.pos) >= 48 and byte_at(d.source, d.pos) <= 57 then scan_digits(DigitScan { source: d.source, pos: d.pos + 1, acc: d.acc * 10 + byte_at(d.source, d.pos) - 48 }) else d.acc
  proofs:
    purity:
      reads : [d.source, d.pos, d.acc]
      calls : [scan_digits]
    termination:
      bound : 256
      increasing : pos


rule skip_digits
  @intention: "Advance past digit characters"
  @source: eval_cmd.intent:3
  input:
    s : ScanState
  output:
    out : number
  logic:
    let len = length(s.source)
    out = if s.pos >= len then s.pos else if byte_at(s.source, s.pos) >= 48 and byte_at(s.source, s.pos) <= 57 then skip_digits(ScanState { source: s.source, pos: s.pos + 1 }) else s.pos
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : [skip_digits]
    termination:
      bound : 256
      increasing : pos


rule read_number_at
  @intention: "Parse decimal number starting at a given position"
  @source: eval_cmd.intent:3
  input:
    s : ScanState
  output:
    out : number
  logic:
    let p = skip_spaces(s)
    out = scan_digits(DigitScan { source: s.source, pos: p, acc: 0 })
  proofs:
    purity:
      reads : [s.source, s]
      calls : [skip_spaces, scan_digits]
    termination:
      bound : 256


rule eval_cmd
  @intention: "Parse and evaluate a command: add X Y, neg X, or bare number"
  @source: eval_cmd.intent:4
  input:
    s : ScanState
  output:
    out : number
  logic:
    let p = skip_spaces(s)
    let wlen = word_length(ScanState { source: s.source, pos: p })
    let p1 = skip_spaces(ScanState { source: s.source, pos: p + wlen })
    let arg1 = scan_digits(DigitScan { source: s.source, pos: p1, acc: 0 })
    let after1 = skip_digits(ScanState { source: s.source, pos: p1 })
    let arg2 = read_number_at(ScanState { source: s.source, pos: after1 })
    out = if wlen == 0 then read_number_at(s) else if wlen != 3 then 0 else if byte_at(s.source, p) == 97 and byte_at(s.source, p + 1) == 100 and byte_at(s.source, p + 2) == 100 then arg1 + arg2 else if byte_at(s.source, p) == 110 and byte_at(s.source, p + 1) == 101 and byte_at(s.source, p + 2) == 103 then 0 - arg1 else 0
  proofs:
    purity:
      reads : [s.source, s]
      calls : [skip_spaces, word_length, scan_digits, skip_digits, read_number_at]
    termination:
      bound : 256
