@verbose 0.1.0

concept ShaState
  @intention: "SHA-256 fold state: 8 hash words + block count, counter, which, hex pre-padded data"
  @source: invoices.intent:1
  fields:
    h0 : number [0, 4294967295]
    h1 : number [0, 4294967295]
    h2 : number [0, 4294967295]
    h3 : number [0, 4294967295]
    h4 : number [0, 4294967295]
    h5 : number [0, 4294967295]
    h6 : number [0, 4294967295]
    h7 : number [0, 4294967295]
    nblocks : number [0, 64]
    i : number [0, 64]
    which : number [0, 31]
    data : text


rule sha256_fold
  @intention: "SHA-256 over N pre-padded 64-byte blocks (hex): state=IV; per block state=compress(state,block); returns digest byte which"
  @source: invoices.intent:1
  input:
    s : ShaState
  output:
    out : number
  logic:
    let bidx = if s.i == 0 then 0 else s.nblocks - s.i
    let boff = bidx * 128
    let w0_hi0 = byte_at(s.data, boff + 0)
    let w0_lo0 = byte_at(s.data, boff + 1)
    let w0_hv0 = if w0_hi0 <= 57 then w0_hi0 - 48 else bor(w0_hi0, 32) - 87
    let w0_lv0 = if w0_lo0 <= 57 then w0_lo0 - 48 else bor(w0_lo0, 32) - 87
    let w0_b0 = 16 * w0_hv0 + w0_lv0
    let w0_hi1 = byte_at(s.data, boff + 2)
    let w0_lo1 = byte_at(s.data, boff + 3)
    let w0_hv1 = if w0_hi1 <= 57 then w0_hi1 - 48 else bor(w0_hi1, 32) - 87
    let w0_lv1 = if w0_lo1 <= 57 then w0_lo1 - 48 else bor(w0_lo1, 32) - 87
    let w0_b1 = 16 * w0_hv1 + w0_lv1
