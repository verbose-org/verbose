    let w0_hi3 = byte_at(s.data, boff + 6)
    let w0_lo3 = byte_at(s.data, boff + 7)
    let w0_hv3 = if w0_hi3 <= 57 then w0_hi3 - 48 else bor(w0_hi3, 32) - 87
    let w0_lv3 = if w0_lo3 <= 57 then w0_lo3 - 48 else bor(w0_lo3, 32) - 87
    let w0_b3 = 16 * w0_hv3 + w0_lv3
    let w0 = band(bor(bor(bor(shl(w0_b0, 24), shl(w0_b1, 16)), shl(w0_b2, 8)), w0_b3), 4294967295)
    let w1_hi0 = byte_at(s.data, boff + 8)
    let w1_lo0 = byte_at(s.data, boff + 9)
    let w1_hv0 = if w1_hi0 <= 57 then w1_hi0 - 48 else bor(w1_hi0, 32) - 87
