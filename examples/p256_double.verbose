    let dbl_delta_v_0_3 = 0 + (g.z1_0 * g.z1_3) + dbl_delta_cc_0_2
    let dbl_delta_t_0_3 = band(dbl_delta_v_0_3, 67108863)
    let dbl_delta_cc_0_3 = shr(dbl_delta_v_0_3, 26)
