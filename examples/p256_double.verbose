@verbose 0.1.0

concept P256DblInput
  @intention: "one Jacobian P-256 point (X1,Y1,Z1), 10 Montgomery limbs each, + which output limb (0..29)"
  @source: invoices.intent:1
  fields:
    x1_0 : number [0, 67108863]
    x1_1 : number [0, 67108863]
    x1_2 : number [0, 67108863]
    x1_3 : number [0, 67108863]
    x1_4 : number [0, 67108863]
    x1_5 : number [0, 67108863]
    x1_6 : number [0, 67108863]
    x1_7 : number [0, 67108863]
    x1_8 : number [0, 67108863]
    x1_9 : number [0, 67108863]
    y1_0 : number [0, 67108863]
    y1_1 : number [0, 67108863]
    y1_2 : number [0, 67108863]
    y1_3 : number [0, 67108863]
    y1_4 : number [0, 67108863]
    y1_5 : number [0, 67108863]
    y1_6 : number [0, 67108863]
    y1_7 : number [0, 67108863]
    y1_8 : number [0, 67108863]
    y1_9 : number [0, 67108863]
    z1_0 : number [0, 67108863]
    z1_1 : number [0, 67108863]
    z1_2 : number [0, 67108863]
    z1_3 : number [0, 67108863]
    z1_4 : number [0, 67108863]
    z1_5 : number [0, 67108863]
    z1_6 : number [0, 67108863]
    z1_7 : number [0, 67108863]
    z1_8 : number [0, 67108863]
    z1_9 : number [0, 67108863]
    which : number [0, 29]


rule p256_double
  @intention: "short-Weierstrass a=-3 Jacobian point doubling (EFD dbl-2001-b) over GF(p256); returns limb which of X3|Y3|Z3 in Montgomery domain"
  @source: invoices.intent:1
  input:
    g : P256DblInput
  output:
    out : number
  logic:
    let dbl_delta_v_0_0 = 0 + (g.z1_0 * g.z1_0) + 0
    let dbl_delta_t_0_0 = band(dbl_delta_v_0_0, 67108863)
    let dbl_delta_cc_0_0 = shr(dbl_delta_v_0_0, 26)
    let dbl_delta_v_0_1 = 0 + (g.z1_0 * g.z1_1) + dbl_delta_cc_0_0
    let dbl_delta_t_0_1 = band(dbl_delta_v_0_1, 67108863)
    let dbl_delta_cc_0_1 = shr(dbl_delta_v_0_1, 26)
    let dbl_delta_v_0_2 = 0 + (g.z1_0 * g.z1_2) + dbl_delta_cc_0_1
    let dbl_delta_t_0_2 = band(dbl_delta_v_0_2, 67108863)
