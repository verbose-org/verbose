    let dbl_delta_rt_1_4 = band(dbl_delta_rv_1_4, 67108863)
    let dbl_delta_rcc_1_4 = shr(dbl_delta_rv_1_4, 26)
    let dbl_delta_rv_1_5 = dbl_delta_t_1_5 + (dbl_delta_m_1 * 0) + dbl_delta_rcc_1_4
    let dbl_delta_rt_1_5 = band(dbl_delta_rv_1_5, 67108863)
    let dbl_delta_rcc_1_5 = shr(dbl_delta_rv_1_5, 26)
    let dbl_delta_rv_1_6 = dbl_delta_t_1_6 + (dbl_delta_m_1 * 0) + dbl_delta_rcc_1_5
    let dbl_delta_rt_1_6 = band(dbl_delta_rv_1_6, 67108863)
    let dbl_delta_rcc_1_6 = shr(dbl_delta_rv_1_6, 26)
    let dbl_delta_rv_1_7 = dbl_delta_t_1_7 + (dbl_delta_m_1 * 1024) + dbl_delta_rcc_1_6
    let dbl_delta_rt_1_7 = band(dbl_delta_rv_1_7, 67108863)
    let dbl_delta_rcc_1_7 = shr(dbl_delta_rv_1_7, 26)
    let dbl_delta_rv_1_8 = dbl_delta_t_1_8 + (dbl_delta_m_1 * 67043328) + dbl_delta_rcc_1_7
