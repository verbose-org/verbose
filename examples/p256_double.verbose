    let dbl_delta_v_1_6 = dbl_delta_rt_0_7 + (g.z1_1 * g.z1_6) + dbl_delta_cc_1_5
    let dbl_delta_t_1_6 = band(dbl_delta_v_1_6, 67108863)
    let dbl_delta_cc_1_6 = shr(dbl_delta_v_1_6, 26)
    let dbl_delta_v_1_7 = dbl_delta_rt_0_8 + (g.z1_1 * g.z1_7) + dbl_delta_cc_1_6
