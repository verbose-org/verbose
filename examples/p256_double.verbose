    let dbl_delta_t_0_4 = band(dbl_delta_v_0_4, 67108863)
    let dbl_delta_cc_0_4 = shr(dbl_delta_v_0_4, 26)
    let dbl_delta_v_0_5 = 0 + (g.z1_0 * g.z1_5) + dbl_delta_cc_0_4
    let dbl_delta_t_0_5 = band(dbl_delta_v_0_5, 67108863)
    let dbl_delta_cc_0_5 = shr(dbl_delta_v_0_5, 26)
    let dbl_delta_v_0_6 = 0 + (g.z1_0 * g.z1_6) + dbl_delta_cc_0_5
    let dbl_delta_t_0_6 = band(dbl_delta_v_0_6, 67108863)
    let dbl_delta_cc_0_6 = shr(dbl_delta_v_0_6, 26)
    let dbl_delta_v_0_7 = 0 + (g.z1_0 * g.z1_7) + dbl_delta_cc_0_6
    let dbl_delta_t_0_7 = band(dbl_delta_v_0_7, 67108863)
