    let dbl_delta_rcc_0_5 = shr(dbl_delta_rv_0_5, 26)
    let dbl_delta_rv_0_6 = dbl_delta_t_0_6 + (dbl_delta_m_0 * 0) + dbl_delta_rcc_0_5
