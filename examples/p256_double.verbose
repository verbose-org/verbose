    let dbl_delta_v_0_9 = 0 + (g.z1_0 * g.z1_9) + dbl_delta_cc_0_8
    let dbl_delta_t_0_9 = band(dbl_delta_v_0_9, 67108863)
    let dbl_delta_cc_0_9 = shr(dbl_delta_v_0_9, 26)
    let dbl_delta_vN_0 = 0 + dbl_delta_cc_0_9
    let dbl_delta_tN_0 = band(dbl_delta_vN_0, 67108863)
    let dbl_delta_tN1_0 = shr(dbl_delta_vN_0, 26)
    let dbl_delta_m_0 = band((dbl_delta_t_0_0 * 1), 67108863)
    let dbl_delta_rc_0_0 = shr(dbl_delta_t_0_0 + (dbl_delta_m_0 * 67108863), 26)
    let dbl_delta_rv_0_1 = dbl_delta_t_0_1 + (dbl_delta_m_0 * 67108863) + dbl_delta_rc_0_0
    let dbl_delta_rt_0_1 = band(dbl_delta_rv_0_1, 67108863)
    let dbl_delta_rcc_0_1 = shr(dbl_delta_rv_0_1, 26)
    let dbl_delta_rv_0_2 = dbl_delta_t_0_2 + (dbl_delta_m_0 * 67108863) + dbl_delta_rcc_0_1
    let dbl_delta_rt_0_2 = band(dbl_delta_rv_0_2, 67108863)
    let dbl_delta_rcc_0_2 = shr(dbl_delta_rv_0_2, 26)
    let dbl_delta_rv_0_3 = dbl_delta_t_0_3 + (dbl_delta_m_0 * 262143) + dbl_delta_rcc_0_2
    let dbl_delta_rt_0_3 = band(dbl_delta_rv_0_3, 67108863)
    let dbl_delta_rcc_0_3 = shr(dbl_delta_rv_0_3, 26)
