@verbose 0.1.0

concept Byte
  @intention: "single byte 0..255"
  @source: aes_gcm.intent:1
  fields:
    b : number [0, 255]

concept GcmInput
  @intention: "16-byte key + 12-byte (96-bit) IV + 16-byte plaintext block + which output byte (0..31 = C||tag)"
  @source: aes_gcm.intent:1
  fields:
    k0 : number [0, 255]
    k1 : number [0, 255]
