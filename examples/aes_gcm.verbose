rule xtime
  @intention: "GF(2^8) multiply by x"
  @source: aes_gcm.intent:3
  input:
    inp : Byte
  output:
    out : number
  logic:
    out = if band(inp.b, 128) > 0 then band(bxor(shl(inp.b, 1), 27), 255) else band(shl(inp.b, 1), 255)
  proofs:
    purity:
      reads : [inp.b]
      calls : []
    termination:
      bound : 20


rule gcm_encrypt
  @intention: "AES-128-GCM AEAD: one plaintext block, 96-bit IV, empty AAD. Returns byte `which` of C||tag (0..15=ciphertext, 16..31=auth tag)"
  @source: aes_gcm.intent:4
  input:
    g : GcmInput
  output:
    out : number
  logic:
    let ks0 = g.k0
    let ks1 = g.k1
    let ks2 = g.k2
    let ks3 = g.k3
    let ks4 = g.k4
    let ks5 = g.k5
    let ks6 = g.k6
    let ks7 = g.k7
    let ks8 = g.k8
    let ks9 = g.k9
    let ks10 = g.k10
    let ks11 = g.k11
    let ks12 = g.k12
    let ks13 = g.k13
    let ks14 = g.k14
    let ks15 = g.k15
    let ks16 = band(bxor(bxor(ks0, aes_sbox(Byte { b: ks13 })), 1), 255)
    let ks17 = band(bxor(ks1, aes_sbox(Byte { b: ks14 })), 255)
    let ks18 = band(bxor(ks2, aes_sbox(Byte { b: ks15 })), 255)
    let ks19 = band(bxor(ks3, aes_sbox(Byte { b: ks12 })), 255)
    let ks20 = band(bxor(ks4, ks16), 255)
    let ks21 = band(bxor(ks5, ks17), 255)
    let ks22 = band(bxor(ks6, ks18), 255)
    let ks23 = band(bxor(ks7, ks19), 255)
    let ks24 = band(bxor(ks8, ks20), 255)
    let ks25 = band(bxor(ks9, ks21), 255)
    let ks26 = band(bxor(ks10, ks22), 255)
    let ks27 = band(bxor(ks11, ks23), 255)
    let ks28 = band(bxor(ks12, ks24), 255)
    let ks29 = band(bxor(ks13, ks25), 255)
    let ks30 = band(bxor(ks14, ks26), 255)
    let ks31 = band(bxor(ks15, ks27), 255)
    let ks32 = band(bxor(bxor(ks16, aes_sbox(Byte { b: ks29 })), 2), 255)
    let ks33 = band(bxor(ks17, aes_sbox(Byte { b: ks30 })), 255)
    let ks34 = band(bxor(ks18, aes_sbox(Byte { b: ks31 })), 255)
    let ks35 = band(bxor(ks19, aes_sbox(Byte { b: ks28 })), 255)
    let ks36 = band(bxor(ks20, ks32), 255)
    let ks37 = band(bxor(ks21, ks33), 255)
    let ks38 = band(bxor(ks22, ks34), 255)
    let ks39 = band(bxor(ks23, ks35), 255)
    let ks40 = band(bxor(ks24, ks36), 255)
