@verbose 0.1.0

-- Verbose-in-Verbose expression PARSER, brick 7 of the self-hosting arc.
--
-- Brick 7 adds two LITERAL kinds to parse_primary: boolean literals (`true` /
-- `false`, lexed as keywords codes 9/10, parsed to AstBool carrying 1/0) and
-- string literals (`"..."` with the closed escape set \n \r \t \\ \", lexed by
-- a new string_run scanner into a Str token, parsed to AstStr identified by its
-- source span). Booleans carry an arithmetic value (eval true=1, false=0) and
-- compose in and/or/not/comparisons; strings have no value without an
-- environment, so eval_ast returns 0 and correctness is proven by shape_ast
-- (dedicated bands AstBool=1000000, AstStr=10000000). The string scanner is the
-- tokenizer-reopening part: a backslash starts a 2-byte escape (LENIENT — this
-- is a token-boundary scanner, not an escape validator), so an escaped quote
-- \" does NOT terminate the string; an unterminated string runs to end-of-source.
--
-- Brick 2 (vtokenstream.verbose) materialized the token stream as a cons-list.
-- Brick 3 consumed that stream and built an arithmetic-expression AST in the
-- arena, WITH operator precedence, then evaluated it. Brick 4 EXTENDED that
-- ladder to the FULL expression precedence: logical or/and, comparisons, and
-- prefix unary (not / negation). Brick 5 grew `primary` to identifiers, function
-- calls, and field access. Brick 6 adds a CONDITIONAL EXPRESSION as the highest-
-- level alternative in `primary`: `if cond then thn else els`, the single-line
-- form (there is no INDENT/DEDENT in this tokenizer, so the multi-line block is a
-- later brick). The grammar (mirroring src/parser.rs, lowest to highest):
--
--   parse_expr = or_expr
--   or_expr    = and_expr ('or'  and_expr)*                 -- left-assoc, kw 'or'
--   and_expr   = cmp_expr ('and' cmp_expr)*                 -- left-assoc, kw 'and'
--   cmp_expr   = add_expr (('==' '!=' '<' '>' '<=' '>=') add_expr)?  -- non-assoc, <=1
--   add_expr   = mul_expr (('+' | '-') mul_expr)*           -- left-assoc  [brick 3]
--   mul_expr   = unary    (('*' | '/' | '%') unary)*        -- left-assoc  [brick 3 + %]
--   unary      = ('not' | '-') unary | primary              -- prefix, right-recursive
--   primary    = 'if' parse_or 'then' parse_or 'else' parse_or  -- brick 6, single-line
--              | '(' parse_or ')' | NUMBER | IDENT trailer       -- bricks 3 + 5
--
-- Each of the conditional's three sub-expressions is a FULL parse_or, so the
-- else-branch absorbs trailing operators: `if 1 then 2 else 3 + 100` parses the
-- else as `3 + 100` (and evaluates to 2, the then-branch). The if-expression is a
-- primary, so it nests in arithmetic via parens: `1 + (if 1 then 2 else 3)` = 3.
--
-- '*' '/' '%' bind tighter than '+' '-', which bind tighter than comparisons,
-- which bind tighter than 'and', which binds tighter than 'or'. Binary operators
-- are LEFT-associative (10-2-3 = 5; 2<3 and 4<5 = 1). Prefix unary is
-- right-recursive (not not 0 = 0; - -3 = 3). Calls, fields, and strings are
-- later bricks; this is the operator precedence ladder in full.
--
-- ============================================================================
-- AST OP-CODE MAP (the AstBin op field; chosen to avoid any collision).
-- ============================================================================
--   arithmetic   +  = 13   -  = 14   *  = 15   /  = 16   %  = 17  (tokenizer op_codes)
--   comparison   == = 1    != = 6    <  = 19   >  = 20   <= = 5   >= = 4   (tokenizer op_codes)
--   logical      and = 30  or = 31   (DEDICATED — kw codes 5/2 would alias <=/?, so remapped)
-- Unary uses its own variants (AstNeg / AstNot), no op code needed.
-- The three bands {13..17} {1,4,5,6,19,20} {30,31} are pairwise disjoint.
--
-- ============================================================================
-- POSITION THREADING (the hard part) — option (c): Parsed{node, next}.
-- ============================================================================
-- A recursive-descent function conceptually returns (ast, new_position): the
-- parsed node AND how far it consumed. A Verbose rule returns ONE value, so
-- each parse rule returns a `Parsed` arena node = { node: Ast, next: number }.
-- The caller reads `.next` to know where to resume and `.node` for the subtree.
-- This threads position cleanly through the arena and uses the group-field ABI
-- shipped in 9529277 (a recursive native rule can take a group-concept field).
--
-- ============================================================================
-- LEFT-ASSOCIATIVITY with single-return rules (no loops in Verbose).
-- ============================================================================
-- Classic recursive descent loops: `lhs = mul(); while op in {+,-}: lhs =
-- Bin(op, lhs, mul())`. Verbose has no loops — only recursion. The loop becomes
-- an accumulator recursion: parse_add parses the FIRST mul operand, then hands
-- (acc = that node, pos = after it) to add_rest. add_rest peeks the operator;
-- if it's +/-, it parses the next mul operand, folds Bin(op, acc, rhs) — acc on
-- the LEFT — and recurses with the new acc and new pos. Folding the accumulator
-- on the left at each step is exactly what makes the tree left-associative.
-- mul_rest does the same for * and /.
--
-- ============================================================================
-- TERMINATION
-- ============================================================================
-- The precedence rules form a cycle: parse_add -> parse_mul -> parse_primary
-- -> parse_add (through parentheses). No `decreasing`/`increasing`/`structural`
-- proof fits a precedence parser (position advances but not by a literal k, and
-- the input is a plain group-field record, not a structurally-shrinking group
-- value at every call). So these rules declare bound-only termination and
-- ACCEPT the mandatory native recursion breadcrumb — same posture as brick 2's
-- tokenize. Runtime backstops: the token list is FINITE (every parse step that
-- recurses has consumed at least one token, so pos strictly grows toward Eof),
-- the arena `max_nodes` is bounded, and every list access is Eof-guarded.
--
-- Oracle: src/parser.rs's parse_add_expr / parse_mul_expr / parse_primary.

-- ============================================================================
-- Arena sizing (the cap). The arena holds EVERY node: the token stream from
-- brick 2 (Token values + TokenList cons cells, ~2N+3 nodes for N tokens) AND
-- the AST (Parsed wrappers + Ast nodes). For an expression of N tokens the AST
-- has ~N/2 leaves and ~N/2 internal nodes plus a Parsed wrapper per parse-rule
-- return. Over the cap a VariantConstruct hits the arena bounds-check and the
-- binary exits 1 (fail-closed) rather than corrupting memory.
--
-- SIZING (self-hosting): when elf_program_src is compiled natively and driven
-- on REAL vexprparse source fragments, the arena must hold the ENTIRE parse
-- (token cons-list + full AST for every rule) PLUS every intermediate list node
-- the codegen walk constructs (fields_to_params / params_to_fields / arg-list
-- builds, re-run per call site because the arena never reclaims). Measured peak
-- for the count_purity_errors closure (174 rules -> a 201 580-byte ELF) is
-- ~2.45M nodes: ~1.67M for the parse alone, ~0.78M added by the walk. The old
-- 2 000 000 cap fit the parse + only ~42% of the walk, so the 174-rule self-
-- checker aborted mid-emit (exit 1, a truncated ELF whose header still claimed
-- the full p_filesz -> SIGBUS when the truncated file was mapped and run).
-- Raised to the verifier's hard ceiling (4 000 000, see
-- docs/arena-allocation-design.md) -- ~63% headroom over the current largest
-- self-host target.
-- ponytail: 4 000 000 is the compiler's max_nodes ceiling; the FULL 509-rule
-- self-compile (~7M nodes) needs BOTH a higher verifier ceiling AND a real fix
-- for the O(sites x program) redundant arena allocation (thread the constant
-- blob_end_off / proc_offset results through ByteGenState instead of
-- recomputing per call site, or add arena reclamation). Neither is needed for
-- the current self-checker milestone.
-- ============================================================================
concept_group VExpr [max_depth: 4096, max_nodes: 6000000]
  @intention: "Tokens, a token cons-list, an arithmetic AST, and a parse result"
  @source: vexprparse.intent:1

  concept Token
    @intention: "One classified lexeme: kind + source span / value"
    @source: vexprparse.intent:1
    variants:
      Ident of (start : number, len : number)
      Keyword of (start : number, len : number, kw : number)
      Num of (value : number, len : number)
      Op of (code : number, len : number)
      -- A string literal token. start = the byte offset of the OPENING quote;
      -- len = the TOTAL byte length of the token INCLUDING both quotes (so
      -- token_end advances past the closing quote naturally). The span is the
      -- string's identity (like Ident / AstVar): brick 7 does not decode the
      -- bytes — that needs an environment — so a Str node's correctness is proven
      -- STRUCTURALLY by the shape walk, never by an evaluated value.
      Str of (start : number, len : number)
      -- BYTES-tier brick B1: a byte-literal token `b"..."`. A `b` IMMEDIATELY
      -- followed by `"` opens a byte literal (distinct from an Ident `b` next to a
      -- string). start = the byte offset of the OPENING quote (the byte just after
      -- the `b`); len = the TOTAL byte length of the token INCLUDING the `b`, both
      -- quotes, and the `\xNN` escapes verbatim (so token_end advances past the
      -- closing quote naturally). The span is the literal's identity — B1 does NOT
      -- hex-decode the bytes (that needs an environment / a bytes value, which is
      -- B2). parse_primary strips the `b"` prefix and closing quote into the
      -- AstBytes content span; the raw-newline gate (like Str) turns an unterminated
      -- byte literal into an IndentErr.
      ByteLit of (start : number, len : number)
      -- A line-boundary token (brick 8a). pos = the byte offset of the newline
      -- byte (10) in the source. The tokenizer no longer STOPS at a newline (the
      -- pre-8a flat scanner classified byte 10 as Eof and tokenize halted at the
      -- first line break); instead next_token recognizes byte 10 — after skipping
      -- INLINE spaces (byte 32 only) — as a Newline token, token_end advances
      -- exactly 1 past it, and tokenize conses it like any other token and keeps
      -- scanning the next line. This lifts the "stops at first newline" limit so a
      -- multi-line source tokenizes into a flat stream WITH Newline tokens marking
      -- line boundaries. Brick 8a emits Newline FAITHFULLY: consecutive newlines
      -- (blank lines) emit consecutive Newline tokens — collapsing blanks and the
      -- INDENT/DEDENT column-stack logic are brick 8b. Brick 8a computes NO
      -- indentation, columns, INDENT, or DEDENT.
      Newline of (pos : number)
      -- Brick 8b: structural block tokens woven into the stream by the line
      -- driver (tokenize_indent). Indent marks entering a deeper block (one per
      -- deeper level, pushed onto the column stack); Dedent marks leaving a block
      -- (one per popped level, emitted on a shallower line AND flushed at EOF for
      -- every still-open level). IndentErr is the fail-closed error token: a
      -- Verbose rule is TOTAL (it cannot abort mid-evaluation the way
      -- src/lexer.rs returns a LexError), so the reference's tab-rejection and
      -- inconsistent-indentation errors become a distinguished token in the
      -- stream that the downstream self-hosting parser treats as a hard stop.
      -- pos = the byte offset of the offending line's content start.
      Indent
      Dedent
      IndentErr of (pos : number)
      Eof

  concept TokenList
    @intention: "Cons-list of tokens: the materialized token stream"
    @source: vexprparse.intent:1
    variants:
      Cons of (head : Token, tail : TokenList)
      Nil

  concept Ast
    @intention: "Expression AST: number leaf, binary op node, or unary op node"
    @source: vexprparse.intent:1
    variants:
      -- A numeric literal leaf
      AstNum of (value : number)
      -- A binary operator node: op is the AST op-code (see the op-code map at
      -- the top — arithmetic 13..17, comparison 1/4/5/6/19/20, logical 30/31),
      -- lhs/rhs are sub-expressions
      AstBin of (op : number, lhs : Ast, rhs : Ast)
      -- Prefix arithmetic negation: -inner
      AstNeg of (inner : Ast)
      -- Prefix logical not: not inner (-> 1 if inner == 0 else 0)
      AstNot of (inner : Ast)
      -- A bare variable reference, identified by its source SPAN (start byte
      -- offset + byte length). The span is the node's identity: two different
      -- identifiers necessarily occupy different (start) offsets, and carrying
      -- len as well distinguishes a short ident from a longer one that happens
      -- to start at the same place (impossible in one source, but the pair is
      -- the honest identity and what src/parser.rs's Expr::Ident name stands in
      -- for). Brick 5 does not resolve the name to bytes — that needs an
      -- environment; here the span IS the variable, proven structurally.
      AstVar of (start : number, len : number)
      -- Field access: base.field. The accessed field is a span (fstart, flen);
      -- base is the sub-expression being accessed. Chains nest left-deep:
      -- a.b.c parses to AstField(AstField(AstVar(a), b), c).
      AstField of (base : Ast, fstart : number, flen : number)
      -- A function call: callee identified by its span (callee_start,
      -- callee_len), args a cons-list (ArgList) of argument sub-expressions.
      -- f() has args = ArgNil; f(x) = ArgCons(AstVar(x), ArgNil); f(x, y) =
      -- ArgCons(AstVar(x), ArgCons(AstVar(y), ArgNil)).
      AstCall of (callee_start : number, callee_len : number, args : ArgList)
      -- A conditional expression: if cond then thn else els. All three are
      -- sub-expressions (each a full parse_or). eval_ast evaluates cond, then
      -- the SELECTED branch only (the language's lazy if, so the dead branch's
      -- eval_ast never runs). Brick 6: single-line form only — there is no
      -- INDENT/DEDENT in this tokenizer, so the multi-line form is a later brick.
      AstIf of (cond : Ast, thn : Ast, els : Ast)
      -- A boolean literal leaf: value is 1 for `true`, 0 for `false`. Brick 7.
      -- Unlike AstStr/AstVar, a boolean DOES carry an arithmetic value, so
      -- eval_ast returns it directly (true -> 1, false -> 0), and it composes in
      -- and/or/not/comparisons exactly as a 1/0 number would.
      AstBool of (value : number)
      -- A string-literal leaf, identified by its source SPAN (start = opening
      -- quote offset, len = total bytes including both quotes — copied from the
      -- Str token). Brick 7. A string has no arithmetic value without an
      -- environment to decode its bytes, so eval_ast returns 0 and correctness
      -- is proven STRUCTURALLY by shape_ast (a dedicated band), exactly like
      -- AstVar / AstCall / AstField.
      AstStr of (start : number, len : number)
      -- BYTES-tier brick B1: a byte-literal leaf `b"..."`, identified by its
      -- source SPAN (start = the byte offset of the CONTENT after the `b"` prefix,
      -- len = the content byte length between the quotes — see parse_primary /
      -- the ByteLit token). Distinct from AstStr: a byte literal's `\xNN` escapes
      -- hex-decode to RAW bytes (no quote-strip / text-slice semantics), and the
      -- emitter (x86_node / le32 / le64 / bytes-concat) is BUILT of these. B1 is
      -- PARSER-ONLY: eval / type / codegen get STUB arms (real handling is B2/B3);
      -- shape_ast gives it a dedicated band (10^10, above AstVariant's 10^9) so a
      -- parsed byte literal has a predictable fingerprint.
      AstBytes of (start : number, len : number)
      -- An error/placeholder leaf (unexpected token); evaluates to 0
      AstErr
      -- Records-arc brick R3: a VARIANT construction `Concept::Variant { f: e, ... }`.
      -- cstart/clen = the concept-name source span; vstart/vlen = the variant-name
      -- source span (both identified by span, like AstVar — R3 does not decode the
      -- names to bytes). `fields` is the (possibly empty) cons-list of named field
      -- initializers (VFieldList); a braceless form like `Token::Eof` has fields =
      -- VFNil. R3 is PARSER-ONLY: eval / type / codegen get STUB arms (real handling
      -- is R6/R7); shape_ast gives it a dedicated band so a parsed variant body has a
      -- predictable fingerprint.
      AstVariant of (cstart : number, clen : number, vstart : number, vlen : number, fields : VFieldList)
      -- Records-arc brick R3: a block-form `match scrut: Variant(binders) => body ...`.
      -- `scrut` is the scrutinee sub-expression (a full parse_or); `arms` is the
      -- cons-list of arms (ArmList), each carrying the variant-name span, its binder
      -- list, and the arm body sub-expression. R3 is PARSER-ONLY: eval / type / codegen
      -- get STUB arms (real handling is R6/R7); shape_ast gives it a dedicated band.
      AstMatch of (scrut : Ast, arms : ArmList)

  -- Records-arc brick R3: a cons-list of a variant-construction's named field
  -- initializers. Each cell carries the field NAME span (name_start, name_len) and
  -- the RHS expression `val` (a full parse_or subtree); `rest` chains to the next
  -- field, VFNil terminates. Same cons family as ArgList (ArgCons/ArgNil) — built
  -- by parse_vfields, the field-list analogue of parse_args.
  concept VFieldList
    @intention: "Cons-list of a variant construction's named field initializers (name span + value)"
    @source: vexprparse.intent:64
    variants:
      VFCons of (name_start : number, name_len : number, val : Ast, rest : VFieldList)
      VFNil

  -- Records-arc brick R3: a cons-list of `match` arms. Each ArmCons carries the
  -- arm's variant-name span (vstart, vlen), its positional binder list (BinderList),
  -- the arm body expression (a full parse_or), and the rest of the arms; ArmNil ends
  -- the list. Same cons family as ArgList / VFieldList. Built by parse_arms.
  concept ArmList
    @intention: "Cons-list of match arms (variant-name span + binders + body expression)"
    @source: vexprparse.intent:64
    variants:
      ArmCons of (vstart : number, vlen : number, binders : BinderList, body : Ast, rest : ArmList)
      ArmNil

  -- Records-arc brick R3: a cons-list of an arm's POSITIONAL binders — each a source
  -- span (start, len) for the binder name, in source order (e.g. `Cons(head, tail)`
  -- yields two BindCons). BindNil terminates (a zero-binder arm like `Nil` or
  -- `Eof`). Same identity model as AstVar / a Binding name (R3 does not decode the
  -- binder name to bytes). Built by parse_binders.
  concept BinderList
    @intention: "Cons-list of a match arm's positional binders (each a source span)"
    @source: vexprparse.intent:64
    variants:
      BindCons of (start : number, len : number, rest : BinderList)
      BindNil

  -- Records-arc brick R3: a variant-field-list parse result — the VFieldList built
  -- plus the token cell just past the closing '}'. Same Parsed-threading shape as
  -- ParsedArgs's MkArgs.
  concept ParsedVFields
    @intention: "A variant-field-list parse result: the VFieldList built plus the end cell"
    @source: vexprparse.intent:64
    variants:
      MkVF of (fields : VFieldList, next : TokenList)

  -- Records-arc brick R3: a match-arm-list parse result — the ArmList built plus the
  -- token cell just past the last arm (at the closing DEDENT / Eof). Same
  -- Parsed-threading shape as ParsedArgs's MkArgs.
  concept ParsedArms
    @intention: "A match-arm-list parse result: the ArmList built plus the end cell"
    @source: vexprparse.intent:64
    variants:
      MkAL of (arms : ArmList, next : TokenList)

  -- Records-arc brick R3: a binder-list parse result — the BinderList built plus the
  -- token cell just past the closing ')' (or the unchanged cell when an arm has no
  -- parenthesized binders). Same Parsed-threading shape as ParsedArgs's MkArgs.
  concept ParsedBinders
    @intention: "A binder-list parse result: the BinderList built plus the end cell"
    @source: vexprparse.intent:64
    variants:
      MkBL of (binders : BinderList, next : TokenList)

  concept ArgList
    @intention: "Cons-list of call-argument AST nodes (like TokenList but for args)"
    @source: vexprparse.intent:1
    variants:
      ArgCons of (head : Ast, tail : ArgList)
      ArgNil

  concept Parsed
    @intention: "A parse result: the AST built plus the index where it ended"
    @source: vexprparse.intent:1
    variants:
      -- node = the subtree parsed; next = the token list CELL just past it
      Mk of (node : Ast, next : TokenList)

  concept ParsedArgs
    @intention: "A call-argument parse result: the ArgList built plus the end index"
    @source: vexprparse.intent:1
    variants:
      -- args = the argument cons-list parsed; next = the cell just past ')'
      MkArgs of (args : ArgList, next : TokenList)

  -- Brick 8b: the column stack. A cons-list of open-block indentation widths,
  -- mirroring src/lexer.rs's `indent_stack: Vec<usize>`. Push(width, rest) is a
  -- level opened at column `width`; Empty is the file's outermost (column-0)
  -- sentinel level that is never popped (top_width returns 0 for it). The stack
  -- lives in the arena exactly like TokenList; the line driver threads it as one
  -- of its two group-concept fields (the multi-group-field recursive ABI,
  -- commit 9529277 — verified to compile by the design note's probe).
  concept ColStack
    @intention: "Indentation column stack: open-block widths (Empty = column-0 sentinel)"
    @source: vexprparse.intent:27
    variants:
      Push of (width : number, rest : ColStack)
      Empty

  -- Brick 8b: the multi-DEDENT result. The shallower-width pop is a recursion
  -- over ColStack that must return THREE things at once (a Verbose rule returns
  -- one value): the stack AFTER popping every level whose width > the target
  -- (`popped`), the NUMBER of levels popped (`count` = the number of Dedent
  -- tokens to emit), and an inconsistency FLAG (`err` = 1 iff after popping the
  -- new top width does not exactly equal the target — i.e. the line's width
  -- matches no enclosing block, src/lexer.rs:227-236). Packed into one concept.
  concept DedentResult
    @intention: "Result of a multi-DEDENT pop: new stack + dedent count + inconsistency flag"
    @source: vexprparse.intent:27
    variants:
      MkDed of (popped : ColStack, count : number, err : number)

  -- Brick 9: a cons-list of let-bindings in the arena. Each cell carries the
  -- bound name as a SOURCE SPAN (name_start, name_len) — the same identity model
  -- as AstVar / a Str token (brick 9 does not resolve the name to bytes; that
  -- needs an environment, which is the OPTIONAL bonus eval below). `value` is the
  -- binding's right-hand-side expression (a full parse_or subtree). `rest` chains
  -- to the next binding; BNil terminates the list. Mirrors src/parser.rs's
  -- ordered `lets: Vec<(name, expr)>` on a logic block, in arena cons-list form.
  concept Binding
    @intention: "Cons-list of let-bindings: bound name span + RHS expression + rest"
    @source: vexprparse.intent:28
    variants:
      BCons of (name_start : number, name_len : number, value : Ast, rest : Binding)
      BNil

  -- Brick 9: a parsed statement block — the ordered binding list plus the final
  -- out-expression. Mirrors src/parser.rs's logic block (a sequence of let
  -- bindings followed by `out = <expr>`): `binds` is the BCons chain in source
  -- order, `result` is the final out-statement's RHS expression subtree.
  concept Block
    @intention: "A parsed statement block: ordered let-bindings + the final out-expression"
    @source: vexprparse.intent:28
    variants:
      MkBlock of (binds : Binding, result : Ast)

  -- Brick 9: a block parse result — the Block built plus the token index just
  -- past it. Same Parsed-threading shape as `Parsed` (Mk) / `ParsedArgs`
  -- (MkArgs), one level up: parse_block / parse_stmts thread `next` so a caller
  -- could continue after the block (e.g. a sibling block at the same level).
  concept ParsedBlock
    @intention: "A block parse result: the Block built plus the end token index"
    @source: vexprparse.intent:28
    variants:
      MkPB of (block : Block, next : TokenList)

  -- Brick 10: the evaluation ENVIRONMENT. A cons-list mapping a bound name —
  -- carried as a SOURCE SPAN (name_start, name_len) exactly like a Binding cell
  -- or an AstVar — to its ALREADY-COMPUTED numeric value `val`. Distinct from
  -- Binding (which carries the unevaluated RHS Ast): Env carries the resolved
  -- number, so a variable reference is one byte-compare + one slot read, with no
  -- re-evaluation of the binding's expression on each lookup. `rest` chains to
  -- the enclosing scope; ENil is the empty environment. build_env conses the
  -- newest binding onto the FRONT, and env_lookup walks front-to-back, so the
  -- MOST RECENT binding of a name wins (shadowing: `let x = 1` then `let x = 2`
  -- resolves x to 2). The name's identity is its bytes in the source text, so
  -- env_lookup byte-compares the query span against each entry's span via the
  -- shared `src`.
  concept Env
    @intention: "Evaluation environment: name span -> already-computed number, innermost first"
    @source: vexprparse.intent:29
    variants:
      ECons of (name_start : number, name_len : number, val : number, rest : Env)
      ENil

  -- Records-arc brick R6c: the interpreter's runtime VALUE. Pre-R6c the evaluator
  -- was number-valued (eval_ast_env : number, and the whole call machinery). To
  -- EVALUATE a match/variant program the evaluator must return either a number OR a
  -- variant value (a tag + a payload) — a number cannot hold a variant. Value is that
  -- one return type across the mutually-recursive eval subsystem. VNum wraps a plain
  -- number; VData carries a variant IDENTITY `tag` (concept_index * 256 +
  -- variant_index, self-computed from the parsed ConceptList of the INTERPRETED source
  -- — no global table) plus its evaluated field values as a ValueList. Text values arc
  -- slice 1: a target TEXT value is a SPAN into the interpreted source — VText carries
  -- (start, len) indexing ea.src, no heap, no copying. An AstStr(start, len) evaluates
  -- to VText with the surrounding quotes stripped (the token span includes both
  -- quotes); substring produces a sub-span of the same source. Concat arc slice 1:
  -- `concat` (fresh text) cannot be a span — but it doesn't need fresh STORAGE if it
  -- is never materialized. VConcat is a ROPE: a tree value whose leaves are existing
  -- spans (VText — zero copy) and numbers (VNum — read through its decimal
  -- rendering); length/byte_at walk the tree (vlength / vbyte_at), no heap, no
  -- copying, mirroring verbosec's own streaming-emitter insight applied to the
  -- interpreter's value model. Lives in this group (the native
  -- one-group cap requires ONE concept_group per program, and VExpr's [max_depth: 4096,
  -- max_nodes: 2000000] bounds give the runtime Value arena the generous, mmap-backed
  -- headroom a recursive list-sum needs).
  concept Value
    @intention: "A runtime interpreter value: a number, a variant (identity tag + evaluated payload), or a text span into the interpreted source"
    @source: vexprparse.intent:36
    variants:
      VNum of (n : number)
      VData of (tag : number, payload : ValueList)
      VText of (start : number, len : number)
      VConcat of (left : Value, right : Value)

  -- Records-arc brick R6c: a cons-list of runtime Values — a variant construction's
  -- evaluated field values in source order, and the carrier a match reads positionally
  -- when binding an arm's binders. Same cons family as ArgList (ArgCons/ArgNil).
  concept ValueList
    @intention: "Cons-list of runtime interpreter values (a variant's evaluated payload)"
    @source: vexprparse.intent:36
    variants:
      VLCons of (head : Value, tail : ValueList)
      VLNil

  -- Records-arc brick R6c: the interpreter's runtime ENVIRONMENT — a name span mapped
  -- to its already-computed Value. DISTINCT from `Env` (which the R6b type checker
  -- reuses, storing a NUMBER type-code in its `val` slot): a field has one declared
  -- type, and the type checker's number-codes and the interpreter's runtime Values
  -- cannot share it — so R6c gives the interpreter its own VEnv rather than touching
  -- the R6b type checker. Same innermost-first cons shape as Env (VECons on the front,
  -- VENil empty); venv_lookup walks front-to-back so the most recent binding wins.
  concept VEnv
    @intention: "Interpreter runtime environment: name span -> already-computed Value, innermost first"
    @source: vexprparse.intent:36
    variants:
      VECons of (name_start : number, name_len : number, val : Value, rest : VEnv)
      VENil

  -- Brick 11: a parsed top-level RULE declaration. `name_start` / `name_len` are
  -- the rule NAME's source span (the same identity model as a Binding name or an
  -- AstVar — brick 11 does not decode the name to bytes; it is proven by the span
  -- length in rule_shape). `body` is the rule's `logic:` block, reusing the
  -- brick-9 Block exactly (a binding list + the final out-expression). Mirrors
  -- src/parser.rs's Rule { name, logic } restricted to the tractable subset:
  -- name + logic block only (no intention / source / input / output / proofs —
  -- those are later bricks). RuleDecl lives in this group because it carries a
  -- group-typed field (body : Block), and cross-group references are rejected.
  -- Records-arc brick R5 widens MkRule with the VERIFICATION SURFACE R2's seek_logic
  -- used to SKIP: `input` (the rule's input fields, reusing R1's FieldList), the single
  -- output field (out_name_start / out_name_len / out_ty), and `proofs` (purity
  -- reads/calls + termination). PARSED, not checked — the AST now REPRESENTS what the
  -- R6 checker will consume.
  concept RuleDecl
    @intention: "A parsed top-level rule declaration: name + params + input/output types + body + proofs"
    @source: vexprparse.intent:30
    variants:
      MkRule of (name_start : number, name_len : number, params : ParamList, return_type : number, body : Block, input : FieldList, out_name_start : number, out_name_len : number, out_ty : number, out_ty_start : number, out_ty_len : number, proofs : Proofs)

  -- Brick 12: a parsed PROGRAM — a cons-list of top-level rule declarations in
  -- source order. RCons carries one RuleDecl head and the rest; RNil is the empty
  -- program (end-of-input). Same cons shape as TokenList / Binding / Env, so the
  -- same arena machinery and the same structural-recursion proof apply. Mirrors
  -- src/parser.rs's Program = Vec<Rule> restricted to rule-only items (no
  -- concept / use / @attributes — those are later bricks).
  concept RuleList
    @intention: "A parsed program: a cons-list of top-level rule declarations"
    @source: vexprparse.intent:31
    variants:
      RCons of (head : RuleDecl, tail : RuleList)
      RNil

  -- Codegen dedup: a bare cons-list of per-rule proc SIZES, in rule order (one
  -- entry per RuleList head). proc_sizes builds it ONCE with a single left-to-right
  -- proc_size pass; proc_offset then sums a prefix of it (walked in lockstep with
  -- the RuleList) instead of re-calling proc_size at every call-emit site, and
  -- ps_total sums the whole list for blob_end_off. Same cons shape as RuleList
  -- (RCons/RNil), so the same arena machinery and structural-recursion proof apply.
  concept ProcSizeList
    @intention: "A cons-list of per-rule emitted-proc byte sizes, in rule order"
    @source: vexprparse.intent:56
    variants:
      PSCons of (size : number, rest : ProcSizeList)
      PSNil

  -- Brick 12: a rule-declaration parse result that THREADS its end position — the
  -- RuleDecl built plus the token index just past its body (the same Parsed-
  -- threading shape as ParsedBlock's MkPB). parse_rule_decl_pos returns this so
  -- the program loop knows where one rule decl ends and can resume scanning for
  -- the next `rule` keyword. `next` comes from the body block's pb_next (just past
  -- the final out-expression); the trailing DEDENT(s) that close the logic + rule
  -- bodies sit at/after `next` and are consumed by the program loop's separator
  -- skip, not by the rule-decl parser.
  concept ParsedRule
    @intention: "A rule-decl parse result: the RuleDecl built plus its end token index"
    @source: vexprparse.intent:31
    variants:
      MkPR of (rule : RuleDecl, next : TokenList)

  -- Brick 16: a rule's PARAMETER list — a cons-list of parameter NAMES, each a
  -- source span (name_start, name_len), in source order. Same identity model as a
  -- Binding name or an AstVar (the param is its bytes in the source text, never
  -- decoded). PNil terminates the list (zero params — `rule f()` or `rule f`).
  -- Mirrors src/parser.rs's Rule.params (the formal parameter names). Brick 20 adds
  -- a `ty` field per param: the declared type code (0=number, 1=bool, 2=text — the
  -- same codes brick 19 uses), defaulting to 0 (number) when a param is untyped.
  -- An untyped `x` carries ty=0; a typed `x : bool` carries ty=1. Lives in the
  -- group because it is the same cons-list family as ArgList / Binding.
  concept ParamList
    @intention: "Cons-list of a rule's formal parameters (each a source span + declared type code)"
    @source: vexprparse.intent:34
    variants:
      PCons of (name_start : number, name_len : number, ty : number, ty_start : number, ty_len : number, rest : ParamList)
      PNil

  -- Brick 16: a parameter-list parse result — the ParamList built plus the token
  -- index just past the closing ')' (or the unchanged start index when there are
  -- no parens at all). Same Parsed-threading shape as ParsedArgs's MkArgs.
  concept ParsedParams
    @intention: "A parameter-list parse result: the ParamList built plus the end index"
    @source: vexprparse.intent:34
    variants:
      MkPP of (params : ParamList, next : TokenList)

  -- Brick 23: a STRUCTURED diagnostic. Brick 22's check_program collapses the whole
  -- program to a single error COUNT — useful as a pass/fail gate, useless for
  -- telling the operator WHERE the program is wrong. A Diag localizes the first
  -- failure: `rule_index` is the 0-based position (in source order) of the first
  -- rule that fails any analysis, and `category` is WHICH analysis failed first
  -- (1=undef-var/use-before-def, 2=undef-callee, 3=arity, 4=ill-typed, 5=arg-type;
  -- 0=clean). A fully clean program is reported as MkDiag(9999, 0) — 9999 is the
  -- sentinel "no bad rule" index (no real program here reaches 9999 rules, the
  -- ProgramState pos field caps at 512). Single-variant "record-like" group concept,
  -- exactly like RuleDecl (MkRule) / Block (MkBlock) / Parsed (Mk): it lives in the
  -- group because find_diag is a recursive rule that RETURNS one (same group-return
  -- ABI as find_rule returning a RuleDecl, or build_env returning an Env), and a
  -- number driver reads a field off it via the bare-group accessors diag_index /
  -- diag_cat (same idiom as rd_body / block_binds). Brick 26 widens MkDiag with two
  -- more number fields — span_start / span_len — so the located full report points AT
  -- the offending token for undefined-variable diagnostics (category 1). For every
  -- other category (2-5) and every sentinel, the span is MkSpan(9999, 0)'s shape
  -- (span_start 9999, span_len 0): "not located". diag_span_start / diag_span_len are
  -- the matching bare-group accessors.
  concept Diag
    @intention: "A structured diagnostic: the failing rule's 0-based index, its error category, and the offending name's source span"
    @source: vexprparse.intent:41
    variants:
      MkDiag of (rule_index : number, category : number, span_start : number, span_len : number)

  -- Brick 24: a cons-list of Diags — the COMPLETE diagnostic report. Brick 23's
  -- find_diag returns ONE Diag (the first failure). This brick generalizes it to a
  -- list: one Diag per (rule, failing-category) pair, in program order, ascending
  -- category within a rule. DCons carries one Diag head + the rest; DNil is the
  -- empty report (a fully clean program yields DNil, NOT MkDiag(9999,0) — the
  -- sentinel was brick 23's single-Diag convention; an empty LIST needs no
  -- sentinel). Same 2-variant cons shape as Binding (BCons|BNil) / ArgList
  -- (ArgCons|ArgNil) / RuleList (RCons|RNil), so the same arena machinery and the
  -- same structural-recursion proof apply. It lives in the group because rule_diags
  -- / diag_append / prog_diags are recursive rules that RETURN one (same group-return
  -- ABI as build_env returning an Env), and the number drivers read off it via
  -- diag_count / nth_diag_rule / nth_diag_cat (the cons-walk idiom).
  concept DiagList
    @intention: "A cons-list of Diags: the complete diagnostic report (one Diag per rule-category pair)"
    @source: vexprparse.intent:42
    variants:
      DCons of (diag : Diag, rest : DiagList)
      DNil

  -- Brick 25: a source SPAN — the (start, len) byte range of a token in the source
  -- buffer. Where brick 13/14 COUNTED undefined-variable references, this brick
  -- finds the FIRST one and returns its name span, so a diagnostic can point AT the
  -- offending token instead of merely tallying. Single-variant "record-like" group
  -- concept, exactly like Diag (MkDiag) / RuleDecl (MkRule) / Block (MkBlock): it
  -- lives in the group because the undef_span_* family are recursive rules that
  -- RETURN one (same group-return ABI as find_diag returning a Diag), and the number
  -- drivers read a field off it via the bare-group accessors span_start / span_len
  -- (same idiom as diag_index / diag_cat). The sentinel "no undefined variable" span
  -- is MkSpan(9999, 0) — 9999 is the same out-of-range marker find_diag uses for the
  -- rule index, so span_or recognizes "no result" by testing span_start == 9999.
  concept Span
    @intention: "A source byte range: the (start, len) span of a token's name in the source text"
    @source: vexprparse.intent:43
    variants:
      MkSpan of (start : number, len : number)

  -- Records-arc brick R1: a parsed `fields:` line — one field NAME span plus its
  -- declared TYPE code (the same 0=number/1=bool/2=text codes type_code_of_span
  -- assigns; a concept-named field type also falls through to 0 in R1 since R1 does
  -- not add record type codes). Same cons-list family as ParamList (PCons/PNil):
  -- FCons carries one field's (name_start, name_len, ty) and the rest; FNil ends
  -- the list. Lives in the group because it is the same cons-list shape as ArgList
  -- / Binding / ParamList.
  concept FieldList
    @intention: "Cons-list of a concept's fields (each a name span + declared type code)"
    @source: vexprparse.intent:62
    variants:
      FCons of (name_start : number, name_len : number, ty : number, ty_start : number, ty_len : number, rest : FieldList)
      FNil

  -- Records-arc brick R4: a parsed `variants:` line — one variant NAME span plus its
  -- payload field list. A SUM-type concept (a `variants:` block) is a list of these:
  -- a bare variant like `Eof` / `Nil` / `Indent` has payload = FNil; a payload variant
  -- like `Cons of (head : Token, tail : TokenList)` carries a FieldList parsed from the
  -- parenthesized `of ( name : type , ... )` list (REUSING the FieldList shape brick R1
  -- already built for `fields:`). Same cons-list family as FieldList (FCons/FNil):
  -- VarCons carries one variant's (name_start, name_len, payload) and the rest; VarNil
  -- ends the list. Lives in the group because it is the same cons-list shape as
  -- FieldList and is reachable from Concept (MkConcept now also carries a VariantList).
  concept VariantList
    @intention: "Cons-list of a concept's variants (each a name span + its payload field list)"
    @source: vexprparse.intent:65
    variants:
      VarCons of (name_start : number, name_len : number, payload : FieldList, rest : VariantList)
      VarNil

  -- Records-arc brick R1: a parsed top-level CONCEPT declaration. `name_start` /
  -- `name_len` are the concept NAME's source span (the same identity model as a
  -- RuleDecl name — R1 does not decode the name to bytes). `fields` is the parsed
  -- `fields:` block, a FieldList. Single-variant record-like group concept, exactly
  -- like RuleDecl (MkRule) / Block (MkBlock): it lives in the group because
  -- find_concept is a recursive rule that RETURNS one (same group-return ABI as
  -- find_rule returning a RuleDecl), and a number driver reads a field off it via
  -- the bare-group accessors (same idiom as rd_body / block_binds).
  concept Concept
    @intention: "A parsed top-level concept declaration: its name span + its field list + its variant list"
    @source: vexprparse.intent:62
    variants:
      MkConcept of (name_start : number, name_len : number, fields : FieldList, variants : VariantList)

  -- Records-arc brick R1: a parsed CONCEPT program slice — a cons-list of top-level
  -- concept declarations in source order. CCons carries one Concept head and the
  -- rest; CNil is the empty list (no concepts). Same cons shape as RuleList
  -- (RCons/RNil), so the same arena machinery and structural-recursion proof apply.
  concept ConceptList
    @intention: "A cons-list of top-level concept declarations"
    @source: vexprparse.intent:62
    variants:
      CCons of (head : Concept, tail : ConceptList)
      CNil

  -- Records-arc brick R1: a concept-declaration parse result that THREADS its end
  -- position — the Concept built plus the token index just past its `fields:` block
  -- (the same Parsed-threading shape as ParsedRule's MkPR). parse_concept_decl_pos
  -- returns this so the concept walk (parse_concepts) knows where one concept decl
  -- ends and can resume scanning for the next top-level keyword.
  concept ParsedConcept
    @intention: "A concept-decl parse result: the Concept built plus its end token index"
    @source: vexprparse.intent:62
    variants:
      MkPC of (concept : Concept, next : TokenList)

  -- Cursor rewrite: a `fields:` block parse result — the FieldList built plus the
  -- token list CELL just past the last field. Mirrors ParsedParams's MkPP exactly.
  -- parse_fields threads this end cell up through every FCons so the caller
  -- (parse_concept_decl_pos) reads the end position structurally rather than
  -- computing it by counting fields (the old `body_idx + 4 * nfields` arithmetic
  -- has no cell analogue).
  concept ParsedFields
    @intention: "A fields-block parse result: the FieldList built plus its end cell"
    @source: vexprparse.intent:62
    variants:
      MkPF of (fields : FieldList, next : TokenList)

  -- Records-arc brick R5: a parsed reads/calls entry list — a cons-list of NAME
  -- spans (each `reads`/`calls` list entry's HEAD identifier span). A reads entry
  -- like `s.source` captures the span of its head ident `s` (head-ident-only, the
  -- simpler choice the task permits — it is enough to COUNT entries and identify the
  -- root binder; the `.field` suffix is skipped by skip_path and not stored). Same
  -- cons-list family as FieldList (NmCons carries one entry's span + the rest, NmNil
  -- ends the list). Lives in the group because Proofs (also in the group) carries a
  -- NameList, and the same arena machinery / structural-recursion proof apply.
  concept NameList
    @intention: "Cons-list of a purity reads/calls list (each entry's head-ident span)"
    @source: vexprparse.intent:30
    variants:
      NmCons of (start : number, len : number, rest : NameList)
      NmNil

  -- Records-arc brick R5: a parsed `proofs:` block — the VERIFICATION SURFACE. `reads`
  -- / `calls` are the purity lists (NameList); `term_kind` codes the termination kind
  -- (0=bound-only, 1=structural, 2=decreasing, 3=increasing); `term_bound` is the
  -- declared `bound :` number; `term_field_start` / `term_field_len` are the span of
  -- the structural/decreasing/increasing FIELD name (0/0 for bound-only). Single-
  -- variant record-like group concept (like Concept's MkConcept), in the group because
  -- RuleDecl (in the group) carries a Proofs.
  concept Proofs
    @intention: "A parsed proofs block: purity reads/calls + the termination kind/bound/field"
    @source: vexprparse.intent:30
    variants:
      MkProofs of (reads : NameList, calls : NameList, term_kind : number, term_bound : number, term_field_start : number, term_field_len : number)

  -- Records-arc brick R5: a name-list parse result that THREADS its end cell — the
  -- NameList built plus the token cell AT the closing `]`. Same Parsed-threading shape
  -- as ParsedFields's MkPF, so parse_proofs reads the position after one list and
  -- resumes scanning for the next (`calls` after `reads`, `termination` after `calls`).
  concept ParsedNames
    @intention: "A name-list parse result: the NameList built plus its end cell (at the closing bracket)"
    @source: vexprparse.intent:30
    variants:
      MkNames of (names : NameList, next : TokenList)


-- ============================================================================
-- Brick 2 reused verbatim: the tokenizer. (Copied so bricks 1-2 stay pristine;
-- the Token/TokenList concepts above are identical to brick 2's, just sharing
-- this program's single concept_group as the native one-group cap requires.)
-- ============================================================================

concept ScanState
  @intention: "Scanner position in source text"
  @source: vexprparse.intent:2
  fields:
    source : text [..256]
    pos : number [0, 4000000]


rule skip_spaces
  @intention: "Advance past spaces"
  @source: vexprparse.intent:3
  input:
    s : ScanState
  output:
    out : number
  logic:
    let len = length(s.source)
    out = if s.pos >= len then s.pos else if byte_at(s.source, s.pos) == 32 then skip_spaces(ScanState { source: s.source, pos: s.pos + 1 }) else s.pos
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : [skip_spaces]
    termination:
      bound : 256
      increasing : pos


rule digit_run
  @intention: "Count consecutive [0-9] bytes from pos"
  @source: vexprparse.intent:4
  input:
    s : ScanState
  output:
    out : number
  logic:
    let len = length(s.source)
    out = if s.pos >= len then 0 else if byte_at(s.source, s.pos) >= 48 and byte_at(s.source, s.pos) <= 57 then 1 + digit_run(ScanState { source: s.source, pos: s.pos + 1 }) else 0
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : [digit_run]
    termination:
      bound : 256
      increasing : pos


rule pow10
  @intention: "10^n for small n (digit-position weight)"
  @source: vexprparse.intent:5
  input:
    s : ScanState
  output:
    out : number
  logic:
    out = if s.pos == 0 then 1 else 10 * pow10(ScanState { source: s.source, pos: s.pos - 1 })
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : [pow10]
    termination:
      bound : 256
      decreasing : pos


rule num_value
  @intention: "Decode the decimal value of the digit run starting at pos"
  @source: vexprparse.intent:6
  input:
    s : ScanState
  output:
    out : number
  logic:
    let len = length(s.source)
    let rl = digit_run(s)
    out = if rl == 0 then 0 else (byte_at(s.source, s.pos) - 48) * pow10(ScanState { source: s.source, pos: rl - 1 }) + num_value(ScanState { source: s.source, pos: s.pos + 1 })
  proofs:
    purity:
      reads : [s.source, s.pos, s]
      calls : [digit_run, pow10, num_value]
    termination:
      bound : 256
      increasing : pos


-- Length of an identifier-continue run [a-zA-Z0-9_]* starting at pos. Brick 4
-- needs identifiers because the logical keywords (and/or/not) lex as identifier
-- runs first, then get a keyword code. (Brick 3 had no idents — arithmetic only.)
rule ident_run
  @intention: "Count consecutive [a-zA-Z0-9_] bytes from pos"
  @source: vexprparse.intent:7
  input:
    s : ScanState
  output:
    out : number
  logic:
    let len = length(s.source)
    out = if s.pos >= len then 0 else if byte_at(s.source, s.pos) == 95 then 1 + ident_run(ScanState { source: s.source, pos: s.pos + 1 }) else if byte_at(s.source, s.pos) >= 48 and byte_at(s.source, s.pos) <= 57 then 1 + ident_run(ScanState { source: s.source, pos: s.pos + 1 }) else if byte_at(s.source, s.pos) >= 65 and byte_at(s.source, s.pos) <= 90 then 1 + ident_run(ScanState { source: s.source, pos: s.pos + 1 }) else if byte_at(s.source, s.pos) >= 97 and byte_at(s.source, s.pos) <= 122 then 1 + ident_run(ScanState { source: s.source, pos: s.pos + 1 }) else 0
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : [ident_run]
    termination:
      bound : 256
      increasing : pos


-- two-letter keywords (brick 4 only needs `or`, but mirror brick 1/2's codes
-- exactly: if=1, or=2, of=3 — so a future brick lexing the rest agrees).
rule kw2
  @intention: "Classify a 2-byte identifier run as a keyword (0 if none)"
  @source: vexprparse.intent:7
  input:
    s : ScanState
  output:
    out : number
  logic:
    out = if byte_at(s.source, s.pos) == 105 and byte_at(s.source, s.pos + 1) == 102 then 1 else if byte_at(s.source, s.pos) == 111 and byte_at(s.source, s.pos + 1) == 114 then 2 else if byte_at(s.source, s.pos) == 111 and byte_at(s.source, s.pos + 1) == 102 then 3 else 0
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : []
    termination:
      bound : 32


-- three-letter keywords: let=4, and=5, not=6 (brick 1/2 codes; brick 4 uses
-- and=5 and not=6).
rule kw3
  @intention: "Classify a 3-byte identifier run as a keyword (0 if none)"
  @source: vexprparse.intent:7
  input:
    s : ScanState
  output:
    out : number
  logic:
    out = if byte_at(s.source, s.pos) == 108 and (byte_at(s.source, s.pos + 1) == 101 and byte_at(s.source, s.pos + 2) == 116) then 4 else if byte_at(s.source, s.pos) == 97 and (byte_at(s.source, s.pos + 1) == 110 and byte_at(s.source, s.pos + 2) == 100) then 5 else if byte_at(s.source, s.pos) == 110 and (byte_at(s.source, s.pos + 1) == 111 and byte_at(s.source, s.pos + 2) == 116) then 6 else 0
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : []
    termination:
      bound : 48


-- four-letter keywords: then=7, else=8 (brick 6 — `if`/`then`/`else` as an
-- expression), true=9 (brick 7 — boolean literal). Codes 7/8/9 don't collide
-- with the existing 1-6 (if/or/of/let/and/not). `then` = t(116) h(104) e(101)
-- n(110); `else` = e(101) l(108) s(115) e(101); `true` = t(116) r(114) u(117)
-- e(101).
rule kw4
  @intention: "Classify a 4-byte identifier run as a keyword (0 if none)"
  @source: vexprparse.intent:7
  input:
    s : ScanState
  output:
    out : number
  logic:
    out = if byte_at(s.source, s.pos) == 116 and (byte_at(s.source, s.pos + 1) == 104 and (byte_at(s.source, s.pos + 2) == 101 and byte_at(s.source, s.pos + 3) == 110)) then 7 else if byte_at(s.source, s.pos) == 101 and (byte_at(s.source, s.pos + 1) == 108 and (byte_at(s.source, s.pos + 2) == 115 and byte_at(s.source, s.pos + 3) == 101)) then 8 else if byte_at(s.source, s.pos) == 116 and (byte_at(s.source, s.pos + 1) == 114 and (byte_at(s.source, s.pos + 2) == 117 and byte_at(s.source, s.pos + 3) == 101)) then 9 else 0
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : []
    termination:
      bound : 64


-- five-letter keywords: false=10 (brick 7 — boolean literal); match=11 (brick R3 —
-- block-form pattern match). The parse layer is source-free (ParseState carries only
-- the token cell), so `match` MUST be a keyword recognized by token kind, exactly as
-- `false` / `then` / `else` are — there is no span check available in parse_primary.
-- longer-or-other 5-byte identifier runs stay plain idents (kw == 0). `false` = f(102)
-- a(97) l(108) s(115) e(101); `match` = m(109) a(97) t(116) c(99) h(104).
rule kw5
  @intention: "Classify a 5-byte identifier run as a keyword (0 if none)"
  @source: vexprparse.intent:7
  input:
    s : ScanState
  output:
    out : number
  logic:
    out = if byte_at(s.source, s.pos) == 102 and (byte_at(s.source, s.pos + 1) == 97 and (byte_at(s.source, s.pos + 2) == 108 and (byte_at(s.source, s.pos + 3) == 115 and byte_at(s.source, s.pos + 4) == 101))) then 10 else if byte_at(s.source, s.pos) == 109 and (byte_at(s.source, s.pos + 1) == 97 and (byte_at(s.source, s.pos + 2) == 116 and (byte_at(s.source, s.pos + 3) == 99 and byte_at(s.source, s.pos + 4) == 104))) then 11 else 0
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : []
    termination:
      bound : 80


-- Dispatch keyword classification by identifier-run length. Brick 6 added the
-- 4-byte keywords (then / else); brick 7 adds the 4-byte `true` and the 5-byte
-- `false` alongside the 2- and 3-byte keywords (or / and / not). Other-length
-- identifier runs lex as plain identifiers here (kw == 0) and are handled by
-- later bricks.
rule keyword_code
  @intention: "Numeric keyword code for the identifier run at pos (0 = plain ident)"
  @source: vexprparse.intent:7
  input:
    s : ScanState
  output:
    out : number
  logic:
    let rl = ident_run(s)
    out = if rl == 2 then kw2(s) else if rl == 3 then kw3(s) else if rl == 4 then kw4(s) else if rl == 5 then kw5(s) else 0
  proofs:
    purity:
      reads : [s]
      calls : [ident_run, kw2, kw3, kw4, kw5]
    termination:
      bound : 16


-- str_content_len: scan a string's CONTENT starting at `pos` (the first byte
-- after the opening quote) and return the number of bytes from `pos` up to AND
-- INCLUDING the closing quote. Escape handling is LENIENT (this is a token-
-- BOUNDARY scanner, not an escape validator — the reference lexer rejects
-- unknown escapes, but here the only goal is to find where the token ends): on a
-- backslash (92) the next byte is part of a 2-byte escape and is skipped
-- unconditionally, so an escaped quote (\") does NOT terminate the string. The
-- closed escape set the language cares about (\n \r \t \\ \") all fit this
-- 2-byte-skip rule; an unknown \x is simply two literal bytes here.
--
-- UNTERMINATED: if the end of source is reached before a closing quote, the run
-- stops and the bytes scanned so far are the token's content length (no closing
-- quote is counted). Fail-closed: every byte_at is guarded by the pos >= len
-- check, and the backslash branch checks pos + 1 < len before skipping the
-- escaped byte (a trailing lone backslash counts as 1 and stops).
--
-- RAW NEWLINE (fail-closed, mirror of line_width's tab sentinel): a raw byte 10
-- before the closing quote returns the sentinel 99998. Real Verbose strings
-- cannot span lines (the reference lexer's escape set is closed — a line break
-- inside a string is `\n`, two bytes); silently accepting a raw newline here
-- corrupted the INDENT/DEDENT accounting of every subsequent line (the driver's
-- next_line_start stops at the FIRST byte 10, i.e. INSIDE the string, while the
-- token span ran past it). The sentinel is 99998 — distinct from the tab
-- sentinel 99999 so the two error sources stay distinguishable when eyeballing
-- a stream — and callers must test with >= 50000, NOT equality: the content
-- bytes scanned before the newline accumulate on top of the sentinel (at most
-- ~2x source length), and string_run adds 1 more for the opening quote. Any
-- real content length is <= the source length (256-bounded), so >= 50000 can
-- never misfire on a valid string. The ESCAPED two-byte sequence backslash-n
-- is untouched: the 92-branch skips it before this check can see byte 110.
-- (A backslash immediately followed by a raw newline still rides the lenient
-- 2-byte escape skip — escape SEMANTICS stay out of scope for this scanner.)
--
-- Termination: pos strictly increases by 1 or 2 each step toward len, so the
-- `increasing : pos` proof holds; bound 256 caps the source length (the
-- sentinel branches return constants — no recursion, proof unaffected).
rule str_content_len
  @intention: "Bytes from pos to the closing quote inclusive (lenient escapes, unterminated stops at end, 99998 sentinel on a raw newline)"
  @source: vexprparse.intent:8
  input:
    s : ScanState
  output:
    out : number
  logic:
    let len = length(s.source)
    out = if s.pos >= len then 0 else if byte_at(s.source, s.pos) == 34 then 1 else if byte_at(s.source, s.pos) == 10 then 99998 else if byte_at(s.source, s.pos) == 92 then (if s.pos + 1 >= len then 1 else 2 + str_content_len(ScanState { source: s.source, pos: s.pos + 2 })) else 1 + str_content_len(ScanState { source: s.source, pos: s.pos + 1 })
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : [str_content_len]
    termination:
      bound : 256
      increasing : pos


-- string_run: total byte length of a string token whose OPENING quote is at
-- `pos`, INCLUDING both quotes. = 1 (the opening quote) + the content length up
-- to and including the closing quote (str_content_len from pos + 1). For an
-- unterminated string the closing quote is absent, so the result is 1 + bytes-
-- to-end — token_end then advances to the end of source and tokenize stops.
-- A raw-newline string propagates str_content_len's 99998 sentinel as 1 + 99998
-- + (content bytes before the newline) — still huge; next_token's >= 50000
-- check turns it into a Token::IndentErr, and token_end's p + srun lands past
-- end-of-source so the line's lexeme scan stops right after the error token.
rule string_run
  @intention: "Total byte length of the string token at the opening quote (both quotes included)"
  @source: vexprparse.intent:8
  input:
    s : ScanState
  output:
    out : number
  logic:
    let len = length(s.source)
    out = if s.pos >= len then 0 else if byte_at(s.source, s.pos) == 34 then 1 + str_content_len(ScanState { source: s.source, pos: s.pos + 1 }) else 0
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : [str_content_len]
    termination:
      bound : 256


rule op_code
  @intention: "Operator/punct class code at pos; two-char before one-char"
  @source: vexprparse.intent:7
  input:
    s : ScanState
  output:
    out : number
  logic:
    let len = length(s.source)
    let c0 = if s.pos >= len then 0 else byte_at(s.source, s.pos)
    let hasnext = if s.pos + 1 < len then 1 else 0
    let c1 = if hasnext == 1 then byte_at(s.source, s.pos + 1) else 0
    out = if c0 == 61 and (hasnext == 1 and c1 == 61) then 1 else if c0 == 61 and (hasnext == 1 and c1 == 62) then 2 else if c0 == 58 and (hasnext == 1 and c1 == 58) then 3 else if c0 == 62 and (hasnext == 1 and c1 == 61) then 4 else if c0 == 60 and (hasnext == 1 and c1 == 61) then 5 else if c0 == 33 and (hasnext == 1 and c1 == 61) then 6 else if c0 == 58 then 10 else if c0 == 44 then 11 else if c0 == 46 then 12 else if c0 == 43 then 13 else if c0 == 45 then 14 else if c0 == 42 then 15 else if c0 == 47 then 16 else if c0 == 37 then 17 else if c0 == 61 then 18 else if c0 == 60 then 19 else if c0 == 62 then 20 else if c0 == 40 then 21 else if c0 == 41 then 22 else if c0 == 123 then 23 else if c0 == 125 then 24 else if c0 == 91 then 25 else if c0 == 93 then 26 else 0
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : []
    termination:
      bound : 80


rule op_len
  @intention: "Byte length of an operator code (2 for two-char ops, 1 otherwise)"
  @source: vexprparse.intent:8
  input:
    s : ScanState
  output:
    out : number
  logic:
    let code = op_code(s)
    out = if code >= 1 and code <= 6 then 2 else 1
  proofs:
    purity:
      reads : [s]
      calls : [op_code]
    termination:
      bound : 8


-- next_token: classify the lexeme at the (space-skipped) position. FAIL-CLOSED
-- string gate (mirror of tokenize_indent's tab path): when string_run comes back
-- >= 50000 the string contains a raw newline (the 99998 sentinel plus scanned
-- content — see str_content_len), so the token is a Token::IndentErr at the
-- opening quote INSTEAD of a Str. The threshold is >=, not ==, because the
-- sentinel accumulates content bytes on its way up; 50000 is unreachable by any
-- real string (content <= source length <= 256-bounded).
rule next_token
  @intention: "Recognize and classify the next core lexeme at the position (IndentErr on a raw-newline string)"
  @source: vexprparse.intent:9
  input:
    s : ScanState
  output:
    out : Token
  logic:
    let len = length(s.source)
    let p = skip_spaces(s)
    let isnl = if p >= len then 0 else if byte_at(s.source, p) == 10 then 1 else 0
    -- BYTES-tier B1: a byte literal is a `b` (98) IMMEDIATELY followed by `"` (34).
    -- Tested BEFORE isalpha (b is in the 97..122 ident range), so `b"..."` becomes
    -- ONE ByteLit token instead of Ident(b) + Str. The token width is 1 (the `b`)
    -- plus string_run measured at the opening quote (p + 1). A raw newline inside
    -- the literal propagates string_run's >= 50000 sentinel (the same fail-closed
    -- gate as Str) into an IndentErr.
    let isbytelit = if p + 1 >= len then 0 else if byte_at(s.source, p) == 98 and byte_at(s.source, p + 1) == 34 then 1 else 0
    let blen = 1 + string_run(ScanState { source: s.source, pos: p + 1 })
    let isalpha = if p >= len then 0 else if byte_at(s.source, p) == 95 then 1 else if byte_at(s.source, p) >= 65 and byte_at(s.source, p) <= 90 then 1 else if byte_at(s.source, p) >= 97 and byte_at(s.source, p) <= 122 then 1 else 0
    let isdigit = if p >= len then 0 else if byte_at(s.source, p) >= 48 and byte_at(s.source, p) <= 57 then 1 else 0
    let isstr = if p >= len then 0 else if byte_at(s.source, p) == 34 then 1 else 0
    let irun = ident_run(ScanState { source: s.source, pos: p })
    let drun = digit_run(ScanState { source: s.source, pos: p })
    let srun = string_run(ScanState { source: s.source, pos: p })
    let kwc = keyword_code(ScanState { source: s.source, pos: p })
    let opc = op_code(ScanState { source: s.source, pos: p })
    let opl = op_len(ScanState { source: s.source, pos: p })
    let nval = num_value(ScanState { source: s.source, pos: p })
    out = if p >= len then Token::Eof else if isnl == 1 then Token::Newline { pos: p } else if isbytelit == 1 then (if blen >= 50000 then Token::IndentErr { pos: p } else Token::ByteLit { start: p, len: blen }) else if isalpha == 1 then (if kwc > 0 then Token::Keyword { start: p, len: irun, kw: kwc } else Token::Ident { start: p, len: irun }) else if isdigit == 1 then Token::Num { value: nval, len: drun } else if isstr == 1 then (if srun >= 50000 then Token::IndentErr { pos: p } else Token::Str { start: p, len: srun }) else if opc > 0 then Token::Op { code: opc, len: opl } else Token::Eof
  proofs:
    purity:
      reads : [s.source, s]
      calls : [skip_spaces, ident_run, digit_run, string_run, keyword_code, op_code, op_len, num_value]
    termination:
      bound : 256


rule token_end
  @intention: "Byte offset just past the next token (post-skip start + width)"
  @source: vexprparse.intent:10
  input:
    s : ScanState
  output:
    out : number
  logic:
    let len = length(s.source)
    let p = skip_spaces(s)
    let isnl = if p >= len then 0 else if byte_at(s.source, p) == 10 then 1 else 0
    -- BYTES-tier B1: mirror next_token's byte-literal detection so token_end
    -- advances by the SAME width (1 for `b` + string_run at the opening quote),
    -- keeping the tokenize walk in sync. Tested before isalpha for the same reason.
    let isbytelit = if p + 1 >= len then 0 else if byte_at(s.source, p) == 98 and byte_at(s.source, p + 1) == 34 then 1 else 0
    let blen = 1 + string_run(ScanState { source: s.source, pos: p + 1 })
    let isalpha = if p >= len then 0 else if byte_at(s.source, p) == 95 then 1 else if byte_at(s.source, p) >= 65 and byte_at(s.source, p) <= 90 then 1 else if byte_at(s.source, p) >= 97 and byte_at(s.source, p) <= 122 then 1 else 0
    let isdigit = if p >= len then 0 else if byte_at(s.source, p) >= 48 and byte_at(s.source, p) <= 57 then 1 else 0
    let isstr = if p >= len then 0 else if byte_at(s.source, p) == 34 then 1 else 0
    let irun = ident_run(ScanState { source: s.source, pos: p })
    let drun = digit_run(ScanState { source: s.source, pos: p })
    let srun = string_run(ScanState { source: s.source, pos: p })
    let opc = op_code(ScanState { source: s.source, pos: p })
    let opl = op_len(ScanState { source: s.source, pos: p })
    out = if p >= len then p else if isnl == 1 then p + 1 else if isbytelit == 1 then p + blen else if isalpha == 1 then p + irun else if isdigit == 1 then p + drun else if isstr == 1 then p + srun else if opc > 0 then p + opl else p
  proofs:
    purity:
      reads : [s.source, s]
      calls : [skip_spaces, ident_run, digit_run, string_run, op_code, op_len]
    termination:
      bound : 256


rule tokenize
  @intention: "Scan the whole source into a cons-list of tokens (trailing Eof)"
  @source: vexprparse.intent:11
  input:
    s : ScanState
  output:
    out : TokenList
  logic:
    let len = length(s.source)
    let p = skip_spaces(s)
    let endp = token_end(s)
    out = if p >= len then TokenList::Cons { head: Token::Eof, tail: TokenList::Nil } else if endp <= p then TokenList::Cons { head: Token::Eof, tail: TokenList::Nil } else TokenList::Cons { head: next_token(s), tail: tokenize(ScanState { source: s.source, pos: endp }) }
  proofs:
    purity:
      reads : [s.source, s]
      calls : [skip_spaces, token_end, next_token, tokenize]
    termination:
      bound : 256


-- ============================================================================
-- Token-stream access helpers (brick 2's drop_cells / head_tok generalized to
-- the parser's needs). The parser peeks tokens by absolute index into the full
-- token list.
-- ============================================================================

-- The cursor walk argument: a token list cell plus how many cons cells to step
-- forward. advance returns the CELL k steps ahead (the cursor model's O(k)
-- forward walk), replacing the O(n)-from-head drop_cells indexing.
concept Advance
  @intention: "A token list cell plus how many cons cells to step forward"
  @source: vexprparse.intent:12
  fields:
    lst : TokenList
    k : number [0, 4000000]


rule advance
  @intention: "The token list cell arg.k cons cells forward from arg.lst"
  @source: vexprparse.intent:12
  input:
    arg : Advance
  output:
    out : TokenList
  logic:
    out = match arg.lst:
      Cons(head, tail) => if arg.k == 0 then arg.lst else advance(Advance { lst: tail, k: arg.k - 1 })
      Nil => TokenList::Nil
  proofs:
    purity:
      reads : [arg.lst, arg.k]
      calls : [advance]
    termination:
      bound : 512
      decreasing : k


rule head_tok
  @intention: "Head token of a list (Eof for Nil)"
  @source: vexprparse.intent:13
  input:
    lst : TokenList
  output:
    out : Token
  logic:
    out = match lst:
      Cons(head, tail) => head
      Nil => Token::Eof
  proofs:
    purity:
      reads : [lst]
      calls : []
    termination:
      bound : 16


-- Kind code of one token, mirroring brick 2: Eof=>0, Ident=>100,
-- Keyword=>200+kw, Num=>300+value, Op=>400+code, Str=>500 (brick 7). The Str
-- kind has no value/code suffix (its identity is the source span), so 500 is a
-- flat sentinel — but a structural test (tok_is_str / peek_is_str) is preferred
-- in the parser, mirroring tok_is_num / tok_is_op, since the Num band (300+value)
-- can overflow into 500 for value >= 200.
rule tok_kind
  @intention: "Kind code of one token"
  @source: vexprparse.intent:13
  input:
    t : Token
  output:
    out : number
  logic:
    out = match t:
      Ident(start, len) => 100
      Keyword(start, len, kw) => 200 + kw
      Num(value, len) => 300 + value
      Op(code, len) => 400 + code
      Str(start, len) => 500
      ByteLit(start, len) => 1000
      Newline(pos) => 600
      Indent => 700
      Dedent => 800
      IndentErr(pos) => 900
      Eof => 0
  proofs:
    purity:
      reads : [t]
      calls : []
    termination:
      bound : 16


-- The numeric value carried by a token (the literal value for Num, else 0).
-- Used so a NUMBER leaf gets its real value, not the kind code.
rule tok_value
  @intention: "The literal value of a Num token (0 for any other token)"
  @source: vexprparse.intent:13
  input:
    t : Token
  output:
    out : number
  logic:
    out = match t:
      Ident(start, len) => 0
      Keyword(start, len, kw) => 0
      Num(value, len) => value
      Op(code, len) => 0
      Str(start, len) => 0
      ByteLit(start, len) => 0
      Newline(pos) => 0
      Indent => 0
      Dedent => 0
      IndentErr(pos) => 0
      Eof => 0
  proofs:
    purity:
      reads : [t]
      calls : []
    termination:
      bound : 16


-- 1 iff the token IS a Num, structurally (independent of its value). The kind
-- code packs Num as 300+value, which OVERFLOWS into the Op kind band (400+code)
-- once value >= 100; so a magnitude-based `300 <= k <= 399` test would misread
-- a literal like 100. This structural test matches the Num variant directly.
rule tok_is_num
  @intention: "1 if the token is a number literal, 0 otherwise (value-independent)"
  @source: vexprparse.intent:13
  input:
    t : Token
  output:
    out : number
  logic:
    out = match t:
      Ident(start, len) => 0
      Keyword(start, len, kw) => 0
      Num(value, len) => 1
      Op(code, len) => 0
      Str(start, len) => 0
      ByteLit(start, len) => 0
      Newline(pos) => 0
      Indent => 0
      Dedent => 0
      IndentErr(pos) => 0
      Eof => 0
  proofs:
    purity:
      reads : [t]
      calls : []
    termination:
      bound : 16


-- 1 iff the token IS an Op, structurally. Same value/kind-band overflow
-- hazard as tok_is_num: a Num literal whose value lands in 13..16 packs to a
-- kind (413..416) that aliases the +,-,*,/ operator kinds. The fold rules use
-- this structural test to decide "is the next token an operator" before reading
-- its code, so a number is never mistaken for an operator.
rule tok_is_op
  @intention: "1 if the token is an operator/punctuation, 0 otherwise"
  @source: vexprparse.intent:13
  input:
    t : Token
  output:
    out : number
  logic:
    out = match t:
      Ident(start, len) => 0
      Keyword(start, len, kw) => 0
      Num(value, len) => 0
      Op(code, len) => 1
      Str(start, len) => 0
      ByteLit(start, len) => 0
      Newline(pos) => 0
      Indent => 0
      Dedent => 0
      IndentErr(pos) => 0
      Eof => 0
  proofs:
    purity:
      reads : [t]
      calls : []
    termination:
      bound : 16


-- The operator code carried by an Op token (0 for any other token).
rule tok_op_code
  @intention: "The operator code of an Op token (0 for any other token)"
  @source: vexprparse.intent:13
  input:
    t : Token
  output:
    out : number
  logic:
    out = match t:
      Ident(start, len) => 0
      Keyword(start, len, kw) => 0
      Num(value, len) => 0
      Op(code, len) => code
      Str(start, len) => 0
      ByteLit(start, len) => 0
      Newline(pos) => 0
      Indent => 0
      Dedent => 0
      IndentErr(pos) => 0
      Eof => 0
  proofs:
    purity:
      reads : [t]
      calls : []
    termination:
      bound : 16


-- 1 iff the token IS an Ident, structurally (kind 100). The keyword tokens
-- and/or/not pack to 200+kw, so they are NOT idents here — exactly what brick 5
-- wants (a primary IDENT is a variable/callee name, never a logical keyword).
rule tok_is_ident
  @intention: "1 if the token is an identifier, 0 otherwise"
  @source: vexprparse.intent:13
  input:
    t : Token
  output:
    out : number
  logic:
    out = match t:
      Ident(start, len) => 1
      Keyword(start, len, kw) => 0
      Num(value, len) => 0
      Op(code, len) => 0
      Str(start, len) => 0
      ByteLit(start, len) => 0
      Newline(pos) => 0
      Indent => 0
      Dedent => 0
      IndentErr(pos) => 0
      Eof => 0
  proofs:
    purity:
      reads : [t]
      calls : []
    termination:
      bound : 16


-- The source-span START offset of an Ident token (0 for any other token).
rule tok_start
  @intention: "The start byte offset of an Ident token (0 for any other token)"
  @source: vexprparse.intent:13
  input:
    t : Token
  output:
    out : number
  logic:
    out = match t:
      Ident(start, len) => start
      Keyword(start, len, kw) => 0
      Num(value, len) => 0
      Op(code, len) => 0
      Str(start, len) => 0
      ByteLit(start, len) => 0
      Newline(pos) => 0
      Indent => 0
      Dedent => 0
      IndentErr(pos) => 0
      Eof => 0
  proofs:
    purity:
      reads : [t]
      calls : []
    termination:
      bound : 16


-- The source-span LENGTH of an Ident token (0 for any other token).
rule tok_len
  @intention: "The byte length of an Ident token (0 for any other token)"
  @source: vexprparse.intent:13
  input:
    t : Token
  output:
    out : number
  logic:
    out = match t:
      Ident(start, len) => len
      Keyword(start, len, kw) => 0
      Num(value, len) => 0
      Op(code, len) => 0
      Str(start, len) => 0
      ByteLit(start, len) => 0
      Newline(pos) => 0
      Indent => 0
      Dedent => 0
      IndentErr(pos) => 0
      Eof => 0
  proofs:
    purity:
      reads : [t]
      calls : []
    termination:
      bound : 16


-- 1 iff the token IS a Str, structurally (brick 7). Mirrors tok_is_num /
-- tok_is_op: a magnitude test on tok_kind (== 500) would misread a Num literal
-- whose value is 200 (kind 500), so the parser uses this structural test to
-- decide "is the next token a string literal" before reading its span.
rule tok_is_str
  @intention: "1 if the token is a string literal, 0 otherwise (value-independent)"
  @source: vexprparse.intent:13
  input:
    t : Token
  output:
    out : number
  logic:
    out = match t:
      Ident(start, len) => 0
      Keyword(start, len, kw) => 0
      Num(value, len) => 0
      Op(code, len) => 0
      Str(start, len) => 1
      ByteLit(start, len) => 0
      Newline(pos) => 0
      Indent => 0
      Dedent => 0
      IndentErr(pos) => 0
      Eof => 0
  proofs:
    purity:
      reads : [t]
      calls : []
    termination:
      bound : 16


-- The source-span START offset of a Str token (0 for any other token). For a
-- Str this is the opening-quote byte offset.
rule tok_str_start
  @intention: "The start byte offset of a Str token (0 for any other token)"
  @source: vexprparse.intent:13
  input:
    t : Token
  output:
    out : number
  logic:
    out = match t:
      Ident(start, len) => 0
      Keyword(start, len, kw) => 0
      Num(value, len) => 0
      Op(code, len) => 0
      Str(start, len) => start
      ByteLit(start, len) => 0
      Newline(pos) => 0
      Indent => 0
      Dedent => 0
      IndentErr(pos) => 0
      Eof => 0
  proofs:
    purity:
      reads : [t]
      calls : []
    termination:
      bound : 16


-- The source-span LENGTH of a Str token (0 for any other token). For a Str this
-- is the total byte length including both quotes.
rule tok_str_len
  @intention: "The byte length of a Str token (0 for any other token)"
  @source: vexprparse.intent:13
  input:
    t : Token
  output:
    out : number
  logic:
    out = match t:
      Ident(start, len) => 0
      Keyword(start, len, kw) => 0
      Num(value, len) => 0
      Op(code, len) => 0
      Str(start, len) => len
      ByteLit(start, len) => 0
      Newline(pos) => 0
      Indent => 0
      Dedent => 0
      IndentErr(pos) => 0
      Eof => 0
  proofs:
    purity:
      reads : [t]
      calls : []
    termination:
      bound : 16


-- BYTES-tier brick B1: 1 iff the token IS a ByteLit, structurally. Mirror of
-- tok_is_str — the parser uses this to decide "is the next token a byte literal"
-- before reading its span, value-independent (no magnitude test on tok_kind).
rule tok_is_bytelit
  @intention: "1 if the token is a byte literal, 0 otherwise (value-independent)"
  @source: vexprparse.intent:13
  input:
    t : Token
  output:
    out : number
  logic:
    out = match t:
      Ident(start, len) => 0
      Keyword(start, len, kw) => 0
      Num(value, len) => 0
      Op(code, len) => 0
      Str(start, len) => 0
      ByteLit(start, len) => 1
      Newline(pos) => 0
      Indent => 0
      Dedent => 0
      IndentErr(pos) => 0
      Eof => 0
  proofs:
    purity:
      reads : [t]
      calls : []
    termination:
      bound : 16


-- BYTES-tier brick B1: the source-span START offset of a ByteLit token (the
-- opening-quote byte, 0 for any other token). Mirror of tok_str_start.
rule tok_bytelit_start
  @intention: "The start byte offset of a ByteLit token (0 for any other token)"
  @source: vexprparse.intent:13
  input:
    t : Token
  output:
    out : number
  logic:
    out = match t:
      Ident(start, len) => 0
      Keyword(start, len, kw) => 0
      Num(value, len) => 0
      Op(code, len) => 0
      Str(start, len) => 0
      ByteLit(start, len) => start
      Newline(pos) => 0
      Indent => 0
      Dedent => 0
      IndentErr(pos) => 0
      Eof => 0
  proofs:
    purity:
      reads : [t]
      calls : []
    termination:
      bound : 16


-- BYTES-tier brick B1: the source-span LENGTH of a ByteLit token (the total
-- byte length including the `b` prefix and both quotes, 0 for any other token).
-- Mirror of tok_str_len.
rule tok_bytelit_len
  @intention: "The byte length of a ByteLit token (0 for any other token)"
  @source: vexprparse.intent:13
  input:
    t : Token
  output:
    out : number
  logic:
    out = match t:
      Ident(start, len) => 0
      Keyword(start, len, kw) => 0
      Num(value, len) => 0
      Op(code, len) => 0
      Str(start, len) => 0
      ByteLit(start, len) => len
      Newline(pos) => 0
      Indent => 0
      Dedent => 0
      IndentErr(pos) => 0
      Eof => 0
  proofs:
    purity:
      reads : [t]
      calls : []
    termination:
      bound : 16


-- Peek the kind code of the token at absolute index `arg.n` in `arg.lst`.
rule peek_kind
  @intention: "Kind code of the token at index n (0 = Eof / past end)"
  @source: vexprparse.intent:14
  input:
    cell : TokenList
  output:
    out : number
  logic:
    out = tok_kind(head_tok(cell))
  proofs:
    purity:
      reads : [cell]
      calls : [tok_kind, head_tok]
    termination:
      bound : 16


-- Peek the literal value of the token at absolute index `arg.n`.
rule peek_value
  @intention: "Literal value of the token at index n (0 if not a Num)"
  @source: vexprparse.intent:14
  input:
    cell : TokenList
  output:
    out : number
  logic:
    out = tok_value(head_tok(cell))
  proofs:
    purity:
      reads : [cell]
      calls : [tok_value, head_tok]
    termination:
      bound : 16


-- Peek whether the token at index `arg.n` is a number literal (structural).
rule peek_is_num
  @intention: "1 if the token at index n is a number literal, 0 otherwise"
  @source: vexprparse.intent:14
  input:
    cell : TokenList
  output:
    out : number
  logic:
    out = tok_is_num(head_tok(cell))
  proofs:
    purity:
      reads : [cell]
      calls : [tok_is_num, head_tok]
    termination:
      bound : 16


-- Peek whether the token at index `arg.n` is an operator (structural).
rule peek_is_op
  @intention: "1 if the token at index n is an operator, 0 otherwise"
  @source: vexprparse.intent:14
  input:
    cell : TokenList
  output:
    out : number
  logic:
    out = tok_is_op(head_tok(cell))
  proofs:
    purity:
      reads : [cell]
      calls : [tok_is_op, head_tok]
    termination:
      bound : 16


-- Peek the operator code of the token at absolute index `arg.n` (0 if not Op).
rule peek_op_code
  @intention: "Operator code of the token at index n (0 if not an operator)"
  @source: vexprparse.intent:14
  input:
    cell : TokenList
  output:
    out : number
  logic:
    out = tok_op_code(head_tok(cell))
  proofs:
    purity:
      reads : [cell]
      calls : [tok_op_code, head_tok]
    termination:
      bound : 16


-- Peek whether the token at index `arg.n` is an identifier (structural).
rule peek_is_ident
  @intention: "1 if the token at index n is an identifier, 0 otherwise"
  @source: vexprparse.intent:14
  input:
    cell : TokenList
  output:
    out : number
  logic:
    out = tok_is_ident(head_tok(cell))
  proofs:
    purity:
      reads : [cell]
      calls : [tok_is_ident, head_tok]
    termination:
      bound : 16


-- Peek the Ident source-span start offset of the token at index `arg.n`.
rule peek_start
  @intention: "Source-span start offset of the Ident token at index n (0 if not an Ident)"
  @source: vexprparse.intent:14
  input:
    cell : TokenList
  output:
    out : number
  logic:
    out = tok_start(head_tok(cell))
  proofs:
    purity:
      reads : [cell]
      calls : [tok_start, head_tok]
    termination:
      bound : 16


-- Peek the Ident source-span length of the token at index `arg.n`.
rule peek_len
  @intention: "Source-span length of the Ident token at index n (0 if not an Ident)"
  @source: vexprparse.intent:14
  input:
    cell : TokenList
  output:
    out : number
  logic:
    out = tok_len(head_tok(cell))
  proofs:
    purity:
      reads : [cell]
      calls : [tok_len, head_tok]
    termination:
      bound : 16


-- Peek whether the token at index `arg.n` is a string literal (structural).
rule peek_is_str
  @intention: "1 if the token at index n is a string literal, 0 otherwise"
  @source: vexprparse.intent:14
  input:
    cell : TokenList
  output:
    out : number
  logic:
    out = tok_is_str(head_tok(cell))
  proofs:
    purity:
      reads : [cell]
      calls : [tok_is_str, head_tok]
    termination:
      bound : 16


-- Peek the Str source-span start offset (opening-quote byte) of the token at
-- index `arg.n`.
rule peek_str_start
  @intention: "Source-span start offset of the Str token at index n (0 if not a Str)"
  @source: vexprparse.intent:14
  input:
    cell : TokenList
  output:
    out : number
  logic:
    out = tok_str_start(head_tok(cell))
  proofs:
    purity:
      reads : [cell]
      calls : [tok_str_start, head_tok]
    termination:
      bound : 16


-- Peek the Str source-span length (both quotes included) of the token at index
-- `arg.n`.
rule peek_str_len
  @intention: "Source-span length of the Str token at index n (0 if not a Str)"
  @source: vexprparse.intent:14
  input:
    cell : TokenList
  output:
    out : number
  logic:
    out = tok_str_len(head_tok(cell))
  proofs:
    purity:
      reads : [cell]
      calls : [tok_str_len, head_tok]
    termination:
      bound : 16


-- BYTES-tier brick B1: peek whether the head token is a byte literal (structural).
rule peek_is_bytelit
  @intention: "1 if the head token is a byte literal, 0 otherwise"
  @source: vexprparse.intent:14
  input:
    cell : TokenList
  output:
    out : number
  logic:
    out = tok_is_bytelit(head_tok(cell))
  proofs:
    purity:
      reads : [cell]
      calls : [tok_is_bytelit, head_tok]
    termination:
      bound : 16


-- BYTES-tier brick B1: peek the ByteLit source-span start (opening-quote byte).
rule peek_bytelit_start
  @intention: "Source-span start offset of the ByteLit head token (0 if not a ByteLit)"
  @source: vexprparse.intent:14
  input:
    cell : TokenList
  output:
    out : number
  logic:
    out = tok_bytelit_start(head_tok(cell))
  proofs:
    purity:
      reads : [cell]
      calls : [tok_bytelit_start, head_tok]
    termination:
      bound : 16


-- BYTES-tier brick B1: peek the ByteLit source-span length (b prefix + quotes).
rule peek_bytelit_len
  @intention: "Source-span length of the ByteLit head token (0 if not a ByteLit)"
  @source: vexprparse.intent:14
  input:
    cell : TokenList
  output:
    out : number
  logic:
    out = tok_bytelit_len(head_tok(cell))
  proofs:
    purity:
      reads : [cell]
      calls : [tok_bytelit_len, head_tok]
    termination:
      bound : 16


-- ============================================================================
-- THE PARSER. Precedence recursive descent over the token list.
-- ParseState carries the FULL token list `toks` plus the current index `pos`.
-- Each parse rule returns a Parsed{node, next}.
-- ============================================================================

concept ParseState
  @intention: "The token list cell at the current parse position (the cursor)"
  @source: vexprparse.intent:15
  fields:
    cell : TokenList


-- Accessors for a Parsed result. A block-form `match` is only legal in the
-- FINAL `out = match ...` position (not as a `let` RHS — see the language gap
-- noted in vexprparse.intent), so destructuring a Parsed is factored into these
-- two tiny rules and called wherever a parse rule needs the node or the index.
rule parsed_node
  @intention: "The AST subtree from a parse result"
  @source: vexprparse.intent:15
  input:
    p : Parsed
  output:
    out : Ast
  logic:
    out = match p:
      Mk(node, next) => node
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


rule parsed_next
  @intention: "The token index just past a parse result"
  @source: vexprparse.intent:15
  input:
    p : Parsed
  output:
    out : TokenList
  logic:
    out = match p:
      Mk(node, next) => next
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


-- A fold-step state: the token list, the current index, and the accumulated
-- left-hand AST node built so far. add_rest / mul_rest carry this.
concept FoldState
  @intention: "Token list cursor cell + the left-associative accumulator"
  @source: vexprparse.intent:15
  fields:
    cell : TokenList
    acc : Ast


-- A join state: a fold accumulator plus the operator and the freshly-parsed
-- right operand (as a Parsed). add_join / mul_join consume this to fold the
-- accumulator one step left-associatively, then continue the fold.
--
-- WHY a separate join rule (and not a let): Verbose `let` bindings are EAGER,
-- but `if` only evaluates the TAKEN branch. The recursive descent into the next
-- operand MUST be guarded — if it ran eagerly (in a let) it would fire even
-- when there is no operator, recursing forever (parse_add -> parse_mul ->
-- parse_primary -> parse_add ...). So the next-operand parse is placed inside
-- the `then` branch (lazy), and its Parsed result is handed to a join rule that
-- extracts node+next ONCE. add_join <-> add_rest and mul_join <-> mul_rest are
-- mutually recursive; both live in the parser's recursion cycle, so the Parsed
-- group-field input compiles natively (the group-field ABI, commit 9529277).
concept JoinState
  @intention: "Fold accumulator + operator + the parsed right operand"
  @source: vexprparse.intent:15
  fields:
    acc : Ast
    opcode : number [0, 64]
    rhs : Parsed


-- A unary-wrap state: the token list, a flag selecting not (1) vs negation (0),
-- and the Parsed inner operand. parse_unary parses the operand LAZILY in the
-- matched branch and hands it here; unary_wrap builds the AstNot / AstNeg node.
-- In the parser cycle (called only from parse_unary), so the Parsed field
-- compiles natively.
concept WrapState
  @intention: "not/neg selector + the parsed unary operand"
  @source: vexprparse.intent:18
  fields:
    isnot : number [0, 1]
    inner : Parsed


-- Brick 9: the let-statement continuation state. Carries the token list, the
-- bound name SPAN (name_start, name_len), and the already-parsed RHS value (as a
-- Parsed). stmt_let_join consumes this — extracts the value node + its end index,
-- recurses parse_stmts on the rest of the block, and conses the binding. Lives in
-- the brick-9 parse cycle (called only from parse_stmts's let-branch), so its
-- Parsed group-field input compiles natively (the group-field recursive ABI).
concept LetJoinState
  @intention: "Bound name span + the parsed let-RHS value"
  @source: vexprparse.intent:28
  fields:
    name_start : number [0, 4000000]
    name_len : number [0, 4000000]
    value : Parsed


-- A paren-close state: the token list plus the Parsed inner expression. Used to
-- consume an optional ')' after a parenthesized sub-expression. In the parser
-- cycle (called only from parse_primary's paren branch), so the Parsed field
-- compiles natively.
concept ParenState
  @intention: "The parsed inner expression of a parenthesis"
  @source: vexprparse.intent:15
  fields:
    inner : Parsed


-- An arg-cons state: the token list plus a freshly-parsed argument (as a
-- Parsed). args_cons consumes this — extracts the arg node + its end index —
-- peeks for a ',' (continue: parse the next arg via parse_args) or ')' (stop),
-- and prepends the arg to the resulting ArgList. Lives in the parser cycle
-- (called only from parse_args), so the Parsed group-field input compiles
-- natively (the group-field ABI, commit 9529277).
concept ArgConsState
  @intention: "One parsed call argument (continuing the arg cons-list)"
  @source: vexprparse.intent:15
  fields:
    first : Parsed


-- An arg-prepend state: the head argument's AST node plus the already-parsed
-- REST of the argument list (as a ParsedArgs). args_prepend consumes this —
-- conses the head onto the rest's ArgList, carrying the rest's end index. A
-- single-input rule (the language allows one input per rule), so the head node
-- and the rest are packed into this one state. In the parser cycle (called only
-- from args_cons), so the ParsedArgs group-field input compiles natively.
concept ArgPrependState
  @intention: "Head argument AST + the parsed rest of the argument list"
  @source: vexprparse.intent:15
  fields:
    head_node : Ast
    rest : ParsedArgs


-- A call-build state: the callee span (start, len) plus the parsed argument
-- list (as a ParsedArgs). call_build extracts the ArgList + its end index and
-- builds the AstCall node. In the parser cycle (called only from
-- parse_primary's call branch), so the ParsedArgs group-field input compiles
-- natively.
concept CallState
  @intention: "Callee span + the parsed argument list of a function call"
  @source: vexprparse.intent:15
  fields:
    cstart : number [0, 4000000]
    clen : number [0, 4000000]
    pargs : ParsedArgs


-- A field-chain state: the token list, the current index, and the accumulated
-- base AST (the expression whose field is being accessed). field_rest folds
-- successive '.IDENT' steps onto the base, left-deep (a.b.c => AstField(
-- AstField(AstVar(a), b), c)).
concept FieldState
  @intention: "Token list cursor cell + the accumulated field-access base"
  @source: vexprparse.intent:15
  fields:
    cell : TokenList
    base : Ast


-- ============================================================================
-- BRICK 6: `if cond then thn else els` as an expression. The single-line form
-- only — there is no INDENT/DEDENT in this tokenizer. parse_primary detects the
-- `if` keyword (kind 201) and threads three sub-parses (cond / thn / els, each a
-- full parse_or) through a chain of continuation rules, because a Verbose rule
-- has ONE input and `let` is EAGER (a let-bound parse_or would fire on every
-- parse_primary call, recursing forever). Each continuation carries the partial
-- state in a single concept and parses its sub-expression LAZILY (only when
-- reached from the if-branch). The chain: parse_primary --(cond Parsed)-->
-- if_then --(thn Parsed)--> if_else --(els Parsed)--> if_build (assembles AstIf).
-- All three continuations live in the parser recursion cycle (they call
-- parse_or), so their Parsed group-field inputs compile natively (group-field
-- ABI, commit 9529277).
-- ============================================================================

-- if_then: given the parsed condition, locate the `then` keyword (kind 207),
-- step over it, and parse the then-branch (a full parse_or). The cond's AST node
-- is carried forward; the thn parse is handed to if_else.
concept IfThenState
  @intention: "The parsed condition of an if-expression"
  @source: vexprparse.intent:25
  fields:
    cond : Parsed


-- if_else: given the cond node and the parsed then-branch, locate the `else`
-- keyword (kind 208), step over it, and parse the else-branch. The cond and thn
-- nodes are carried forward; the els parse is handed to if_build.
concept IfElseState
  @intention: "The if-expression condition node + the parsed then-branch"
  @source: vexprparse.intent:25
  fields:
    cond_node : Ast
    thn : Parsed


-- if_build: given the cond and thn nodes and the parsed else-branch, assemble the
-- AstIf node carrying the else-branch's end index.
concept IfBuildState
  @intention: "The if-expression cond + then nodes + the parsed else-branch"
  @source: vexprparse.intent:25
  fields:
    cond_node : Ast
    thn_node : Ast
    els : Parsed


-- Records-arc brick R3: variant-construction states. A VariantState carries the
-- concept span + variant span + the parsed field list; variant_build extracts the
-- VFieldList + end cell and builds the AstVariant node. Same shape as CallState.
concept VariantState
  @intention: "Concept span + variant span + the parsed field list of a variant construction"
  @source: vexprparse.intent:64
  fields:
    cstart : number [0, 4000000]
    clen : number [0, 4000000]
    vstart : number [0, 4000000]
    vlen : number [0, 4000000]
    pfields : ParsedVFields


-- Records-arc brick R3: a vfield-cons state — one field's name span plus its parsed
-- value (as a Parsed). vfields_cons extracts the value node + end cell, peeks for a
-- ',' (continue) or '}' (stop). Mirror of ArgConsState.
concept VFieldConsState
  @intention: "One parsed variant field (name span + value) continuing the field cons-list"
  @source: vexprparse.intent:64
  fields:
    name_start : number [0, 4000000]
    name_len : number [0, 4000000]
    value : Parsed


-- Records-arc brick R3: a vfield-prepend state — the head field's name span + value
-- node + the parsed rest of the field list. Mirror of ArgPrependState.
concept VFieldPrependState
  @intention: "Head variant field (name span + value) + the parsed rest of the field list"
  @source: vexprparse.intent:64
  fields:
    name_start : number [0, 4000000]
    name_len : number [0, 4000000]
    val : Ast
    rest : ParsedVFields


-- Records-arc brick R3: a binder-prepend state — the head binder span + the parsed
-- rest of the binder list. Mirror of ArgPrependState (binders carry no sub-AST).
concept BinderPrependState
  @intention: "Head binder span + the parsed rest of the binder list"
  @source: vexprparse.intent:64
  fields:
    start : number [0, 4000000]
    len : number [0, 4000000]
    rest : ParsedBinders


-- Records-arc brick R3: an arm-join state — one arm's variant span + its parsed
-- binder list. arm_join skips the '=>', parses the body, recurses parse_arms on the
-- rest, and conses the arm. Analogue of LetJoinState (carries a parsed sub-result
-- and continues the recursion).
concept ArmJoinState
  @intention: "An arm's variant span + its parsed binder list (continuing the arm list)"
  @source: vexprparse.intent:64
  fields:
    vstart : number [0, 4000000]
    vlen : number [0, 4000000]
    binders : ParsedBinders


-- Pull the ArgList out of a ParsedArgs result.
rule parsed_args_list
  @intention: "The argument cons-list from a call-argument parse result"
  @source: vexprparse.intent:15
  input:
    p : ParsedArgs
  output:
    out : ArgList
  logic:
    out = match p:
      MkArgs(args, next) => args
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


-- Pull the end index out of a ParsedArgs result.
rule parsed_args_next
  @intention: "The token index just past a call-argument parse result"
  @source: vexprparse.intent:15
  input:
    p : ParsedArgs
  output:
    out : TokenList
  logic:
    out = match p:
      MkArgs(args, next) => next
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


-- Consume the optional ')' after a '(' add_expr. Reads where the inner
-- expression ended; if the next token is ')' (kind 422) it is consumed
-- (next = inner_end + 1), otherwise the position is left as-is (a missing ')'
-- is tolerated rather than aborting — error recovery is a later brick).
rule paren_close
  @intention: "Consume a closing paren after a parenthesized sub-expression"
  @source: vexprparse.intent:16
  input:
    ps : ParenState
  output:
    out : Parsed
  logic:
    let inner_next = parsed_next(ps.inner)
    let inner_node = parsed_node(ps.inner)
    let after_op = peek_op_code(inner_next)
    let close_pos = if after_op == 22 then advance(Advance { lst: inner_next, k: 1 }) else inner_next
    out = Parsed::Mk { node: inner_node, next: close_pos }
  proofs:
    purity:
      reads : [ps.inner]
      calls : [parsed_next, parsed_node, peek_op_code, advance]
    termination:
      bound : 512


-- ============================================================================
-- BRICK 5: identifiers, function calls, field access. Mirrors src/parser.rs's
-- parse_primary ident path:
--   primary = '(' parse_or ')' | NUMBER | IDENT trailer
--   trailer = '(' arglist ')'   -- function call
--           | ('.' IDENT)*      -- field access chain (left-deep)
--           | (nothing)         -- a bare variable reference
--   arglist = (parse_or (',' parse_or)*)?   -- zero or more comma-separated exprs
-- An IDENT here is a Token::Ident (kind 100); the logical keywords and/or/not
-- lex as Keyword (kind 200+kw) so they never reach this path.
-- ============================================================================

-- arglist parsing — itself a recursive cons-list builder (like tokenize builds
-- TokenList). parse_args is entered at the token index of the FIRST argument
-- (just past the '('). Zero-arg case: if the very next token is ')' (op 22) the
-- list is empty and we consume the ')'. Otherwise parse one argument (parse_or,
-- LAZILY in the else branch so a non-call ident never descends here) and hand
-- it to args_cons, which decides comma-continue vs ')'-stop.
rule parse_args
  @intention: "Parse a (possibly empty) comma-separated call-argument list, consuming the ')'"
  @source: vexprparse.intent:16
  input:
    st : ParseState
  output:
    out : ParsedArgs
  logic:
    let opc = peek_op_code(st.cell)
    let isclose = if opc == 22 then 1 else 0
    out = if isclose == 1 then ParsedArgs::MkArgs { args: ArgList::ArgNil, next: advance(Advance { lst: st.cell, k: 1 }) } else args_cons(ArgConsState { first: parse_or(st) })
  proofs:
    purity:
      reads : [st.cell, st]
      calls : [peek_op_code, parse_or, args_cons, advance]
    termination:
      bound : 512


-- args_cons: given a freshly-parsed argument (Parsed), fold it into the arg
-- cons-list. Extract the arg node + its end index, peek the next token: a ','
-- (op 11) continues — parse the REST of the list (LAZILY, in the then branch)
-- from just past the comma and prepend this arg; a ')' (op 22) stops, consuming
-- it (next = arg_end + 1); anything else stops too (missing ')' tolerated, like
-- paren_close — error recovery is a later brick), leaving next = arg_end.
rule args_cons
  @intention: "Fold one parsed argument into the cons-list, continuing on ',' or stopping on ')'"
  @source: vexprparse.intent:16
  input:
    cs : ArgConsState
  output:
    out : ParsedArgs
  logic:
    let arg_node = parsed_node(cs.first)
    let arg_next = parsed_next(cs.first)
    let opc = peek_op_code(arg_next)
    let iscomma = if opc == 11 then 1 else 0
    let close_next = if opc == 22 then advance(Advance { lst: arg_next, k: 1 }) else arg_next
    out = if iscomma == 1 then args_prepend(ArgPrependState { head_node: arg_node, rest: parse_args(ParseState { cell: advance(Advance { lst: arg_next, k: 1 }) }) }) else ParsedArgs::MkArgs { args: ArgList::ArgCons { head: arg_node, tail: ArgList::ArgNil }, next: close_next }
  proofs:
    purity:
      reads : [cs.first]
      calls : [parsed_node, parsed_next, peek_op_code, args_prepend, parse_args, advance]
    termination:
      bound : 512


-- args_prepend: cons the head argument onto the front of the already-parsed
-- REST of the argument list, carrying the rest's end index through. Splitting
-- this out of args_cons keeps the recursive parse_args call lazily inside the
-- comma branch (a let would force it eagerly). Reached only from args_cons in
-- the parser cycle, so the ParsedArgs group-field input compiles natively.
rule args_prepend
  @intention: "Cons the head argument onto the front of the parsed rest of the list"
  @source: vexprparse.intent:16
  input:
    aps : ArgPrependState
  output:
    out : ParsedArgs
  logic:
    let rest_list = parsed_args_list(aps.rest)
    let rest_next = parsed_args_next(aps.rest)
    out = ParsedArgs::MkArgs { args: ArgList::ArgCons { head: aps.head_node, tail: rest_list }, next: rest_next }
  proofs:
    purity:
      reads : [aps.head_node, aps.rest]
      calls : [parsed_args_list, parsed_args_next]
    termination:
      bound : 16


-- call_build: given the callee span and the parsed argument list, build the
-- AstCall node carrying the arg cons-list and the index just past the ')'.
-- In the parser cycle (called only from parse_primary's call branch).
rule call_build
  @intention: "Build an AstCall node from the callee span and the parsed argument list"
  @source: vexprparse.intent:16
  input:
    cs : CallState
  output:
    out : Parsed
  logic:
    let arglist = parsed_args_list(cs.pargs)
    let argnext = parsed_args_next(cs.pargs)
    out = Parsed::Mk { node: Ast::AstCall { callee_start: cs.cstart, callee_len: cs.clen, args: arglist }, next: argnext }
  proofs:
    purity:
      reads : [cs.cstart, cs.clen, cs.pargs]
      calls : [parsed_args_list, parsed_args_next]
    termination:
      bound : 16


-- ============================================================================
-- Records-arc brick R3: VARIANT CONSTRUCTION and block-form MATCH parsing.
-- ============================================================================

-- pvf_fields / pvf_next: destructure a ParsedVFields result (the VFieldList +
-- end cell). Mirror of parsed_args_list / parsed_args_next.
rule pvf_fields
  @intention: "The VFieldList from a variant-field-list parse result"
  @source: vexprparse.intent:64
  input:
    p : ParsedVFields
  output:
    out : VFieldList
  logic:
    out = match p:
      MkVF(fields, next) => fields
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


rule pvf_next
  @intention: "The end cell from a variant-field-list parse result"
  @source: vexprparse.intent:64
  input:
    p : ParsedVFields
  output:
    out : TokenList
  logic:
    out = match p:
      MkVF(fields, next) => next
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


-- pal_arms / pal_next: destructure a ParsedArms result (the ArmList + end cell).
rule pal_arms
  @intention: "The ArmList from a match-arm-list parse result"
  @source: vexprparse.intent:64
  input:
    p : ParsedArms
  output:
    out : ArmList
  logic:
    out = match p:
      MkAL(arms, next) => arms
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


rule pal_next
  @intention: "The end cell from a match-arm-list parse result"
  @source: vexprparse.intent:64
  input:
    p : ParsedArms
  output:
    out : TokenList
  logic:
    out = match p:
      MkAL(arms, next) => next
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


-- pbl_binders / pbl_next: destructure a ParsedBinders result (the BinderList +
-- end cell).
rule pbl_binders
  @intention: "The BinderList from a binder-list parse result"
  @source: vexprparse.intent:64
  input:
    p : ParsedBinders
  output:
    out : BinderList
  logic:
    out = match p:
      MkBL(binders, next) => binders
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


rule pbl_next
  @intention: "The end cell from a binder-list parse result"
  @source: vexprparse.intent:64
  input:
    p : ParsedBinders
  output:
    out : TokenList
  logic:
    out = match p:
      MkBL(binders, next) => next
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


-- parse_vfields: parse a (possibly empty) comma-separated `name : expr` field list
-- inside `{ ... }`, consuming the '}'. Cursor positioned just past the '{'. Mirror
-- of parse_args. '}' (op 24) immediately => empty VFNil. Otherwise the leading
-- token is the field NAME (IDENT at st.cell), the ':' is at st.cell+1 (grammar is
-- fixed), and the value parse is a full parse_or from st.cell+2 (LAZILY, in the
-- else branch), handed to vfields_cons.
rule parse_vfields
  @intention: "Parse a comma-separated variant field list, consuming the '}'"
  @source: vexprparse.intent:64
  input:
    st : ParseState
  output:
    out : ParsedVFields
  logic:
    let opc = peek_op_code(st.cell)
    let isclose = if opc == 24 then 1 else 0
    let name_start = peek_start(st.cell)
    let name_len = peek_len(st.cell)
    out = if isclose == 1 then ParsedVFields::MkVF { fields: VFieldList::VFNil, next: advance(Advance { lst: st.cell, k: 1 }) } else vfields_cons(VFieldConsState { name_start: name_start, name_len: name_len, value: parse_or(ParseState { cell: advance(Advance { lst: st.cell, k: 2 }) }) })
  proofs:
    purity:
      reads : [st.cell]
      calls : [peek_op_code, peek_start, peek_len, parse_or, vfields_cons, advance]
    termination:
      bound : 512


-- vfields_cons: fold one parsed field initializer into the VFieldList. Extract the
-- value node + end cell, peek the next token: a ',' (op 11) continues — parse the
-- REST (LAZILY) and prepend this field; a '}' (op 24) stops, consuming it; anything
-- else stops too (missing '}' tolerated, like args_cons). Mirror of args_cons.
rule vfields_cons
  @intention: "Fold one parsed variant field into the cons-list, continuing on ',' or stopping on '}'"
  @source: vexprparse.intent:64
  input:
    cs : VFieldConsState
  output:
    out : ParsedVFields
  logic:
    let val_node = parsed_node(cs.value)
    let val_next = parsed_next(cs.value)
    let opc = peek_op_code(val_next)
    let iscomma = if opc == 11 then 1 else 0
    let close_next = if opc == 24 then advance(Advance { lst: val_next, k: 1 }) else val_next
    out = if iscomma == 1 then vfields_prepend(VFieldPrependState { name_start: cs.name_start, name_len: cs.name_len, val: val_node, rest: parse_vfields(ParseState { cell: advance(Advance { lst: val_next, k: 1 }) }) }) else ParsedVFields::MkVF { fields: VFieldList::VFCons { name_start: cs.name_start, name_len: cs.name_len, val: val_node, rest: VFieldList::VFNil }, next: close_next }
  proofs:
    purity:
      reads : [cs.name_start, cs.name_len, cs.value]
      calls : [parsed_node, parsed_next, peek_op_code, vfields_prepend, parse_vfields, advance]
    termination:
      bound : 512


-- vfields_prepend: cons the head field onto the front of the parsed rest of the
-- field list, carrying the rest's end cell through. Mirror of args_prepend.
rule vfields_prepend
  @intention: "Cons the head variant field onto the front of the parsed rest of the list"
  @source: vexprparse.intent:64
  input:
    ps : VFieldPrependState
  output:
    out : ParsedVFields
  logic:
    let rest_list = pvf_fields(ps.rest)
    let rest_next = pvf_next(ps.rest)
    out = ParsedVFields::MkVF { fields: VFieldList::VFCons { name_start: ps.name_start, name_len: ps.name_len, val: ps.val, rest: rest_list }, next: rest_next }
  proofs:
    purity:
      reads : [ps.name_start, ps.name_len, ps.val, ps.rest]
      calls : [pvf_fields, pvf_next]
    termination:
      bound : 16


-- variant_build: given the concept span, variant span, and parsed field list, build
-- the AstVariant node carrying the VFieldList and the end cell. Mirror of call_build.
rule variant_build
  @intention: "Build an AstVariant node from the concept/variant spans and the parsed field list"
  @source: vexprparse.intent:64
  input:
    vs : VariantState
  output:
    out : Parsed
  logic:
    let flist = pvf_fields(vs.pfields)
    let fnext = pvf_next(vs.pfields)
    out = Parsed::Mk { node: Ast::AstVariant { cstart: vs.cstart, clen: vs.clen, vstart: vs.vstart, vlen: vs.vlen, fields: flist }, next: fnext }
  proofs:
    purity:
      reads : [vs.cstart, vs.clen, vs.vstart, vs.vlen, vs.pfields]
      calls : [pvf_fields, pvf_next]
    termination:
      bound : 16


-- parse_binders: parse an arm's OPTIONAL parenthesized positional binder list.
-- Cursor positioned at the token right after the arm's variant-name IDENT. A '('
-- (op 21) opens the list — binders_scan from just past it (LAZILY). Anything else
-- means a zero-binder arm (e.g. `Nil =>` / `Eof =>`): BindNil, cursor unchanged.
rule parse_binders
  @intention: "Parse an arm's optional parenthesized binder list (BindNil if no parens)"
  @source: vexprparse.intent:64
  input:
    st : ParseState
  output:
    out : ParsedBinders
  logic:
    let opc = peek_op_code(st.cell)
    let isparen = if opc == 21 then 1 else 0
    out = if isparen == 1 then binders_scan(ParseState { cell: advance(Advance { lst: st.cell, k: 1 }) }) else ParsedBinders::MkBL { binders: BinderList::BindNil, next: st.cell }
  proofs:
    purity:
      reads : [st.cell]
      calls : [peek_op_code, binders_scan, advance]
    termination:
      bound : 16


-- binders_scan: scan the comma-separated IDENT binder names inside '( ... )',
-- consuming the ')'. Cursor positioned just past the '('. A ')' (op 22) immediately
-- => empty BindNil. Otherwise the leading token is a binder IDENT (span at st.cell);
-- peek the token after it: a ',' (op 11) continues (LAZILY) from st.cell+2, a ')'
-- (op 22) stops consuming it (next = st.cell+2), anything else stops at st.cell+1.
-- Binders carry no sub-expression, so the recursion is a plain forward scan.
rule binders_scan
  @intention: "Scan the comma-separated binder names inside parens, consuming the ')'"
  @source: vexprparse.intent:64
  input:
    st : ParseState
  output:
    out : ParsedBinders
  logic:
    let opc = peek_op_code(st.cell)
    let isclose = if opc == 22 then 1 else 0
    let bstart = peek_start(st.cell)
    let blen = peek_len(st.cell)
    let after_opc = peek_op_code(advance(Advance { lst: st.cell, k: 1 }))
    let iscomma = if after_opc == 11 then 1 else 0
    let close_next = if after_opc == 22 then advance(Advance { lst: st.cell, k: 2 }) else advance(Advance { lst: st.cell, k: 1 })
    out = if isclose == 1 then ParsedBinders::MkBL { binders: BinderList::BindNil, next: advance(Advance { lst: st.cell, k: 1 }) } else if iscomma == 1 then binders_prepend(BinderPrependState { start: bstart, len: blen, rest: binders_scan(ParseState { cell: advance(Advance { lst: st.cell, k: 2 }) }) }) else ParsedBinders::MkBL { binders: BinderList::BindCons { start: bstart, len: blen, rest: BinderList::BindNil }, next: close_next }
  proofs:
    purity:
      reads : [st.cell]
      calls : [peek_op_code, peek_start, peek_len, binders_prepend, binders_scan, advance]
    termination:
      bound : 512


-- binders_prepend: cons the head binder span onto the front of the parsed rest of
-- the binder list, carrying the rest's end cell through. Mirror of args_prepend.
rule binders_prepend
  @intention: "Cons the head binder onto the front of the parsed rest of the binder list"
  @source: vexprparse.intent:64
  input:
    ps : BinderPrependState
  output:
    out : ParsedBinders
  logic:
    let rest_list = pbl_binders(ps.rest)
    let rest_next = pbl_next(ps.rest)
    out = ParsedBinders::MkBL { binders: BinderList::BindCons { start: ps.start, len: ps.len, rest: rest_list }, next: rest_next }
  proofs:
    purity:
      reads : [ps.start, ps.len, ps.rest]
      calls : [pbl_binders, pbl_next]
    termination:
      bound : 16


-- parse_arms: parse the arm sequence of a block-form match. Reuses R2's separator
-- skipping (skip_seps swallows the Newline + Indent before the first arm and the
-- Newline between arms); the sweep stops at a Dedent (kind 800) or Eof (kind 0),
-- returning ArmNil at that cell. Otherwise the leading token is the arm's
-- variant-name IDENT (span at headp); its optional binder list is parsed from
-- headp+1 and handed to arm_join, which skips '=>', parses the body, and recurses.
-- A flat single-line arm sequence (no Newline/Indent/Dedent) also parses: skip_seps
-- is a no-op and the sweep stops at Eof. Forward scan; bound + recursion breadcrumb.
rule parse_arms
  @intention: "Parse a match's arm sequence (Variant(binders) => body)* up to the closing DEDENT/Eof"
  @source: vexprparse.intent:64
  input:
    st : ParseState
  output:
    out : ParsedArms
  logic:
    let headp = skip_seps(ParseState { cell: st.cell })
    let knd = peek_kind(headp)
    let isdedent = if knd == 800 then 1 else 0
    let iseof = if knd == 0 then 1 else 0
    let isend = if isdedent == 1 then 1 else iseof
    let vstart = peek_start(headp)
    let vlen = peek_len(headp)
    out = if isend == 1 then ParsedArms::MkAL { arms: ArmList::ArmNil, next: headp } else arm_join(ArmJoinState { vstart: vstart, vlen: vlen, binders: parse_binders(ParseState { cell: advance(Advance { lst: headp, k: 1 }) }) })
  proofs:
    purity:
      reads : [st.cell]
      calls : [skip_seps, peek_kind, peek_start, peek_len, arm_join, parse_binders, advance]
    termination:
      bound : 512


-- arm_join: the arm continuation. Given the arm's variant span + its parsed binder
-- list, extract the binder list + the cell at '=>' (op 2), parse the body (a full
-- parse_or from just past '=>'), recurse parse_arms on the body's end cell, and cons
-- ArmCons(span, binders, body, rest). Analogue of stmt_let_join: the recursion is
-- reached ONLY here (parse_arms gates entry on not-end), so the cycle terminates.
rule arm_join
  @intention: "Cons one parsed arm (span + binders + body) onto the recursively-parsed rest"
  @source: vexprparse.intent:64
  input:
    aj : ArmJoinState
  output:
    out : ParsedArms
  logic:
    let blist = pbl_binders(aj.binders)
    let bnext = pbl_next(aj.binders)
    let body_parsed = parse_or(ParseState { cell: advance(Advance { lst: bnext, k: 1 }) })
    let body_node = parsed_node(body_parsed)
    let body_next = parsed_next(body_parsed)
    let rest = parse_arms(ParseState { cell: body_next })
    let rest_arms = pal_arms(rest)
    let rest_next = pal_next(rest)
    out = ParsedArms::MkAL { arms: ArmList::ArmCons { vstart: aj.vstart, vlen: aj.vlen, binders: blist, body: body_node, rest: rest_arms }, next: rest_next }
  proofs:
    purity:
      reads : [aj.vstart, aj.vlen, aj.binders]
      calls : [pbl_binders, pbl_next, parse_or, parsed_node, parsed_next, parse_arms, pal_arms, pal_next, advance]
    termination:
      bound : 512


-- parse_match: build an AstMatch node. Cursor positioned at the `match` keyword.
-- The scrutinee is a full parse_or from st.cell+1; it stops at the ':' (op 10).
-- Skip the ':' and start the arm sweep at scrut_next+1 (parse_arms re-skips the
-- Newline + Indent). Reached only from parse_primary's match branch (guarded by the
-- match keyword), so the eager scrut/arms parses are safe (committed).
rule parse_match
  @intention: "Parse a block-form match into an AstMatch node (scrutinee + arm list)"
  @source: vexprparse.intent:64
  input:
    st : ParseState
  output:
    out : Parsed
  logic:
    let scrut_parsed = parse_or(ParseState { cell: advance(Advance { lst: st.cell, k: 1 }) })
    let scrut_node = parsed_node(scrut_parsed)
    let scrut_next = parsed_next(scrut_parsed)
    let parsed_arms = parse_arms(ParseState { cell: advance(Advance { lst: scrut_next, k: 1 }) })
    let armlist = pal_arms(parsed_arms)
    let arms_next = pal_next(parsed_arms)
    out = Parsed::Mk { node: Ast::AstMatch { scrut: scrut_node, arms: armlist }, next: arms_next }
  proofs:
    purity:
      reads : [st.cell]
      calls : [parse_or, parsed_node, parsed_next, parse_arms, pal_arms, pal_next, advance]
    termination:
      bound : 512


-- field_rest: fold a chain of '.IDENT' field accesses onto a base AST, left-deep
-- (a.b.c => AstField(AstField(AstVar(a), b), c)). Peeks the op at fs.pos: a '.'
-- (op 12) followed by an IDENT consumes both, wraps the base in AstField with
-- the field's span, and recurses with the new base at pos+2. Anything else
-- stops, returning the base unchanged at the current position. The recursion is
-- in the then branch (LAZY); each step consumes at least two tokens so pos
-- strictly grows toward Eof.
rule field_rest
  @intention: "Fold a chain of '.field' accesses onto a base, left-deep"
  @source: vexprparse.intent:16
  input:
    fs : FieldState
  output:
    out : Parsed
  logic:
    let opc = peek_op_code(fs.cell)
    let isdot = if opc == 12 then 1 else 0
    let fstart = peek_start(advance(Advance { lst: fs.cell, k: 1 }))
    let flen = peek_len(advance(Advance { lst: fs.cell, k: 1 }))
    let isident = peek_is_ident(advance(Advance { lst: fs.cell, k: 1 }))
    let isfield = if isdot == 1 and isident == 1 then 1 else 0
    out = if isfield == 1 then field_rest(FieldState { cell: advance(Advance { lst: fs.cell, k: 2 }), base: Ast::AstField { base: fs.base, fstart: fstart, flen: flen } }) else Parsed::Mk { node: fs.base, next: fs.cell }
  proofs:
    purity:
      reads : [fs.cell, fs.base]
      calls : [peek_op_code, peek_start, peek_len, peek_is_ident, field_rest, advance]
    termination:
      bound : 512


-- if_then: the parsed condition arrives as cs.cond. Extract its node + end
-- index. The `then` keyword (kind 207) should sit at cond_next; if it does, step
-- over it (then_pos = cond_next + 1), otherwise tolerate its absence (then_pos =
-- cond_next) — error recovery is a later brick, like paren_close's missing ')'.
-- Parse the then-branch (a full parse_or) from then_pos and hand it, with the
-- cond node, to if_else. The parse_or is unconditional (a then-branch is always
-- required once we are in an if-expression) and strictly advances position.
rule if_then
  @intention: "Consume 'then' after the condition, parse the then-branch, continue to if_else"
  @source: vexprparse.intent:25
  input:
    cs : IfThenState
  output:
    out : Parsed
  logic:
    let cond_node = parsed_node(cs.cond)
    let cond_next = parsed_next(cs.cond)
    let knd = peek_kind(cond_next)
    let then_pos = if knd == 207 then advance(Advance { lst: cond_next, k: 1 }) else cond_next
    out = if_else(IfElseState { cond_node: cond_node, thn: parse_or(ParseState { cell: then_pos }) })
  proofs:
    purity:
      reads : [cs.cond]
      calls : [parsed_node, parsed_next, peek_kind, if_else, parse_or, advance]
    termination:
      bound : 512


-- if_else: the parsed then-branch arrives as cs.thn (cond node carried in
-- cs.cond_node). Extract the thn node + end index. The `else` keyword (kind 208)
-- should sit at thn_next; step over it if present (else_pos = thn_next + 1),
-- tolerate its absence otherwise. Parse the else-branch from else_pos and hand
-- it, with the cond + thn nodes, to if_build.
rule if_else
  @intention: "Consume 'else' after the then-branch, parse the else-branch, continue to if_build"
  @source: vexprparse.intent:25
  input:
    cs : IfElseState
  output:
    out : Parsed
  logic:
    let thn_node = parsed_node(cs.thn)
    let thn_next = parsed_next(cs.thn)
    let knd = peek_kind(thn_next)
    let else_pos = if knd == 208 then advance(Advance { lst: thn_next, k: 1 }) else thn_next
    out = if_build(IfBuildState { cond_node: cs.cond_node, thn_node: thn_node, els: parse_or(ParseState { cell: else_pos }) })
  proofs:
    purity:
      reads : [cs.cond_node, cs.thn]
      calls : [parsed_node, parsed_next, peek_kind, if_build, parse_or, advance]
    termination:
      bound : 512


-- if_build: the parsed else-branch arrives as cs.els (cond + thn nodes carried).
-- Extract the els node + end index and assemble the AstIf node, carrying the
-- else-branch's end index as the conditional's `next`.
rule if_build
  @intention: "Assemble the AstIf node from the cond, then, and else sub-expressions"
  @source: vexprparse.intent:25
  input:
    cs : IfBuildState
  output:
    out : Parsed
  logic:
    let els_node = parsed_node(cs.els)
    let els_next = parsed_next(cs.els)
    out = Parsed::Mk { node: Ast::AstIf { cond: cs.cond_node, thn: cs.thn_node, els: els_node }, next: els_next }
  proofs:
    purity:
      reads : [cs.cond_node, cs.thn_node, cs.els]
      calls : [parsed_node, parsed_next]
    termination:
      bound : 16


-- primary = 'if' parse_or 'then' parse_or 'else' parse_or
--         | '(' parse_or ')' | NUMBER | IDENT trailer | <error leaf>
-- Peeks the token at pos. A '(' (op code 21 => kind 421) opens a sub-expr:
-- parse_or inside (LAZILY, only in this branch), then paren_close consumes the
-- ')'. A Num (kind 300+value) becomes an AstNum leaf consuming one token. An
-- IDENT (kind 100) takes the brick-5 trailer path: look at the NEXT token —
-- '(' (op 21) => a function call (parse_args from pos+2, build AstCall); '.'
-- (op 12) => a field-access chain (AstVar base folded by field_rest from pos+1);
-- anything else => a bare AstVar consuming one token. Any other lead token is an
-- AstErr leaf that consumes nothing (position does not advance => higher levels
-- read it as "stop").
--
-- All recursive descents (parse_or for parens, parse_args for a call) live
-- INSIDE their guarded branch so eager let evaluation never descends on the
-- wrong lead token (the loop trap). The trailer dispatch is on op codes of the
-- token at pos+1, computed up front in lets (those peeks are pure/total — they
-- only READ the token list, never recurse), but each descent stays lazy.
rule parse_primary
  @intention: "Parse a primary: parenthesized expr, number, or identifier (var / call / field)"
  @source: vexprparse.intent:16
  input:
    st : ParseState
  output:
    out : Parsed
  logic:
    let lead_kind = peek_kind(st.cell)
    let isif = if lead_kind == 201 then 1 else 0
    let istrue = if lead_kind == 209 then 1 else 0
    let isfalse = if lead_kind == 210 then 1 else 0
    let isnum = peek_is_num(st.cell)
    let isstr = peek_is_str(st.cell)
    -- BYTES-tier B1: a ByteLit head token parses to an AstBytes leaf. The token
    -- span covers `b"..."` (bstart = the `b` byte, blen = whole token incl `b`
    -- and both quotes); the AstBytes CONTENT span strips them: start = bstart + 2
    -- (past `b"`), len = blen - 3 (minus `b` and the two quotes). The blen >= 3
    -- clamp keeps an unterminated literal (`b"` at EOF, blen 2) from producing a
    -- negative-length span — same defensive shape as the AstStr len >= 2 clamp.
    let isbytelit = peek_is_bytelit(st.cell)
    let bstart = peek_bytelit_start(st.cell)
    let blen = peek_bytelit_len(st.cell)
    let opc = peek_op_code(st.cell)
    let isparen = if opc == 21 then 1 else 0
    let isident = peek_is_ident(st.cell)
    let numval = peek_value(st.cell)
    let sstart = peek_str_start(st.cell)
    let slen = peek_str_len(st.cell)
    let idstart = peek_start(st.cell)
    let idlen = peek_len(st.cell)
    let next_opc = peek_op_code(advance(Advance { lst: st.cell, k: 1 }))
    let iscall = if next_opc == 21 then 1 else 0
    let ismatch = if lead_kind == 211 then 1 else 0
    let isvariant = if next_opc == 3 then 1 else 0
    let vstart = peek_start(advance(Advance { lst: st.cell, k: 2 }))
    let vlen = peek_len(advance(Advance { lst: st.cell, k: 2 }))
    let has_braces = if peek_op_code(advance(Advance { lst: st.cell, k: 3 })) == 23 then 1 else 0
    let isrecord = if next_opc == 23 then 1 else 0
    out = if ismatch == 1 then parse_match(st) else if isif == 1 then if_then(IfThenState { cond: parse_or(ParseState { cell: advance(Advance { lst: st.cell, k: 1 }) }) }) else if istrue == 1 then Parsed::Mk { node: Ast::AstBool { value: 1 }, next: advance(Advance { lst: st.cell, k: 1 }) } else if isfalse == 1 then Parsed::Mk { node: Ast::AstBool { value: 0 }, next: advance(Advance { lst: st.cell, k: 1 }) } else if isnum == 1 then Parsed::Mk { node: Ast::AstNum { value: numval }, next: advance(Advance { lst: st.cell, k: 1 }) } else if isstr == 1 then Parsed::Mk { node: Ast::AstStr { start: sstart, len: slen }, next: advance(Advance { lst: st.cell, k: 1 }) } else if isbytelit == 1 then Parsed::Mk { node: Ast::AstBytes { start: bstart + 2, len: if blen >= 3 then blen - 3 else 0 }, next: advance(Advance { lst: st.cell, k: 1 }) } else if isparen == 1 then paren_close(ParenState { inner: parse_or(ParseState { cell: advance(Advance { lst: st.cell, k: 1 }) }) }) else if isident == 1 then (if isvariant == 1 then (if has_braces == 1 then variant_build(VariantState { cstart: idstart, clen: idlen, vstart: vstart, vlen: vlen, pfields: parse_vfields(ParseState { cell: advance(Advance { lst: st.cell, k: 4 }) }) }) else variant_build(VariantState { cstart: idstart, clen: idlen, vstart: vstart, vlen: vlen, pfields: ParsedVFields::MkVF { fields: VFieldList::VFNil, next: advance(Advance { lst: st.cell, k: 3 }) } })) else if iscall == 1 then call_build(CallState { cstart: idstart, clen: idlen, pargs: parse_args(ParseState { cell: advance(Advance { lst: st.cell, k: 2 }) }) }) else if isrecord == 1 then variant_build(VariantState { cstart: idstart, clen: idlen, vstart: idstart, vlen: idlen, pfields: parse_vfields(ParseState { cell: advance(Advance { lst: st.cell, k: 2 }) }) }) else field_rest(FieldState { cell: advance(Advance { lst: st.cell, k: 1 }), base: Ast::AstVar { start: idstart, len: idlen } })) else Parsed::Mk { node: Ast::AstErr, next: st.cell }
  proofs:
    purity:
      reads : [st.cell, st]
      calls : [peek_kind, peek_is_num, peek_is_str, peek_is_bytelit, peek_bytelit_start, peek_bytelit_len, peek_op_code, peek_is_ident, peek_value, peek_str_start, peek_str_len, peek_start, peek_len, if_then, paren_close, parse_or, call_build, parse_args, field_rest, parse_match, variant_build, parse_vfields, advance]
    termination:
      bound : 512


-- unary = ('not' | '-') unary | primary
-- A prefix-unary level sitting between mul and primary. Peeks the token at pos:
-- a 'not' keyword (kind 206) wraps the rest in AstNot; a '-' operator (op 14,
-- kind 414) in OPERAND position wraps it in AstNeg; otherwise it is a primary.
-- Right-recursive (not not 0, - -3 both parse): the inner parse_unary call lives
-- INSIDE the matched branch (LAZY), so on a non-prefix token no descent fires.
-- A unary node consumes the prefix token (pos + 1) then whatever its operand
-- consumed; the Parsed.next from the inner operand is the node's next.
rule parse_unary
  @intention: "Parse a prefix-unary expression: not / negation, else a primary"
  @source: vexprparse.intent:18
  input:
    st : ParseState
  output:
    out : Parsed
  logic:
    let knd = peek_kind(st.cell)
    let opc = peek_op_code(st.cell)
    let isnot = if knd == 206 then 1 else 0
    let isneg = if opc == 14 then 1 else 0
    out = if isnot == 1 then unary_wrap(WrapState { isnot: 1, inner: parse_unary(ParseState { cell: advance(Advance { lst: st.cell, k: 1 }) }) }) else if isneg == 1 then unary_wrap(WrapState { isnot: 0, inner: parse_unary(ParseState { cell: advance(Advance { lst: st.cell, k: 1 }) }) }) else parse_primary(st)
  proofs:
    purity:
      reads : [st.cell, st]
      calls : [peek_kind, peek_op_code, unary_wrap, parse_unary, parse_primary, advance]
    termination:
      bound : 512


-- unary_wrap: given a parsed inner operand and which prefix it was, build the
-- AstNot or AstNeg node carrying the operand's `next` index unchanged (the
-- prefix token was already stepped over by parse_unary at pos + 1). Lives in the
-- parser cycle (called only from parse_unary), so the Parsed group-field input
-- compiles natively.
rule unary_wrap
  @intention: "Wrap a parsed operand in AstNot or AstNeg, keeping its end index"
  @source: vexprparse.intent:18
  input:
    ws : WrapState
  output:
    out : Parsed
  logic:
    let inner_node = parsed_node(ws.inner)
    let inner_next = parsed_next(ws.inner)
    out = if ws.isnot == 1 then Parsed::Mk { node: Ast::AstNot { inner: inner_node }, next: inner_next } else Parsed::Mk { node: Ast::AstNeg { inner: inner_node }, next: inner_next }
  proofs:
    purity:
      reads : [ws.isnot, ws.inner]
      calls : [parsed_node, parsed_next]
    termination:
      bound : 16


-- mul_join: fold one * or / step. Given the parsed right primary, build
-- AstBin(op, acc, rhs) — acc on the LEFT for left-associativity — and continue
-- folding from just past the right operand via mul_rest.
rule mul_join
  @intention: "Fold one multiplicative step then continue the fold"
  @source: vexprparse.intent:17
  input:
    js : JoinState
  output:
    out : Parsed
  logic:
    let rhs_node = parsed_node(js.rhs)
    let rhs_next = parsed_next(js.rhs)
    out = mul_rest(FoldState { cell: rhs_next, acc: Ast::AstBin { op: js.opcode, lhs: js.acc, rhs: rhs_node } })
  proofs:
    purity:
      reads : [js.acc, js.opcode, js.rhs]
      calls : [parsed_node, parsed_next, mul_rest]
    termination:
      bound : 512
-- (mul_join now folds onto a unary operand; see parse_mul / mul_rest below.)


-- mul_rest: left-associative fold of ('*' | '/' | '%') unary onto an accumulator.
-- Peeks the op at fs.pos. If it is '*' (15), '/' (16), or '%' (17), parse the
-- next unary operand (LAZILY, in the then-branch) and hand it to mul_join.
-- Otherwise return the accumulator unchanged at the current position.
rule mul_rest
  @intention: "Fold *, /, and % onto the accumulator, left-associatively"
  @source: vexprparse.intent:17
  input:
    fs : FoldState
  output:
    out : Parsed
  logic:
    let opcode = peek_op_code(fs.cell)
    let ismul = if opcode == 15 or (opcode == 16 or opcode == 17) then 1 else 0
    out = if ismul == 1 then mul_join(JoinState { acc: fs.acc, opcode: opcode, rhs: parse_unary(ParseState { cell: advance(Advance { lst: fs.cell, k: 1 }) }) }) else Parsed::Mk { node: fs.acc, next: fs.cell }
  proofs:
    purity:
      reads : [fs.cell, fs.acc]
      calls : [peek_op_code, mul_join, parse_unary, advance]
    termination:
      bound : 512


-- mul_expr = unary (('*' | '/' | '%') unary)*
-- Parse the first unary operand, then fold the rest via mul_rest with that
-- operand as the initial accumulator. The first descent is unconditional (an
-- operand is always required) and bounded.
rule parse_mul
  @intention: "Parse a multiplicative expression (*, /, %, left-associative)"
  @source: vexprparse.intent:18
  input:
    st : ParseState
  output:
    out : Parsed
  logic:
    let first = parse_unary(st)
    let first_node = parsed_node(first)
    let first_next = parsed_next(first)
    out = mul_rest(FoldState { cell: first_next, acc: first_node })
  proofs:
    purity:
      reads : [st]
      calls : [parse_unary, mul_rest, parsed_node, parsed_next]
    termination:
      bound : 512


-- add_join: fold one + or - step. Given the parsed right mul_expr, build
-- AstBin(op, acc, rhs) — acc on the LEFT — and continue folding via add_rest.
rule add_join
  @intention: "Fold one additive step then continue the fold"
  @source: vexprparse.intent:19
  input:
    js : JoinState
  output:
    out : Parsed
  logic:
    let rhs_node = parsed_node(js.rhs)
    let rhs_next = parsed_next(js.rhs)
    out = add_rest(FoldState { cell: rhs_next, acc: Ast::AstBin { op: js.opcode, lhs: js.acc, rhs: rhs_node } })
  proofs:
    purity:
      reads : [js.acc, js.opcode, js.rhs]
      calls : [parsed_node, parsed_next, add_rest]
    termination:
      bound : 512


-- add_rest: left-associative fold of ('+' | '-') mul_expr onto an accumulator.
-- Symmetric to mul_rest but for '+' (kind 413) and '-' (kind 414); the next
-- operand is a full mul_expr (so * / bind tighter). The descent is LAZY (in the
-- then-branch) and handed to add_join.
rule add_rest
  @intention: "Fold + and - onto the accumulator, left-associatively"
  @source: vexprparse.intent:19
  input:
    fs : FoldState
  output:
    out : Parsed
  logic:
    let opcode = peek_op_code(fs.cell)
    let isadd = if opcode == 13 or opcode == 14 then 1 else 0
    out = if isadd == 1 then add_join(JoinState { acc: fs.acc, opcode: opcode, rhs: parse_mul(ParseState { cell: advance(Advance { lst: fs.cell, k: 1 }) }) }) else Parsed::Mk { node: fs.acc, next: fs.cell }
  proofs:
    purity:
      reads : [fs.cell, fs.acc]
      calls : [peek_op_code, add_join, parse_mul, advance]
    termination:
      bound : 512


-- add_expr = mul_expr (('+' | '-') mul_expr)*
-- The top of the precedence ladder. Parse the first mul_expr, then fold the
-- rest via add_rest.
rule parse_add
  @intention: "Parse an additive expression (+ and -, left-associative)"
  @source: vexprparse.intent:20
  input:
    st : ParseState
  output:
    out : Parsed
  logic:
    let first = parse_mul(st)
    let first_node = parsed_node(first)
    let first_next = parsed_next(first)
    out = add_rest(FoldState { cell: first_next, acc: first_node })
  proofs:
    purity:
      reads : [st]
      calls : [parse_mul, add_rest, parsed_node, parsed_next]
    termination:
      bound : 512


-- ============================================================================
-- cmp_expr = add_expr (('==' | '!=' | '<' | '>' | '<=' | '>=') add_expr)?
-- A comparison binds looser than +/- and is NON-associative: at most ONE
-- comparison operator (so `1 < 2 < 3` does not chain — the trailing `< 3` is
-- left for a higher level to reject/stop on, matching most languages and
-- src/parser.rs's single-comparison rule). The AST op-code IS the tokenizer
-- op_code (== =1, >= =4, <= =5, != =6, < =19, > =20), all disjoint from the
-- arithmetic and logical bands.
--
-- cmp_join folds the single comparison: build AstBin(op, lhs, rhs) and STOP
-- (return at the rhs end index — no further comparison consumed). The rhs
-- descent is LAZY (inside the matched branch) and handed to cmp_join, keeping it
-- in the recursion cycle so the Parsed group-field input compiles natively.
rule cmp_join
  @intention: "Fold the single comparison step (non-associative, stops after one)"
  @source: vexprparse.intent:19
  input:
    js : JoinState
  output:
    out : Parsed
  logic:
    let rhs_node = parsed_node(js.rhs)
    let rhs_next = parsed_next(js.rhs)
    out = Parsed::Mk { node: Ast::AstBin { op: js.opcode, lhs: js.acc, rhs: rhs_node }, next: rhs_next }
  proofs:
    purity:
      reads : [js.acc, js.opcode, js.rhs]
      calls : [parsed_node, parsed_next]
    termination:
      bound : 512


rule parse_cmp
  @intention: "Parse a comparison: an additive expr, optionally one compare op + additive expr"
  @source: vexprparse.intent:19
  input:
    st : ParseState
  output:
    out : Parsed
  logic:
    let lhs = parse_add(st)
    let lhs_node = parsed_node(lhs)
    let lhs_next = parsed_next(lhs)
    let opcode = peek_op_code(lhs_next)
    let iscmp = if opcode == 1 or (opcode == 4 or (opcode == 5 or (opcode == 6 or (opcode == 19 or opcode == 20)))) then 1 else 0
    out = if iscmp == 1 then cmp_join(JoinState { acc: lhs_node, opcode: opcode, rhs: parse_add(ParseState { cell: advance(Advance { lst: lhs_next, k: 1 }) }) }) else Parsed::Mk { node: lhs_node, next: lhs_next }
  proofs:
    purity:
      reads : [st]
      calls : [parse_add, parsed_node, parsed_next, peek_op_code, cmp_join, advance]
    termination:
      bound : 512


-- ============================================================================
-- and_expr = cmp_expr ('and' cmp_expr)*    left-associative, keyword 'and'.
-- The `and` keyword lexes as Token::Keyword(kw=5) -> kind 205. and_rest peeks
-- the kind (NOT an op code) at fs.pos; on 205 it parses the next cmp_expr
-- (LAZILY, in the then-branch) and folds AstBin(30, acc, rhs) left-associatively
-- via and_join. AST op-code 30 is dedicated to `and` (disjoint from all others).
-- ============================================================================
rule and_join
  @intention: "Fold one 'and' step then continue the fold"
  @source: vexprparse.intent:20
  input:
    js : JoinState
  output:
    out : Parsed
  logic:
    let rhs_node = parsed_node(js.rhs)
    let rhs_next = parsed_next(js.rhs)
    out = and_rest(FoldState { cell: rhs_next, acc: Ast::AstBin { op: 30, lhs: js.acc, rhs: rhs_node } })
  proofs:
    purity:
      reads : [js.acc, js.rhs]
      calls : [parsed_node, parsed_next, and_rest]
    termination:
      bound : 512


rule and_rest
  @intention: "Fold 'and' onto the accumulator, left-associatively"
  @source: vexprparse.intent:20
  input:
    fs : FoldState
  output:
    out : Parsed
  logic:
    let knd = peek_kind(fs.cell)
    let isand = if knd == 205 then 1 else 0
    out = if isand == 1 then and_join(JoinState { acc: fs.acc, opcode: 30, rhs: parse_cmp(ParseState { cell: advance(Advance { lst: fs.cell, k: 1 }) }) }) else Parsed::Mk { node: fs.acc, next: fs.cell }
  proofs:
    purity:
      reads : [fs.cell, fs.acc]
      calls : [peek_kind, and_join, parse_cmp, advance]
    termination:
      bound : 512


rule parse_and
  @intention: "Parse an 'and' expression: a comparison followed by any number of 'and's"
  @source: vexprparse.intent:20
  input:
    st : ParseState
  output:
    out : Parsed
  logic:
    let first = parse_cmp(st)
    let first_node = parsed_node(first)
    let first_next = parsed_next(first)
    out = and_rest(FoldState { cell: first_next, acc: first_node })
  proofs:
    purity:
      reads : [st]
      calls : [parse_cmp, and_rest, parsed_node, parsed_next]
    termination:
      bound : 512


-- ============================================================================
-- or_expr = and_expr ('or' and_expr)*    left-associative, keyword 'or'.
-- The `or` keyword lexes as Token::Keyword(kw=2) -> kind 202. or_rest peeks the
-- kind at fs.pos; on 202 it parses the next and_expr (LAZILY) and folds
-- AstBin(31, acc, rhs) via or_join. AST op-code 31 is dedicated to `or`.
-- parse_or is the TOP of the ladder (the entry point for any sub-expression,
-- including the one inside parentheses).
-- ============================================================================
rule or_join
  @intention: "Fold one 'or' step then continue the fold"
  @source: vexprparse.intent:21
  input:
    js : JoinState
  output:
    out : Parsed
  logic:
    let rhs_node = parsed_node(js.rhs)
    let rhs_next = parsed_next(js.rhs)
    out = or_rest(FoldState { cell: rhs_next, acc: Ast::AstBin { op: 31, lhs: js.acc, rhs: rhs_node } })
  proofs:
    purity:
      reads : [js.acc, js.rhs]
      calls : [parsed_node, parsed_next, or_rest]
    termination:
      bound : 512


rule or_rest
  @intention: "Fold 'or' onto the accumulator, left-associatively"
  @source: vexprparse.intent:21
  input:
    fs : FoldState
  output:
    out : Parsed
  logic:
    let knd = peek_kind(fs.cell)
    let isor = if knd == 202 then 1 else 0
    out = if isor == 1 then or_join(JoinState { acc: fs.acc, opcode: 31, rhs: parse_and(ParseState { cell: advance(Advance { lst: fs.cell, k: 1 }) }) }) else Parsed::Mk { node: fs.acc, next: fs.cell }
  proofs:
    purity:
      reads : [fs.cell, fs.acc]
      calls : [peek_kind, or_join, parse_and, advance]
    termination:
      bound : 512


rule parse_or
  @intention: "Parse the full expression: an 'and' expr followed by any number of 'or's"
  @source: vexprparse.intent:21
  input:
    st : ParseState
  output:
    out : Parsed
  logic:
    let first = parse_and(st)
    let first_node = parsed_node(first)
    let first_next = parsed_next(first)
    out = or_rest(FoldState { cell: first_next, acc: first_node })
  proofs:
    purity:
      reads : [st]
      calls : [parse_and, or_rest, parsed_node, parsed_next]
    termination:
      bound : 512


-- ============================================================================
-- EVALUATOR. Recursive walk over the Ast group, computing the number.
-- AstBin dispatches on the operator code (13=+, 14=-, 15=*, 16=/). Verbose
-- itself has NO operator precedence, so every non-leftmost product in this
-- body is parenthesized — note: that is the LANGUAGE's left-to-right rule, a
-- different level entirely from the precedence this program PARSES.
-- ============================================================================
rule eval_ast
  @intention: "Evaluate an arithmetic AST to a number"
  @source: vexprparse.intent:21
  input:
    e : Ast
  output:
    out : number
  logic:
    -- R6c: eval_ast is now a THIN WRAPPER over eval_ast_env (the Value-valued
    -- evaluator), unwrapping the result via vnum_of. It no longer duplicates the
    -- arithmetic arm set. The empty env (VENil), empty program (RNil) and empty
    -- concept list (CNil) make it byte-identical to the pre-R6c arithmetic evaluator
    -- for variable-free / call-free expressions (an AstVar / AstCall / AstStr / a
    -- variant / a match all resolve to VNum 0 with no env / program / concepts, then
    -- vnum_of extracts 0 — exactly the old stub values). src is "" because eval_ast
    -- carries no source text (its env is empty, so name_eq is never reached).
    out = vnum_of(eval_ast_env(EvalEnvArg { node: e, env: VEnv::VENil, src: "", prog: RuleList::RNil, concepts: ConceptList::CNil }))
  proofs:
    purity:
      reads : [e]
      calls : [vnum_of, eval_ast_env]
    termination:
      bound : 4000


-- ============================================================================
-- STRUCTURAL SIGNATURE (the brick-5 oracle). Unlike bricks 3/4, a variable /
-- call / field node has no numeric value (no environment), so brick 5's parser
-- is validated by the SHAPE of the AST it builds, not by an evaluated number.
--
-- shape_ast walks the tree and returns a signature that counts node kinds:
--
--   10000000 * (#AstStr) + 1000000 * (#AstBool) + 100000 * (#AstIf)
--     + 10000 * (#AstCall) + 1000 * (#AstField) + 100 * (#AstVar)
--     + 10 * (#AstBin) + (#AstNot + #AstNeg)
--
-- The count bands are spaced by powers of ten wide enough that no test input
-- overflows a lower band into a higher one (the deepest test has at most a
-- handful of each kind). AstNum and AstErr contribute 0 — they are not part of
-- the brick-5/7 surface being proven by shape. Each test input's signature is
-- hand-derivable and distinct, so a single number certifies the exact shape.
-- Brick 7 added the two top bands: AstBool (1000000) and AstStr (10000000).
--
-- shape_ast and shape_args are mutually recursive (a call's signature includes
-- its arguments' signatures). Both walk a strictly-shrinking group value at
-- every recursive step (a sub-Ast or the tail ArgList), so they declare the
-- structural termination proof — same posture as eval_ast.
-- ============================================================================
rule shape_args
  @intention: "Sum the structural signatures of every argument in a call-argument list"
  @source: vexprparse.intent:23
  input:
    a : ArgList
  output:
    out : number
  logic:
    out = match a:
      ArgCons(head, tail) => shape_ast(head) + shape_args(tail)
      ArgNil => 0
  proofs:
    purity:
      reads : [a]
      calls : [shape_ast, shape_args]
    termination:
      bound : 4000
      structural : a


rule shape_ast
  @intention: "Structural signature of an AST: a kind-count fingerprint of its shape"
  @source: vexprparse.intent:23
  input:
    e : Ast
  output:
    out : number
  logic:
    out = match e:
      AstNum(value) => 0
      AstBin(op, lhs, rhs) => 10 + shape_ast(lhs) + shape_ast(rhs)
      AstNeg(inner) => 1 + shape_ast(inner)
      AstNot(inner) => 1 + shape_ast(inner)
      AstVar(start, len) => 100
      AstField(base, fstart, flen) => 1000 + shape_ast(base)
      AstCall(callee_start, callee_len, args) => 10000 + shape_args(args)
      -- An AstIf contributes a dedicated top band (100000) plus the signatures of
      -- its three sub-expressions, so a conditional's shape is hand-derivable and
      -- distinct from every other kind. (Brick 6.)
      AstIf(cond, thn, els) => 100000 + shape_ast(cond) + shape_ast(thn) + shape_ast(els)
      -- Brick 7's literals each get a dedicated band ABOVE AstIf's 100000, so a
      -- bool or string node is countable and distinct from every other kind:
      -- AstBool adds 1000000, AstStr adds 10000000. (A bool/string leaf has no
      -- sub-expressions, so neither recurses.)
      AstBool(value) => 1000000
      AstStr(start, len) => 10000000
      AstBytes(start, len) => 10000000000
      AstErr => 0
      -- R3: dedicated bands ABOVE AstStr's 10000000 so a parsed variant / match body
      -- has a hand-derivable fingerprint distinct from the AstErr fingerprint (0).
      -- AstVariant adds 1000000000 plus the signatures of its field values
      -- (shape_vfields); AstMatch adds 100000000 plus the scrutinee's signature and
      -- the sum of every arm body's signature (shape_arms). Recursing into the
      -- sub-ASTs makes nested structure count, exactly like AstIf / AstCall.
      AstVariant(cstart, clen, vstart, vlen, fields) => 1000000000 + shape_vfields(fields)
      AstMatch(scrut, arms) => 100000000 + shape_ast(scrut) + shape_arms(arms)
  proofs:
    purity:
      reads : [e]
      calls : [shape_ast, shape_args, shape_vfields, shape_arms]
    termination:
      bound : 4000
      structural : e


-- shape_vfields (brick R3): sum the structural signatures of every field value in a
-- variant construction's field list. Mirror of shape_args. Walks a strictly-shrinking
-- group value (the tail) at each step, so it declares the structural proof.
rule shape_vfields
  @intention: "Sum the structural signatures of every field value in a variant field list"
  @source: vexprparse.intent:64
  input:
    a : VFieldList
  output:
    out : number
  logic:
    out = match a:
      VFCons(name_start, name_len, val, rest) => shape_ast(val) + shape_vfields(rest)
      VFNil => 0
  proofs:
    purity:
      reads : [a]
      calls : [shape_ast, shape_vfields]
    termination:
      bound : 4000
      structural : a


-- shape_arms (brick R3): sum the structural signatures of every arm BODY in a match's
-- arm list. Mirror of shape_args. The binder list carries no sub-AST, so only the
-- arm body recurses. Structural proof over the shrinking arm-list tail.
rule shape_arms
  @intention: "Sum the structural signatures of every arm body in a match arm list"
  @source: vexprparse.intent:64
  input:
    a : ArmList
  output:
    out : number
  logic:
    out = match a:
      ArmCons(vstart, vlen, binders, body, rest) => shape_ast(body) + shape_arms(rest)
      ArmNil => 0
  proofs:
    purity:
      reads : [a]
      calls : [shape_ast, shape_arms]
    termination:
      bound : 4000
      structural : a


-- shape: the brick-5 driver. Tokenize the source, parse the full expression
-- from index 0, and return the STRUCTURAL signature of the resulting AST. This
-- is the observable that proves f(x, y) builds an AstCall with a 2-element
-- ArgList and a.b.c builds nested AstField — by a number we can predict by hand.
rule shape
  @intention: "Tokenize, parse, and return the AST's structural signature"
  @source: vexprparse.intent:23
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = tokenize(ScanState { source: s.source, pos: 0 })
    let parsed = parse_or(ParseState { cell: toks })
    let root = parsed_node(parsed)
    out = shape_ast(root)
  proofs:
    purity:
      reads : [s.source]
      calls : [tokenize, parse_or, shape_ast, parsed_node]
    termination:
      bound : 256


-- ============================================================================
-- DRIVER (observable, end-to-end): text -> tokens -> AST -> value.
-- Tokenize the source, parse an add_expr from index 0, evaluate the AST.
-- This is the money shot: eval_expr("2+3*4") must be 14 (precedence!), NOT 20.
-- Entry rule takes a TEXT input (ScanState), so argv can supply it — the
-- group-field parse rules are reached internally, never as _start's input.
-- ============================================================================
rule eval_expr
  @intention: "Tokenize, parse with precedence, and evaluate an arithmetic expression"
  @source: vexprparse.intent:22
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = tokenize(ScanState { source: s.source, pos: 0 })
    let parsed = parse_or(ParseState { cell: toks })
    let root = parsed_node(parsed)
    out = eval_ast(root)
  proofs:
    purity:
      reads : [s.source]
      calls : [tokenize, parse_or, eval_ast, parsed_node]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 8a VALIDATION DRIVERS (structural — multi-line eval is not meaningful
-- yet, so these certify the token STREAM shape, like brick 7's shape_ast).
--
-- count_cells walks the materialized TokenList and counts every cons cell —
-- including the Newline cells brick 8a now emits and the trailing Eof cell. The
-- count is a single number predictable by hand for each multi-line source, so
-- it certifies "the tokenizer traversed every line and emitted a Newline at each
-- line boundary" without needing to evaluate anything.
--
-- Trailing-Eof convention (stated): tokenize always appends ONE Cons{Eof, Nil}
-- at end of source (brick 2's convention, unchanged). So an N-real-token source
-- with K newlines produces N + K + 1 cells: N lexeme cells + K Newline cells +
-- 1 trailing Eof cell. Blank lines contribute an extra Newline cell each (8a
-- emits newlines faithfully; collapsing blanks is brick 8b).
-- ============================================================================

-- 1 iff the token IS a Newline, structurally (brick 8a). Mirrors tok_is_str /
-- tok_is_num: a magnitude test on tok_kind (== 600) would misread a Num literal
-- whose value is 300 (kind 600), so the position check uses this structural test.
rule tok_is_newline
  @intention: "1 if the token is a line-boundary Newline, 0 otherwise (value-independent)"
  @source: vexprparse.intent:26
  input:
    t : Token
  output:
    out : number
  logic:
    out = match t:
      Ident(start, len) => 0
      Keyword(start, len, kw) => 0
      Num(value, len) => 0
      Op(code, len) => 0
      Str(start, len) => 0
      ByteLit(start, len) => 0
      Newline(pos) => 1
      Indent => 0
      Dedent => 0
      IndentErr(pos) => 0
      Eof => 0
  proofs:
    purity:
      reads : [t]
      calls : []
    termination:
      bound : 16


-- Count every cons cell of a token list (lexeme cells + Newline cells + the
-- trailing Eof cell). Walks a strictly-shrinking group value (the tail) at each
-- step, so it declares the structural termination proof — same posture as
-- shape_ast / eval_ast.
rule count_cells
  @intention: "Number of cons cells in a token list (every token incl. Newline and trailing Eof)"
  @source: vexprparse.intent:26
  input:
    lst : TokenList
  output:
    out : number
  logic:
    out = match lst:
      Cons(head, tail) => 1 + count_cells(tail)
      Nil => 0
  proofs:
    purity:
      reads : [lst]
      calls : [count_cells]
    termination:
      bound : 4000
      structural : lst


-- An entry concept carrying a source text plus a token index, so a single-input
-- entry rule can tokenize then peek the kind of the token at that index.
concept KindAtState
  @intention: "Source text plus a token index to peek the kind of"
  @source: vexprparse.intent:26
  fields:
    source : text [..256]
    idx : number [0, 4000000]


-- Entry driver: tokenize the source (from argv) and return the KIND code of the
-- token at index `arg.idx` (Eof=0, Ident=100, Keyword=200+kw, Num=300+value,
-- Op=400+code, Str=500, Newline=600). Confirms the Newline appears at the right
-- position in the stream: kind_at("a\nb", 1) = 600. Native-only for newline
-- sources (same JSON \n limit as count_cells_src).
rule kind_at
  @intention: "Tokenize a source and return the kind code of the token at the given index"
  @source: vexprparse.intent:26
  input:
    arg : KindAtState
  output:
    out : number
  logic:
    let toks = tokenize(ScanState { source: arg.source, pos: 0 })
    out = peek_kind(advance(Advance { lst: toks, k: arg.idx }))
  proofs:
    purity:
      reads : [arg.source, arg.idx]
      calls : [tokenize, peek_kind, advance]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 8b: INDENT / DEDENT via a column stack (design (a), docs/indent-dedent-
-- design.md). Turns the flat-plus-Newline stream of brick 8a into a block-
-- structured stream by weaving Indent / Dedent tokens at line starts, driven by
-- a column stack (ColStack) threaded alongside the output token list through a
-- line-by-line driver recursion. Mirrors src/lexer.rs::handle_line_start +
-- tokenize one-to-one. The two errors the reference returns as a LexError
-- (tab-in-indent, inconsistent indentation) become Token::IndentErr in the
-- stream, because a Verbose rule is TOTAL (cannot abort mid-evaluation).
--
-- Faithful simplifications vs the reference (documented, not silent):
--  * BLANK lines (whitespace only, to the newline or EOF) are SKIPPED entirely
--    — no Indent/Dedent and no Newline. They carry no block structure; the
--    reference's main loop would emit a Newline for them but suppresses it after
--    a prior Newline. Skipping keeps the observable hand-derivable (test 7).
--  * The TAB sentinel (line_width returns 99999 on a tab in leading whitespace)
--    is well above any real width (source is <= 256 bytes), so it never aliases
--    a genuine indentation level.
-- ============================================================================

-- line_width: from a line-start position `pos`, count consecutive leading
-- spaces (byte 32). If a TAB (byte 9) appears in the leading whitespace, return
-- the sentinel 99999 (> any real width, since source <= 256) so the driver can
-- turn it into a Token::IndentErr — the faithful translation of src/lexer.rs's
-- tab rejection (:193-199). byte_at is fail-closed OOB, so at end-of-source the
-- count so far is returned. Termination: pos strictly increases toward len.
rule line_width
  @intention: "Count leading spaces at a line start; 99999 sentinel if a tab is seen"
  @source: vexprparse.intent:27
  input:
    s : ScanState
  output:
    out : number
  logic:
    let len = length(s.source)
    out = if s.pos >= len then 0 else if byte_at(s.source, s.pos) == 9 then 99999 else if byte_at(s.source, s.pos) == 32 then 1 + line_width(ScanState { source: s.source, pos: s.pos + 1 }) else 0
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : [line_width]
    termination:
      bound : 256
      increasing : pos


-- next_line_start: from anywhere on a line, scan forward to the byte AFTER the
-- next newline (byte 10), or to length(source) at end-of-source. This is how the
-- driver steps from one line to the next — it replaces the brick-2 scanner's
-- "a newline stops tokenize" behaviour. Termination: pos strictly increases.
rule next_line_start
  @intention: "Index just past the next newline, or end-of-source"
  @source: vexprparse.intent:27
  input:
    s : ScanState
  output:
    out : number
  logic:
    let len = length(s.source)
    out = if s.pos >= len then len else if byte_at(s.source, s.pos) == 10 then s.pos + 1 else next_line_start(ScanState { source: s.source, pos: s.pos + 1 })
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : [next_line_start]
    termination:
      bound : 256
      increasing : pos


-- top_width: the head width of the column stack (0 for Empty, the column-0
-- sentinel). Trivial match — no recursion.
rule top_width
  @intention: "Head width of the column stack (0 for the Empty sentinel)"
  @source: vexprparse.intent:27
  input:
    cs : ColStack
  output:
    out : number
  logic:
    out = match cs:
      Push(width, rest) => width
      Empty => 0
  proofs:
    purity:
      reads : [cs]
      calls : []
    termination:
      bound : 16


-- A multi-DEDENT pop argument: the column stack and the target width.
concept PopArg
  @intention: "Column stack + the line's width to pop down to"
  @source: vexprparse.intent:27
  fields:
    stk : ColStack
    width : number [0, 4000000]


-- dedents_to: the multi-DEDENT recursion (src/lexer.rs:223-236). Pop every level
-- whose width is STRICTLY GREATER than the target `width`, counting one Dedent
-- per pop. Stops when the top width is <= the target (or the stack is the Empty
-- sentinel). Returns the popped stack, the pop count, AND an inconsistency flag:
-- err = 1 iff after popping the new top width does NOT exactly equal the target
-- (the line's width matches no enclosing block). The sentinel Empty has width 0,
-- so a target of 0 pops everything and lands exactly (err = 0). Termination: the
-- ColStack strictly shrinks (one Push removed per recursive step), so it is a
-- structural recursion on `stk`.
rule dedents_to
  @intention: "Pop the column stack down to a width, returning new stack + dedent count + inconsistency flag"
  @source: vexprparse.intent:27
  input:
    pa : PopArg
  output:
    out : DedentResult
  logic:
    out = match pa.stk:
      Push(width, rest) => if width > pa.width then dedent_bump(dedents_to(PopArg { stk: rest, width: pa.width })) else (if width == pa.width then DedentResult::MkDed { popped: pa.stk, count: 0, err: 0 } else DedentResult::MkDed { popped: pa.stk, count: 0, err: 1 })
      Empty => if pa.width == 0 then DedentResult::MkDed { popped: ColStack::Empty, count: 0, err: 0 } else DedentResult::MkDed { popped: ColStack::Empty, count: 0, err: 1 }
  proofs:
    purity:
      reads : [pa.stk, pa.width]
      calls : [dedents_to, dedent_bump]
    termination:
      bound : 4096


-- dedent_bump: add one to the pop count of a DedentResult, carrying the popped
-- stack and the err flag through unchanged. Used by dedents_to to fold "+1
-- Dedent" onto the result of the deeper pop. A trivial wrapper so dedents_to's
-- recursive arm stays a single constructor expression.
rule dedent_bump
  @intention: "Increment a DedentResult's pop count by one (stack + err unchanged)"
  @source: vexprparse.intent:27
  input:
    dr : DedentResult
  output:
    out : DedentResult
  logic:
    out = match dr:
      MkDed(popped, count, err) => DedentResult::MkDed { popped: popped, count: count + 1, err: err }
  proofs:
    purity:
      reads : [dr]
      calls : []
    termination:
      bound : 16


-- Accessors for a DedentResult. A block-form `match` is only legal in the FINAL
-- `out = match ...` position (not as a `let` RHS, and a sum-typed value cannot be
-- field-accessed with `.field`), so destructuring a DedentResult is factored into
-- these three tiny rules — exactly the parsed_node / parsed_next pattern.
rule dr_popped
  @intention: "The popped column stack from a DedentResult"
  @source: vexprparse.intent:27
  input:
    dr : DedentResult
  output:
    out : ColStack
  logic:
    out = match dr:
      MkDed(popped, count, err) => popped
  proofs:
    purity:
      reads : [dr]
      calls : []
    termination:
      bound : 16


rule dr_count
  @intention: "The dedent count from a DedentResult"
  @source: vexprparse.intent:27
  input:
    dr : DedentResult
  output:
    out : number
  logic:
    out = match dr:
      MkDed(popped, count, err) => count
  proofs:
    purity:
      reads : [dr]
      calls : []
    termination:
      bound : 16


rule dr_err
  @intention: "The inconsistency flag from a DedentResult"
  @source: vexprparse.intent:27
  input:
    dr : DedentResult
  output:
    out : number
  logic:
    out = match dr:
      MkDed(popped, count, err) => err
  proofs:
    purity:
      reads : [dr]
      calls : []
    termination:
      bound : 16


-- A cons-dedents argument: how many Dedent tokens to prepend, and the tail list
-- they prepend onto (the already-built continuation).
concept ConsDedArg
  @intention: "A dedent count plus the tail list to prepend the Dedent tokens onto"
  @source: vexprparse.intent:27
  fields:
    count : number [0, 4000000]
    tail : TokenList


-- cons_dedents: prepend `count` Token::Dedent cells onto the front of `tail`.
-- The tail is the already-computed continuation (the rest of the stream); each
-- recursive step conses ONE Dedent and decrements the count, so the result is
-- count Dedents followed by tail. Termination: count strictly decreases.
rule cons_dedents
  @intention: "Prepend `count` Dedent tokens onto a tail token list"
  @source: vexprparse.intent:27
  input:
    cda : ConsDedArg
  output:
    out : TokenList
  logic:
    out = if cda.count <= 0 then cda.tail else TokenList::Cons { head: Token::Dedent, tail: cons_dedents(ConsDedArg { count: cda.count - 1, tail: cda.tail }) }
  proofs:
    purity:
      reads : [cda.count, cda.tail]
      calls : [cons_dedents]
    termination:
      bound : 4096
      decreasing : count


-- tokenize_line: tokenize ONE line's lexemes, starting at `pos`, stopping at (and
-- NOT consuming) the line's newline (byte 10) or end-of-source. Returns a
-- Nil-terminated list of the line's lexeme tokens — no Newline, no Eof. This is
-- brick 2's `tokenize` bounded to a single line: it conses next_token / advances
-- by token_end exactly as `tokenize` does, but the stop condition is "reached a
-- newline or end-of-source" instead of "reached end-of-source". A Newline token
-- is never produced here (the driver conses the line's Newline itself); if the
-- next lexeme would be a Newline we stop. Termination: pos strictly advances by
-- at least one byte each step (endp > p), bounded by source length.
rule tokenize_line
  @intention: "Tokenize one line's lexemes up to (not including) its newline; Nil-terminated"
  @source: vexprparse.intent:27
  input:
    s : ScanState
  output:
    out : TokenList
  logic:
    let len = length(s.source)
    let p = skip_spaces(s)
    let endp = token_end(s)
    let atnl = if p >= len then 1 else if byte_at(s.source, p) == 10 then 1 else 0
    out = if atnl == 1 then TokenList::Nil else if endp <= p then TokenList::Nil else TokenList::Cons { head: next_token(s), tail: tokenize_line(ScanState { source: s.source, pos: endp }) }
  proofs:
    purity:
      reads : [s.source, s]
      calls : [skip_spaces, token_end, next_token, tokenize_line]
    termination:
      bound : 256


-- An append argument: a front list and a back list to append onto it.
concept AppendArg
  @intention: "A front token list and a back token list to append onto its end"
  @source: vexprparse.intent:27
  fields:
    front : TokenList
    back : TokenList


-- append_toks: append `back` onto the end of `front`, returning front ++ back.
-- Walks `front` to its Nil and splices `back` there. Used by the driver to put a
-- line's lexeme list (front) in front of the continuation (back = Newline + the
-- rest of the stream). Termination: structural recursion on `front`.
rule append_toks
  @intention: "Append the back token list onto the end of the front token list"
  @source: vexprparse.intent:27
  input:
    aa : AppendArg
  output:
    out : TokenList
  logic:
    out = match aa.front:
      Cons(head, tail) => TokenList::Cons { head: head, tail: append_toks(AppendArg { front: tail, back: aa.back }) }
      Nil => aa.back
  proofs:
    purity:
      reads : [aa.front, aa.back]
      calls : [append_toks]
    termination:
      bound : 65535


-- The line-driver state: the source text, the column stack, and the current
-- byte position (always a LINE START by invariant). Two group-concept fields
-- (ColStack, and the output is built as the return value so it is NOT a field —
-- the driver returns a TokenList and threads the stack forward). Note: unlike
-- the design note's first sketch, the output list is the RETURN value (built
-- front-to-back, like brick 2's tokenize), so the state carries only ONE group
-- field (the stack) plus the text and position. This still exercises the
-- text + group-field recursive ABI (text input in a recursive callable, PR #52,
-- composed with a group-concept field).
concept LineState
  @intention: "Line driver state: source text + column stack + line-start position"
  @source: vexprparse.intent:27
  fields:
    src : text [..256]
    stack : ColStack
    pos : number [0, 4000000]


-- tokenize_indent: THE line driver. Processes the source line by line from a
-- line-start `pos`, threading the column stack, and returns the full block-
-- structured token stream (Indent/Dedent/Newline woven in, trailing Eof).
--
-- At each line start:
--  * EOF (pos >= len): flush a Dedent per still-open level (dedents_to to width
--    0 pops every Push), then cons the trailing Eof. This is src/lexer.rs's EOF
--    flush (:176-179).
--  * TAB in indent (width == 99999): cons a Token::IndentErr, then skip the rest
--    of this line and continue at the next line with the stack UNCHANGED (the
--    error token is the hard-stop signal for the downstream parser).
--  * BLANK line (content start at newline or EOF): skip entirely — recurse to the
--    next line with no structural token (documented simplification).
--  * width > top: ONE Indent, push width, then the line's lexemes + Newline +
--    recurse with the deeper stack.
--  * width < top: dedents_to pops to width; cons that many Dedents; if the pop
--    landed inconsistently (err == 1) weave a Token::IndentErr; then the line's
--    lexemes + Newline + recurse with the popped stack.
--  * width == top: no structural token; the line's lexemes + Newline + recurse.
--
-- LAZINESS: every recursive call to tokenize_indent sits inside an if-branch (or
-- as a constructor/call arg reached only within a branch), NEVER in a `let`, so
-- the forward recursion fires only along the taken path and pos strictly advances
-- to next_line_start each step (the eager-let trap, vexprparse.verbose:1198-1210).
-- Termination: bound-only + the mandatory recursion breadcrumb (a line scanner
-- has no structural/decreasing field that fits — the backstop is the finite
-- source length: pos advances to next_line_start, strictly greater, each step).
rule tokenize_indent
  @intention: "Line-by-line driver: weave Indent/Dedent/Newline into the token stream"
  @source: vexprparse.intent:27
  input:
    ls : LineState
  output:
    out : TokenList
  logic:
    let len = length(ls.src)
    let width = line_width(ScanState { source: ls.src, pos: ls.pos })
    let cstart = ls.pos + width
    let nls = next_line_start(ScanState { source: ls.src, pos: ls.pos })
    let tw = top_width(ls.stack)
    let istab = if width == 99999 then 1 else 0
    let c0b = if cstart >= len then 0 else byte_at(ls.src, cstart)
    let c1b = if cstart + 1 >= len then 0 else byte_at(ls.src, cstart + 1)
    let iscomment = if c0b == 45 then (if c1b == 45 then 1 else 0) else 0
    let isattr = if c0b == 64 then 1 else 0
    let isblank = if istab == 1 then 0 else if cstart >= len then 1 else if byte_at(ls.src, cstart) == 10 then 1 else if iscomment == 1 then 1 else if isattr == 1 then 1 else 0
    let dr = dedents_to(PopArg { stk: ls.stack, width: width })
    let dr_c = dr_count(dr)
    let dr_e = dr_err(dr)
    let dr_p = dr_popped(dr)
    let flush_c = dr_count(dedents_to(PopArg { stk: ls.stack, width: 0 }))
    out = if ls.pos >= len then cons_dedents(ConsDedArg { count: flush_c, tail: TokenList::Cons { head: Token::Eof, tail: TokenList::Nil } }) else if istab == 1 then TokenList::Cons { head: Token::IndentErr { pos: ls.pos }, tail: tokenize_indent(LineState { src: ls.src, stack: ls.stack, pos: nls }) } else if isblank == 1 then tokenize_indent(LineState { src: ls.src, stack: ls.stack, pos: nls }) else if width > tw then TokenList::Cons { head: Token::Indent, tail: append_toks(AppendArg { front: tokenize_line(ScanState { source: ls.src, pos: cstart }), back: TokenList::Cons { head: Token::Newline { pos: nls }, tail: tokenize_indent(LineState { src: ls.src, stack: ColStack::Push { width: width, rest: ls.stack }, pos: nls }) } }) } else if width < tw then cons_dedents(ConsDedArg { count: dr_c, tail: (if dr_e == 1 then TokenList::Cons { head: Token::IndentErr { pos: cstart }, tail: append_toks(AppendArg { front: tokenize_line(ScanState { source: ls.src, pos: cstart }), back: TokenList::Cons { head: Token::Newline { pos: nls }, tail: tokenize_indent(LineState { src: ls.src, stack: dr_p, pos: nls }) } }) } else append_toks(AppendArg { front: tokenize_line(ScanState { source: ls.src, pos: cstart }), back: TokenList::Cons { head: Token::Newline { pos: nls }, tail: tokenize_indent(LineState { src: ls.src, stack: dr_p, pos: nls }) } })) }) else append_toks(AppendArg { front: tokenize_line(ScanState { source: ls.src, pos: cstart }), back: TokenList::Cons { head: Token::Newline { pos: nls }, tail: tokenize_indent(LineState { src: ls.src, stack: ls.stack, pos: nls }) } })
  proofs:
    purity:
      reads : [ls.src, ls.stack, ls.pos]
      calls : [line_width, next_line_start, top_width, dedents_to, dr_count, dr_err, dr_popped, cons_dedents, tokenize_line, append_toks, tokenize_indent]
    termination:
      bound : 65535


-- shape_toks: the brick-8b structural observable. Walks a block-structured token
-- list and returns a kind-count fingerprint with a dedicated band per structural
-- token kind, so each test input's signature is a single number predictable by
-- hand (the shape_ast technique, brick 7):
--
--   1000000 * (#IndentErr) + 10000 * (#Newline) + 100 * (#Dedent) + (#Indent)
--
-- The bands are spaced wide enough that no test input overflows a lower band
-- (the deepest test has a handful of each). Lexeme tokens (Ident/Keyword/Num/
-- Op/Str) and Eof contribute 0 — they are brick 2/8a's surface, not 8b's.
-- Structural recursion on the tail.
rule shape_toks
  @intention: "Structural signature of a token list: a kind-count fingerprint of its block tokens"
  @source: vexprparse.intent:27
  input:
    lst : TokenList
  output:
    out : number
  logic:
    out = match lst:
      Cons(head, tail) => tok_band(head) + shape_toks(tail)
      Nil => 0
  proofs:
    purity:
      reads : [lst]
      calls : [tok_band, shape_toks]
    termination:
      bound : 65535
      structural : lst


-- tok_band: the per-token contribution to shape_toks. Indent=1, Dedent=100,
-- Newline=10000, IndentErr=1000000; every other token (lexemes + Eof) = 0.
rule tok_band
  @intention: "shape_toks band contribution of one token (block tokens only)"
  @source: vexprparse.intent:27
  input:
    t : Token
  output:
    out : number
  logic:
    out = match t:
      Ident(start, len) => 0
      Keyword(start, len, kw) => 0
      Num(value, len) => 0
      Op(code, len) => 0
      Str(start, len) => 0
      ByteLit(start, len) => 0
      Newline(pos) => 10000
      Indent => 1
      Dedent => 100
      IndentErr(pos) => 1000000
      Eof => 0
  proofs:
    purity:
      reads : [t]
      calls : []
    termination:
      bound : 16


-- begin_tokenize: a thin entry into the line driver that builds the initial
-- empty column stack INSIDE a callable body (the final-position call), so the
-- ColStack::Empty VariantConstruct sees the arena context. (A group-variant
-- construction in a `let` RHS at an entry rule's frame has no arena context in
-- the native emitter — the let-eval path runs without it — so the construction
-- is pushed down into this callable, whose body emit does thread the arena. The
-- entry drivers below therefore call begin_tokenize instead of constructing
-- ColStack::Empty themselves.) Returns the full block-structured token stream.
rule begin_tokenize
  @intention: "Start the line driver from an empty column stack at line 0"
  @source: vexprparse.intent:27
  input:
    s : ScanState
  output:
    out : TokenList
  logic:
    out = tokenize_indent(LineState { src: s.source, stack: ColStack::Empty, pos: 0 })
  proofs:
    purity:
      reads : [s.source]
      calls : [tokenize_indent]
    termination:
      bound : 256


-- An entry concept for the brick-8b drivers: a source text (argv) to tokenize
-- with indentation. (pos always starts at 0 — the file's first line start.)
concept IndentSrc
  @intention: "Source text for the block-structured (INDENT/DEDENT) tokenizer"
  @source: vexprparse.intent:27
  fields:
    source : text [..256]


-- shape_indent_src: the brick-8b money-shot observable. Tokenize the source with
-- indentation (tokenize_indent from line start 0, empty column stack) and return
-- the structural signature of the resulting block-structured stream. A single
-- number, hand-derivable per input, certifies the exact Indent/Dedent/Newline/
-- IndentErr shape. NATIVE-ONLY for newline-bearing sources (the interpreter's
-- JSON reader does not decode \n into a real byte 10 — see count_cells_src).
rule shape_indent_src
  @intention: "Tokenize a source with INDENT/DEDENT and return its block-structure signature"
  @source: vexprparse.intent:27
  input:
    a : IndentSrc
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: a.source, pos: 0 })
    out = shape_toks(toks)
  proofs:
    purity:
      reads : [a.source]
      calls : [begin_tokenize, shape_toks]
    termination:
      bound : 256


-- kind_at_indent: like kind_at (brick 8a) but over the block-structured stream.
-- Tokenize with indentation and return the KIND code of the token at index
-- `arg.idx` (… Newline=600, Indent=700, Dedent=800, IndentErr=900). Confirms a
-- structural token appears at the expected position. Native-only for newline
-- sources. Reuses KindAtState (source + idx).
rule kind_at_indent
  @intention: "Tokenize a source with INDENT/DEDENT and return the kind of the token at an index"
  @source: vexprparse.intent:27
  input:
    arg : KindAtState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: arg.source, pos: 0 })
    out = peek_kind(advance(Advance { lst: toks, k: arg.idx }))
  proofs:
    purity:
      reads : [arg.source, arg.idx]
      calls : [begin_tokenize, peek_kind, advance]
    termination:
      bound : 256


-- count_cells_indent: count every cons cell of the block-structured stream
-- (lexemes + Indent + Dedent + Newline + IndentErr + trailing Eof). A coarser
-- companion to shape_indent_src. Native-only for newline sources.
rule count_cells_indent
  @intention: "Tokenize a source with INDENT/DEDENT and count its token cons cells"
  @source: vexprparse.intent:27
  input:
    a : IndentSrc
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: a.source, pos: 0 })
    out = count_cells(toks)
  proofs:
    purity:
      reads : [a.source]
      calls : [begin_tokenize, count_cells]
    termination:
      bound : 256


-- 1 iff the token IS an IndentErr, structurally (mirror of tok_is_num). The
-- lexer's fail-closed error token now has TWO producers — a tab in leading
-- whitespace (line_width's 99999 sentinel) and a raw newline inside a string
-- literal (str_content_len's 99998 sentinel via next_token) — and this test
-- is how a driver counts them without decoding the kind band arithmetic.
rule tok_is_err
  @intention: "1 if the token is an IndentErr (lex error token), 0 otherwise"
  @source: vexprparse.intent:1741
  input:
    t : Token
  output:
    out : number
  logic:
    out = match t:
      Ident(start, len) => 0
      Keyword(start, len, kw) => 0
      Num(value, len) => 0
      Op(code, len) => 0
      Str(start, len) => 0
      ByteLit(start, len) => 0
      Newline(pos) => 0
      Indent => 0
      Dedent => 0
      IndentErr(pos) => 1
      Eof => 0
  proofs:
    purity:
      reads : [t]
      calls : []
    termination:
      bound : 16


-- count_errs: count the IndentErr tokens in a token list (mirror of shape_toks'
-- walk, but a plain count instead of a banded fingerprint — no band overflow
-- concern, the count IS the observable). Structural recursion on the tail.
rule count_errs
  @intention: "Number of IndentErr (lex error) tokens in a token list"
  @source: vexprparse.intent:1741
  input:
    lst : TokenList
  output:
    out : number
  logic:
    out = match lst:
      Cons(head, tail) => tok_is_err(head) + count_errs(tail)
      Nil => 0
  proofs:
    purity:
      reads : [lst]
      calls : [tok_is_err, count_errs]
    termination:
      bound : 65535
      structural : lst


-- count_lex_errors: the LOUD gate. Tokenize the source with indentation (same
-- entry as count_rules) and count the kind-900 error tokens in the stream. A
-- source that lexes cleanly returns 0; a tab-indented line or a raw newline
-- inside a string literal each contribute >= 1. The driver a harness runs
-- BEFORE trusting count_rules — a nonzero count means the token stream carries
-- error tokens and downstream structural counts describe a damaged stream.
-- NATIVE-ONLY for newline-bearing sources (same JSON-reader limit as
-- count_rules). Takes a ScanState: source is argv arg 1, pos is argv arg 2
-- (always 0).
rule count_lex_errors
  @intention: "Tokenize a program with INDENT/DEDENT and count its lex error tokens"
  @source: vexprparse.intent:1741
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    out = count_errs(toks)
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, count_errs]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 9: parse a statement BLOCK (let-bindings + a final out value). The first
-- PROGRAM-grammar parse that consumes the block-structured tokens (Indent /
-- Dedent / Newline) brick 8b weaves in. The grammar mirrors src/parser.rs's
-- logic-block shape:
--
--   <block>  = Indent stmt_seq Dedent
--   stmt_seq = (let_stmt Newline)* out_stmt Newline?
--   let_stmt = 'let' IDENT '=' expr
--   out_stmt = IDENT '=' expr          (conventionally `out = expr`)
--
-- BLOCK FRAMING (documented invariant). The brick-9 test sources are the block
-- BODY lines, written at COLUMN 0 (no leading indentation). begin_tokenize then
-- produces a stream of the shape `[lexemes Newline]* Eof` with NO Indent/Dedent
-- (every line sits at width 0 == the column-0 sentinel top, so the line driver
-- weaves neither). parse_stmts is nonetheless written to be framing-AGNOSTIC: at
-- each step it first SKIPS any leading Newline / Indent tokens (skip_seps), so a
-- genuinely-indented block (a leading Indent, statements separated by Newline,
-- closed by a Dedent) parses identically — the leading Indent is skipped, each
-- statement's trailing Newline is skipped before the next, and a Dedent or Eof
-- ends the binding scan exactly like the column-0 Eof does. The parser STOPS the
-- binding sweep at a Dedent (800) or Eof (0): in the column-0 framing the final
-- out-statement is followed by Newline then Eof, so after the out value parse the
-- block is complete.
--
-- The let-vs-out distinction is purely the leading token of the (sep-skipped)
-- line: kind 204 (the `let` keyword, kw=4) => a let_stmt; otherwise a bare IDENT
-- (kind 100) followed by `=` (op 18) => the out_stmt. Each statement's `=` is the
-- op-code-18 token; each RHS is a full parse_or expression. parse_or already
-- stops at a Newline (kind 600 is not an operator at any precedence level), so an
-- expression never bleeds across a line boundary.
--
-- RECURSION / LAZINESS. parse_stmts is self-recursive THROUGH a continuation
-- (stmt_let_join), exactly like the expression fold rules (add_rest <-> add_join).
-- The eager-let trap (vexprparse.verbose: the parse-fold comment) applies: the
-- recursive descent into the next statement must be GUARDED, so it sits inside the
-- let-branch's continuation, never in a bare `let`. parse_stmts only ever parses
-- the CURRENT statement eagerly; the tail recursion is reached only along the
-- let-branch, via stmt_let_join, after the value's `next` index is known. Both
-- live in the brick-9 parse cycle, so their TokenList / Parsed group-field inputs
-- compile natively (the group-field recursive ABI).
-- ============================================================================

-- Accessors for a Block (a match-block is only legal in final position, so
-- destructuring is factored into tiny rules, like parsed_node / parsed_next).
rule block_binds
  @intention: "The binding list of a parsed block"
  @source: vexprparse.intent:28
  input:
    b : Block
  output:
    out : Binding
  logic:
    out = match b:
      MkBlock(binds, result) => binds
  proofs:
    purity:
      reads : [b]
      calls : []
    termination:
      bound : 16


rule block_result
  @intention: "The final out-expression of a parsed block"
  @source: vexprparse.intent:28
  input:
    b : Block
  output:
    out : Ast
  logic:
    out = match b:
      MkBlock(binds, result) => result
  proofs:
    purity:
      reads : [b]
      calls : []
    termination:
      bound : 16


-- Accessors for a ParsedBlock parse result.
rule pb_block
  @intention: "The Block from a block parse result"
  @source: vexprparse.intent:28
  input:
    p : ParsedBlock
  output:
    out : Block
  logic:
    out = match p:
      MkPB(block, next) => block
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


rule pb_next
  @intention: "The token index just past a block parse result"
  @source: vexprparse.intent:28
  input:
    p : ParsedBlock
  output:
    out : TokenList
  logic:
    out = match p:
      MkPB(block, next) => next
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


-- skip_seps: advance past any leading separator tokens (Newline kind 600 OR
-- Indent kind 700) starting at `st.pos`, returning the index of the first
-- non-separator token. Stops at a Dedent (800), Eof (0), or any lexeme. Used at
-- the head of each statement so parse_stmts dispatches on the real leading token
-- regardless of the framing (column-0: skip the inter-statement Newline; indented
-- block: skip the leading Indent too). Recursion advances `pos` strictly toward
-- the finite end of the token list; no structural/decreasing FIELD fits a forward
-- index scan, so it carries the bound + the mandatory recursion breadcrumb (the
-- backstop is the finite token-list length, bounded by max_nodes).
rule skip_seps
  @intention: "The cell at the first non-separator token at/after the cursor (skips Newline/Indent)"
  @source: vexprparse.intent:28
  input:
    st : ParseState
  output:
    out : TokenList
  logic:
    let knd = peek_kind(st.cell)
    let issep = if knd == 600 then 1 else if knd == 700 then 1 else 0
    out = if issep == 1 then skip_seps(ParseState { cell: advance(Advance { lst: st.cell, k: 1 }) }) else st.cell
  proofs:
    purity:
      reads : [st.cell]
      calls : [peek_kind, skip_seps, advance]
    termination:
      bound : 512


-- stmt_let_join: the continuation that threads a parsed let-value's `next` index
-- into the recursive scan of the REST of the block, then conses the binding onto
-- the front of the rest's binding list. Called ONLY from parse_stmts's let-branch
-- (so the recursion stays guarded, never eager). It:
--   * extracts the value node + next index from the already-parsed RHS (jl.value),
--   * recurses parse_stmts at that next index (which re-skips the trailing
--     Newline before the next statement),
--   * conses BCons(name span, value, rest.binds) and keeps rest.result + rest.next.
-- In the brick-9 parse cycle, so its Parsed / TokenList group-field inputs compile
-- natively.
rule stmt_let_join
  @intention: "Cons a parsed let-binding onto the recursively-parsed rest of the block"
  @source: vexprparse.intent:28
  input:
    jl : LetJoinState
  output:
    out : ParsedBlock
  logic:
    let vnode = parsed_node(jl.value)
    let vnext = parsed_next(jl.value)
    let rest = parse_stmts(ParseState { cell: vnext })
    let rblock = pb_block(rest)
    let rbinds = block_binds(rblock)
    let rresult = block_result(rblock)
    let rnext = pb_next(rest)
    out = ParsedBlock::MkPB { block: Block::MkBlock { binds: Binding::BCons { name_start: jl.name_start, name_len: jl.name_len, value: vnode, rest: rbinds }, result: rresult }, next: rnext }
  proofs:
    purity:
      reads : [jl.name_start, jl.name_len, jl.value]
      calls : [parsed_node, parsed_next, parse_stmts, pb_block, block_binds, block_result, pb_next]
    termination:
      bound : 512


-- parse_stmts: parse a statement sequence starting at st.pos. Skips leading
-- separators, then:
--   * if the leading token is `let` (kind 204): it is a let_stmt. The bound name
--     is the IDENT at headp+1 (its span via peek_start / peek_len); the `=` is at
--     headp+2 (op 18, not re-checked here — the grammar is fixed); the RHS is a
--     full parse_or from headp+3. The RHS parse is handed to stmt_let_join, which
--     recurses on the rest and conses this binding. The recursion is reached ONLY
--     on this branch, keeping it guarded (the eager-let discipline).
--   * otherwise (a bare IDENT `=` expr, the out_stmt): the RHS is a full parse_or
--     from headp+2 (IDENT at headp, `=` at headp+1). The block terminates here:
--     return MkBlock(BNil, value) with next = the value's end index. A Dedent or
--     Eof leading token would also land here (peek_kind != 204) and produce an
--     empty-result block — but in the brick-9 column-0 framing the out_stmt always
--     precedes the Eof, so this is the normal terminator.
-- Self-recursive THROUGH stmt_let_join; both in the parse cycle. Bound + recursion
-- breadcrumb (the backstop: each step's RHS parse consumes >=1 token, and the
-- finite token list is bounded by max_nodes).
rule parse_stmts
  @intention: "Parse a (let_stmt Newline)* out_stmt sequence into a Block + end index"
  @source: vexprparse.intent:28
  input:
    st : ParseState
  output:
    out : ParsedBlock
  logic:
    let headp = skip_seps(ParseState { cell: st.cell })
    let knd = peek_kind(headp)
    let islet = if knd == 204 then 1 else 0
    let name_start = if islet == 1 then peek_start(advance(Advance { lst: headp, k: 1 })) else peek_start(headp)
    let name_len = if islet == 1 then peek_len(advance(Advance { lst: headp, k: 1 })) else peek_len(headp)
    out = if islet == 1 then stmt_let_join(LetJoinState { name_start: name_start, name_len: name_len, value: parse_or(ParseState { cell: advance(Advance { lst: headp, k: 3 }) }) }) else ParsedBlock::MkPB { block: Block::MkBlock { binds: Binding::BNil, result: parsed_node(parse_or(ParseState { cell: advance(Advance { lst: headp, k: 2 }) })) }, next: parsed_next(parse_or(ParseState { cell: advance(Advance { lst: headp, k: 2 }) })) }
  proofs:
    purity:
      reads : [st.cell]
      calls : [skip_seps, peek_kind, peek_start, peek_len, stmt_let_join, parse_or, parsed_node, parsed_next, advance]
    termination:
      bound : 512


-- parse_block: the brick-9 block entry. The documented framing makes the source
-- the block BODY (column-0 lines); parse_stmts is framing-agnostic, so this is a
-- thin wrapper that starts the sweep at index 0. (A future brick that nests a
-- block under a header would start parse_stmts after the header's Newline+Indent;
-- the skip_seps head makes that a position change only.)
rule parse_block
  @intention: "Parse a statement block from token index 0 into a Block + end index"
  @source: vexprparse.intent:28
  input:
    st : ParseState
  output:
    out : ParsedBlock
  logic:
    out = parse_stmts(st)
  proofs:
    purity:
      reads : [st]
      calls : [parse_stmts]
    termination:
      bound : 16


-- ============================================================================
-- BRICK 9 STRUCTURAL ORACLE. A block with name-bearing bindings has no numeric
-- value without an environment (the bonus eval below adds one), so the parser is
-- validated by the SHAPE of the Block it builds, like brick 5/7's shape_ast. The
-- signature is hand-derivable per input:
--
--   block_shape = 1000000 * (#bindings) + shape_binds(binds) + shape_ast(result)
--
-- where shape_binds sums shape_ast over every binding's RHS expression. The
-- 1000000 band counts bindings (each test has <100); shape_binds + shape_ast(result)
-- both stay well under 1000000 for every test input, so a single number certifies
-- the exact (#bindings, per-binding RHS shapes, result shape) triple.
-- ============================================================================

-- count_binds: number of bindings in a Binding cons-list. Structural recursion.
rule count_binds
  @intention: "Number of let-bindings in a binding cons-list"
  @source: vexprparse.intent:28
  input:
    b : Binding
  output:
    out : number
  logic:
    out = match b:
      BCons(name_start, name_len, value, rest) => 1 + count_binds(rest)
      BNil => 0
  proofs:
    purity:
      reads : [b]
      calls : [count_binds]
    termination:
      bound : 4000
      structural : b


-- shape_binds: sum of shape_ast over every binding's RHS expression. Structural
-- recursion on the binding tail; shape_ast (the brick-5/7 oracle) supplies each
-- value's structural signature.
rule shape_binds
  @intention: "Sum of the structural signatures of every binding's RHS expression"
  @source: vexprparse.intent:28
  input:
    b : Binding
  output:
    out : number
  logic:
    out = match b:
      BCons(name_start, name_len, value, rest) => shape_ast(value) + shape_binds(rest)
      BNil => 0
  proofs:
    purity:
      reads : [b]
      calls : [shape_ast, shape_binds]
    termination:
      bound : 4000
      structural : b


-- block_shape: tokenize a block-body source (column-0 lines) with indentation,
-- parse a statement block from index 0, and return its structural signature.
-- The brick-9 money-shot observable. NATIVE-ONLY for newline-bearing sources
-- (the interpreter's JSON reader does not decode \n into a real byte 10 — see
-- count_cells_src). Reuses IndentSrc (source text).
rule block_shape
  @intention: "Parse a statement block and return 1000000*#binds + binding-shapes + result-shape"
  @source: vexprparse.intent:28
  input:
    a : IndentSrc
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: a.source, pos: 0 })
    let pb = parse_block(ParseState { cell: toks })
    let blk = pb_block(pb)
    let binds = block_binds(blk)
    let result = block_result(blk)
    out = 1000000 * count_binds(binds) + (shape_binds(binds) + shape_ast(result))
  proofs:
    purity:
      reads : [a.source]
      calls : [begin_tokenize, parse_block, pb_block, block_binds, block_result, count_binds, shape_binds, shape_ast]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 10: EVALUATING A LET-BLOCK WITH AN ENVIRONMENT (name resolution).
--
-- Brick 9 PARSED a let-block into a Block { binds, result } and proved the parse
-- structurally (block_shape). Brick 10 RUNS it to a number, resolving variable
-- references by BYTES against the source text. The pieces:
--
--   * name_eq      — are two source spans byte-for-byte equal? (recursion over a
--                    byte range, bounded by the span length).
--   * env_lookup   — find a name in the Env by byte-comparing its span against
--                    each entry's span; return the bound value (recursion over
--                    the Env list, innermost-first so the latest binding wins).
--   * eval_ast_env — eval_ast EXTENDED with an Env + src: AstVar(start, len) now
--                    resolves to env_lookup(...) instead of 0. This rule carries
--                    BOTH a group field (node : Ast) AND a text field (src) and
--                    recurses with sibling calls (AstBin lhs/rhs) — the shape the
--                    2b052a7 compiler fix unblocked (cf. recursive_text_eval).
--   * build_env    — walk the binding list IN ORDER, evaluating each binding's
--                    RHS against the env built SO FAR (so `let y = x + 1` sees an
--                    earlier `let x = 1`), consing (name span, value) on the front.
--   * eval_block   — the entry: tokenize -> parse_block -> build_env -> eval the
--                    result against the populated env. The money shot.
--
-- NAME RESOLUTION BY BYTES. A variable's identity is its bytes in the source, not
-- a symbol-table index: two `x` at different spans ARE the same variable. So both
-- the binding name (recorded as a span by parse_stmts) and the AstVar reference
-- (recorded as a span by parse_primary) are resolved by comparing the actual
-- source bytes. eval_ast_env and build_env therefore both carry the source text
-- alongside the AST/Env — exactly the "group field + text field, recursive" shape.
--
-- OUT OF SCOPE FOR THIS BRICK (documented, evaluate to 0 like brick 7's eval_ast):
-- AstField / AstCall / AstStr — they need a richer environment (records, function
-- values, decoded string bytes). The point of brick 10 is VARIABLE resolution in
-- arithmetic/logic let-blocks; those three stay 0 and are proven by shape_ast.
--
-- TERMINATION. name_eq recurses over a byte range with `increasing : off` bounded
-- by the span length (a Number field of its packed input — same shape as the
-- tokenizer's scanners, so the proof verifies mechanically). env_lookup,
-- build_env, and eval_ast_env recurse over a strictly-shrinking cons-list tail /
-- Ast sub-node, but that shrinking value is a FIELD of a packed input concept,
-- not the input itself; the `structural` proof requires the input to BE a group
-- concept, so it does not fit. Like the parser's packed-state rules (parse_add,
-- stmt_let_join, ...) these carry bound-only termination and ACCEPT the mandatory
-- native recursion breadcrumb. Backstops: the Env / binding lists are finite
-- (built by a finite binding sweep) and the AST is finite (bounded by max_nodes),
-- so every recursion strictly shrinks toward a leaf / Nil. byte_at is fail-closed
-- OOB (returns 0), so an out-of-range span never reads past the buffer.
-- ============================================================================

-- A name-equality probe: the source text, the two span starts, the common length
-- to compare, and the current byte offset within the spans. name_eq compares
-- src[a_start+off] vs src[b_start+off] for off in [0, len).
concept NameEqState
  @intention: "Source text + two span starts + length + current offset, for byte-comparing two names"
  @source: vexprparse.intent:29
  fields:
    src : text [..256]
    a_start : number [0, 4000000]
    b_start : number [0, 4000000]
    len : number [0, 4000000]
    off : number [0, 4000000]


-- name_eq: 1 iff the byte ranges src[a_start..a_start+len] and
-- src[b_start..b_start+len] are equal. Compares byte by byte from `off` up to
-- `len`; equal when off reaches len. The caller checks the two LENGTHS are equal
-- BEFORE calling (env_lookup does this), so this rule assumes a common len and
-- only walks the bytes. Recursion advances `off` toward `len`; bounded by 256.
rule name_eq
  @intention: "1 if two source spans of equal length are byte-for-byte identical, 0 otherwise"
  @source: vexprparse.intent:29
  input:
    st : NameEqState
  output:
    out : number
  logic:
    out = if st.off >= st.len then 1 else if byte_at(st.src, st.a_start + st.off) == byte_at(st.src, st.b_start + st.off) then name_eq(NameEqState { src: st.src, a_start: st.a_start, b_start: st.b_start, len: st.len, off: st.off + 1 }) else 0
  proofs:
    purity:
      reads : [st.src, st.a_start, st.b_start, st.len, st.off]
      calls : [name_eq]
    termination:
      bound : 256
      increasing : off


-- The environment-lookup probe: the Env to search, the source text (for byte
-- comparison), and the query name's span (q_start, q_len).
concept EnvLookState
  @intention: "An Env to search + the source text + the query name's span"
  @source: vexprparse.intent:29
  fields:
    env : Env
    src : text [..256]
    q_start : number [0, 4000000]
    q_len : number [0, 4000000]


-- env_lookup: find the query name in the Env and return its bound value, or 0 if
-- the name is unbound (an unbound variable evaluates to 0 — the same default as a
-- brick-7 AstVar, just now reachable through the environment). Walks the Env
-- innermost-first: at each ECons it checks the entry's LENGTH equals the query
-- length AND the bytes match (name_eq); on a match it returns the entry's `val`,
-- otherwise it recurses into `rest`. Because build_env conses the newest binding
-- on the front, the FIRST match is the most recent binding — shadowing wins.
-- Bound-only termination + the native recursion breadcrumb (packed input concept;
-- the shrinking Env tail is a field, not the input — see the header).
rule env_lookup
  @intention: "Value bound to a name in the environment (0 if unbound); innermost binding wins"
  @source: vexprparse.intent:29
  input:
    st : EnvLookState
  output:
    out : number
  logic:
    out = match st.env:
      ECons(name_start, name_len, val, rest) => if name_len == st.q_len and name_eq(NameEqState { src: st.src, a_start: name_start, b_start: st.q_start, len: name_len, off: 0 }) == 1 then val else env_lookup(EnvLookState { env: rest, src: st.src, q_start: st.q_start, q_len: st.q_len })
      ENil => 0
  proofs:
    purity:
      reads : [st.env, st.src, st.q_start, st.q_len]
      calls : [name_eq, env_lookup]
    termination:
      bound : 4000


-- eval_ast_env's input: the AST node to evaluate, the environment to resolve
-- variable references against, and the source text the spans index into. Carries
-- a group field (node : Ast) AND a text field (src) — the 2b052a7 shape.
concept EvalEnvArg
  @intention: "An Ast node + the environment + the source text + the program + the concept list, for evaluating with name resolution, calls, and variant tagging"
  @source: vexprparse.intent:36
  fields:
    node : Ast
    env : VEnv
    src : text [..256]
    prog : RuleList
    concepts : ConceptList


-- eval_ast_env: eval_ast EXTENDED with an environment. Identical to eval_ast for
-- every variable-free node (the same arithmetic / comparison / logical / unary /
-- if / bool dispatch), but AstVar(start, len) now RESOLVES the name: it looks the
-- span up in the env by byte comparison and returns the bound value. Every
-- recursive call threads the SAME env and src down, so a nested sub-expression
-- sees the same bindings. AstBin makes TWO sibling recursive calls (lhs and rhs)
-- while carrying the text field src — exactly the shape the 2b052a7 fix unblocked.
-- Text values slice 1: AstStr now evaluates to a VText SPAN (quotes stripped), and
-- the AstCall arm dispatches the three scanner PRIMITIVES (byte_at / length /
-- substring) BEFORE delegating to eval_call — eval_call's lets are EAGER
-- (find_rule runs unconditionally), so primitive dispatch cannot live there.
-- Primitive names shadow user rules of the same name (reserved, same as verbosec).
-- Records-arc
-- slice 2: AstField(base, .name) now RESOLVES a record/variant field access — it
-- evaluates base to a VData, recovers the concept from tag / 256, finds the field's
-- position via field_index_of, and reads that slot of the payload via vlist_nth
-- (defensive VNum 0 when base is not a VData, the field is absent, or out of range).
-- Bound-only termination + the native recursion breadcrumb: each recursive call
-- walks a strict sub-node of ea.node, but ea.node is a FIELD of the packed input
-- (not the input), so the `structural` proof does not fit — see the header.
rule eval_ast_env
  @intention: "Evaluate an AST to a number, resolving variable references against an environment"
  @source: vexprparse.intent:29
  input:
    ea : EvalEnvArg
  output:
    out : Value
  logic:
    out = match ea.node:
      AstNum(value) => Value::VNum { n: value }
      AstBin(op, lhs, rhs) => Value::VNum { n: if op == 13 then vnum_of(eval_ast_env(EvalEnvArg { node: lhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) + vnum_of(eval_ast_env(EvalEnvArg { node: rhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) else if op == 14 then vnum_of(eval_ast_env(EvalEnvArg { node: lhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) - vnum_of(eval_ast_env(EvalEnvArg { node: rhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) else if op == 15 then vnum_of(eval_ast_env(EvalEnvArg { node: lhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) * vnum_of(eval_ast_env(EvalEnvArg { node: rhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) else if op == 16 then vnum_of(eval_ast_env(EvalEnvArg { node: lhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) / vnum_of(eval_ast_env(EvalEnvArg { node: rhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) else if op == 17 then vnum_of(eval_ast_env(EvalEnvArg { node: lhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) % vnum_of(eval_ast_env(EvalEnvArg { node: rhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) else if op == 1 then (if vnum_of(eval_ast_env(EvalEnvArg { node: lhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) == vnum_of(eval_ast_env(EvalEnvArg { node: rhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) then 1 else 0) else if op == 6 then (if vnum_of(eval_ast_env(EvalEnvArg { node: lhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) != vnum_of(eval_ast_env(EvalEnvArg { node: rhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) then 1 else 0) else if op == 19 then (if vnum_of(eval_ast_env(EvalEnvArg { node: lhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) < vnum_of(eval_ast_env(EvalEnvArg { node: rhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) then 1 else 0) else if op == 20 then (if vnum_of(eval_ast_env(EvalEnvArg { node: lhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) > vnum_of(eval_ast_env(EvalEnvArg { node: rhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) then 1 else 0) else if op == 5 then (if vnum_of(eval_ast_env(EvalEnvArg { node: lhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) <= vnum_of(eval_ast_env(EvalEnvArg { node: rhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) then 1 else 0) else if op == 4 then (if vnum_of(eval_ast_env(EvalEnvArg { node: lhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) >= vnum_of(eval_ast_env(EvalEnvArg { node: rhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) then 1 else 0) else if op == 30 then (if vnum_of(eval_ast_env(EvalEnvArg { node: lhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) != 0 and vnum_of(eval_ast_env(EvalEnvArg { node: rhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) != 0 then 1 else 0) else if op == 31 then (if vnum_of(eval_ast_env(EvalEnvArg { node: lhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) != 0 or vnum_of(eval_ast_env(EvalEnvArg { node: rhs, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) != 0 then 1 else 0) else 0 }
      AstNeg(inner) => Value::VNum { n: 0 - vnum_of(eval_ast_env(EvalEnvArg { node: inner, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) }
      AstNot(inner) => Value::VNum { n: if vnum_of(eval_ast_env(EvalEnvArg { node: inner, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) == 0 then 1 else 0 }
      AstVar(start, len) => venv_lookup(VEnvLookState { env: ea.env, src: ea.src, q_start: start, q_len: len })
      AstField(base, fstart, flen) => vlist_nth(VListNthState { vs: vdata_payload(eval_ast_env(EvalEnvArg { node: base, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })), k: field_index_of(FieldIdxState { fields: cd_fields(concept_at_index(ConceptAtState { concepts: ea.concepts, idx: vdata_tag(eval_ast_env(EvalEnvArg { node: base, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) / 256 })), src: ea.src, q_start: fstart, q_len: flen, idx: 0 }) })
      -- Text values slice 1: primitive dispatch FIRST (byte_at / length / substring,
      -- byte-compared against the callee span), THEN eval_call for user rules.
      -- Dispatch must happen HERE and not inside eval_call: eval_call's lets are
      -- EAGER (find_rule / bind_params / build_env run before any `out` if), so a
      -- primitive routed through it would drag the whole user-rule machinery along.
      -- A user rule named byte_at / length / substring / concat is shadowed by the
      -- primitive (reserved names, same as verbosec). Concat arc slice 1: concat
      -- joins the family — prim_concat folds the evaluated args into a rope value.
      AstCall(callee_start, callee_len, args) => if span_is_byte_at(SpanCheck { src: ea.src, start: callee_start, len: callee_len }) == 1 then prim_byte_at(EvalCallState { callee_start: callee_start, callee_len: callee_len, args: args, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts }) else if span_is_length(SpanCheck { src: ea.src, start: callee_start, len: callee_len }) == 1 then prim_length(EvalCallState { callee_start: callee_start, callee_len: callee_len, args: args, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts }) else if span_is_substring(SpanCheck { src: ea.src, start: callee_start, len: callee_len }) == 1 then prim_substring(EvalCallState { callee_start: callee_start, callee_len: callee_len, args: args, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts }) else if span_is_concat(SpanCheck { src: ea.src, start: callee_start, len: callee_len }) == 1 then prim_concat(EvalCallState { callee_start: callee_start, callee_len: callee_len, args: args, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts }) else eval_call(EvalCallState { callee_start: callee_start, callee_len: callee_len, args: args, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })
      AstIf(cond, thn, els) => if vnum_of(eval_ast_env(EvalEnvArg { node: cond, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })) != 0 then eval_ast_env(EvalEnvArg { node: thn, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts }) else eval_ast_env(EvalEnvArg { node: els, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })
      AstBool(value) => Value::VNum { n: value }
      -- Text values slice 1: a string literal is a SPAN into the interpreted source.
      -- The lexer's Str token span INCLUDES both quotes (string_run counts the opening
      -- quote + content + closing quote, and parse_primary copies the token span
      -- verbatim into AstStr), so strip them: content = (start + 1, len - 2). The
      -- len >= 2 clamp keeps an unterminated string (lone quote at EOF, len 1) from
      -- producing a negative-length span.
      AstStr(start, len) => Value::VText { start: start + 1, len: if len >= 2 then len - 2 else 0 }
      AstBytes(start, len) => Value::VNum { n: 0 }
      AstErr => Value::VNum { n: 0 }
      -- R6c: construct a runtime variant value. `tag` is the variant's identity
      -- (variant_tag resolves the concept/variant name spans against the ConceptList);
      -- `payload` is the cons-list of evaluated field values (eval_vfields).
      AstVariant(cstart, clen, vstart, vlen, fields) => Value::VData { tag: variant_tag(VariantTagState { concepts: ea.concepts, src: ea.src, cstart: cstart, clen: clen, vstart: vstart, vlen: vlen }), payload: eval_vfields(EvalVFieldsState { fields: fields, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts }) }
      -- R6c: evaluate the scrutinee to a Value, then dispatch to the arm whose variant
      -- tag equals the scrutinee's, binding the arm's binders positionally to the
      -- scrutinee's payload (eval_match).
      AstMatch(scrut, arms) => eval_match(EvalMatchState { scrutval: eval_ast_env(EvalEnvArg { node: scrut, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts }), arms: arms, env: ea.env, src: ea.src, prog: ea.prog, concepts: ea.concepts })
  proofs:
    purity:
      reads : [ea.node, ea.env, ea.src, ea.prog, ea.concepts]
      calls : [eval_ast_env, venv_lookup, eval_call, vnum_of, variant_tag, eval_vfields, eval_match, vdata_payload, vdata_tag, concept_at_index, cd_fields, field_index_of, vlist_nth, span_is_byte_at, span_is_length, span_is_substring, span_is_concat, prim_byte_at, prim_length, prim_substring, prim_concat]
    termination:
      bound : 4000


-- build_env's input: the remaining binding list, the env built so far, and the
-- source text (each binding's RHS is evaluated against env_so_far, and AstVar
-- references in it resolve via src).
concept BuildEnvArg
  @intention: "Remaining bindings + the env built so far + the source text + the program + the concept list (for calls / variants in RHSes)"
  @source: vexprparse.intent:36
  fields:
    binds : Binding
    env : VEnv
    src : text [..256]
    prog : RuleList
    concepts : ConceptList


-- ============================================================================
-- BRICK 18: call/apply in the evaluator. The evaluator resolved VARIABLES
-- (brick 10) but returned 0 for CALLS. Brick 18 makes AstCall actually EXECUTE
-- a rule: find the called rule by NAME in the program, evaluate the argument
-- expressions against the CALLER's env, bind them to the callee's params in a
-- FRESH env (lexical scoping — the callee does NOT see the caller's locals),
-- build the callee's let-env on top of that, then evaluate the callee's result.
-- Calls recurse naturally: a `fact` that calls itself just works if it
-- terminates. This closes the loop from source text to a real computed call
-- result — the file is now a (toy) INTERPRETER, not just a parser + var-resolver.
--
-- THE SCC. eval_ast_env, eval_call, bind_params, and build_env now form one
-- mutual-recursion cluster (eval_ast_env -> eval_call -> bind_params/build_env ->
-- eval_ast_env). Like the brick-10 evaluator rules they carry bound-only
-- termination and ACCEPT the mandatory native recursion breadcrumb: each
-- recursive call walks a strict sub-node / shorter tail, but that shrinking
-- value is a FIELD of a packed input concept (not the input itself), so the
-- `structural` proof does not fit. The backstops are the same as brick 10 (finite
-- Env / binding / arg / param lists and a finite AST bounded by max_nodes) PLUS:
-- a call chain is bounded only by the source program's own termination — an
-- infinite Verbose program (no base case) would not terminate here either, which
-- is the honest interpreter semantics, not a soundness gap in this brick.
-- ============================================================================

-- The call-evaluation probe: the callee's name span (callee_start, callee_len),
-- the call's argument AST list, the CALLER's environment (arg expressions are
-- evaluated against it), the source text (for name byte-comparison), and the
-- whole program (the scope the callee name is resolved against, and threaded so
-- the callee body can itself call other rules).
concept EvalCallState
  @intention: "A callee name span + the call's args + the caller env + the source text + the program + the concept list"
  @source: vexprparse.intent:36
  fields:
    callee_start : number [0, 4000000]
    callee_len : number [0, 4000000]
    args : ArgList
    env : VEnv
    src : text [..256]
    prog : RuleList
    concepts : ConceptList


-- The parameter-binding probe: the callee's remaining formal parameter list, the
-- remaining call-argument AST list (positional, in lock-step with params), the
-- CALLER's environment (each arg expression is evaluated against it), the source
-- text, and the program (threaded because an argument can itself be a call).
concept BindParamsState
  @intention: "Callee params + call args + the caller env + the source text + the program + the concept list"
  @source: vexprparse.intent:36
  fields:
    params : ParamList
    args : ArgList
    env : VEnv
    src : text [..256]
    prog : RuleList
    concepts : ConceptList


-- The rule-lookup probe: the program's rule list to search, the source text (for
-- byte-comparison), and the query name's span (q_start, q_len). Same shape as the
-- arity pass's RuleNamedState, but returns the matched RuleDecl rather than 0/1.
concept FindRuleState
  @intention: "A program rule list to search + the source text + the query name's span"
  @source: vexprparse.intent:36
  fields:
    rules : RuleList
    src : text [..256]
    q_start : number [0, 4000000]
    q_len : number [0, 4000000]


-- CallRetState (brick 33): the inputs to type a CALL's result — the program rule
-- list (callee scope), the source text, and the callee name's span. Drives
-- call_result_type, which resolves the callee's DECLARED return type and maps the
-- "unannotated" sentinel (9) back to number (0) so a call to an unannotated rule
-- still types as number (preserving brick 32).
concept CallRetState
  @intention: "A program rule list + source text + the callee name's span, for typing a call result"
  @source: vexprparse.intent:51
  fields:
    prog : RuleList
    src : text [..256]
    callee_start : number [0, 4000000]
    callee_len : number [0, 4000000]


-- A one-field probe to read the HEAD of an argument list (block-form match is only
-- legal in final position, so destructuring an ArgList is factored into a tiny
-- rule — same idiom as parsed_args_* / pp_params).
concept AHeadState
  @intention: "A call-argument list, for reading its head node"
  @source: vexprparse.intent:36
  fields:
    args : ArgList


-- A one-field probe to read the TAIL of an argument list (mirror of AHeadState).
concept ATailState
  @intention: "A call-argument list, for reading its tail"
  @source: vexprparse.intent:36
  fields:
    args : ArgList


-- build_env: fold the binding list (in source order) into an Env. For each
-- BCons, evaluate the binding's RHS Ast against the env built SO FAR (so a later
-- binding can reference an earlier one — `let x = 1` then `let y = x + 1` makes y
-- see x = 1), then cons (name span, computed value) onto the FRONT of the env and
-- recurse on the rest with the extended env. BNil returns the accumulated env
-- unchanged. Consing on the front means env_lookup finds the most-recent binding
-- first, which gives last-binding-wins shadowing. Bound-only termination + the
-- native recursion breadcrumb (packed input; the shrinking binding tail is a
-- field, not the input — see the header).
rule build_env
  @intention: "Fold a binding list into an environment, evaluating each RHS against the env so far"
  @source: vexprparse.intent:29
  input:
    ba : BuildEnvArg
  output:
    out : VEnv
  logic:
    out = match ba.binds:
      BCons(name_start, name_len, value, rest) => build_env(BuildEnvArg { binds: rest, env: VEnv::VECons { name_start: name_start, name_len: name_len, val: eval_ast_env(EvalEnvArg { node: value, env: ba.env, src: ba.src, prog: ba.prog, concepts: ba.concepts }), rest: ba.env }, src: ba.src, prog: ba.prog, concepts: ba.concepts })
      BNil => ba.env
  proofs:
    purity:
      reads : [ba.binds, ba.env, ba.src, ba.prog, ba.concepts]
      calls : [build_env, eval_ast_env]
    termination:
      bound : 4000


-- arg_head: the HEAD argument AST of a call's ArgList (an AstNum(0) placeholder
-- when the list is empty). bind_params reads one argument per parameter via this;
-- a call with fewer args than params binds the surplus params to 0 (the same
-- "missing -> 0" default the rest of the evaluator uses, e.g. an unbound variable
-- or an out-of-scope callee). Factored into a tiny rule because block-form match
-- is only legal in final position (same idiom as parsed_args_head / pp_params).
rule arg_head
  @intention: "The head argument AST of a call's argument list (AstNum 0 if empty)"
  @source: vexprparse.intent:36
  input:
    a : AHeadState
  output:
    out : Ast
  logic:
    out = match a.args:
      ArgCons(head, tail) => head
      ArgNil => Ast::AstNum { value: 0 }
  proofs:
    purity:
      reads : [a.args]
      calls : []
    termination:
      bound : 16


-- arg_tail: the TAIL of a call's ArgList (ArgNil when already empty). bind_params
-- consumes one argument per parameter and recurses on this tail in lock-step with
-- the parameter list's tail. Mirror of arg_head.
rule arg_tail
  @intention: "The tail of a call's argument list (ArgNil if empty)"
  @source: vexprparse.intent:36
  input:
    a : ATailState
  output:
    out : ArgList
  logic:
    out = match a.args:
      ArgCons(head, tail) => tail
      ArgNil => ArgList::ArgNil
  proofs:
    purity:
      reads : [a.args]
      calls : []
    termination:
      bound : 16


-- find_rule: locate the rule whose NAME span byte-equals the query span and return
-- its RuleDecl, walking the program rule list front-to-back. Same name-matching
-- idiom as the arity pass's rule_named (length equality first, then name_eq on the
-- bytes), but returns the matched RuleDecl instead of 0/1. On no match it returns
-- a SENTINEL MkRule(0, 0, PNil, MkBlock(BNil, AstErr)) — an empty-param rule whose
-- body is AstErr, so eval_call on a nonexistent callee evaluates to 0, preserving
-- the pre-brick-18 "AstCall => 0" behavior (the undefined-callee lint pass flags
-- the missing rule separately). Bound-only termination + the native recursion
-- breadcrumb (the shrinking rule-list tail is a field of the packed input).
rule find_rule
  @intention: "The RuleDecl whose name matches the query span (sentinel empty rule if none)"
  @source: vexprparse.intent:36
  input:
    st : FindRuleState
  output:
    out : RuleDecl
  logic:
    out = match st.rules:
      RCons(head, tail) => if rd_name_len(head) == st.q_len and name_eq(NameEqState { src: st.src, a_start: rd_name_start(head), b_start: st.q_start, len: st.q_len, off: 0 }) == 1 then head else find_rule(FindRuleState { rules: tail, src: st.src, q_start: st.q_start, q_len: st.q_len })
      RNil => RuleDecl::MkRule { name_start: 0, name_len: 0, params: ParamList::PNil, return_type: 0, body: Block::MkBlock { binds: Binding::BNil, result: Ast::AstErr }, input: FieldList::FNil, out_name_start: 0, out_name_len: 0, out_ty: 0, out_ty_start: 0, out_ty_len: 0, proofs: Proofs::MkProofs { reads: NameList::NmNil, calls: NameList::NmNil, term_kind: 0, term_bound: 0, term_field_start: 0, term_field_len: 0 } }
  proofs:
    purity:
      reads : [st.rules, st.src, st.q_start, st.q_len]
      calls : [rd_name_len, rd_name_start, name_eq, find_rule]
    termination:
      bound : 4000


-- bind_params: build the callee's PARAMETER environment by walking the callee's
-- formal parameter list and the call's argument list in lock-step. For each
-- PCons(name span, rest), evaluate the corresponding argument AST (arg_head) against
-- the CALLER's environment bp.env (threading bp.prog, since an argument can itself
-- be a call), cons (param name span, computed value) onto a FRESH env, and recurse
-- on the param tail with the argument tail (arg_tail). PNil returns ENil — the
-- accumulation base is the EMPTY environment, NOT the caller env, which is exactly
-- lexical scoping: the callee body sees only its parameters (and its own lets,
-- added later by build_env on top of this), never the caller's locals. Bound-only
-- termination + the native recursion breadcrumb (the shrinking param/arg tails are
-- fields of the packed input).
rule bind_params
  @intention: "Bind a callee's params to its call's args (each evaluated in the caller env) onto a fresh env"
  @source: vexprparse.intent:36
  input:
    bp : BindParamsState
  output:
    out : VEnv
  logic:
    out = match bp.params:
      PCons(name_start, name_len, ty, ty_start, ty_len, rest) => VEnv::VECons { name_start: name_start, name_len: name_len, val: eval_ast_env(EvalEnvArg { node: arg_head(AHeadState { args: bp.args }), env: bp.env, src: bp.src, prog: bp.prog, concepts: bp.concepts }), rest: bind_params(BindParamsState { params: rest, args: arg_tail(ATailState { args: bp.args }), env: bp.env, src: bp.src, prog: bp.prog, concepts: bp.concepts }) }
      PNil => VEnv::VENil
  proofs:
    purity:
      reads : [bp.params, bp.args, bp.env, bp.src, bp.prog, bp.concepts]
      calls : [eval_ast_env, arg_head, arg_tail, bind_params]
    termination:
      bound : 4000


-- eval_call: APPLY a rule. (1) find_rule resolves the callee name span against the
-- program; (2) bind_params evaluates each argument in the CALLER env and binds it
-- to the callee's parameters in a FRESH env (penv) — lexical scoping, no leak of
-- caller locals; (3) build_env folds the callee's own let-bindings on TOP of penv
-- (so a let RHS sees both the parameters and earlier lets) into cenv; (4)
-- eval_ast_env evaluates the callee's result expression against cenv. Plain rule
-- (not a match arm) so it can use `let` bindings. Recurses through eval_ast_env ->
-- AstCall -> eval_call for nested / self / mutual calls; a Verbose `fact` that
-- calls itself terminates iff the source program terminates (honest interpreter
-- semantics). Bound-only termination + the native recursion breadcrumb: this rule
-- is in the eval SCC, and a call chain's length is the source program's own depth,
-- not a structurally-shrinking field of this input.
rule eval_call
  @intention: "Evaluate a function call: find the rule, bind params in a fresh env, build its lets, evaluate its body"
  @source: vexprparse.intent:36
  input:
    ec : EvalCallState
  output:
    out : Value
  logic:
    let callee = find_rule(FindRuleState { rules: ec.prog, src: ec.src, q_start: ec.callee_start, q_len: ec.callee_len })
    let penv = bind_params(BindParamsState { params: rule_params_of(callee), args: ec.args, env: ec.env, src: ec.src, prog: ec.prog, concepts: ec.concepts })
    let cbody = rd_body(callee)
    let cbinds = block_binds(cbody)
    let cresult = block_result(cbody)
    let cenv = build_env(BuildEnvArg { binds: cbinds, env: penv, src: ec.src, prog: ec.prog, concepts: ec.concepts })
    out = eval_ast_env(EvalEnvArg { node: cresult, env: cenv, src: ec.src, prog: ec.prog, concepts: ec.concepts })
  proofs:
    purity:
      reads : [ec.callee_start, ec.callee_len, ec.args, ec.env, ec.src, ec.prog, ec.concepts]
      calls : [find_rule, bind_params, rule_params_of, rd_body, block_binds, block_result, build_env, eval_ast_env]
    termination:
      bound : 4000


-- ============================================================================
-- R6c: the runtime Value machinery — the pieces eval_ast_env's variant / match
-- arms + the Value-valued call machinery need. venv_lookup mirrors env_lookup but
-- over VEnv (Values, not type codes); vnum_of / vdata_tag / vdata_payload destructure
-- a Value; variant_tag self-computes a variant identity from the ConceptList;
-- bind_val_binders binds a match arm's binders to a scrutinee's payload; eval_vfields
-- and eval_match are in the eval SCC (they call eval_ast_env).
-- ============================================================================

-- The interpreter env-lookup probe: the VEnv to search + the source (for byte
-- comparison) + the query name's span. Mirror of EnvLookState but over VEnv.
concept VEnvLookState
  @intention: "A VEnv to search + the source text + the query name's span"
  @source: vexprparse.intent:36
  fields:
    env : VEnv
    src : text [..256]
    q_start : number [0, 4000000]
    q_len : number [0, 4000000]


-- venv_lookup: the Value bound to a name in the interpreter environment (VNum 0 if
-- unbound). Innermost-first walk (the most recent VECons wins — shadowing). Mirror of
-- env_lookup but returns a Value. Bound-only termination + the native recursion
-- breadcrumb (the shrinking VEnv tail is a field of the packed input).
rule venv_lookup
  @intention: "Value bound to a name in the interpreter environment (VNum 0 if unbound); innermost binding wins"
  @source: vexprparse.intent:36
  input:
    st : VEnvLookState
  output:
    out : Value
  logic:
    out = match st.env:
      VECons(name_start, name_len, val, rest) => if name_len == st.q_len and name_eq(NameEqState { src: st.src, a_start: name_start, b_start: st.q_start, len: name_len, off: 0 }) == 1 then val else venv_lookup(VEnvLookState { env: rest, src: st.src, q_start: st.q_start, q_len: st.q_len })
      VENil => Value::VNum { n: 0 }
  proofs:
    purity:
      reads : [st.env, st.src, st.q_start, st.q_len]
      calls : [name_eq, venv_lookup]
    termination:
      bound : 4000


-- vnum_of: the number a Value carries (0 for a variant or text value — the number
-- drivers return numbers, so a VText result unwraps to 0, same convention as VData).
-- The unwrap the number drivers apply to a Value result, and the arithmetic arms
-- apply to each operand.
rule vnum_of
  @intention: "The number carried by a Value (0 for a variant or text value)"
  @source: vexprparse.intent:36
  input:
    v : Value
  output:
    out : number
  logic:
    out = match v:
      VNum(n) => n
      VData(tag, payload) => 0
      VText(start, len) => 0
      VConcat(left, right) => 0
  proofs:
    purity:
      reads : [v]
      calls : []
    termination:
      bound : 16


-- vdata_tag: the identity tag of a variant Value (-1 for a VNum — a non-variant
-- scrutinee that matches no arm, since every real tag is >= 0).
rule vdata_tag
  @intention: "The identity tag of a variant Value (-1 for a non-variant value)"
  @source: vexprparse.intent:36
  input:
    v : Value
  output:
    out : number
  logic:
    out = match v:
      VNum(n) => 0 - 1
      VData(tag, payload) => tag
      VText(start, len) => 0 - 1
      VConcat(left, right) => 0 - 1
  proofs:
    purity:
      reads : [v]
      calls : []
    termination:
      bound : 16


-- vdata_payload: the evaluated payload of a variant Value (VLNil for a VNum).
rule vdata_payload
  @intention: "The payload value-list of a variant Value (empty for a non-variant value)"
  @source: vexprparse.intent:36
  input:
    v : Value
  output:
    out : ValueList
  logic:
    out = match v:
      VNum(n) => ValueList::VLNil
      VData(tag, payload) => payload
      VText(start, len) => ValueList::VLNil
      VConcat(left, right) => ValueList::VLNil
  proofs:
    purity:
      reads : [v]
      calls : []
    termination:
      bound : 16


-- ============================================================================
-- Text values arc slice 1: the three VText accessors + the three primitive-name
-- span checks + the three scanner primitives. A target text value is a SPAN
-- (start, len) into the interpreted source, and the target's primitives are
-- implemented WITH THE HOST'S OWN primitives on that source: target
-- byte_at(t, i) = host byte_at(ec.src, t.start + i). Every host byte_at call is
-- GUARDED FIRST (the host primitive is fail-closed — sys_exit on OOB — and a
-- buggy TARGET program must never kill the interpreter): out-of-bounds target
-- reads produce a defensive VNum 0, total, never abort.
-- ============================================================================

-- vtext_is: 1 iff a Value is a text span. Mirror of the vnum_of/vdata_tag accessor
-- trio — the primitives use it as the shape guard before touching span fields.
rule vtext_is
  @intention: "1 if a Value is a text span, 0 otherwise"
  @source: vexprparse.intent:39
  input:
    v : Value
  output:
    out : number
  logic:
    out = match v:
      VNum(n) => 0
      VData(tag, payload) => 0
      VText(start, len) => 1
      -- Concat arc slice 1: a rope is NOT a span — vtext_is stays the "may I read
      -- (start, len) directly?" gate, so rope consumers must go through
      -- vlength / vbyte_at instead.
      VConcat(left, right) => 0
  proofs:
    purity:
      reads : [v]
      calls : []
    termination:
      bound : 16


-- vtext_start: the source offset a VText span begins at (0 for a non-text value —
-- callers must gate on vtext_is first, same discipline as vdata_tag's -1 sentinel).
rule vtext_start
  @intention: "The source start offset of a text-span Value (0 for a non-text value)"
  @source: vexprparse.intent:39
  input:
    v : Value
  output:
    out : number
  logic:
    out = match v:
      VNum(n) => 0
      VData(tag, payload) => 0
      VText(start, len) => start
      VConcat(left, right) => 0
  proofs:
    purity:
      reads : [v]
      calls : []
    termination:
      bound : 16


-- vtext_len: the byte length of a VText span (0 for a non-text value).
rule vtext_len
  @intention: "The byte length of a text-span Value (0 for a non-text value)"
  @source: vexprparse.intent:39
  input:
    v : Value
  output:
    out : number
  logic:
    out = match v:
      VNum(n) => 0
      VData(tag, payload) => 0
      VText(start, len) => len
      VConcat(left, right) => 0
  proofs:
    purity:
      reads : [v]
      calls : []
    termination:
      bound : 16


-- ── Concat arc slice 1: rope helpers ─────────────────────────────────────────
-- A rope (VConcat tree) is never materialized; length and byte_at WALK it. The
-- shared value-level length is vlength (the one place that knows a VNum reads as
-- its decimal rendering); vbyte_at is the shared descent. The digit math lives in
-- two tiny recursive helpers over a nonnegative magnitude (the sign is handled at
-- the VNum arm, where the binder is a plain Ident — deliberately NOT a ranged
-- concept field, so the optimizer's interval arithmetic cannot fold the `n < 0`
-- test away; see the optimizer default-field-range note in CLAUDE.md).

-- mag_digits's input: a nonnegative magnitude (callers strip the sign first).
concept MagState
  @intention: "A nonnegative decimal magnitude, for counting its digits"
  @source: vexprparse.intent:68
  fields:
    m : number [0, 4000000]

-- mag_digits: the decimal digit count of a nonnegative magnitude (m = 0 -> 1).
-- Divide-by-10 recursion; strictly shrinking but m/10 is not the `m - k` shape
-- the `decreasing` proof checks, so bound-only + the native recursion breadcrumb.
rule mag_digits
  @intention: "The decimal digit count of a nonnegative magnitude (0 counts as 1 digit)"
  @source: vexprparse.intent:68
  input:
    dm : MagState
  output:
    out : number
  logic:
    out = if dm.m < 10 then 1 else 1 + mag_digits(MagState { m: dm.m / 10 })
  proofs:
    purity:
      reads : [dm.m]
      calls : [mag_digits]
    termination:
      bound : 64


-- mag_digit_at's input: a nonnegative magnitude + a 0-based digit position
-- (counted from the LEFT: position 0 is the most significant digit).
concept DigitState
  @intention: "A nonnegative magnitude + a 0-based digit position from the left, for reading one decimal digit byte"
  @source: vexprparse.intent:68
  fields:
    m : number [0, 4000000]
    k : number [0, 4000000]

-- mag_digit_at: the ASCII byte (48..57) of the k-th decimal digit of m, counted
-- from the left. Key identity: for k < digits(m) - 1, digit k of m == digit k of
-- m / 10 (dropping the LAST digit leaves the leading positions untouched), so the
-- recursion peels trailing digits until k is the last position. The m < 10 base
-- case is checked FIRST so an out-of-range k (never equal to the last position)
-- still terminates at the single-digit floor with a defensive 0 — total even when
-- a caller forgets the bounds guard.
rule mag_digit_at
  @intention: "The ASCII byte of the k-th decimal digit (from the left) of a nonnegative magnitude (defensive 0 when k is out of range)"
  @source: vexprparse.intent:68
  input:
    dg : DigitState
  output:
    out : number
  logic:
    out = if dg.m < 10 then (if dg.k == 0 then dg.m + 48 else 0) else if dg.k == mag_digits(MagState { m: dg.m }) - 1 then dg.m % 10 + 48 else mag_digit_at(DigitState { m: dg.m / 10, k: dg.k })
  proofs:
    purity:
      reads : [dg.m, dg.k]
      calls : [mag_digit_at, mag_digits]
    termination:
      bound : 64


-- vlength: the byte length of a Value read as text — THE shared rope walker
-- (prim_length reports it; vbyte_at's descent steers by it). VText -> the span
-- length; VNum -> the decimal rendering's width (digit count, +1 for '-' when
-- negative); VConcat -> left + right, recursively; VData -> 0 (a variant value
-- has no text reading — defensive, mirroring the accessors above). Structural
-- recursion: both recursive calls descend into binders of the self-referential
-- VConcat payload, exactly shape_ast's proof shape.
rule vlength
  @intention: "The byte length of a value read as text: span length, decimal width of a number, or the recursive sum over a rope"
  @source: vexprparse.intent:68
  input:
    v : Value
  output:
    out : number
  logic:
    out = match v:
      VNum(n) => if n < 0 then 1 + mag_digits(MagState { m: 0 - n }) else mag_digits(MagState { m: n })
      VData(tag, payload) => 0
      VText(start, len) => len
      VConcat(left, right) => vlength(left) + vlength(right)
  proofs:
    purity:
      reads : [v]
      calls : [vlength, mag_digits]
    termination:
      bound : 4000
      structural : v


-- vbyte_at's input: the value to read, the byte index, and the interpreted
-- source (VText leaves are spans into it). The index range deliberately includes
-- negatives: a target program can ask for byte_at(t, -5), and the `bs.i >= 0`
-- guards below must stay LIVE (a [0, N] range would let the optimizer's interval
-- arithmetic fold them to true and reach the host byte_at with a negative index).
concept VByteState
  @intention: "A value + a byte index + the interpreted source, for reading one byte of the value's text reading"
  @source: vexprparse.intent:68
  fields:
    v : Value
    i : number [-4000000, 4000000]
    src : text [..256]

-- vbyte_at: the i-th byte of a Value read as text — the shared rope descent.
-- VText -> the HOST byte_at on the interpreted source, bounds-guarded FIRST
-- (same fail-closed-host / defensive-interpreter split as prim_byte_at pre-rope);
-- VNum -> the i-th byte of the decimal rendering ('-' at 0 for negatives, then
-- mag_digit_at on the magnitude); VConcat -> descend left when i falls inside
-- the left length, else right with i shifted down (vlength recomputed per
-- descent — O(depth * size) worst case, fine for the interpreter tier); VData ->
-- 0. Every arm is total and defensive: any out-of-range or negative index
-- bottoms out at a leaf guard and returns 0, never aborts. Packed input (the
-- shrinking value is a FIELD), so bound-only termination + the native recursion
-- breadcrumb, like the eval SCC.
rule vbyte_at
  @intention: "The i-th byte of a value read as text: source byte through a span, decimal-rendering byte of a number, or the recursive rope descent (defensive 0 out of bounds)"
  @source: vexprparse.intent:68
  input:
    bs : VByteState
  output:
    out : number
  logic:
    out = match bs.v:
      VNum(n) => if n < 0 then (if bs.i == 0 then 45 else if bs.i >= 1 and bs.i < 1 + mag_digits(MagState { m: 0 - n }) then mag_digit_at(DigitState { m: 0 - n, k: bs.i - 1 }) else 0) else (if bs.i >= 0 and bs.i < mag_digits(MagState { m: n }) then mag_digit_at(DigitState { m: n, k: bs.i }) else 0)
      VData(tag, payload) => 0
      VText(start, len) => if bs.i >= 0 and bs.i < len then byte_at(bs.src, start + bs.i) else 0
      VConcat(left, right) => if bs.i < vlength(left) then vbyte_at(VByteState { v: left, i: bs.i, src: bs.src }) else vbyte_at(VByteState { v: right, i: bs.i - vlength(left), src: bs.src })
  proofs:
    purity:
      reads : [bs.v, bs.i, bs.src]
      calls : [vbyte_at, vlength, mag_digits, mag_digit_at]
    termination:
      bound : 4000


-- span_is_byte_at: 1 iff the span src[start..start+len] is exactly the 7 bytes
-- "byte_at" (b=98 y=121 t=116 e=101 _=95 a=97 t=116). Flat fixed-width check
-- (mirroring span_is_rule), length-guarded first.
rule span_is_byte_at
  @intention: "1 if a callee span spells exactly \"byte_at\", 0 otherwise"
  @source: vexprparse.intent:39
  input:
    sc : SpanCheck
  output:
    out : number
  logic:
    out = if sc.len == 7 and (byte_at(sc.src, sc.start) == 98 and (byte_at(sc.src, sc.start + 1) == 121 and (byte_at(sc.src, sc.start + 2) == 116 and (byte_at(sc.src, sc.start + 3) == 101 and (byte_at(sc.src, sc.start + 4) == 95 and (byte_at(sc.src, sc.start + 5) == 97 and byte_at(sc.src, sc.start + 6) == 116)))))) then 1 else 0
  proofs:
    purity:
      reads : [sc.src, sc.start, sc.len]
      calls : []
    termination:
      bound : 64


-- span_is_length: 1 iff the span src[start..start+len] is exactly the 6 bytes
-- "length" (l=108 e=101 n=110 g=103 t=116 h=104). Flat fixed-width check.
rule span_is_length
  @intention: "1 if a callee span spells exactly \"length\", 0 otherwise"
  @source: vexprparse.intent:39
  input:
    sc : SpanCheck
  output:
    out : number
  logic:
    out = if sc.len == 6 and (byte_at(sc.src, sc.start) == 108 and (byte_at(sc.src, sc.start + 1) == 101 and (byte_at(sc.src, sc.start + 2) == 110 and (byte_at(sc.src, sc.start + 3) == 103 and (byte_at(sc.src, sc.start + 4) == 116 and byte_at(sc.src, sc.start + 5) == 104))))) then 1 else 0
  proofs:
    purity:
      reads : [sc.src, sc.start, sc.len]
      calls : []
    termination:
      bound : 64


-- span_is_substring: 1 iff the span src[start..start+len] is exactly the 9 bytes
-- "substring" (s=115 u=117 b=98 s=115 t=116 r=114 i=105 n=110 g=103). Flat
-- fixed-width check.
rule span_is_substring
  @intention: "1 if a callee span spells exactly \"substring\", 0 otherwise"
  @source: vexprparse.intent:39
  input:
    sc : SpanCheck
  output:
    out : number
  logic:
    out = if sc.len == 9 and (byte_at(sc.src, sc.start) == 115 and (byte_at(sc.src, sc.start + 1) == 117 and (byte_at(sc.src, sc.start + 2) == 98 and (byte_at(sc.src, sc.start + 3) == 115 and (byte_at(sc.src, sc.start + 4) == 116 and (byte_at(sc.src, sc.start + 5) == 114 and (byte_at(sc.src, sc.start + 6) == 105 and (byte_at(sc.src, sc.start + 7) == 110 and byte_at(sc.src, sc.start + 8) == 103)))))))) then 1 else 0
  proofs:
    purity:
      reads : [sc.src, sc.start, sc.len]
      calls : []
    termination:
      bound : 64


-- span_is_concat: 1 iff the span src[start..start+len] is exactly the 6 bytes
-- "concat" (c=99 o=111 n=110 c=99 a=97 t=116). Flat fixed-width check, mirror of
-- span_is_length. Concat arc slice 1.
rule span_is_concat
  @intention: "1 if a callee span spells exactly \"concat\", 0 otherwise"
  @source: vexprparse.intent:68
  input:
    sc : SpanCheck
  output:
    out : number
  logic:
    out = if sc.len == 6 and (byte_at(sc.src, sc.start) == 99 and (byte_at(sc.src, sc.start + 1) == 111 and (byte_at(sc.src, sc.start + 2) == 110 and (byte_at(sc.src, sc.start + 3) == 99 and (byte_at(sc.src, sc.start + 4) == 97 and byte_at(sc.src, sc.start + 5) == 116))))) then 1 else 0
  proofs:
    purity:
      reads : [sc.src, sc.start, sc.len]
      calls : []
    termination:
      bound : 64


-- prim_byte_at: the target-language byte_at(t, i). Both args are evaluated against
-- the caller's env (an arg can itself be a primitive call — spans compose); t must
-- be a VText and i a number with 0 <= i < t.len, in which case the result is the
-- HOST byte_at on the interpreted source at t.start + i (the span model: the target
-- text IS bytes of ec.src). The bounds guard runs BEFORE the host call — the host
-- byte_at is fail-closed (sys_exit on OOB), and a target program's out-of-range
-- index must produce a defensive VNum 0, never kill the interpreter. Arity/shape
-- mismatches (missing args evaluate AstNum 0 via arg_head's sentinel; a non-text t)
-- fall to the same defensive VNum 0 — total. Reuses EvalCallState (the callee span
-- fields ride along unused). In the eval SCC: bound-only termination + the native
-- recursion breadcrumb, like eval_call.
-- Concat arc slice 1: the whole dispatch now routes through vbyte_at — its VText
-- arm reproduces the pre-rope semantics exactly (bounds guard FIRST, then the host
-- byte_at on ec.src), and its VNum / VConcat arms add the decimal-rendering and
-- rope-descent readings. One shared path, no duplicated guard.
rule prim_byte_at
  @intention: "Evaluate the byte_at primitive: the i-th byte of the argument's text reading — span byte, decimal-rendering byte, or rope descent (defensive 0 when out of bounds or ill-shaped)"
  @source: vexprparse.intent:39
  input:
    ec : EvalCallState
  output:
    out : Value
  logic:
    let tv = eval_ast_env(EvalEnvArg { node: arg_head(AHeadState { args: ec.args }), env: ec.env, src: ec.src, prog: ec.prog, concepts: ec.concepts })
    let iv = vnum_of(eval_ast_env(EvalEnvArg { node: arg_head(AHeadState { args: arg_tail(ATailState { args: ec.args }) }), env: ec.env, src: ec.src, prog: ec.prog, concepts: ec.concepts }))
    out = Value::VNum { n: vbyte_at(VByteState { v: tv, i: iv, src: ec.src }) }
  proofs:
    purity:
      reads : [ec.args, ec.env, ec.src, ec.prog, ec.concepts]
      calls : [eval_ast_env, vnum_of, arg_head, arg_tail, vbyte_at]
    termination:
      bound : 4000


-- prim_length: the target-language length(t). A VText's byte length as a VNum;
-- no host call at all — the span already carries its length. Concat arc slice 1:
-- routed through vlength, which extends the reading to VNum (decimal digit count,
-- +1 for '-' when negative) and VConcat (recursive rope sum). A VData argument
-- stays a defensive VNum 0 (vlength's VData arm).
rule prim_length
  @intention: "Evaluate the length primitive: the byte length of the argument's text reading — span length, decimal width, or recursive rope sum (defensive 0 for a variant argument)"
  @source: vexprparse.intent:39
  input:
    ec : EvalCallState
  output:
    out : Value
  logic:
    let tv = eval_ast_env(EvalEnvArg { node: arg_head(AHeadState { args: ec.args }), env: ec.env, src: ec.src, prog: ec.prog, concepts: ec.concepts })
    out = Value::VNum { n: vlength(tv) }
  proofs:
    purity:
      reads : [ec.args, ec.env, ec.src, ec.prog, ec.concepts]
      calls : [eval_ast_env, arg_head, vlength]
    termination:
      bound : 4000


-- prim_substring: the target-language substring(t, a, b) — the half-open byte
-- slice [a, b) of a text span, as a NEW span into the same source (no copying:
-- start' = t.start + a, len' = b - a). Guard: t is a VText and 0 <= a <= b <=
-- t.len, which preserves the span invariant (start' + len' <= start + len <=
-- length(src)) so every later host byte_at through this span stays in bounds.
-- Anything else is a defensive VNum 0 — total, never abort. Concat arc slice 1:
-- substring on a rope (VConcat) or a number stays REFUSED semantics — vtext_is
-- gates the span path, so both fall to the defensive VNum 0 (the emitters tier
-- never re-slices built text; slicing a rope would need materialization or a
-- rope-splitting design, deliberately out of slice 1).
rule prim_substring
  @intention: "Evaluate the substring primitive: a half-open sub-span of a text-span value (defensive 0 when out of bounds or ill-shaped)"
  @source: vexprparse.intent:39
  input:
    ec : EvalCallState
  output:
    out : Value
  logic:
    let tv = eval_ast_env(EvalEnvArg { node: arg_head(AHeadState { args: ec.args }), env: ec.env, src: ec.src, prog: ec.prog, concepts: ec.concepts })
    let av = vnum_of(eval_ast_env(EvalEnvArg { node: arg_head(AHeadState { args: arg_tail(ATailState { args: ec.args }) }), env: ec.env, src: ec.src, prog: ec.prog, concepts: ec.concepts }))
    let bv = vnum_of(eval_ast_env(EvalEnvArg { node: arg_head(AHeadState { args: arg_tail(ATailState { args: arg_tail(ATailState { args: ec.args }) }) }), env: ec.env, src: ec.src, prog: ec.prog, concepts: ec.concepts }))
    out = if vtext_is(tv) == 1 and (av >= 0 and (av <= bv and bv <= vtext_len(tv))) then Value::VText { start: vtext_start(tv) + av, len: bv - av } else Value::VNum { n: 0 }
  proofs:
    purity:
      reads : [ec.args, ec.env, ec.src, ec.prog, ec.concepts]
      calls : [eval_ast_env, vnum_of, arg_head, arg_tail, vtext_is, vtext_start, vtext_len]
    termination:
      bound : 4000


-- prim_concat: the target-language concat(...) — n-ary, built as a ROPE, never
-- materialized. Walk the ArgList: each argument evaluates against the caller's
-- env (an arg can itself be a concat — ropes nest), and the results fold into
-- RIGHT-NESTED VConcats terminated by an empty VText: 0 args -> VText(0, 0);
-- 1 arg -> VConcat(v, VText(0, 0)); n args -> VConcat(v1, VConcat(v2, ...)).
-- The single-arg case is deliberately WRAPPED (not returned bare) so the
-- rope-aware readings apply uniformly — concat(42) is a TEXT value whose length
-- is 2 and whose bytes are '4' '2', which is exactly what print_chain's
-- `Int(v) => concat(v)` arm needs (number -> decimal text). The empty-VText
-- terminator costs 0 bytes in every reading (vlength adds 0, vbyte_at never
-- lands in it). In the eval SCC (each arg evaluation re-enters eval_ast_env):
-- bound-only termination + the native recursion breadcrumb, like the other prims.
rule prim_concat
  @intention: "Evaluate the concat primitive: fold the evaluated arguments into a right-nested rope value (empty text for zero arguments), never materializing bytes"
  @source: vexprparse.intent:68
  input:
    ec : EvalCallState
  output:
    out : Value
  logic:
    out = match ec.args:
      ArgCons(head, tail) => Value::VConcat { left: eval_ast_env(EvalEnvArg { node: head, env: ec.env, src: ec.src, prog: ec.prog, concepts: ec.concepts }), right: prim_concat(EvalCallState { callee_start: ec.callee_start, callee_len: ec.callee_len, args: tail, env: ec.env, src: ec.src, prog: ec.prog, concepts: ec.concepts }) }
      ArgNil => Value::VText { start: 0, len: 0 }
  proofs:
    purity:
      reads : [ec.callee_start, ec.callee_len, ec.args, ec.env, ec.src, ec.prog, ec.concepts]
      calls : [eval_ast_env, prim_concat]
    termination:
      bound : 4000


-- vl_head: the head Value of a ValueList (VNum 0 if empty). Mirror of arg_head, over
-- the runtime payload list — a match arm's k-th binder reads the k-th payload Value.
rule vl_head
  @intention: "The head value of a value-list (VNum 0 if empty)"
  @source: vexprparse.intent:36
  input:
    p : ValueList
  output:
    out : Value
  logic:
    out = match p:
      VLCons(head, tail) => head
      VLNil => Value::VNum { n: 0 }
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


-- vl_tail: the tail of a ValueList (VLNil if empty). Mirror of arg_tail.
rule vl_tail
  @intention: "The tail of a value-list (VLNil if empty)"
  @source: vexprparse.intent:36
  input:
    p : ValueList
  output:
    out : ValueList
  logic:
    out = match p:
      VLCons(head, tail) => tail
      VLNil => ValueList::VLNil
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


-- field_index_of's input: a concept's field list + source + a query field-name span
-- + the running 0-based index. Mirror of FindVarIdxState but over a FieldList (used
-- by AstField eval to resolve `s.a` to the field's position in the concept).
concept FieldIdxState
  @intention: "A field list + the source + a query field-name span + the running index, for finding a field's position"
  @source: vexprparse.intent:36
  fields:
    fields : FieldList
    src : text [..256]
    q_start : number [0, 4000000]
    q_len : number [0, 4000000]
    idx : number [0, 4000000]


-- field_index_of: the 0-based position of the field whose name byte-equals the query
-- span (-1 if none). Mirror of find_variant_index over a FieldList: the k-th record
-- field lives at the k-th payload slot, so AstField reads the payload at this index.
-- Assumes construction field order == declaration order (records-arc slice 2). Bound-
-- only termination (the shrinking list tail is a field of the packed input) + the
-- native recursion breadcrumb, exactly like find_variant_index / find_concept_index.
rule field_index_of
  @intention: "The 0-based position of the field whose name matches the query span (-1 if none)"
  @source: vexprparse.intent:36
  input:
    fi : FieldIdxState
  output:
    out : number
  logic:
    out = match fi.fields:
      FCons(name_start, name_len, ty, ty_start, ty_len, rest) => if name_len == fi.q_len and name_eq(NameEqState { src: fi.src, a_start: name_start, b_start: fi.q_start, len: fi.q_len, off: 0 }) == 1 then fi.idx else field_index_of(FieldIdxState { fields: rest, src: fi.src, q_start: fi.q_start, q_len: fi.q_len, idx: fi.idx + 1 })
      FNil => 0 - 1
  proofs:
    purity:
      reads : [fi.fields, fi.src, fi.q_start, fi.q_len, fi.idx]
      calls : [name_eq, field_index_of]
    termination:
      bound : 4000


-- vlist_nth's input: a value-list (a variant/record's evaluated payload) + a 0-based
-- index. Reads the k-th payload Value.
concept VListNthState
  @intention: "A value-list + a 0-based index, for reading the k-th payload value"
  @source: vexprparse.intent:36
  fields:
    vs : ValueList
    k : number [0, 4000000]


-- vlist_nth: the k-th Value of a ValueList (VNum 0 if the index is out of range).
-- Mirror of concept_at_index over a ValueList: recurses only when k != 0, so a valid
-- k in [0, len) walks straight to its slot and an over-long / empty list falls to
-- VLNil -> VNum 0. Bound-only termination + the native recursion breadcrumb.
rule vlist_nth
  @intention: "The k-th value of a value-list (VNum 0 if out of range)"
  @source: vexprparse.intent:36
  input:
    vn : VListNthState
  output:
    out : Value
  logic:
    out = match vn.vs:
      VLCons(head, tail) => if vn.k == 0 then head else vlist_nth(VListNthState { vs: tail, k: vn.k - 1 })
      VLNil => Value::VNum { n: 0 }
  proofs:
    purity:
      reads : [vn.vs, vn.k]
      calls : [vlist_nth]
    termination:
      bound : 4000


-- find_variant_index's input: a variant list + source + a query variant-name span +
-- the running 0-based index. Mirror of FindConceptIdxState but over a VariantList.
concept FindVarIdxState
  @intention: "A variant list + the source + a query variant-name span + the running index"
  @source: vexprparse.intent:36
  fields:
    variants : VariantList
    src : text [..256]
    q_start : number [0, 4000000]
    q_len : number [0, 4000000]
    idx : number [0, 4000000]


-- find_variant_index: the 0-based position of the variant whose name byte-equals the
-- query span (999999 if none). Mirror of find_concept_index over a VariantList.
rule find_variant_index
  @intention: "The 0-based position of the variant whose name matches the query span (999999 if none)"
  @source: vexprparse.intent:36
  input:
    fvi : FindVarIdxState
  output:
    out : number
  logic:
    out = match fvi.variants:
      VarCons(name_start, name_len, payload, rest) => if name_len == fvi.q_len and name_eq(NameEqState { src: fvi.src, a_start: name_start, b_start: fvi.q_start, len: fvi.q_len, off: 0 }) == 1 then fvi.idx else find_variant_index(FindVarIdxState { variants: rest, src: fvi.src, q_start: fvi.q_start, q_len: fvi.q_len, idx: fvi.idx + 1 })
      VarNil => 999999
  proofs:
    purity:
      reads : [fvi.variants, fvi.src, fvi.q_start, fvi.q_len, fvi.idx]
      calls : [name_eq, find_variant_index]
    termination:
      bound : 4000


-- variant_tag's input: the concept list + source + the concept-name span + the
-- variant-name span of a construction `Concept::Variant`.
concept VariantTagState
  @intention: "The concept list + source + a concept-name span + a variant-name span, for computing a variant identity tag"
  @source: vexprparse.intent:36
  fields:
    concepts : ConceptList
    src : text [..256]
    cstart : number [0, 4000000]
    clen : number [0, 4000000]
    vstart : number [0, 4000000]
    vlen : number [0, 4000000]


-- variant_tag: a variant construction's identity tag = concept_index * 256 +
-- variant_index, both resolved against the parsed ConceptList of the interpreted
-- source (no global table). At a match, the scrutinee VData carries this tag; the
-- dispatch recovers concept_index = tag / 256 and recomputes each arm's tag to
-- compare. Non-recursive (bound-only). 256 > the max variants of any one concept.
-- Records-arc slice 2: a record construction `Foo { a, b }` parses to
-- AstVariant(Foo, Foo, fields) — the variant span equals the concept name. Foo is a
-- record, so its VariantList is empty and find_variant_index returns 999999 (no such
-- variant). In that case the tag defaults to concept_index * 256 + 0 (variant-index
-- 0 for the sole record shape), so AstField eval recovers the concept from tag / 256.
-- Real variants always resolve (vidx < 999999), so their tag is unperturbed.
rule variant_tag
  @intention: "A variant construction's identity tag: concept_index * 256 + variant_index"
  @source: vexprparse.intent:36
  input:
    vt : VariantTagState
  output:
    out : number
  logic:
    let cidx = find_concept_index(FindConceptIdxState { concepts: vt.concepts, src: vt.src, q_start: vt.cstart, q_len: vt.clen, idx: 0 })
    let variants = cd_variants(concept_at_index(ConceptAtState { concepts: vt.concepts, idx: cidx }))
    let vidx = find_variant_index(FindVarIdxState { variants: variants, src: vt.src, q_start: vt.vstart, q_len: vt.vlen, idx: 0 })
    out = if vidx == 999999 and variant_list_len(variants) == 0 then cidx * 256 else cidx * 256 + vidx
  proofs:
    purity:
      reads : [vt.concepts, vt.src, vt.cstart, vt.clen, vt.vstart, vt.vlen]
      calls : [find_concept_index, find_variant_index, cd_variants, concept_at_index, variant_list_len]
    termination:
      bound : 64


-- bind_val_binders's input: a match arm's positional binder list + the scrutinee's
-- payload value-list (walked in step) + the enclosing VEnv to extend.
concept BindValState
  @intention: "A match arm's binders + the scrutinee payload values + the env to extend"
  @source: vexprparse.intent:36
  fields:
    binders : BinderList
    payload : ValueList
    env : VEnv


-- bind_val_binders: extend the interpreter env by binding each positional arm binder
-- to the corresponding payload Value (walking binders and payload in step). Mirror of
-- the type checker's bind_binders, but binds VALUES not type codes. BindNil returns
-- the env unchanged. Bound-only termination + breadcrumb.
rule bind_val_binders
  @intention: "Extend an interpreter env by binding each match-arm binder to its scrutinee payload value"
  @source: vexprparse.intent:36
  input:
    bv : BindValState
  output:
    out : VEnv
  logic:
    out = match bv.binders:
      BindCons(start, len, rest) => VEnv::VECons { name_start: start, name_len: len, val: vl_head(bv.payload), rest: bind_val_binders(BindValState { binders: rest, payload: vl_tail(bv.payload), env: bv.env }) }
      BindNil => bv.env
  proofs:
    purity:
      reads : [bv.binders, bv.payload, bv.env]
      calls : [vl_head, vl_tail, bind_val_binders]
    termination:
      bound : 4000


-- eval_vfields's input: a variant construction's field list + the env + source +
-- program + concept list. Evaluates each field's RHS to a Value in source order.
concept EvalVFieldsState
  @intention: "A variant's field-init list + the env + source + program + concept list, for evaluating the payload"
  @source: vexprparse.intent:36
  fields:
    fields : VFieldList
    env : VEnv
    src : text [..256]
    prog : RuleList
    concepts : ConceptList


-- eval_vfields: evaluate a variant construction's field initializers into a ValueList
-- (in source order). In the eval SCC (calls eval_ast_env). Bound-only + breadcrumb.
rule eval_vfields
  @intention: "Evaluate a variant construction's field initializers into a value-list"
  @source: vexprparse.intent:36
  input:
    ev : EvalVFieldsState
  output:
    out : ValueList
  logic:
    out = match ev.fields:
      VFCons(name_start, name_len, val, rest) => ValueList::VLCons { head: eval_ast_env(EvalEnvArg { node: val, env: ev.env, src: ev.src, prog: ev.prog, concepts: ev.concepts }), tail: eval_vfields(EvalVFieldsState { fields: rest, env: ev.env, src: ev.src, prog: ev.prog, concepts: ev.concepts }) }
      VFNil => ValueList::VLNil
  proofs:
    purity:
      reads : [ev.fields, ev.env, ev.src, ev.prog, ev.concepts]
      calls : [eval_ast_env, eval_vfields]
    termination:
      bound : 4000


-- eval_match's input: the already-evaluated scrutinee Value + the arm list + the env
-- + source + program + concept list.
concept EvalMatchState
  @intention: "The scrutinee value + the match arms + the env + source + program + concept list"
  @source: vexprparse.intent:36
  fields:
    scrutval : Value
    arms : ArmList
    env : VEnv
    src : text [..256]
    prog : RuleList
    concepts : ConceptList


-- eval_match: dispatch a match. Recover the scrutinee's tag (stag) and its concept
-- index (stag / 256); the concept's VariantList resolves each arm's variant name to a
-- tag (cidx * 256 + variant_index). The FIRST arm whose tag equals stag wins: bind
-- its binders positionally to the scrutinee's payload (bind_val_binders) and evaluate
-- its body against the extended env. No arm matches (or a non-variant scrutinee) ->
-- VNum 0 (total). In the eval SCC (calls eval_ast_env). Bound-only + breadcrumb.
rule eval_match
  @intention: "Dispatch a match to the arm whose variant tag equals the scrutinee's, binding binders to the payload"
  @source: vexprparse.intent:36
  input:
    em : EvalMatchState
  output:
    out : Value
  logic:
    let stag = vdata_tag(em.scrutval)
    let cidx = stag / 256
    let variants = cd_variants(concept_at_index(ConceptAtState { concepts: em.concepts, idx: cidx }))
    out = match em.arms:
      ArmCons(vstart, vlen, binders, body, rest) => if cidx * 256 + find_variant_index(FindVarIdxState { variants: variants, src: em.src, q_start: vstart, q_len: vlen, idx: 0 }) == stag then eval_ast_env(EvalEnvArg { node: body, env: bind_val_binders(BindValState { binders: binders, payload: vdata_payload(em.scrutval), env: em.env }), src: em.src, prog: em.prog, concepts: em.concepts }) else eval_match(EvalMatchState { scrutval: em.scrutval, arms: rest, env: em.env, src: em.src, prog: em.prog, concepts: em.concepts })
      ArmNil => Value::VNum { n: 0 }
  proofs:
    purity:
      reads : [em.scrutval, em.arms, em.env, em.src, em.prog, em.concepts]
      calls : [vdata_tag, cd_variants, concept_at_index, find_variant_index, eval_ast_env, bind_val_binders, vdata_payload, eval_match]
    termination:
      bound : 4000


-- eval_block: the brick-10 money-shot driver. Tokenize the block-body source
-- (column-0 lines) with indentation, parse a statement block from index 0, build
-- the environment from its bindings (in order, each RHS resolved against the env
-- so far), then evaluate the block's final out-expression against that env. The
-- result is a real NUMBER — a let-block interpreter written in Verbose.
--
--   eval_block("let x = 1\nlet y = x + 1\nout = y") = 2
--
-- NATIVE-ONLY for newline-bearing sources (the interpreter's JSON reader does not
-- decode \n into a real byte 10 — see count_cells_src). Single-line, zero-binding
-- sources (e.g. "out = 2 + 3 * 4" — but a bare expression like "2 + 3 * 4" also
-- works: parse_stmts treats the leading non-`let` token as the out_stmt's IDENT
-- and parses the value from headp+2, so a single expression with no `name =`
-- prefix lands as the result with an empty binding list) cross-check native vs
-- interpreter. eval_block takes a ScanState (source + pos) like eval_expr, so the
-- source is argv arg 1 and pos is argv arg 2 (always 0).
rule eval_block
  @intention: "Tokenize, parse, build the environment, and evaluate a let-block to a number"
  @source: vexprparse.intent:29
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let pb = parse_block(ParseState { cell: toks })
    let blk = pb_block(pb)
    let binds = block_binds(blk)
    let result = block_result(blk)
    let env = build_env(BuildEnvArg { binds: binds, env: VEnv::VENil, src: s.source, prog: RuleList::RNil, concepts: ConceptList::CNil })
    out = vnum_of(eval_ast_env(EvalEnvArg { node: result, env: env, src: s.source, prog: RuleList::RNil, concepts: ConceptList::CNil }))
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_block, pb_block, block_binds, block_result, build_env, eval_ast_env, vnum_of]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 11: parse a top-level `rule` declaration with a `logic:` block. This
-- lifts the parser from a bare statement-block (brick 9/10) to a real top-level
-- PROGRAM item: a named rule whose body is a logic block. The grammar mirrors
-- src/parser.rs's parse_rule, restricted to the tractable subset:
--
--   rule_decl = 'rule' IDENT Newline Indent
--                 'logic' ':' Newline Indent
--                   <stmt_seq>          -- the brick-9 (let ...)* out = ... body
--                 Dedent Dedent
--
-- WHAT IS PARSED (the subset). Only the `rule` keyword, the rule NAME, and the
-- `logic:` section. No @intention / @source / input: / output: / proofs: — those
-- are later bricks. The point of brick 11 is the HEADER (the `rule NAME` line and
-- the nested `logic:` indent framing) plus delegating the body to the brick-9
-- block parser.
--
-- `rule` AND `logic` ARE PLAIN IDENTS (no keyword code). The tokenizer's
-- keyword_code only classifies if/or/of/let/and/not/then/else/true/false; `rule`
-- and `logic` lex as ordinary Ident tokens (kind 100). So the parser recognizes
-- them by BYTE COMPARISON of the Ident's source span against the literal bytes
-- "rule" (r=114 u=117 l=108 e=101) and "logic" (l=108 o=111 g=103 i=105 c=99).
-- This is why the rule-parsing rules carry `src` (the source text) ALONGSIDE the
-- token list: the byte comparison reads the actual source bytes the Ident's span
-- points at. span_is_rule / span_is_logic are flat fixed-width byte checks (like
-- the tokenizer's kw4 / kw5), not recursions.
--
-- THE NESTED INDENT/DEDENT. The token stream for `rule f\n  logic:\n    out=...`
-- is (verified via kind_at_indent):
--   0 Ident"rule"  1 Ident"f"  2 Newline  3 Indent      <- enter rule body
--   4 Ident"logic" 5 Op`:`(10) 6 Newline  7 Indent      <- enter logic body
--   8 <first stmt token> ...  Newline  Dedent Dedent Eof
-- parse_rule_decl consumes the two nested INDENTs by SKIPPING separators
-- (skip_seps skips Newline 600 AND Indent 700): after the name at index 1 it
-- skip_seps from 2 to land on `logic` (index 4); after the `:` at index 5 it
-- skip_seps from 6 to land on the first statement (index 8). The trailing two
-- DEDENTs need no explicit consumption — parse_stmts already STOPS its binding
-- sweep at a Dedent (800) or Eof (0), so the block body ends exactly there. This
-- reuses the framing-agnostic block parser unchanged (brick 9's design payoff).
--
-- HOW src IS THREADED. The brick-9 block parser threads only the TokenList. The
-- rule-header recognition needs the source text too, so parse_rule_decl takes a
-- RuleParseState { toks : TokenList, src : text } — a group field (the token
-- list) ALONGSIDE a text field (the source) — exactly the multi-field recursive
-- shape the 2b052a7 / 9529277 compiler fixes support. parse_rule_decl itself is
-- NOT recursive (it is a one-shot fixed-grammar parse delegating the body to the
-- self-recursive parse_stmts), so it carries bound-only termination with no
-- recursion breadcrumb.
--
-- VALIDATION. A RuleDecl carries a Block, so it is BOTH evaluable (brick 10) and
-- structurally checkable (brick 9):
--   * eval_rule_decl(source) parses the rule decl, extracts its body Block,
--     build_env's the bindings, and evaluates the result — proving the HEADER
--     parsed AND the body still evaluates correctly (the rule's `out` value).
--   * rule_shape(source) = 1000 * name_len + block_shape(body), proving the name
--     span length AND the body's structural signature (brick 9's block_shape).
-- Both are NATIVE-ONLY (the source is multi-line — the interpreter's JSON reader
-- does not decode \n into a real byte 10; see count_cells_src). Multi-line argv
-- via $'rule f\n  logic:\n    out = 2 + 3'.
--
-- Oracle: src/parser.rs's parse_rule (the `rule NAME` + `logic:` block shape).
-- ============================================================================

-- The rule-parse entry state: the whole token list plus the source text. The
-- token list drives the structural parse; the source text backs the byte
-- comparison that recognizes the `rule` / `logic` idents (which have no keyword
-- code). A group field (toks) + a text field (src) — the supported multi-field
-- shape.
concept RuleParseState
  @intention: "The token list cursor cell plus the source text, for parsing a rule declaration"
  @source: vexprparse.intent:30
  fields:
    cell : TokenList
    src : text [..256]


-- Brick 16: the parameter-list parse cursor — the token list plus the index at
-- which the parameter list (or its absence) begins. Same shape as ParseState; a
-- distinct name keeps parse_params's input self-documenting. parse_params reads
-- the token at `pos`: a '(' opens a comma-separated IDENT list; anything else
-- means "no parameters".
-- Brick 20: ParamParseState also carries the SOURCE TEXT so params_scan can read a
-- type-name Ident span (after a `:`) and map it to a type code via type_code_of_span.
concept ParamParseState
  @intention: "The token list cursor cell plus the source text, where a parameter list may begin"
  @source: vexprparse.intent:34
  fields:
    cell : TokenList
    src : text [..256]


-- A fixed-width span byte-check probe: the source text plus an Ident token's
-- span (start, len). span_is_rule / span_is_logic compare the span against a
-- fixed literal word, length first then each byte.
concept SpanCheck
  @intention: "Source text + an Ident span, for byte-comparing it to a fixed keyword"
  @source: vexprparse.intent:30
  fields:
    src : text [..256]
    start : number [0, 4000000]
    len : number [0, 4000000]


-- span_is_rule: 1 iff the span src[start..start+len] is exactly the 4 bytes
-- "rule" (r=114 u=117 l=108 e=101). Flat fixed-width check (like the tokenizer's
-- kw4), length-guarded first so a shorter/longer ident never reads past its span.
rule span_is_rule
  @intention: "1 if an Ident span spells exactly \"rule\", 0 otherwise"
  @source: vexprparse.intent:30
  input:
    sc : SpanCheck
  output:
    out : number
  logic:
    out = if sc.len == 4 and (byte_at(sc.src, sc.start) == 114 and (byte_at(sc.src, sc.start + 1) == 117 and (byte_at(sc.src, sc.start + 2) == 108 and byte_at(sc.src, sc.start + 3) == 101))) then 1 else 0
  proofs:
    purity:
      reads : [sc.src, sc.start, sc.len]
      calls : []
    termination:
      bound : 64


-- span_is_logic: 1 iff the span src[start..start+len] is exactly the 5 bytes
-- "logic" (l=108 o=111 g=103 i=105 c=99). Flat fixed-width check (like kw5).
rule span_is_logic
  @intention: "1 if an Ident span spells exactly \"logic\", 0 otherwise"
  @source: vexprparse.intent:30
  input:
    sc : SpanCheck
  output:
    out : number
  logic:
