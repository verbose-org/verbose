-- name_list_len (records-arc brick R5): the number of entries in a NameList.
-- Structural recursion on the NmCons tail (Phase C), like field_list_len.
rule name_list_len
  @intention: "Number of entries in a purity reads/calls name-list"
  @source: vexprparse.intent:30
  input:
    nl : NameList
  output:
    out : number
  logic:
    out = match nl:
      NmCons(start, len, rest) => 1 + name_list_len(rest)
      NmNil => 0
  proofs:
    purity:
      reads : [nl]
      calls : [name_list_len]
    termination:
      bound : 4000
      structural : nl


