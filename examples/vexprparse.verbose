  logic:
    out = match p:
      MkNames(names, next) => names
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


rule pn_next
  @intention: "The end cell (at the closing bracket) of a name-list parse result"
  @source: vexprparse.intent:30
  input:
    p : ParsedNames
  output:
    out : TokenList
  logic:
    out = match p:
      MkNames(names, next) => next
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


-- fl_head_start / fl_head_len / fl_head_ty (records-arc brick R5): the span + type
-- code of the HEAD field of a FieldList (0 for an empty list). Used to extract the
-- single `output:` field into the RuleDecl's out_name_start / out_name_len / out_ty.
rule fl_head_start
  @intention: "The name-span start of the head field of a field list (0 if empty)"
  @source: vexprparse.intent:30
  input:
    fl : FieldList
  output:
    out : number
  logic:
    out = match fl:
      FCons(name_start, name_len, ty, ty_start, ty_len, rest) => name_start
      FNil => 0
  proofs:
    purity:
      reads : [fl]
      calls : []
    termination:
      bound : 16


rule fl_head_len
  @intention: "The name-span length of the head field of a field list (0 if empty)"
  @source: vexprparse.intent:30
  input:
    fl : FieldList
  output:
    out : number
  logic:
    out = match fl:
      FCons(name_start, name_len, ty, ty_start, ty_len, rest) => name_len
      FNil => 0
  proofs:
    purity:
      reads : [fl]
      calls : []
    termination:
      bound : 16


rule fl_head_ty
  @intention: "The declared type code of the head field of a field list (0 if empty)"
  @source: vexprparse.intent:30
  input:
    fl : FieldList
  output:
    out : number
  logic:
    out = match fl:
      FCons(name_start, name_len, ty, ty_start, ty_len, rest) => ty
      FNil => 0
  proofs:
    purity:
      reads : [fl]
      calls : []
    termination:
      bound : 16


-- R6b: the type-NAME SPAN (start/len) of the head field of a field list (0 if
-- empty). Where fl_head_ty gives the lossy type CODE (concept names collapse to 0),
-- these give the SPAN so resolve_type can recover the concept identity against the
-- ConceptList at check time. Mirror of fl_head_start/len for the type span.
rule fl_head_ty_start
  @intention: "The type-name span start of the head field of a field list (0 if empty)"
  @source: vexprparse.intent:62
  input:
    fl : FieldList
  output:
    out : number
  logic:
    out = match fl:
      FCons(name_start, name_len, ty, ty_start, ty_len, rest) => ty_start
      FNil => 0
  proofs:
    purity:
      reads : [fl]
      calls : []
    termination:
      bound : 16


rule fl_head_ty_len
  @intention: "The type-name span length of the head field of a field list (0 if empty)"
  @source: vexprparse.intent:62
  input:
    fl : FieldList
  output:
    out : number
  logic:
    out = match fl:
      FCons(name_start, name_len, ty, ty_start, ty_len, rest) => ty_len
      FNil => 0
  proofs:
    purity:
      reads : [fl]
      calls : []
    termination:
      bound : 16


-- R6b: the TAIL of a field list (the fields after the head), or FNil when empty.
-- Used by bind_binders to walk a variant payload's FieldList in step with the arm's
-- positional BinderList. Mirror of ptail for parameters.
rule fl_tail
  @intention: "The tail of a field list (FNil if empty)"
  @source: vexprparse.intent:62
  input:
    fl : FieldList
  output:
    out : FieldList
  logic:
    out = match fl:
      FCons(name_start, name_len, ty, ty_start, ty_len, rest) => rest
      FNil => FieldList::FNil
  proofs:
    purity:
      reads : [fl]
      calls : []
    termination:
      bound : 16


-- Accessors for a ParsedParams result (block-form match only legal in final
-- position, so destructuring is factored into tiny rules — like parsed_args_*).
rule pp_params
  @intention: "The ParamList from a parameter-list parse result"
  @source: vexprparse.intent:34
  input:
    p : ParsedParams
  output:
    out : ParamList
  logic:
    out = match p:
      MkPP(params, next) => params
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


rule pp_next
  @intention: "The token index just past a parameter-list parse result"
  @source: vexprparse.intent:34
  input:
    p : ParsedParams
  output:
    out : TokenList
  logic:
    out = match p:
      MkPP(params, next) => next
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


-- params_prepend: cons the head parameter span onto the front of the already-
-- parsed REST of the parameter list, carrying the rest's end index through.
-- Splitting this out keeps the recursive params_scan call lazily inside the comma
-- branch (a let would force it eagerly) — the same shape as args_prepend.
-- Brick 20: ParamPrependState also carries head_ty — the head parameter's declared
-- type code — so params_prepend can cons it into the PCons it builds.
concept ParamPrependState
  @intention: "A head parameter span + its type code, plus the parsed rest of the parameter list"
  @source: vexprparse.intent:34
  fields:
    head_start : number
    head_len : number
    head_ty : number
    head_ty_start : number
    head_ty_len : number
    rest : ParsedParams


rule params_prepend
  @intention: "Cons a parameter span (with its type code) onto the front of the parsed rest of the list"
  @source: vexprparse.intent:34
  input:
    pps : ParamPrependState
  output:
    out : ParsedParams
  logic:
    let rest_list = pp_params(pps.rest)
    let rest_next = pp_next(pps.rest)
    out = ParsedParams::MkPP { params: ParamList::PCons { name_start: pps.head_start, name_len: pps.head_len, ty: pps.head_ty, ty_start: pps.head_ty_start, ty_len: pps.head_ty_len, rest: rest_list }, next: rest_next }
  proofs:
    purity:
      reads : [pps.head_start, pps.head_len, pps.head_ty, pps.head_ty_start, pps.head_ty_len, pps.rest]
      calls : [pp_params, pp_next]
    termination:
      bound : 16


-- params_scan: parse a NON-EMPTY comma-separated parameter list starting at the
-- FIRST parameter's token index `ps.pos`. Brick 20 makes each parameter OPTIONALLY
-- TYPED: `IDENT` (untyped) OR `IDENT : TYPENAME` (typed). In the token stream a
-- typed param is THREE tokens (name, `:` op-10, typename-IDENT) before the
-- separator; an untyped param is ONE token before it.
--
-- Read the name IDENT span at ps.pos. Peek ps.pos+1: if it is `:` (op 10) the param
-- is typed — read the TYPENAME span at ps.pos+2 and map it to a code via
-- type_code_of_span (reading ps.src); the separator is at ps.pos+3. Otherwise the
-- param is untyped (ty defaults to 0 = number) and the separator is at ps.pos+1.
-- Then the brick-16 separator dispatch on that separator position: a ',' (op 11)
-- continues — parse the REST (LAZILY, in the then branch) from just past the comma
-- and prepend this param; a ')' (op 22) stops, consuming it (next = sep_pos + 1);
-- anything else stops too (missing ')' tolerated, like args_cons), leaving
-- next = sep_pos. When UNTYPED, sep_pos = ps.pos + 1 and this reduces EXACTLY to the
-- brick-16 behavior (close_next = pos+2 on ')', else pos+1; comma-continue from
-- pos+2), so untyped lists parse byte-identically to before. Recurses over a forward
-- token scan (no structural FIELD fits), so bound + the mandatory recursion
-- breadcrumb (the backstop is the finite token list, bounded by max_nodes). Every
-- peek is OOB-guarded by the token-list accessors (Eof past the end).
rule params_scan
  @intention: "Parse a non-empty comma-separated list of optionally-typed params, consuming the ')'"
  @source: vexprparse.intent:38
  input:
    ps : ParamParseState
  output:
    out : ParsedParams
  logic:
    let name_start = peek_start(ps.cell)
    let name_len = peek_len(ps.cell)
    let colon_opc = peek_op_code(advance(Advance { lst: ps.cell, k: 1 }))
    let typed = if colon_opc == 10 then 1 else 0
    let ty_start = if typed == 1 then peek_start(advance(Advance { lst: ps.cell, k: 2 })) else 0
    let ty_len = if typed == 1 then peek_len(advance(Advance { lst: ps.cell, k: 2 })) else 0
    let ty = if typed == 1 then type_code_of_span(SpanCheck { src: ps.src, start: ty_start, len: ty_len }) else 0
    let sep_pos = if typed == 1 then advance(Advance { lst: ps.cell, k: 3 }) else advance(Advance { lst: ps.cell, k: 1 })
    let sep_opc = peek_op_code(sep_pos)
    let iscomma = if sep_opc == 11 then 1 else 0
    let close_next = if sep_opc == 22 then advance(Advance { lst: sep_pos, k: 1 }) else sep_pos
    out = if iscomma == 1 then params_prepend(ParamPrependState { head_start: name_start, head_len: name_len, head_ty: ty, head_ty_start: ty_start, head_ty_len: ty_len, rest: params_scan(ParamParseState { cell: advance(Advance { lst: sep_pos, k: 1 }), src: ps.src }) }) else ParsedParams::MkPP { params: ParamList::PCons { name_start: name_start, name_len: name_len, ty: ty, ty_start: ty_start, ty_len: ty_len, rest: ParamList::PNil }, next: close_next }
  proofs:
    purity:
      reads : [ps.cell, ps.src]
      calls : [peek_start, peek_len, peek_op_code, type_code_of_span, params_prepend, params_scan, advance]
    termination:
      bound : 512


-- parse_params: parse an OPTIONAL parameter list starting at ps.pos (the token
-- right AFTER a rule's name). Three cases, in order:
--   * token at pos is NOT '(' (op 21): no parens at all -> PNil, next = pos
--     unchanged (the caller continues to `logic:` from there).
--   * token at pos IS '(' and the next token is ')' (op 22): empty param list
--     `()` -> PNil, next = pos + 2 (past both parens).
--   * otherwise: a non-empty list -> params_scan from pos + 1 (the first IDENT).
-- Mirrors parse_args's '(' / ')' / first-arg dispatch, but builds a ParamList of
-- bare name spans instead of an ArgList of AST nodes. One-shot dispatch (the
-- recursion lives in params_scan); bound-only termination.
rule parse_params
  @intention: "Parse an optional '(' name, name, ... ')' parameter list into a ParamList + end index"
  @source: vexprparse.intent:34
  input:
    ps : ParamParseState
  output:
    out : ParsedParams
  logic:
    let opc = peek_op_code(ps.cell)
    let isopen = if opc == 21 then 1 else 0
    let next_opc = peek_op_code(advance(Advance { lst: ps.cell, k: 1 }))
    let isempty = if next_opc == 22 then 1 else 0
    out = if isopen == 0 then ParsedParams::MkPP { params: ParamList::PNil, next: ps.cell } else (if isempty == 1 then ParsedParams::MkPP { params: ParamList::PNil, next: advance(Advance { lst: ps.cell, k: 2 }) } else params_scan(ParamParseState { cell: advance(Advance { lst: ps.cell, k: 1 }), src: ps.src }))
  proofs:
    purity:
      reads : [ps.cell, ps.src]
      calls : [peek_op_code, params_scan, advance]
    termination:
      bound : 16


-- parse_rule_decl: parse ONE top-level rule declaration into a RuleDecl. The
-- grammar is fixed, so positions are computed by skipping separators rather than
-- re-validated token by token:
--   * index 0 is the `rule` Ident, RECOGNIZED by byte-comparing its span against
--     "rule" (span_is_rule, reading rp.src). The keyword `rule` has no keyword
--     code, so this byte check is how the header is recognized at all.
--   * the NAME is the Ident at index 1; its span is (peek_start 1, peek_len 1).
--   * skip_seps from index 2 skips Newline + the rule-body Indent, landing on the
--     `logic` Ident (index 4 in the canonical stream), RECOGNIZED by byte-
--     comparing its span against "logic" (span_is_logic, also via rp.src).
--   * the `:` is at logic_idx + 1; skip_seps from logic_idx + 2 skips Newline +
--     the logic-body Indent, landing on the first statement token (index 8).
--   * parse_stmts parses the body block from there; it stops at the trailing
--     Dedent/Eof, so the two closing DEDENTs need no explicit consumption.
-- FAIL-GRACEFUL: a Verbose rule is total, so a malformed header cannot abort.
-- When BOTH byte checks pass (`hdr_ok == 1`) the body is the parsed block;
-- otherwise the body is an empty block (BNil result AstErr) — eval_rule_decl
-- then yields 0 and rule_shape yields name-band-only, a distinguishable signal
-- rather than a crash. One-shot (not self-recursive); delegates the body to the
-- self-recursive parse_stmts. Bound-only termination, no recursion breadcrumb.
rule parse_rule_decl
  @intention: "Parse a `rule NAME` + `logic:` block into a RuleDecl (byte-recognizing the rule/logic idents)"
  @source: vexprparse.intent:30
  input:
    rp : RuleParseState
  output:
    out : RuleDecl
  logic:
    let name_start = peek_start(advance(Advance { lst: rp.cell, k: 1 }))
    let name_len = peek_len(advance(Advance { lst: rp.cell, k: 1 }))
    let kw_start = peek_start(rp.cell)
    let kw_len = peek_len(rp.cell)
    let is_rule = span_is_rule(SpanCheck { src: rp.src, start: kw_start, len: kw_len })
    let pp = parse_params(ParamParseState { cell: advance(Advance { lst: rp.cell, k: 2 }), src: rp.src })
    let params = pp_params(pp)
    let after_params = pp_next(pp)
    let ret_colon = peek_op_code(after_params)
    let typed_ret = if ret_colon == 10 then 1 else 0
    let ret_ty_start = peek_start(advance(Advance { lst: after_params, k: 1 }))
    let ret_ty_len = peek_len(advance(Advance { lst: after_params, k: 1 }))
    let return_type = if typed_ret == 1 then type_code_of_span(SpanCheck { src: rp.src, start: ret_ty_start, len: ret_ty_len }) else 9
    let after_ret = if typed_ret == 1 then advance(Advance { lst: after_params, k: 2 }) else after_params
    let scan0 = skip_seps(ParseState { cell: after_ret })
    let logic_idx = if is_rule == 1 then seek_logic(ProgramState { cell: scan0, src: rp.src }) else scan0
    let logic_start = peek_start(logic_idx)
    let logic_len = peek_len(logic_idx)
    let is_logic = span_is_logic(SpanCheck { src: rp.src, start: logic_start, len: logic_len })
    let hdr_ok = if is_rule == 1 and is_logic == 1 then 1 else 0
    let body_idx = skip_seps(ParseState { cell: advance(Advance { lst: logic_idx, k: 2 }) })
    let pb = parse_stmts(ParseState { cell: body_idx })
    let goodblk = pb_block(pb)
    out = RuleDecl::MkRule { name_start: name_start, name_len: name_len, params: params, return_type: return_type, body: if hdr_ok == 1 then goodblk else Block::MkBlock { binds: Binding::BNil, result: Ast::AstErr }, input: FieldList::FNil, out_name_start: 0, out_name_len: 0, out_ty: 0, out_ty_start: 0, out_ty_len: 0, proofs: Proofs::MkProofs { reads: NameList::NmNil, calls: NameList::NmNil, term_kind: 0, term_bound: 0, term_field_start: 0, term_field_len: 0 } }
  proofs:
    purity:
      reads : [rp.cell, rp.src]
      calls : [peek_start, peek_len, span_is_rule, parse_params, pp_params, pp_next, peek_op_code, type_code_of_span, span_is_logic, skip_seps, seek_logic, parse_stmts, pb_block, advance]
    termination:
      bound : 64


-- eval_rule_decl: the brick-11 money-shot driver. Tokenize the rule-declaration
-- source (with indentation), parse the rule decl, extract its body Block, build
-- the environment from the body's bindings (in order, each RHS against the env so
-- far), and evaluate the body's final out-expression against that env. The result
-- is the rule's `out` value — proving the HEADER parsed AND the body evaluates.
--
--   eval_rule_decl("rule add\n  logic:\n    let x = 5\n    out = x + 1") = 6
--
-- NATIVE-ONLY (multi-line source — the interpreter's JSON reader does not decode
-- \n; see count_cells_src). Takes a ScanState (source + pos) like eval_block, so
-- the source is argv arg 1 and pos is argv arg 2 (always 0).
rule eval_rule_decl
  @intention: "Tokenize, parse a rule decl, build the environment, and evaluate its body to a number"
  @source: vexprparse.intent:30
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let rd = parse_rule_decl(RuleParseState { cell: toks, src: s.source })
    let blk = rd_body(rd)
    let binds = block_binds(blk)
    let result = block_result(blk)
    let env = build_env(BuildEnvArg { binds: binds, env: VEnv::VENil, src: s.source, prog: RuleList::RNil, concepts: ConceptList::CNil })
    out = vnum_of(eval_ast_env(EvalEnvArg { node: result, env: env, src: s.source, prog: RuleList::RNil, concepts: ConceptList::CNil }))
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_rule_decl, rd_body, block_binds, block_result, build_env, eval_ast_env, vnum_of]
    termination:
      bound : 256


-- rule_shape: the brick-11 STRUCTURAL oracle. Tokenize, parse the rule decl, and
-- return 1000 * name_len + block_shape(body). The 1000 band carries the rule
-- NAME's span length (every test name is < 1000 chars and block_shape's smallest
-- nonzero contribution is shape_ast >= 0, with the binding-count band at 1000000
-- well clear), so a single number certifies the name length AND the full body
-- structure (binding count, per-binding RHS shapes, result shape). NATIVE-ONLY.
rule rule_shape
  @intention: "Parse a rule decl and return 1000*name_len + block_shape(body)"
  @source: vexprparse.intent:30
  input:
    a : IndentSrc
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: a.source, pos: 0 })
    let rd = parse_rule_decl(RuleParseState { cell: toks, src: a.source })
    let nlen = rd_name_len(rd)
    let blk = rd_body(rd)
    let binds = block_binds(blk)
    let result = block_result(blk)
    out = 1000 * nlen + (1000000 * count_binds(binds) + (shape_binds(binds) + shape_ast(result)))
  proofs:
    purity:
      reads : [a.source]
      calls : [begin_tokenize, parse_rule_decl, rd_name_len, rd_body, block_binds, block_result, count_binds, shape_binds, shape_ast]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 12: parse a PROGRAM = a SEQUENCE of top-level rule declarations.
--
-- This lifts the parser from ONE rule decl (brick 11) to a whole (rule-only)
-- program. The grammar:
--
--   program   = rule_decl*
--   rule_decl = 'rule' IDENT Newline Indent 'logic' ':' Newline Indent <stmts> Dedent Dedent
--
-- TOKEN STREAM at a rule boundary (hand-traced for two rules whose bodies are at
-- column 4, logic: at column 2, rule at column 0):
--
--   rule f          rule(0) f(1) Nl(2)
--     logic:        Indent(3) logic(4) :(5) Nl(6)
--       out = 2+3   Indent(7) out(8) =(9) 2(10) +(11) 3(12) Nl(13)
--   rule g          Dedent(14) Dedent(15) rule(16) g(17) Nl(18)
--     logic:        Indent(19) logic(20) :(21) Nl(22)
--       ...         Indent(23) ... Nl  ...  Dedent Dedent Eof
--
-- So rule f's body parse (parse_stmts from idx 8) parses `out = 2 + 3` and STOPS
-- at the Dedent(14) — its pb_next is 13 (just past the `3` at idx 12, before the
-- Newline). Between that end position and the next `rule` keyword (idx 16) sit:
-- Newline(13) Dedent(14) Dedent(15). The program loop must skip ALL of these
-- (Newline + Indent + Dedent) to reach the next `rule`. skip_seps (brick 9) stops
-- at a Dedent (it only skips Newline 600 / Indent 700), so brick 12 adds
-- skip_seps_dedent, which ALSO skips Dedent 800 — landing on the next lexeme
-- (`rule`) or the trailing Eof.
--
-- POSITION THREADING (option a). parse_rule_decl (brick 11) returns a RuleDecl
-- but NOT where it stopped; to parse a sequence we need both. Brick 12 adds
-- parse_rule_decl_pos, which takes a ProgramState (toks + src + a START position
-- p) and returns a ParsedRule = MkPR(rule, next). It generalizes the brick-11
-- offsets — which assumed the `rule` keyword sits at index 0 — to start at p:
-- keyword at p, name at p+1, skip_seps from p+2 to `logic`, `:` at logic_idx+1,
-- skip_seps from logic_idx+2 to the first body token, parse_stmts from there.
-- `next` is the body block's pb_next. Brick 11's parse_rule_decl stays untouched
-- (the p=0 special case) so its drivers (eval_rule_decl / rule_shape) do not
-- regress.
--
-- VALIDATION DRIVERS:
--   * count_rules(source)         = length of the parsed RuleList (the program
--                                   split into the right number of rule decls).
--   * eval_nth_rule(source, n)    = evaluate the body of the n-th rule decl
--                                   (build_env + eval its Block result), proving
--                                   each rule parsed AND its body is intact.
-- Both NATIVE-ONLY (multi-line source — the interpreter's JSON reader does not
-- decode \n; see count_cells_src).
--
-- Oracle: src/parser.rs's top-level item loop (parse a `rule`, push, repeat).
-- ============================================================================

-- The program-parse entry/cursor state: the whole token list, the source text
-- (backs the byte recognition of the `rule` keyword), and the current scan index.
-- A group field (toks) + a text field (src) + a number (pos) — the supported
-- multi-field shape (same as RuleParseState plus a cursor).
concept ProgramState
  @intention: "The token list cursor cell plus the source text, for parsing a program"
  @source: vexprparse.intent:31
  fields:
    cell : TokenList
    src : text [..256]


-- The eval-nth-rule driver state: a multi-line source plus the rule index n.
concept EvalNthState
  @intention: "A program source plus the index of the rule decl to evaluate"
  @source: vexprparse.intent:31
  fields:
    source : text [..256]
    n : number [0, 4000000]


-- The block-skip cursor state (records-arc brick R2): the current token cell plus a
-- running INDENT/DEDENT depth and a `seen` flag (1 once at least one Indent has been
-- consumed). skip_indented_block walks tokens, +1 on Indent, -1 on Dedent, and stops
-- the moment depth returns to 0 AFTER an Indent was seen — i.e. it has skipped one
-- balanced INDENT…DEDENT block. depth never reaches a recursive call as a negative
-- value: every call site starts the walk on a header line whose first structural
-- token is an Indent (the body opener), so a Dedent can only fire after seen == 1.
concept SkipBlockState
  @intention: "A token cursor plus the running indent depth and seen-an-indent flag, for skipping a block"
  @source: vexprparse.intent:63
  fields:
    cell : TokenList
    depth : number [0, 4000000]
    seen : number [0, 4000000]


-- skip_seps_dedent: advance past any leading SEPARATOR token — Newline (600),
-- Indent (700), OR Dedent (800) — starting at st.pos, returning the index of the
-- first non-separator token (a lexeme such as `rule`, or the trailing Eof 0).
-- Brick 9's skip_seps stops at a Dedent because INSIDE a block the Dedent is the
-- block terminator; at the PROGRAM level the Dedents that close one rule's body
-- are just noise between two sibling rule decls, so the program loop skips them
-- too. Same forward-index recursion as skip_seps (strictly advancing toward the
-- finite end of the token list); bound + the mandatory recursion breadcrumb (the
-- backstop is the finite token-list length, bounded by max_nodes).
rule skip_seps_dedent
  @intention: "The cell at the first non-separator token at/after the cursor (skips Newline/Indent/Dedent)"
  @source: vexprparse.intent:31
  input:
    st : ParseState
  output:
    out : TokenList
  logic:
    let knd = peek_kind(st.cell)
    let issep = if knd == 600 then 1 else if knd == 700 then 1 else if knd == 800 then 1 else 0
    out = if issep == 1 then skip_seps_dedent(ParseState { cell: advance(Advance { lst: st.cell, k: 1 }) }) else st.cell
  proofs:
    purity:
      reads : [st.cell]
      calls : [peek_kind, skip_seps_dedent, advance]
    termination:
      bound : 512


-- skip_indented_block (records-arc brick R2): given a cursor positioned AT a
-- block-header line (a top-level `concept_group` / `concept` / `rule` keyword, or a
-- rule's `input:` / `output:` / `logic:` / `proofs:` header), advance past that
-- header's WHOLE indented body and return the cell just past the matching DEDENT —
-- i.e. the next sibling item at the same (or a shallower) column. It tracks a depth
-- counter: +1 per Indent (700), -1 per Dedent (800), `seen` set once the first
-- Indent is consumed. The walk stops the instant depth returns to 0 after `seen`,
-- returning `nxt` (the cell after the closing Dedent). Eof (kind 0, which also covers
-- a Nil cell via head_tok) is a hard backstop. Header-line lexemes before the first
-- Indent (e.g. the `[max_depth: …]` of a group, or the `IDENT : TYPE` of a field) are
-- passed through untouched — only Indent/Dedent move the counter. Trailing Dedents
-- beyond the matched one are left for the caller's skip_seps_dedent to swallow, so an
-- off-by-a-separator never drops a sibling. Forward-index recursion (strictly toward
-- the finite token end); bound + the mandatory recursion breadcrumb (the backstop is
-- the finite token list, bounded by max_nodes).
rule skip_indented_block
  @intention: "Skip a header line and its whole indented block, returning the next sibling cell"
  @source: vexprparse.intent:63
  input:
    bs : SkipBlockState
  output:
    out : TokenList
  logic:
    let knd = peek_kind(bs.cell)
    let nxt = advance(Advance { lst: bs.cell, k: 1 })
    let is_indent = if knd == 700 then 1 else 0
    let is_dedent = if knd == 800 then 1 else 0
    let is_eof = if knd == 0 then 1 else 0
    let ndepth = if is_indent == 1 then bs.depth + 1 else if is_dedent == 1 then bs.depth - 1 else bs.depth
    let nseen = if is_indent == 1 then 1 else bs.seen
    let closed = if nseen == 1 then (if ndepth == 0 then 1 else 0) else 0
    out = if is_eof == 1 then bs.cell else if closed == 1 then nxt else skip_indented_block(SkipBlockState { cell: nxt, depth: ndepth, seen: nseen })
  proofs:
    purity:
      reads : [bs.cell, bs.depth, bs.seen]
      calls : [peek_kind, advance, skip_indented_block]
    termination:
      bound : 4000000


-- seek_logic (records-arc brick R2): from a cursor at the first block-header inside a
-- rule body (after the `rule NAME` header, the params, and the return type), scan
-- FORWARD over the rule's pre-logic blocks (`input:` / `output:`, and any other col-2
-- header that is not `logic`) and return the cell at the `logic` header. After R2.a
-- strips the `@intention` / `@source` LINES at tokenization, the blocks that remain
-- to skip are `input:` and `output:`. Each non-logic header is skipped whole via
-- skip_indented_block (header line + its indented body), landing on the next sibling
-- header; the walk stops at `logic` (span_is_logic) or at Eof (kind 0) as a backstop.
-- Toy grammars whose `logic:` is the FIRST header return immediately (is_logic == 1),
-- so the pre-R2 single-rule drivers stay byte-identical. Forward recursion (each step
-- advances past one whole block toward the finite token end); bound + the mandatory
-- recursion breadcrumb.
rule seek_logic
  @intention: "Scan past a rule's pre-logic header blocks and return the cell at the logic header"
  @source: vexprparse.intent:63
  input:
    ps : ProgramState
  output:
    out : TokenList
  logic:
    let hstart = peek_start(ps.cell)
    let hlen = peek_len(ps.cell)
    let is_logic = span_is_logic(SpanCheck { src: ps.src, start: hstart, len: hlen })
    let knd = peek_kind(ps.cell)
    let is_eof = if knd == 0 then 1 else 0
    let skipped = skip_indented_block(SkipBlockState { cell: ps.cell, depth: 0, seen: 0 })
    out = if is_eof == 1 then ps.cell else (if is_logic == 1 then ps.cell else seek_logic(ProgramState { cell: skipped, src: ps.src }))
  proofs:
    purity:
      reads : [ps.cell, ps.src]
      calls : [peek_start, peek_len, span_is_logic, peek_kind, skip_indented_block, seek_logic]
    termination:
      bound : 4000000


-- Accessors for a ParsedRule (a block-form match is only legal in final position,
-- so destructuring is factored into tiny rules — like pb_block / pb_next).
rule pr_rule
  @intention: "The RuleDecl from a rule-decl parse result"
  @source: vexprparse.intent:31
  input:
    p : ParsedRule
  output:
    out : RuleDecl
  logic:
    out = match p:
      MkPR(rule, next) => rule
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


rule pr_next
  @intention: "The token index just past a rule-decl parse result"
  @source: vexprparse.intent:31
  input:
    p : ParsedRule
  output:
    out : TokenList
  logic:
    out = match p:
      MkPR(rule, next) => next
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


-- parse_rule_decl_pos: parse ONE top-level rule declaration STARTING at ps.pos,
-- returning a ParsedRule (the RuleDecl + the end index). The position-aware
-- generalization of brick 11's parse_rule_decl: every fixed offset (0, 1, 2)
-- becomes relative to the start position p = ps.pos.
--   * the `rule` keyword is at index p, recognized by byte-comparing its span to
--     "rule" (span_is_rule, reading ps.src).
--   * the NAME is the Ident at p+1; its span is (peek_start p+1, peek_len p+1).
--   * skip_seps from p+2 skips the Newline + the rule-body Indent, landing on the
--     `logic` Ident, recognized by byte-comparing its span to "logic".
--   * the `:` is at logic_idx+1; skip_seps from logic_idx+2 skips the Newline +
--     the logic-body Indent, landing on the first body statement token.
--   * parse_stmts parses the body block from there; it stops at the trailing
--     Dedent/Eof, and pb_next is the index just past the body's final expression.
-- FAIL-GRACEFUL like brick 11: when both byte checks pass the body is the parsed
-- block, else an empty block (BNil result AstErr). `next` is always the body's
-- pb_next, so the program loop advances even on a malformed header. One-shot
-- (delegates body recursion to parse_stmts); bound-only termination.
rule parse_rule_decl_pos
  @intention: "Parse a `rule NAME` + `logic:` block starting at ps.pos into a RuleDecl + end index"
  @source: vexprparse.intent:31
  input:
    ps : ProgramState
  output:
    out : ParsedRule
  logic:
    let kw_start = peek_start(ps.cell)
    let kw_len = peek_len(ps.cell)
    let is_rule = span_is_rule(SpanCheck { src: ps.src, start: kw_start, len: kw_len })
    let name_start = peek_start(advance(Advance { lst: ps.cell, k: 1 }))
    let name_len = peek_len(advance(Advance { lst: ps.cell, k: 1 }))
    let pp = parse_params(ParamParseState { cell: advance(Advance { lst: ps.cell, k: 2 }), src: ps.src })
    let params = pp_params(pp)
    let after_params = pp_next(pp)
    let ret_colon = peek_op_code(after_params)
    let typed_ret = if ret_colon == 10 then 1 else 0
    let ret_ty_start = peek_start(advance(Advance { lst: after_params, k: 1 }))
    let ret_ty_len = peek_len(advance(Advance { lst: after_params, k: 1 }))
    let return_type = if typed_ret == 1 then type_code_of_span(SpanCheck { src: ps.src, start: ret_ty_start, len: ret_ty_len }) else 9
    let after_ret = if typed_ret == 1 then advance(Advance { lst: after_params, k: 2 }) else after_params
    let scan0 = skip_seps(ParseState { cell: after_ret })
    let in_kw_start = peek_start(scan0)
    let in_kw_len = peek_len(scan0)
    let is_input = span_is_input(SpanCheck { src: ps.src, start: in_kw_start, len: in_kw_len })
    let in_body = skip_seps(ParseState { cell: advance(Advance { lst: scan0, k: 2 }) })
    let pin = parse_fields(FieldParseState { cell: in_body, src: ps.src })
    let input_fl = if is_input == 1 then pf_fields(pin) else FieldList::FNil
    let out_hdr = if is_input == 1 then skip_seps_dedent(ParseState { cell: pf_next(pin) }) else scan0
    let out_kw_start = peek_start(out_hdr)
    let out_kw_len = peek_len(out_hdr)
    let is_output = span_is_output(SpanCheck { src: ps.src, start: out_kw_start, len: out_kw_len })
    let out_body = skip_seps(ParseState { cell: advance(Advance { lst: out_hdr, k: 2 }) })
    let pout = parse_fields(FieldParseState { cell: out_body, src: ps.src })
    let out_fl = if is_output == 1 then pf_fields(pout) else FieldList::FNil
    let out_name_start = fl_head_start(out_fl)
    let out_name_len = fl_head_len(out_fl)
    let out_ty = fl_head_ty(out_fl)
    let out_ty_start = fl_head_ty_start(out_fl)
    let out_ty_len = fl_head_ty_len(out_fl)
    let logic_idx = if is_rule == 1 then seek_logic(ProgramState { cell: scan0, src: ps.src }) else scan0
    let logic_start = peek_start(logic_idx)
    let logic_len = peek_len(logic_idx)
    let is_logic = span_is_logic(SpanCheck { src: ps.src, start: logic_start, len: logic_len })
    let hdr_ok = if is_rule == 1 and is_logic == 1 then 1 else 0
    let body_idx = skip_seps(ParseState { cell: advance(Advance { lst: logic_idx, k: 2 }) })
    let pb = parse_stmts(ParseState { cell: body_idx })
    let goodblk = pb_block(pb)
    let logic_end = if is_rule == 1 then skip_indented_block(SkipBlockState { cell: logic_idx, depth: 0, seen: 0 }) else pb_next(pb)
    let after_logic = skip_seps_dedent(ParseState { cell: logic_end })
    let p2start = peek_start(after_logic)
    let p2len = peek_len(after_logic)
    let is_proofs = span_is_proofs(SpanCheck { src: ps.src, start: p2start, len: p2len })
    let proofs_parsed = if is_proofs == 1 then parse_proofs(ProgramState { cell: after_logic, src: ps.src }) else Proofs::MkProofs { reads: NameList::NmNil, calls: NameList::NmNil, term_kind: 0, term_bound: 0, term_field_start: 0, term_field_len: 0 }
    let endp = if is_proofs == 1 then skip_indented_block(SkipBlockState { cell: after_logic, depth: 0, seen: 0 }) else after_logic
    out = ParsedRule::MkPR { rule: RuleDecl::MkRule { name_start: name_start, name_len: name_len, params: params, return_type: return_type, body: if hdr_ok == 1 then goodblk else Block::MkBlock { binds: Binding::BNil, result: Ast::AstErr }, input: input_fl, out_name_start: out_name_start, out_name_len: out_name_len, out_ty: out_ty, out_ty_start: out_ty_start, out_ty_len: out_ty_len, proofs: proofs_parsed }, next: endp }
  proofs:
    purity:
      reads : [ps.cell, ps.src]
      calls : [peek_start, peek_len, span_is_rule, parse_params, pp_params, pp_next, peek_op_code, type_code_of_span, span_is_input, span_is_output, parse_fields, pf_fields, pf_next, fl_head_start, fl_head_len, fl_head_ty, fl_head_ty_start, fl_head_ty_len, span_is_logic, skip_seps, seek_logic, parse_stmts, pb_block, pb_next, skip_indented_block, skip_seps_dedent, span_is_proofs, parse_proofs, advance]
    termination:
      bound : 64


-- parse_program: parse a SEQUENCE of rule declarations starting at ps.pos into a
-- RuleList. The loop:
--   * skip_seps_dedent from ps.pos to the first significant token (a lexeme or
--     Eof), past any leftover Newline / Indent / Dedent that closes a prior rule.
--   * if that token's span spells `rule` (span_is_rule), parse one rule decl there
--     via parse_rule_decl_pos, then RCons it onto the recursive parse of the rest
--     starting at the rule decl's `next` index — which the next iteration's
--     skip_seps_dedent will advance past the body's closing Dedents to the next
--     `rule` (or Eof).
--   * else (Eof, or any non-`rule` token) the program ends: RNil.
-- TERMINATION: each iteration that conses a rule advances the cursor by at least
-- the rule decl's whole body (parse_rule_decl_pos's `next` is strictly past the
-- starting `rule` token), so pos grows strictly toward the finite end of the
-- token list. No structural/decreasing FIELD fits a forward token-index scan, so
-- this carries the bound + the mandatory recursion breadcrumb (the backstop is
-- the finite token list, bounded by max_nodes).
-- Records-arc brick R1 extends parse_program's loop from a 2-way (rule | stop) to
-- a 3-way (rule | skip-concept | stop). The is_rule branch is UNCHANGED (cons +
-- recurse from the rule's end). A skip branch SKIPS a top-level item that is not a
-- rule and recurses WITHOUT consing — so rules AFTER it are still found (before R1
-- the loop stopped on a concept, silently dropping them). Anything else still ends
-- the list (RNil). CRITICAL INVARIANT: a rule-only program never spells `concept`
-- (or `concept_group`) at a top-level item, so the RuleList it produces is
-- BYTE-IDENTICAL to the pre-R1 loop. parse_program's return type stays RuleList —
-- no call site changes.
-- Records-arc brick R2 makes the skip branch handle REAL source: `is_skip` now
-- folds BOTH `is_concept` AND `is_concept_group` (the 13-byte group header), and
-- the skip is computed STRUCTURALLY via skip_indented_block (depth-counted
-- INDENT/DEDENT) rather than via parse_concept_decl_pos's field-counting `next`.
-- The structural skip is what makes count_rules work on the self-source: it jumps a
-- group's whole nested block AND a plain concept whose fields carry range
-- annotations (`text [..256]`) that R1's 3-tokens-per-field counter mis-measured.
-- Rules themselves are skipped to their next sibling via parse_rule_decl_pos's
-- `next`, which R2.c also made structural (past the logic + proofs blocks).
rule parse_program
  @intention: "Parse a sequence of top-level rule declarations into a RuleList (skipping concept blocks)"
  @source: vexprparse.intent:31
  input:
    ps : ProgramState
  output:
    out : RuleList
  logic:
    let hp = skip_seps_dedent(ParseState { cell: ps.cell })
    let kw_start = peek_start(hp)
    let kw_len = peek_len(hp)
    let is_rule = span_is_rule(SpanCheck { src: ps.src, start: kw_start, len: kw_len })
    let is_concept = span_is_concept(SpanCheck { src: ps.src, start: kw_start, len: kw_len })
    let is_concept_group = span_is_concept_group(SpanCheck { src: ps.src, start: kw_start, len: kw_len })
    let is_skip = if is_concept == 1 then 1 else if is_concept_group == 1 then 1 else 0
    let pr = parse_rule_decl_pos(ProgramState { cell: hp, src: ps.src })
    let rd = pr_rule(pr)
    let endp = pr_next(pr)
    let skip_end = if is_skip == 1 then skip_indented_block(SkipBlockState { cell: hp, depth: 0, seen: 0 }) else hp
    out = if is_rule == 1 then RuleList::RCons { head: rd, tail: parse_program(ProgramState { cell: endp, src: ps.src }) } else (if is_skip == 1 then parse_program(ProgramState { cell: skip_end, src: ps.src }) else RuleList::RNil)
  proofs:
    purity:
      reads : [ps.cell, ps.src]
      calls : [skip_seps_dedent, peek_start, peek_len, span_is_rule, span_is_concept, span_is_concept_group, parse_rule_decl_pos, pr_rule, pr_next, skip_indented_block, parse_program]
    termination:
      bound : 512


-- rule_list_len: the number of rule declarations in a parsed program. Structural
-- recursion on the RuleList tail (Phase C), like count_binds on a Binding list.
rule rule_list_len
  @intention: "Number of rule declarations in a parsed program"
  @source: vexprparse.intent:31
  input:
    rl : RuleList
  output:
    out : number
  logic:
    out = match rl:
      RCons(head, tail) => 1 + rule_list_len(tail)
      RNil => 0
  proofs:
    purity:
      reads : [rl]
      calls : [rule_list_len]
    termination:
      bound : 4000
      structural : rl


-- ============================================================================
-- RECORDS-ARC BRICK R1: parse top-level `concept` declarations.
--
-- Before R1 parse_program (brick 12) recognized only `rule` at a top-level item
-- and STOPPED (RNil) on anything else — so a `concept` declaration silently
-- dropped every rule after it. R1:
--   * teaches parse_program to SKIP concept blocks (rules after a concept are
--     still found) WITHOUT changing its return type (stays RuleList);
--   * adds a SEPARATE parse_concepts walk that CAPTURES the concepts.
--
-- TOKEN STREAM at a concept boundary (concept at col 0, fields: at col 2,
-- field lines at col 4):
--
--   concept Pair    concept(0) Pair(1) Nl(2)
--     fields:       Indent(3) fields(4) :(5) Nl(6)
--       a : number  Indent(7) a(8) :(9) number(10) Nl(11)
--       b : number  b(12) :(13) number(14) Nl(15)
--   rule main       Dedent(16) Dedent(17) rule(18) ...
--
-- A field line is `IDENT : TYPE` — name at fp, `:` (op 10) at fp+1, type IDENT at
-- fp+2, then a Newline. parse_fields skips leading separators (skip_seps: Newline
-- 600 / Indent 700), and while the landed token is an Ident (kind 100) it parses
-- one field and recurses from fp+3 (skip_seps eats the trailing Newline); a Dedent
-- (800) / Eof (0) / non-Ident ends the list (FNil). This is R1 parser+AST ONLY: no
-- type checker change, no emitter change, no new lattice.
-- ============================================================================

-- The field-list parse cursor: the token list, the source text (backs the type-
-- name byte recognition via type_code_of_span), and the current scan index. Same
-- multi-field shape as ProgramState.
concept FieldParseState
  @intention: "The token list cursor cell plus the source text, for parsing a fields block"
  @source: vexprparse.intent:62
  fields:
    cell : TokenList
    src : text [..256]


-- Records-arc brick R4: the variant-list parse cursor — the token list cell plus the
-- source text (backs the payload type-name byte recognition via type_code_of_span).
-- Same multi-field shape as FieldParseState, just driving parse_variants.
concept VariantParseState
  @intention: "The token list cursor cell plus the source text, for parsing a variants block"
  @source: vexprparse.intent:65
  fields:
    cell : TokenList
    src : text [..256]


-- parse_fields: parse the body of a `fields:` block into a FieldList, starting at
-- fp.pos. skip_seps lands on the next significant token: if it is an Ident (kind
-- 100) it is a field NAME — read its span, read the TYPE Ident span two tokens on
-- (after the `:` op-10), map it to a code via type_code_of_span (reading fp.src),
-- and recurse from name_idx + 3 (skip_seps will eat the trailing Newline before the
-- next field). A Dedent (800) / Eof (0) / any non-Ident ends the block (FNil). The
-- recursive call is LAZY (inside the then branch of the Ident dispatch), like
-- parse_program's RCons tail. Recurses over a forward token scan (no structural
-- FIELD fits), so bound + the mandatory recursion breadcrumb (the backstop is the
-- finite token list, bounded by max_nodes). Every peek is OOB-guarded by the
-- token-list accessors (Eof past the end).
-- Accessors for a ParsedFields result (block-form match only in final position).
rule pf_fields
  @intention: "The FieldList from a fields-block parse result"
  @source: vexprparse.intent:62
  input:
    p : ParsedFields
  output:
    out : FieldList
  logic:
    out = match p:
      MkPF(fields, next) => fields
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


rule pf_next
  @intention: "The end cell just past a fields-block parse result"
  @source: vexprparse.intent:62
  input:
    p : ParsedFields
  output:
    out : TokenList
  logic:
    out = match p:
      MkPF(fields, next) => next
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


-- A field-cons continuation state: the head field's span + type plus the parsed
-- REST of the field list (as a ParsedFields). fields_cons consumes this — conses
-- the head onto the rest's FieldList, carrying the rest's end cell through.
-- Splitting this out of parse_fields keeps the recursive parse_fields call lazily
-- inside the Ident branch (a let would force it eagerly), exactly like args_cons /
-- args_prepend in the call-argument parser.
concept FieldConsState
  @intention: "Head field span + type + the parsed rest of the field list"
  @source: vexprparse.intent:62
  fields:
    head_start : number [0, 4000000]
    head_len : number [0, 4000000]
    head_ty : number [0, 64]
    head_ty_start : number [0, 4000000]
    head_ty_len : number [0, 4000000]
    rest : ParsedFields


rule fields_cons
  @intention: "Cons the head field onto the front of the parsed rest of the field list"
  @source: vexprparse.intent:62
  input:
    fc : FieldConsState
  output:
    out : ParsedFields
  logic:
    let rest_list = pf_fields(fc.rest)
    let rest_next = pf_next(fc.rest)
    out = ParsedFields::MkPF { fields: FieldList::FCons { name_start: fc.head_start, name_len: fc.head_len, ty: fc.head_ty, ty_start: fc.head_ty_start, ty_len: fc.head_ty_len, rest: rest_list }, next: rest_next }
  proofs:
    purity:
      reads : [fc.head_start, fc.head_len, fc.head_ty, fc.head_ty_start, fc.head_ty_len, fc.rest]
      calls : [pf_fields, pf_next]
    termination:
      bound : 16


-- skip_field_range (verbatim-source probe, 2026-07-06): a REAL field declaration may
-- carry a range after its type — `pos : number [0, 256]` or `source : text [..256]`.
-- parse_fields consumed exactly `name : type` (3 tokens) per field, so a range ENDED
-- the field list early (silently dropping later fields) and left the concept walk
-- standing inside `[..256]`, whose `.` tokens (op 12) drove a no-advance infinite
-- recursion -> stack overflow. This helper skips an optional bracketed range: on `[`
-- (op 25), scan to the matching `]` (op 26) and land one past it; anything else
-- returns the cell unchanged. Ranges stay verifier material (the toy checker does not
-- exploit them yet) — this is a faithful SKIP, mirroring R2's attribute skipping.
rule skip_field_range
  @intention: "Skip an optional bracketed field range after a field's type, landing past the closing bracket"
  @source: vexprparse.intent:1688
  input:
    st : ParseState
  output:
    out : TokenList
  logic:
    let isopen = if peek_op_code(st.cell) == 25 then 1 else 0
    out = if isopen == 1 then skip_range_body(ParseState { cell: advance(Advance { lst: st.cell, k: 1 }) }) else st.cell
  proofs:
    purity:
      reads : [st.cell]
      calls : [peek_op_code, skip_range_body, advance]
    termination:
      bound : 512


-- skip_range_body: advance token by token until the closing `]` (op 26), returning
-- the cell one past it. Guarded on Eof (peek_kind 0) so an unterminated `[` is total
-- (returns the end cell) instead of recursing forever. Forward scan; bound + the
-- mandatory recursion breadcrumb (backstop: the finite token list).
rule skip_range_body
  @intention: "Scan forward to the closing bracket of a field range, landing one past it"
  @source: vexprparse.intent:1688
  input:
    st : ParseState
  output:
    out : TokenList
  logic:
    let isclose = if peek_op_code(st.cell) == 26 then 1 else 0
    let iseof = if peek_kind(st.cell) == 0 then 1 else 0
    out = if isclose == 1 then advance(Advance { lst: st.cell, k: 1 }) else if iseof == 1 then st.cell else skip_range_body(ParseState { cell: advance(Advance { lst: st.cell, k: 1 }) })
  proofs:
    purity:
      reads : [st.cell]
      calls : [peek_op_code, peek_kind, skip_range_body, advance]
    termination:
      bound : 512


rule parse_fields
  @intention: "Parse the body of a fields: block into a FieldList + its end cell (one FCons per IDENT : TYPE line, optional [range] skipped)"
  @source: vexprparse.intent:62
  input:
    fp : FieldParseState
  output:
    out : ParsedFields
  logic:
    let hp = skip_seps(ParseState { cell: fp.cell })
    let knd = peek_kind(hp)
    let is_field = if knd == 100 then 1 else 0
    let name_start = peek_start(hp)
    let name_len = peek_len(hp)
    let ty_start = peek_start(advance(Advance { lst: hp, k: 2 }))
    let ty_len = peek_len(advance(Advance { lst: hp, k: 2 }))
    let ty = type_code_of_span(SpanCheck { src: fp.src, start: ty_start, len: ty_len })
    out = if is_field == 1 then fields_cons(FieldConsState { head_start: name_start, head_len: name_len, head_ty: ty, head_ty_start: ty_start, head_ty_len: ty_len, rest: parse_fields(FieldParseState { cell: skip_field_range(ParseState { cell: advance(Advance { lst: hp, k: 3 }) }), src: fp.src }) }) else ParsedFields::MkPF { fields: FieldList::FNil, next: hp }
  proofs:
    purity:
      reads : [fp.cell, fp.src]
      calls : [skip_seps, peek_kind, peek_start, peek_len, type_code_of_span, parse_fields, fields_cons, skip_field_range, advance]
    termination:
      bound : 512


-- params_to_fields (records-arc brick R4): convert a ParamList (built by the proven
-- brick-20 params_scan / parse_params, which parses a comma-separated `( name : type ,
-- ... )` list) into the structurally-identical FieldList. A variant payload `of (a : T,
-- b : T)` has EXACTLY the parenthesized comma shape parse_params already handles, so
-- parse_variants reuses parse_params for the payload and converts its ParamList result
-- to the FieldList the AST stores. PCons -> FCons one-for-one; PNil -> FNil. Structural
-- recursion on the cons tail (Phase C), like field_list_len.
rule params_to_fields
  @intention: "Convert a parsed ParamList into the structurally-identical FieldList"
  @source: vexprparse.intent:65
  input:
    pl : ParamList
  output:
    out : FieldList
  logic:
    out = match pl:
      PCons(name_start, name_len, ty, ty_start, ty_len, rest) => FieldList::FCons { name_start: name_start, name_len: name_len, ty: ty, ty_start: ty_start, ty_len: ty_len, rest: params_to_fields(rest) }
      PNil => FieldList::FNil
  proofs:
    purity:
      reads : [pl]
      calls : [params_to_fields]
    termination:
      bound : 512
      structural : pl


-- fields_to_params (input:-block bridge): convert a FieldList (built by parse_fields
-- from an `input:` block) into the structurally-identical ParamList — the EXACT
-- inverse of params_to_fields. FCons -> PCons one-for-one, FNil -> PNil, preserving
-- the name span AND the ty code + ty span. Both parse paths compute ty via the same
-- type_code_of_span, so the copied code is exactly what the toy params_scan would
-- have produced for the same span; the ty span itself must survive because
-- static_concept_of resolves a param's concept from it (record params in codegen
-- depend on that resolution). Structural recursion on the FCons tail (Phase C),
-- like params_to_fields.
rule fields_to_params
  @intention: "Convert a parsed input: FieldList into the structurally-identical ParamList"
  @source: vexprparse.intent:1673
  input:
    fl : FieldList
  output:
    out : ParamList
  logic:
    out = match fl:
      FCons(name_start, name_len, ty, ty_start, ty_len, rest) => ParamList::PCons { name_start: name_start, name_len: name_len, ty: ty, ty_start: ty_start, ty_len: ty_len, rest: fields_to_params(rest) }
      FNil => ParamList::PNil
  proofs:
    purity:
      reads : [fl]
      calls : [fields_to_params]
    termination:
      bound : 512
      structural : fl


-- rule_params_of (input:-block bridge): the EFFECTIVE parameter list of a rule for
-- the EXECUTORS (eval_call's bind_params; proc_size / x86_proc's frame + lowering
-- params). Toy-form rules declare `rule f(x : T)` -> rd_params is non-empty and is
-- returned unchanged, so toy-form behavior is byte-identical. Real self-source
-- rules declare an `input:` block instead -> rd_params is PNil and rd_input is
-- converted via fields_to_params. If BOTH are present, params wins — the
-- self-source never mixes the two forms; the tie-break is a note, not a supported
-- shape. Checkers (lints, types, purity, termination) keep reading rd_params /
-- rd_input directly — this accessor is executor-only.
rule rule_params_of
  @intention: "The effective executor parameter list of a rule: declared params if non-empty, else the input: block converted"
  @source: vexprparse.intent:1673
  input:
    r : RuleDecl
  output:
    out : ParamList
  logic:
    out = if param_list_len(rd_params(r)) > 0 then rd_params(r) else fields_to_params(rd_input(r))
  proofs:
    purity:
      reads : [r]
      calls : [param_list_len, rd_params, fields_to_params, rd_input]
    termination:
      bound : 512


-- parse_variants (records-arc brick R4): parse the body of a `variants:` block into a
-- VariantList, starting at vp.cell. skip_seps lands on the next significant token: if
-- it is an Ident (kind 100) it is a variant NAME — read its span. A payload follows
-- iff the token two on (name+2) is `(` (op 21): the shape is `NAME of ( ... )`, so
-- name+1 is `of` and name+2 is the open paren. When present, parse_params (brick 20)
-- parses the parenthesized `( name : type , ... )` payload, CONSUMING the `)`, and its
-- ParamList is converted to a FieldList via params_to_fields; the recursion resumes
-- from parse_params' end cell. A bare variant (`Eof` / `Nil` / `Indent`) has payload
-- FNil and the recursion resumes from name+1. A Dedent (800) / Eof (0) / any non-Ident
-- ends the block (VarNil). The recursive call is LAZY (inside the then branch of the
-- Ident dispatch, exactly like parse_program's RCons tail / parse_fields' FCons), so
-- it only fires on a real variant line. Recurses over a forward token scan (no
-- structural FIELD fits), so bound + the mandatory recursion breadcrumb (the backstop
-- is the finite token list, bounded by max_nodes). Every peek is OOB-guarded by the
-- token-list accessors (Eof past the end), and parse_params on a non-`(` token returns
-- PNil immediately (no recursion) so the eager pre-eval is safe on bare variants.
rule parse_variants
  @intention: "Parse the body of a variants: block into a VariantList (one VarCons per variant line)"
  @source: vexprparse.intent:65
  input:
    vp : VariantParseState
  output:
    out : VariantList
  logic:
    let hp = skip_seps(ParseState { cell: vp.cell })
    let knd = peek_kind(hp)
    let is_variant = if knd == 100 then 1 else 0
    let name_start = peek_start(hp)
    let name_len = peek_len(hp)
    let after_name = advance(Advance { lst: hp, k: 1 })
    let open_cell = advance(Advance { lst: hp, k: 2 })
    let has_payload = if peek_op_code(open_cell) == 21 then 1 else 0
    let pp = parse_params(ParamParseState { cell: open_cell, src: vp.src })
    let payload_fields = params_to_fields(pp_params(pp))
    let rest_cell = if has_payload == 1 then pp_next(pp) else after_name
    out = if is_variant == 1 then VariantList::VarCons { name_start: name_start, name_len: name_len, payload: payload_fields, rest: parse_variants(VariantParseState { cell: rest_cell, src: vp.src }) } else VariantList::VarNil
  proofs:
    purity:
      reads : [vp.cell, vp.src]
      calls : [skip_seps, peek_kind, peek_start, peek_len, peek_op_code, parse_params, pp_params, pp_next, params_to_fields, parse_variants, advance]
    termination:
      bound : 512


-- skip_to_newline (records-arc brick R4): advance the cursor forward until the first
-- Newline (kind 600) or Eof (kind 0), returning that cell. Used by parse_concepts to
-- DESCEND into a `concept_group`: the group header (`concept_group NAME [ ... ]`) is
-- one line, so skipping to its Newline — then skip_seps over the Newline + the group-
-- body Indent — lands on the first nested concept. The `[max_depth: …, max_nodes: …]`
-- bounds on the header are passed through untouched (parser-only brick R4 does not
-- need them). Forward-index recursion (strictly toward the finite token end); bound +
-- the mandatory recursion breadcrumb (the backstop is the finite token list).
rule skip_to_newline
  @intention: "The cell at the first Newline (or Eof) at/after the cursor"
  @source: vexprparse.intent:65
  input:
    st : ParseState
  output:
    out : TokenList
  logic:
    let knd = peek_kind(st.cell)
    let stop = if knd == 600 then 1 else if knd == 0 then 1 else 0
    out = if stop == 1 then st.cell else skip_to_newline(ParseState { cell: advance(Advance { lst: st.cell, k: 1 }) })
  proofs:
    purity:
      reads : [st.cell]
      calls : [peek_kind, skip_to_newline, advance]
    termination:
      bound : 512


-- ============================================================================
-- RECORDS-ARC BRICK R5: parse the rule's `input:`/`output:` TYPES + `proofs:`
-- (purity reads/calls + termination) into the RuleDecl AST.
--
-- Before R5 parse_rule_decl_pos SKIPPED these whole blocks (seek_logic walked past
-- input/output to find logic; the trailing proofs block was skipped to compute the
-- end position). R5 PARSES them — the AST now REPRESENTS the verification surface the
-- R6 checker will consume. PARSER-ONLY: no checking, no codegen.
--
-- A `reads`/`calls` list is `[ entry , entry , ... ]` where each entry is an ident-
-- path `ident (.ident)*` (e.g. `s.source`). parse_name_list captures each entry's
-- HEAD-IDENT span (the simpler choice the task allows — enough to COUNT entries and
-- name the root binder; skip_path skips the `.field` suffix). The proofs sub-blocks
-- (purity / reads / calls / termination / bound / structural|decreasing|increasing)
-- are reached POSITIONALLY (fixed token offsets + skip_seps), so the only new span
-- helpers are the optional-block detectors (input/output) and the termination-kind
-- keyword detectors (structural/decreasing/increasing).
-- ============================================================================

-- A name-cons continuation: the head entry's span plus the parsed REST of the list.
-- names_cons conses the head onto the rest's NameList, threading the rest's end cell.
-- Mirrors FieldConsState exactly, keeping the recursive parse_name_list call lazily
-- inside the entry branch (a let would force it eagerly).
concept NameConsState
  @intention: "Head name-list entry span + the parsed rest of the name list"
  @source: vexprparse.intent:30
  fields:
    head_start : number [0, 4000000]
    head_len : number [0, 4000000]
    rest : ParsedNames


rule names_cons
  @intention: "Cons the head entry onto the front of the parsed rest of the name list"
  @source: vexprparse.intent:30
  input:
    nc : NameConsState
  output:
    out : ParsedNames
  logic:
    let rest_list = pn_names(nc.rest)
    let rest_next = pn_next(nc.rest)
    out = ParsedNames::MkNames { names: NameList::NmCons { start: nc.head_start, len: nc.head_len, rest: rest_list }, next: rest_next }
  proofs:
    purity:
      reads : [nc.head_start, nc.head_len, nc.rest]
      calls : [pn_names, pn_next]
    termination:
      bound : 16


-- skip_path (records-arc brick R5): from a cell AT an entry's head ident, advance
-- past the ident and any trailing `.ident` pairs (op 12 = `.`), returning the cell
-- AT the following `,` (op 11) or `]` (op 26). For a bare entry (`s`) it returns the
-- cell right after the ident; for `s.source` it skips `.` `source` and lands on the
-- separator. Forward-index recursion (each step advances by 2 toward the finite token
-- end); bound + the mandatory recursion breadcrumb.
rule skip_path
  @intention: "Skip an ident-path entry (ident then any .field pairs), landing on the separator cell"
  @source: vexprparse.intent:30
  input:
    st : ParseState
  output:
    out : TokenList
  logic:
    let after_id = advance(Advance { lst: st.cell, k: 1 })
    let isdot = if peek_op_code(after_id) == 12 then 1 else 0
    out = if isdot == 1 then skip_path(ParseState { cell: advance(Advance { lst: st.cell, k: 2 }) }) else after_id
  proofs:
    purity:
      reads : [st.cell]
      calls : [peek_op_code, skip_path, advance]
    termination:
      bound : 512


-- parse_name_list (records-arc brick R5): parse the body of a bracketed `[ a, b.c,
-- ... ]` list into a NameList, starting at the cell of the FIRST entry token (right
-- after the `[`). If that token is an Ident (kind 100) it is an entry head — capture
-- its span, skip the rest of the entry (skip_path), then if the separator is `,` (op
-- 11) advance past it and recurse on the next entry; a `]` (op 26) or any non-ident
-- ends the list (NmNil) and threads the closing-`]` cell as `next`. The recursive
-- call is LAZY (inside names_cons, exactly like parse_fields' FCons tail). Forward
-- token scan; bound + the mandatory recursion breadcrumb (the backstop is the finite
-- token list, bounded by max_nodes). Empty list `[]` lands on `]` immediately => NmNil.
rule parse_name_list
  @intention: "Parse a bracketed reads/calls list into a NameList + its end cell (one NmCons per entry)"
  @source: vexprparse.intent:30
  input:
    st : ParseState
  output:
    out : ParsedNames
  logic:
    let knd = peek_kind(st.cell)
    let is_entry = if knd == 100 then 1 else 0
    let name_start = peek_start(st.cell)
    let name_len = peek_len(st.cell)
    let after_path = skip_path(ParseState { cell: st.cell })
    let nextop = peek_op_code(after_path)
    let rest_cell = if nextop == 11 then advance(Advance { lst: after_path, k: 1 }) else after_path
    out = if is_entry == 1 then names_cons(NameConsState { head_start: name_start, head_len: name_len, rest: parse_name_list(ParseState { cell: rest_cell }) }) else ParsedNames::MkNames { names: NameList::NmNil, next: st.cell }
  proofs:
    purity:
      reads : [st.cell]
      calls : [peek_kind, peek_start, peek_len, skip_path, peek_op_code, names_cons, parse_name_list, advance]
    termination:
      bound : 512


-- parse_proofs (records-arc brick R5): parse a rule's `proofs:` block into a Proofs,
-- starting at the `proofs` header cell. The grammar is fixed, so every sub-block is
-- reached POSITIONALLY (no span checks for purity/reads/calls/termination/bound):
--   proofs:                       cell+0 `proofs` cell+1 `:` then Nl, Indent
--     purity:                     skip_seps(cell+2) => `purity`; +2 then Nl, Indent
--       reads : [ ... ]           skip_seps(purity+2) => `reads`; reads+2 = `[`, +3 = first entry
--       calls : [ ... ]           skip_seps(after `]` Nl) => `calls`
--     termination:                skip_seps_dedent(after `]` Nl Dedent) => `termination`
--       bound : N                 skip_seps(termination+2) => `bound`; bound+2 = the Num
--       structural : x            optional: skip_seps(bound+3) => kw ident OR a Dedent
-- The termination kind is the one keyword present after `bound : N` (structural=1,
-- decreasing=2, increasing=3, none=0); its field name is two tokens on (`kw` `:` field).
-- One-shot (delegates the list recursion to parse_name_list); bound-only termination.
rule parse_proofs
  @intention: "Parse a proofs block into a Proofs (purity reads/calls + termination kind/bound/field)"
  @source: vexprparse.intent:30
  input:
    ps : ProgramState
  output:
    out : Proofs
  logic:
    let purity_hdr = skip_seps(ParseState { cell: advance(Advance { lst: ps.cell, k: 2 }) })
    let reads_hdr = skip_seps(ParseState { cell: advance(Advance { lst: purity_hdr, k: 2 }) })
    let pnreads = parse_name_list(ParseState { cell: advance(Advance { lst: reads_hdr, k: 3 }) })
    let reads_names = pn_names(pnreads)
    let after_reads = pn_next(pnreads)
    let calls_hdr = skip_seps(ParseState { cell: advance(Advance { lst: after_reads, k: 1 }) })
    let pncalls = parse_name_list(ParseState { cell: advance(Advance { lst: calls_hdr, k: 3 }) })
    let calls_names = pn_names(pncalls)
    let after_calls = pn_next(pncalls)
    let term_hdr = skip_seps_dedent(ParseState { cell: advance(Advance { lst: after_calls, k: 1 }) })
    let bound_hdr = skip_seps(ParseState { cell: advance(Advance { lst: term_hdr, k: 2 }) })
    let term_bound = peek_value(advance(Advance { lst: bound_hdr, k: 2 }))
    let extra_hdr = skip_seps(ParseState { cell: advance(Advance { lst: bound_hdr, k: 3 }) })
    let ek_start = peek_start(extra_hdr)
    let ek_len = peek_len(extra_hdr)
    let is_struct = span_is_structural(SpanCheck { src: ps.src, start: ek_start, len: ek_len })
    let is_decr = span_is_decreasing(SpanCheck { src: ps.src, start: ek_start, len: ek_len })
    let is_incr = span_is_increasing(SpanCheck { src: ps.src, start: ek_start, len: ek_len })
    let term_kind = if is_struct == 1 then 1 else if is_decr == 1 then 2 else if is_incr == 1 then 3 else 0
    let tf = advance(Advance { lst: extra_hdr, k: 2 })
    let term_field_start = if term_kind == 0 then 0 else peek_start(tf)
    let term_field_len = if term_kind == 0 then 0 else peek_len(tf)
    out = Proofs::MkProofs { reads: reads_names, calls: calls_names, term_kind: term_kind, term_bound: term_bound, term_field_start: term_field_start, term_field_len: term_field_len }
  proofs:
    purity:
      reads : [ps.cell, ps.src]
      calls : [skip_seps, skip_seps_dedent, parse_name_list, pn_names, pn_next, peek_value, peek_start, peek_len, span_is_structural, span_is_decreasing, span_is_increasing, advance]
    termination:
      bound : 64


-- Accessors for a ParsedConcept (a block-form match is only legal in final
-- position, so destructuring is factored into tiny rules — like pr_rule / pr_next).
rule pc_concept
  @intention: "The Concept from a concept-decl parse result"
  @source: vexprparse.intent:62
  input:
    p : ParsedConcept
  output:
    out : Concept
  logic:
    out = match p:
      MkPC(concept, next) => concept
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


rule pc_next
  @intention: "The token index just past a concept-decl parse result"
  @source: vexprparse.intent:62
  input:
    p : ParsedConcept
  output:
    out : TokenList
  logic:
    out = match p:
      MkPC(concept, next) => next
  proofs:
    purity:
      reads : [p]
      calls : []
    termination:
      bound : 16


-- Accessors for a Concept (same tiny-destructuring shape as rd_name_start / rd_body).
rule cd_name_start
  @intention: "The name-span start offset of a parsed concept declaration"
  @source: vexprparse.intent:62
  input:
    c : Concept
  output:
    out : number
  logic:
    out = match c:
      MkConcept(name_start, name_len, fields, variants) => name_start
  proofs:
    purity:
      reads : [c]
      calls : []
    termination:
      bound : 16


rule cd_name_len
  @intention: "The name-span length of a parsed concept declaration"
  @source: vexprparse.intent:62
  input:
    c : Concept
  output:
    out : number
  logic:
    out = match c:
      MkConcept(name_start, name_len, fields, variants) => name_len
  proofs:
    purity:
      reads : [c]
      calls : []
    termination:
      bound : 16


rule cd_fields
  @intention: "The field list of a parsed concept declaration"
  @source: vexprparse.intent:62
  input:
    c : Concept
  output:
    out : FieldList
  logic:
    out = match c:
      MkConcept(name_start, name_len, fields, variants) => fields
  proofs:
    purity:
      reads : [c]
      calls : []
    termination:
      bound : 16


-- cd_variants (records-arc brick R4): the variant list of a parsed concept
-- declaration (VarNil for a record-shape concept). Mirror of cd_fields.
rule cd_variants
  @intention: "The variant list of a parsed concept declaration"
  @source: vexprparse.intent:65
  input:
    c : Concept
  output:
    out : VariantList
  logic:
    out = match c:
      MkConcept(name_start, name_len, fields, variants) => variants
  proofs:
    purity:
      reads : [c]
      calls : []
    termination:
      bound : 16


-- field_list_len: the number of fields in a concept's FieldList. Structural
-- recursion on the FCons tail (Phase C), like rule_list_len / param_list_len.
rule field_list_len
  @intention: "Number of fields in a concept's field list"
  @source: vexprparse.intent:62
  input:
    fl : FieldList
  output:
    out : number
  logic:
    out = match fl:
      FCons(name_start, name_len, ty, ty_start, ty_len, rest) => 1 + field_list_len(rest)
      FNil => 0
  proofs:
    purity:
      reads : [fl]
      calls : [field_list_len]
    termination:
      bound : 512
      structural : fl


-- variant_list_len (records-arc brick R4): the number of variants in a concept's
-- VariantList. Structural recursion on the VarCons tail (Phase C), like field_list_len.
rule variant_list_len
  @intention: "Number of variants in a concept's variant list"
  @source: vexprparse.intent:65
  input:
    vl : VariantList
  output:
    out : number
  logic:
    out = match vl:
      VarCons(name_start, name_len, payload, rest) => 1 + variant_list_len(rest)
      VarNil => 0
  proofs:
    purity:
      reads : [vl]
      calls : [variant_list_len]
    termination:
      bound : 4000
      structural : vl


-- parse_concept_decl_pos: parse ONE top-level concept declaration STARTING at
-- ps.pos, returning a ParsedConcept (the Concept + the end index). The
-- position-aware analogue of parse_rule_decl_pos:
--   * the `concept` keyword is at index p, recognized by byte-comparing its span to
--     "concept" (span_is_concept, reading ps.src).
--   * the NAME is the Ident at p+1; its span is (peek_start p+1, peek_len p+1).
--   * skip_seps from p+2 skips the Newline + the concept-body Indent, landing on the
--     `fields` Ident, recognized by byte-comparing its span to "fields".
--   * the `:` is at fields_idx+1; skip_seps from fields_idx+2 skips the Newline +
--     the fields-body Indent, landing on the first field-line token.
--   * parse_fields parses the field list from there; FNil at the trailing Dedent.
-- FAIL-GRACEFUL like the rule parsers: when both byte checks pass the fields are the
-- parsed list, else an empty list (FNil). `next` is the index just past the last
-- field line (name_idx + 3 of the final field, or the fields-body start when the
-- block is empty) — computed by walking parse_fields' span via a length count is
-- not needed: the program walk's skip_seps_dedent will advance from `next` past the
-- trailing Dedents to the next top-level keyword. We thread `next` as the index of
-- the first non-field token AFTER the block by re-scanning: end_of_fields advances
-- field by field. To keep this one-shot, `next` is computed as the fields-body start
-- plus 4 * (number of fields) — each field line is exactly 4 tokens (name, `:`,
-- type, Newline) in the canonical stream. The trailing Dedents past that are
-- swallowed by the caller's skip_seps_dedent, so an off-by-a-separator never drops a
-- sibling item.
rule parse_concept_decl_pos
  @intention: "Parse a `concept NAME` + `fields:` block starting at ps.pos into a Concept + end index"
  @source: vexprparse.intent:62
  input:
    ps : ProgramState
  output:
    out : ParsedConcept
  logic:
    let kw_start = peek_start(ps.cell)
    let kw_len = peek_len(ps.cell)
    let is_concept = span_is_concept(SpanCheck { src: ps.src, start: kw_start, len: kw_len })
    let name_start = peek_start(advance(Advance { lst: ps.cell, k: 1 }))
    let name_len = peek_len(advance(Advance { lst: ps.cell, k: 1 }))
    let block_idx = skip_seps(ParseState { cell: advance(Advance { lst: ps.cell, k: 2 }) })
    let block_start = peek_start(block_idx)
    let block_len = peek_len(block_idx)
    let is_fields = span_is_fields(SpanCheck { src: ps.src, start: block_start, len: block_len })
    let is_variants = span_is_variants(SpanCheck { src: ps.src, start: block_start, len: block_len })
    let fields_ok = if is_concept == 1 and is_fields == 1 then 1 else 0
    let variants_ok = if is_concept == 1 and is_variants == 1 then 1 else 0
    let body_idx = skip_seps(ParseState { cell: advance(Advance { lst: block_idx, k: 2 }) })
    let pfields = parse_fields(FieldParseState { cell: body_idx, src: ps.src })
    let fl = pf_fields(pfields)
    let endp = pf_next(pfields)
    let vl = parse_variants(VariantParseState { cell: body_idx, src: ps.src })
    out = ParsedConcept::MkPC { concept: Concept::MkConcept { name_start: name_start, name_len: name_len, fields: if fields_ok == 1 then fl else FieldList::FNil, variants: if variants_ok == 1 then vl else VariantList::VarNil }, next: endp }
  proofs:
    purity:
      reads : [ps.cell, ps.src]
      calls : [peek_start, peek_len, span_is_concept, skip_seps, span_is_fields, span_is_variants, parse_fields, pf_fields, pf_next, parse_variants, advance]
    termination:
      bound : 64


-- parse_concept_decl: parse ONE top-level concept declaration at index 0 into a
-- Concept (the p=0 special case of parse_concept_decl_pos, mirroring brick 11's
-- parse_rule_decl vs brick 12's parse_rule_decl_pos). Drops the threaded `next`.
rule parse_concept_decl
  @intention: "Parse a `concept NAME` + `fields:` block at index 0 into a Concept"
  @source: vexprparse.intent:62
  input:
    rp : RuleParseState
  output:
    out : Concept
  logic:
    let pc = parse_concept_decl_pos(ProgramState { cell: rp.cell, src: rp.src })
    out = pc_concept(pc)
  proofs:
    purity:
      reads : [rp.cell, rp.src]
      calls : [parse_concept_decl_pos, pc_concept]
    termination:
      bound : 64


-- parse_concepts: the NEW top-level walk that CAPTURES concept declarations into a
-- ConceptList, starting at ps.pos. The loop:
--   * skip_seps_dedent from ps.pos to the first significant token, past any leftover
--     Newline / Indent / Dedent that closes a prior item.
--   * if that token spells `concept` (span_is_concept): parse one concept decl via
--     parse_concept_decl_pos, CCons it onto the recursive parse of the rest from its
--     `next`.
--   * else if it spells `rule` (span_is_rule): SKIP that rule decl — advance past it
--     via parse_rule_decl_pos's `next` — and recurse (so concepts AFTER a rule are
--     still captured), DO NOT cons.
--   * else if it spells `concept_group` (span_is_concept_group): records-arc brick R4
--     DESCENDS into the group instead of skipping it (R2 skipped the whole block).
--     skip_to_newline walks past the `concept_group NAME [ ... ]` header line; skip_seps
--     then eats the header Newline + the group-body Indent, landing on the FIRST nested
--     `concept`. The recursion continues from there, so each nested concept is captured
--     via the is_concept branch (its `variants:` block parsed by parse_variants), and
--     after the last nested concept the trailing Dedents flow back out to the top level
--     through the next iteration's skip_seps_dedent — no nesting-depth bookkeeping needed.
--     parse_program's rule walk STILL skips the group (count_rules unchanged): types and
--     rules stay separate side-lists per the records design.
--   * else (Eof or any other token): the walk ends — CNil.
-- TERMINATION: each iteration advances the cursor by at least one whole declaration
-- (parse_concept_decl_pos / parse_rule_decl_pos `next` is strictly past the starting
-- keyword), so pos grows strictly toward the finite end of the token list. No
-- structural/decreasing FIELD fits a forward token scan, so bound + the mandatory
-- recursion breadcrumb (the backstop is the finite token list, bounded by max_nodes).
rule parse_concepts
  @intention: "Walk top-level items capturing concept declarations into a ConceptList (skipping rules)"
  @source: vexprparse.intent:62
  input:
    ps : ProgramState
  output:
    out : ConceptList
  logic:
    let hp = skip_seps_dedent(ParseState { cell: ps.cell })
    let kw_start = peek_start(hp)
    let kw_len = peek_len(hp)
    let is_concept = span_is_concept(SpanCheck { src: ps.src, start: kw_start, len: kw_len })
    let is_rule = span_is_rule(SpanCheck { src: ps.src, start: kw_start, len: kw_len })
    let is_concept_group = span_is_concept_group(SpanCheck { src: ps.src, start: kw_start, len: kw_len })
    let need_skip = if is_concept == 1 then 1 else 0
    let pc = parse_concept_decl_pos(ProgramState { cell: hp, src: ps.src })
    let cd = pc_concept(pc)
    let pr = parse_rule_decl_pos(ProgramState { cell: hp, src: ps.src })
    let rend = pr_next(pr)
    let blk_end = if need_skip == 1 then skip_indented_block(SkipBlockState { cell: hp, depth: 0, seen: 0 }) else hp
    let grp_nl = skip_to_newline(ParseState { cell: hp })
    let grp_body = skip_seps(ParseState { cell: grp_nl })
    out = if is_concept == 1 then ConceptList::CCons { head: cd, tail: parse_concepts(ProgramState { cell: blk_end, src: ps.src }) } else (if is_rule == 1 then parse_concepts(ProgramState { cell: rend, src: ps.src }) else (if is_concept_group == 1 then parse_concepts(ProgramState { cell: grp_body, src: ps.src }) else ConceptList::CNil))
  proofs:
    purity:
      reads : [ps.cell, ps.src]
      calls : [skip_seps_dedent, skip_seps, peek_start, peek_len, span_is_concept, span_is_rule, span_is_concept_group, parse_concept_decl_pos, pc_concept, parse_rule_decl_pos, pr_next, skip_indented_block, skip_to_newline, parse_concepts]
    termination:
      bound : 512


-- concept_list_len: the number of concept declarations in a parsed ConceptList.
-- Structural recursion on the CCons tail (Phase C), like rule_list_len.
rule concept_list_len
  @intention: "Number of concept declarations in a parsed concept list"
  @source: vexprparse.intent:62
  input:
    cl : ConceptList
  output:
    out : number
  logic:
    out = match cl:
      CCons(head, tail) => 1 + concept_list_len(tail)
      CNil => 0
  proofs:
    purity:
      reads : [cl]
      calls : [concept_list_len]
    termination:
      bound : 4000
      structural : cl


-- The concept-lookup probe: the concept list to search, the source text (for
-- byte-comparison), and the query name's span (q_start, q_len). Same shape as
-- FindRuleState but over a ConceptList.
concept FindConceptState
  @intention: "A concept list to search + the source text + the query name's span"
  @source: vexprparse.intent:62
  fields:
    concepts : ConceptList
    src : text [..256]
    q_start : number [0, 4000000]
    q_len : number [0, 4000000]


-- find_concept: locate the concept whose NAME span byte-equals the query span and
-- return its Concept, walking the list front-to-back. Mirror of find_rule. On no
-- match it returns a SENTINEL MkConcept(0, 0, FNil) — an empty concept, so a number
-- driver reading off it yields 0 fields rather than crashing. Bound-only
-- termination + the native recursion breadcrumb (the shrinking list tail is a field
-- of the packed input).
rule find_concept
  @intention: "The Concept whose name matches the query span (sentinel empty concept if none)"
  @source: vexprparse.intent:62
  input:
    st : FindConceptState
  output:
    out : Concept
  logic:
    out = match st.concepts:
      CCons(head, tail) => if cd_name_len(head) == st.q_len and name_eq(NameEqState { src: st.src, a_start: cd_name_start(head), b_start: st.q_start, len: st.q_len, off: 0 }) == 1 then head else find_concept(FindConceptState { concepts: tail, src: st.src, q_start: st.q_start, q_len: st.q_len })
      CNil => Concept::MkConcept { name_start: 0, name_len: 0, fields: FieldList::FNil, variants: VariantList::VarNil }
  proofs:
    purity:
      reads : [st.concepts, st.src, st.q_start, st.q_len]
      calls : [cd_name_len, cd_name_start, name_eq, find_concept]
    termination:
      bound : 4000


-- cl_head_fields: the FieldList of the HEAD concept of a concept list (an empty
-- list — FNil — for an empty list). Mirror of rl_head_body for concepts.
rule cl_head_fields
  @intention: "The field list of the head concept of a concept list (FNil if none)"
  @source: vexprparse.intent:62
  input:
    cl : ConceptList
  output:
    out : FieldList
  logic:
    out = match cl:
      CCons(head, tail) => cd_fields(head)
      CNil => FieldList::FNil
  proofs:
    purity:
      reads : [cl]
      calls : [cd_fields]
    termination:
      bound : 16


-- cl_head_variants (records-arc brick R4): the VariantList of the HEAD concept of a
-- concept list (VarNil for an empty list). Mirror of cl_head_fields for variants.
rule cl_head_variants
  @intention: "The variant list of the head concept of a concept list (VarNil if none)"
  @source: vexprparse.intent:65
  input:
    cl : ConceptList
  output:
    out : VariantList
  logic:
    out = match cl:
      CCons(head, tail) => cd_variants(head)
      CNil => VariantList::VarNil
  proofs:
    purity:
      reads : [cl]
      calls : [cd_variants]
    termination:
      bound : 16


-- count_concepts: the records-arc R1 STRUCTURAL driver. Tokenize the program
-- source (with indentation), walk the whole top-level item sequence from index 0
-- CAPTURING concepts, and return the ConceptList length. Proves the program's
-- concept declarations are found (and that rules between/around them are skipped,
-- not mistaken for concepts).
--
--   count_concepts("concept Pair\n  fields:\n    a : number\n    b : number\nrule main\n  logic:\n    out = 1") = 1
--
-- NATIVE-ONLY (multi-line source). Takes a ScanState: source is argv arg 1, pos is
-- argv arg 2 (always 0).
rule count_concepts
  @intention: "Tokenize a program, walk top-level items, and count the concept declarations"
  @source: vexprparse.intent:62
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let cl = parse_concepts(ProgramState { cell: toks, src: s.source })
    out = concept_list_len(cl)
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_concepts, concept_list_len]
    termination:
      bound : 256


-- concept_field_count: the records-arc R1 FIELD driver. Tokenize the program
-- source, walk the top-level items capturing concepts, and return the number of
-- fields of the FIRST concept. Proves the `fields:` block parsed into the right
-- number of fields.
--
--   concept_field_count("concept Pair\n  fields:\n    a : number\n    b : number\nrule main\n  logic:\n    out = 1") = 2
--
-- NATIVE-ONLY (multi-line source).
rule concept_field_count
  @intention: "Parse a program and return the number of fields of its first concept"
  @source: vexprparse.intent:62
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let cl = parse_concepts(ProgramState { cell: toks, src: s.source })
    let fields = cl_head_fields(cl)
    out = field_list_len(fields)
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_concepts, cl_head_fields, field_list_len]
    termination:
      bound : 256


-- count_variants: the records-arc R4 VARIANT driver. Tokenize the program source,
-- walk the top-level items (DESCENDING into the concept_group) capturing concepts,
-- and return the number of variants of the FIRST concept. Proves the group's nested
-- sum-type concepts and their `variants:` blocks parse — e.g. on the real self-source
-- the first concept is the group's `Token` (10 variants), and a `TokenList` (Cons/Nil)
-- has 2. A record-shape first concept (a `fields:` concept) returns 0.
--
--   count_variants("concept_group G [max_depth: 4, max_nodes: 10]\n  concept Foo\n    variants:\n      A of (x : number)\n      B\nrule main\n  logic:\n    out = 1") = 2
--
-- NATIVE-ONLY (multi-line indented source).
rule count_variants
  @intention: "Parse a program and return the number of variants of its first concept"
  @source: vexprparse.intent:65
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let cl = parse_concepts(ProgramState { cell: toks, src: s.source })
    let vs = cl_head_variants(cl)
    out = variant_list_len(vs)
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_concepts, cl_head_variants, variant_list_len]
    termination:
      bound : 256


-- param_list_len: the number of formal parameters in a rule's ParamList.
-- Structural recursion on the PCons tail (Phase C), like count_binds / rule_list_len.
rule param_list_len
  @intention: "Number of formal parameters in a rule's parameter list"
  @source: vexprparse.intent:34
  input:
    pl : ParamList
  output:
    out : number
  logic:
    out = match pl:
      PCons(name_start, name_len, ty, ty_start, ty_len, rest) => 1 + param_list_len(rest)
      PNil => 0
  proofs:
    purity:
      reads : [pl]
      calls : [param_list_len]
    termination:
      bound : 512
      structural : pl


-- drop_rules: the RuleList with its first dr.n rule cells removed — the cons-list
-- analogue of drop_cells on a TokenList. A decreasing number field (dr.n) drives
-- termination: each step recurses on the tail with n - 1. RNil (or n == 0)
-- returns the list as-is. Used by eval_nth_rule to land on the n-th rule.
concept DropRules
  @intention: "A rule list plus a count of leading rule cells to remove"
  @source: vexprparse.intent:31
  fields:
    rl : RuleList
    n : number [0, 4000000]


rule drop_rules
  @intention: "The rule list with its first dr.n rule cells removed"
  @source: vexprparse.intent:31
  input:
    dr : DropRules
  output:
    out : RuleList
  logic:
    out = match dr.rl:
      RCons(head, tail) => if dr.n == 0 then dr.rl else drop_rules(DropRules { rl: tail, n: dr.n - 1 })
      RNil => RuleList::RNil
  proofs:
    purity:
      reads : [dr.rl, dr.n]
      calls : [drop_rules]
    termination:
      bound : 512
      decreasing : n


-- rl_head_body: the body Block of the HEAD rule of a rule list (an empty block —
-- BNil result AstErr — for an empty list, so eval yields 0 rather than crashing).
rule rl_head_body
  @intention: "The logic block of the head rule of a rule list (empty block if none)"
  @source: vexprparse.intent:31
  input:
    rl : RuleList
  output:
    out : Block
  logic:
    out = match rl:
      RCons(head, tail) => rd_body(head)
      RNil => Block::MkBlock { binds: Binding::BNil, result: Ast::AstErr }
  proofs:
    purity:
      reads : [rl]
      calls : [rd_body]
    termination:
      bound : 16


-- rl_head_params: the parameter list of the head rule of a rule list (empty list
-- if none). Mirror of rl_head_body for brick 16's parameters.
rule rl_head_params
  @intention: "The formal parameter list of the head rule of a rule list (PNil if none)"
  @source: vexprparse.intent:34
  input:
    rl : RuleList
  output:
    out : ParamList
  logic:
    out = match rl:
      RCons(head, tail) => rd_params(head)
      RNil => ParamList::PNil
  proofs:
    purity:
      reads : [rl]
      calls : [rd_params]
    termination:
      bound : 16


-- R6b: the input FieldList of the head rule of a rule list (FNil if none). Mirror of
-- rl_head_params; lets the R6b body-type driver seed the type env from a rule's
-- declared input fields (the real self-source shape: `input:` block, no params).
rule rl_head_input
  @intention: "The input field list of the head rule of a rule list (FNil if none)"
  @source: vexprparse.intent:62
  input:
    rl : RuleList
  output:
    out : FieldList
  logic:
    out = match rl:
      RCons(head, tail) => rd_input(head)
      RNil => FieldList::FNil
  proofs:
    purity:
      reads : [rl]
      calls : [rd_input]
    termination:
      bound : 16


-- rl_head_return_type: the declared return-type code of the head rule of a rule
-- list (0=number default if none). Mirror of rl_head_params for brick 31.
rule rl_head_return_type
  @intention: "The declared return-type code of the head rule of a rule list (0 if none)"
  @source: vexprparse.intent:49
  input:
    rl : RuleList
  output:
    out : number
  logic:
    out = match rl:
      RCons(head, tail) => rd_return_type(head)
      RNil => 0
  proofs:
    purity:
      reads : [rl]
      calls : [rd_return_type]
    termination:
      bound : 16


-- rl_head_proofs (records-arc brick R5): the parsed proofs block of the head rule of
-- a rule list (an empty proofs block for an empty list). Mirror of rl_head_body.
rule rl_head_proofs
  @intention: "The parsed proofs block of the head rule of a rule list (empty if none)"
  @source: vexprparse.intent:30
  input:
    rl : RuleList
  output:
    out : Proofs
  logic:
    out = match rl:
      RCons(head, tail) => rd_proofs(head)
      RNil => Proofs::MkProofs { reads: NameList::NmNil, calls: NameList::NmNil, term_kind: 0, term_bound: 0, term_field_start: 0, term_field_len: 0 }
  proofs:
    purity:
      reads : [rl]
      calls : [rd_proofs]
    termination:
      bound : 16


-- count_reads (records-arc brick R5 driver): tokenize a program, parse it, and
-- return the number of `reads` entries in the FIRST rule's proofs. Proves the purity
-- reads list parses into the right number of NameList entries (e.g. `reads : [s.source,
-- s]` => 2). NATIVE-ONLY (multi-line indented source); source is argv arg 1, pos is 0.
rule count_reads
  @intention: "Parse a program and return the number of reads entries of its first rule's proofs"
  @source: vexprparse.intent:30
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let pf = rl_head_proofs(prog)
    out = name_list_len(prf_reads(pf))
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, rl_head_proofs, prf_reads, name_list_len]
    termination:
      bound : 256


-- count_calls (records-arc brick R5 driver): like count_reads but the `calls` list
-- (e.g. `calls : [skip_spaces, token_end, next_token, tokenize]` => 4; `calls : []` => 0).
rule count_calls
  @intention: "Parse a program and return the number of calls entries of its first rule's proofs"
  @source: vexprparse.intent:30
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let pf = rl_head_proofs(prog)
    out = name_list_len(prf_calls(pf))
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, rl_head_proofs, prf_calls, name_list_len]
    termination:
      bound : 256


-- rule_term_bound (records-arc brick R5 driver): the declared `bound :` number of the
-- first rule's termination proof (e.g. `bound : 256` => 256). NATIVE-ONLY.
rule rule_term_bound
  @intention: "Parse a program and return the declared termination bound of its first rule"
  @source: vexprparse.intent:30
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let pf = rl_head_proofs(prog)
    out = prf_term_bound(pf)
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, rl_head_proofs, prf_term_bound]
    termination:
      bound : 256


-- rule_term_kind (records-arc brick R5 driver): the termination-kind code of the
-- first rule's proofs (0=bound-only, 1=structural, 2=decreasing, 3=increasing). NATIVE-ONLY.
rule rule_term_kind
  @intention: "Parse a program and return the termination-kind code of its first rule"
  @source: vexprparse.intent:30
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let pf = rl_head_proofs(prog)
    out = prf_term_kind(pf)
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, rl_head_proofs, prf_term_kind]
    termination:
      bound : 256


-- count_rules: the brick-12 STRUCTURAL driver. Tokenize the program source (with
-- indentation), parse the whole sequence of rule decls from index 0, and return
-- the RuleList length. Proves the program splits into the right number of rule
-- declarations.
--
--   count_rules("rule f\n  logic:\n    out = 7")                                   = 1
--   count_rules("rule f\n  logic:\n    out = 2 + 3\nrule g\n  logic:\n    ...")     = 2
--
-- NATIVE-ONLY (multi-line source). Takes a ScanState (source + pos) so the source
-- is argv arg 1 and pos is argv arg 2 (always 0).
rule count_rules
  @intention: "Tokenize a program, parse the rule-decl sequence, and count the rules"
  @source: vexprparse.intent:31
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    out = rule_list_len(prog)
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, rule_list_len]
    termination:
      bound : 256


-- rule_param_count: the brick-16 PARSE money-shot driver. Tokenize the program
-- source, parse the whole rule-decl sequence, and return the number of formal
-- parameters of the FIRST rule.
--
--   rule_param_count("rule add(x, y)\n  logic:\n    out = x + y") = 2
--   rule_param_count("rule f()\n  logic:\n    out = 1")          = 0   (empty parens)
--   rule_param_count("rule g\n  logic:\n    out = 1")            = 0   (no parens)
--
-- NATIVE-ONLY (multi-line source). Takes a ScanState: source is argv arg 1, pos
-- is argv arg 2 (always 0).
rule rule_param_count
  @intention: "Parse a program and return the number of parameters of its first rule"
  @source: vexprparse.intent:34
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let params = rl_head_params(prog)
    out = param_list_len(params)
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, rl_head_params, param_list_len]
    termination:
      bound : 256


-- rule_return_type: the brick-31 PARSE money-shot driver. Tokenize the program
-- source, parse the whole rule-decl sequence, and return the declared return-type
-- code of the FIRST rule. An optional `: TYPENAME` after the parameter list (and
-- before the `logic:` line) declares the return type — 0=number / 1=bool / 2=text;
-- when absent the default is the sentinel 9 ("unannotated", brick 33 — was 0 in
-- brick 31). call_result_type maps 9 -> number when typing a call; tcheck_rule's
-- return-vs-body check skips unannotated rules. PARSER-ONLY: this brick stores the return type
-- in RuleDecl but does NOT yet feed it into the type checker (that needs threading
-- the program through type_of_env, a later brick).
--
--   rule_return_type("rule add(x : number, y : number) : number\n  logic:\n    out = x + y") = 0  (number)
--   rule_return_type("rule p(x : number) : bool\n  logic:\n    out = x > 0")                  = 1  (bool)
--   rule_return_type("rule q(x : number) : text\n  logic:\n    out = \"hi\"")                  = 2  (text)
--   rule_return_type("rule r(x : number)\n  logic:\n    out = x")                              = 9  (no annotation -> sentinel 9, brick 33)
--   rule_return_type("rule s() : bool\n  logic:\n    out = 1 < 2")                             = 1  (no params, return type)
--
-- NATIVE-ONLY (multi-line source). Takes a ScanState: source is argv arg 1, pos
-- is argv arg 2 (always 0).
rule rule_return_type
  @intention: "Parse a program and return the declared return-type code of its first rule"
  @source: vexprparse.intent:49
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    out = rl_head_return_type(prog)
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, rl_head_return_type]
    termination:
      bound : 256


-- ParamNthState (Brick 20): a ParamList plus a 0-based index n, the input to
-- param_nth_type. The decreasing `n` field drives termination as the list is walked.
concept ParamNthState
  @intention: "A parameter list plus a 0-based index, for reading the n-th param's type code"
  @source: vexprparse.intent:38
  fields:
    params : ParamList
    n : number [0, 4000000]


-- param_nth_type (Brick 20): the declared type code of the n-th parameter (0-based)
-- of a ParamList. Walk the PCons tail n times, then return that cell's `ty`. A
-- sentinel of 9 is returned when n runs past the end (PNil) — distinguishable from
-- every real type code (0/1/2). Recursion is driven by the decreasing Number field
-- `n` (each step recurses on the tail with n - 1), which mechanically proves
-- termination (Phase C decreasing proof), exactly like drop_rules over a RuleList.
rule param_nth_type
  @intention: "The declared type code of the n-th parameter (0-based), sentinel 9 if out of range"
  @source: vexprparse.intent:38
  input:
    q : ParamNthState
  output:
    out : number
  logic:
    out = match q.params:
      PCons(name_start, name_len, ty, ty_start, ty_len, rest) => if q.n == 0 then ty else param_nth_type(ParamNthState { params: rest, n: q.n - 1 })
      PNil => 9
  proofs:
    purity:
      reads : [q.params, q.n]
      calls : [param_nth_type]
    termination:
      bound : 512
      decreasing : n


-- nth_param_type (Brick 20): the BRICK-20 money-shot driver. Tokenize the program
-- source, parse the whole rule-decl sequence, take the FIRST rule's parameter list,
-- and return the type code of its s.pos-th parameter (0-based — s.pos doubles as the
-- index n). This proves the type ANNOTATION on each parameter parsed correctly:
--
--   nth_param_type("rule add(x : number, y : bool)\n  logic:\n    out = x + 1", 0) = 0  (number)
--   nth_param_type("rule add(x : number, y : bool)\n  logic:\n    out = x + 1", 1) = 1  (bool)
--   nth_param_type("rule f(a : text, b : number, c : bool)\n  logic:\n    out = b + 1", 0) = 2  (text)
--   nth_param_type("rule g(x)\n  logic:\n    out = x + 1", 0)                       = 0  (untyped -> number)
--   nth_param_type("rule h()\n  logic:\n    out = 1", 0)                            = 9  (no params -> sentinel)
--
-- NATIVE-ONLY (multi-line source). Takes a ScanState: source is argv arg 1, the
-- index n is argv arg 2 (carried in s.pos).
rule nth_param_type
  @intention: "Parse a program and return the declared type code of the n-th param of its first rule"
  @source: vexprparse.intent:38
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let params = rl_head_params(prog)
    out = param_nth_type(ParamNthState { params: params, n: s.pos })
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : [begin_tokenize, parse_program, rl_head_params, param_nth_type]
    termination:
      bound : 256


-- eval_nth_rule: the brick-12 money-shot driver. Tokenize the program source,
-- parse the whole rule-decl sequence, DROP the first n rule cells to land on the
-- n-th rule (0-based), take its body Block, build the environment from the body's
-- bindings (each RHS against the env so far), and evaluate the body's final
-- out-expression. The result is the n-th rule's `out` value — proving the rule
-- parsed AND its body is intact and evaluable.
--
--   eval_nth_rule("rule f\n  logic:\n    out = 2+3\nrule g\n  logic:\n    let x=4\n    out = x*2", 0) = 5
--   eval_nth_rule(same, 1) = 8
--
-- NATIVE-ONLY (multi-line source). Takes an EvalNthState (source + n): source is
-- argv arg 1 and n is argv arg 2.
rule eval_nth_rule
  @intention: "Parse a program, select the n-th rule, build its env, and evaluate its body to a number"
  @source: vexprparse.intent:31
  input:
    e : EvalNthState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: e.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: e.source })
    let nth = drop_rules(DropRules { rl: prog, n: e.n })
    let blk = rl_head_body(nth)
    let binds = block_binds(blk)
    let result = block_result(blk)
    let env = build_env(BuildEnvArg { binds: binds, env: VEnv::VENil, src: e.source, prog: prog, concepts: ConceptList::CNil })
    out = vnum_of(eval_ast_env(EvalEnvArg { node: result, env: env, src: e.source, prog: prog, concepts: ConceptList::CNil }))
  proofs:
    purity:
      reads : [e.source, e.n]
      calls : [begin_tokenize, parse_program, drop_rules, rl_head_body, block_binds, block_result, build_env, eval_ast_env, vnum_of]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 18 driver: eval_main — run a whole PROGRAM. Tokenize, parse the entire
-- rule sequence, then evaluate the FIRST rule's body with the program threaded so
-- its calls resolve against the other rules. This is the brick-18 money-shot: a
-- multi-rule Verbose program whose entry rule CALLS the others, evaluated to a
-- real number by an interpreter that is itself written in Verbose.
--
-- Convention: the FIRST rule in the source is the entry point (like `main`), and
-- the rest are its (possibly recursive) callees. The entry's `out =` result is
-- evaluated; calls in it dispatch through eval_ast_env -> eval_call -> find_rule.
--
-- Worked examples (all NATIVE-ONLY — multi-line sources; the interpreter's JSON
-- reader does not decode \n into a real byte 10):
--
--   rule main
--     logic:
--       out = double(21)
--   rule double(x)
--     logic:
--       out = x * 2                                   = 42
--
--   rule main
--     logic:
--       out = add(20, 22)
--   rule add(x, y)
--     logic:
--       out = x + y                                   = 42   (two params)
--
--   rule main
--     logic:
--       out = f(10)
--   rule f(n)
--     logic:
--       let d = n * 2
--       out = d + 1                                   = 21   (callee has a let)
--
--   rule main
--     logic:
--       out = double(inc(20))
--   rule double(x)
--     logic:
--       out = x * 2
--   rule inc(n)
--     logic:
--       out = n + 1                                   = 42   (nested call as arg)
--
--   rule main
--     logic:
--       out = fact(5)
--   rule fact(n)
--     logic:
--       out = if n == 0 then 1 else n * fact(n - 1)   = 120  (RECURSIVE)
--
-- eval_main takes a ScanState (source + pos) like eval_block, so the source is
-- argv arg 1 and pos is argv arg 2 (always 0).
rule eval_main
  @intention: "Tokenize, parse a program, and evaluate the FIRST rule's body with calls resolving against the program"
  @source: vexprparse.intent:36
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let concepts = parse_concepts(ProgramState { cell: toks, src: s.source })
    let body = rl_head_body(prog)
    let binds = block_binds(body)
    let result = block_result(body)
    let env = build_env(BuildEnvArg { binds: binds, env: VEnv::VENil, src: s.source, prog: prog, concepts: concepts })
    out = vnum_of(eval_ast_env(EvalEnvArg { node: result, env: env, src: s.source, prog: prog, concepts: concepts }))
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, parse_concepts, rl_head_body, block_binds, block_result, build_env, eval_ast_env, vnum_of]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 13: a LINTER in Verbose — detect undefined-variable references. This is
-- the FIRST static analysis written in Verbose that consumes a parsed Verbose
-- program (brick 12's RuleList) and reports a diagnostic count. It turns the
-- parser front end into a TOOL: lint_program(source) = the total number of
-- undefined-variable references across every rule in the program. 0 = clean.
--
-- THE LINT. For each rule, every variable referenced in the rule's body (the
-- `out =` result expression AND every let-binding's RHS) must be bound by a
-- `let` in that same rule. A reference is an AstVar(start, len); it is DEFINED
-- iff its source span byte-equals SOME binding name in the rule's `binds` list.
-- An AstVar whose name matches no binding name is a LINT ERROR.
--
-- SCOPING RULE CHOSEN (the SIMPLE, whole-rule rule). A variable is defined iff
-- it appears as ANY binding name in the rule's `binds` list — the WHOLE rule's
-- bindings are treated as mutually in scope. So in
--     let x = 1
--     out = x + y
-- x is defined, y is undefined -> 1 error. This deliberately ignores let-order
-- (it does not flag use-before-def within a let RHS): it is a SOUND
-- over-approximation of "defined somewhere in the rule". Order-sensitivity
-- (a let RHS sees only EARLIER lets) is a later refinement, not built here.
-- Documented trade-off: the simple rule never reports a false UNDEF (every
-- name that IS a binding is accepted), but it does not catch forward references.
--
-- WHAT COUNTS AS A VARIABLE REFERENCE (and what does NOT):
--   * AstVar(start, len) is the only variable reference. It is checked.
--   * AstCall callee names are RULE names, not variables — IGNORED. Only the
--     call's ARGUMENT expressions (its ArgList) are walked for AstVar refs.
--   * AstField field names (the .b in a.b) are RECORD field names, not
--     variables — IGNORED. Only the field-access BASE expression is walked
--     (so the `a` in a.b IS checked as an AstVar, the `.b` is not).
--   * AstStr / AstBool / AstNum / AstErr carry no variable reference -> 0.
--
-- NATIVE-ONLY (multi-line program source, as in bricks 10/12): the interpreter's
-- JSON reader does not decode \n into a real byte 10. The lint drivers take a
-- ScanState (source + pos) so the source is argv arg 1 and pos is argv arg 2
-- (always 0). The supporting structural rules (name_bound,
-- count_undef_binds_ordered, the program fold) ARE cross-checkable on hand-built
-- inputs, but the headline
-- driver runs on multi-line source and is native-only.
--
-- RECURSION SHAPES.
-- ALL FIVE recursive lint rules pack the cons-list (Binding / ArgList / RuleList)
-- as a FIELD of their input concept (so they can carry the scope + src alongside),
-- so they recurse over a field, NOT over the input itself. Phase C's structural
-- proof requires the input to BE the group cons-list (structural_param ==
-- input_name); a field-borne list does not fit. They therefore use bound + the
-- mandatory native recursion breadcrumb — exactly like env_lookup / build_env /
-- eval_ast_env, which recurse over a field-borne Env / Binding / Ast for the same
-- reason. The shrinking is real (each step recurses on the list tail), just not
-- expressible as a structural FIELD proof.
--   * name_bound      — walks the Binding cons-list, returns 1/0 membership.
--                       Mirrors env_lookup's byte compare (length-guard then
--                       name_eq) but yields presence, not value.
--   * count_undef_ast — walks an Ast (a FIELD of the packed input, like
--                       eval_ast_env). Mutually recursive with count_undef_args
--                       (over ArgList).
--   * count_undef_binds_ordered — walks the Binding cons-list (the bindings being
--                       iterated), checking each binding's RHS against the PREFIX
--                       of earlier bindings only (proper let-ordering — catches
--                       use-before-def and self-reference).
--   * lint_list       — walks the RuleList tail (like rule_list_len, but over a
--                       field, so bound + breadcrumb not structural).
-- ============================================================================

-- name_bound's probe: the Binding list to search + the source text + the query
-- name's span (q_start, q_len). The membership analogue of EnvLookState.
concept NameBoundState
  @intention: "A binding list to search + the source text + the query name's span"
  @source: vexprparse.intent:32
  fields:
    binds : Binding
    src : text [..256]
    q_start : number [0, 4000000]
    q_len : number [0, 4000000]


-- name_bound: 1 iff the query span byte-equals some binding NAME in the list, 0
-- otherwise. Walks the Binding cons-list; at each BCons it checks the binding
-- name's LENGTH equals the query length AND the bytes match (name_eq); on a match
-- it returns 1, otherwise it recurses into `rest`. BNil (end of list) returns 0
-- (not found). Mirrors env_lookup's structure but returns presence (1/0) — the
-- distinct found/not-found a lint needs, where env_lookup's 0 is ambiguous (an
-- unbound var and a var bound to 0 both look like 0). Recurses over the binding
-- tail, which is a FIELD of the input (not the input), so bound + breadcrumb,
-- like env_lookup (the structural proof needs the input to BE the cons-list).
rule name_bound
  @intention: "1 if a name span matches some binding name in the list, 0 otherwise"
  @source: vexprparse.intent:32
  input:
    st : NameBoundState
  output:
    out : number
  logic:
    out = match st.binds:
      BCons(name_start, name_len, value, rest) => if name_len == st.q_len and name_eq(NameEqState { src: st.src, a_start: name_start, b_start: st.q_start, len: name_len, off: 0 }) == 1 then 1 else name_bound(NameBoundState { binds: rest, src: st.src, q_start: st.q_start, q_len: st.q_len })
      BNil => 0
  proofs:
    purity:
      reads : [st.binds, st.src, st.q_start, st.q_len]
      calls : [name_eq, name_bound]
    termination:
      bound : 4000


-- count_undef_args's input: the argument list to walk + the rule's binding list
-- (the SCOPE every AstVar is checked against) + the source text.
concept UndefArgsState
  @intention: "A call-argument list + the rule's bindings (scope) + the source text"
  @source: vexprparse.intent:32
  fields:
    args : ArgList
    binds : Binding
    src : text [..256]


-- The Ast-walking input: the AST node + the rule's binding list (scope) + src.
-- Carries a group field (node : Ast) AND a text field (src) — the 2b052a7 shape,
-- same as EvalEnvArg. The node is a FIELD of the packed input (not the input
-- itself), so the recursion uses bound + breadcrumb, not a structural FIELD proof.
concept UndefAstState
  @intention: "An Ast node + the rule's bindings (scope) + the source text"
  @source: vexprparse.intent:32
  fields:
    node : Ast
    binds : Binding
    src : text [..256]


-- count_undef_args: sum count_undef_ast over every argument of a call's ArgList.
-- Mutually recursive with count_undef_ast (a call's arguments are themselves Asts
-- that may contain variable references). Recurses over the ArgList tail (a field
-- of the input), so bound + breadcrumb. Threads the same binds (scope) + src down.
rule count_undef_args
  @intention: "Total undefined-variable references across every argument of a call"
  @source: vexprparse.intent:32
  input:
    a : UndefArgsState
  output:
    out : number
  logic:
    out = match a.args:
      ArgCons(head, tail) => count_undef_ast(UndefAstState { node: head, binds: a.binds, src: a.src }) + count_undef_args(UndefArgsState { args: tail, binds: a.binds, src: a.src })
      ArgNil => 0
  proofs:
    purity:
      reads : [a.args, a.binds, a.src]
      calls : [count_undef_ast, count_undef_args]
    termination:
      bound : 4000


-- count_undef_ast: walk an Ast and count the AstVar references whose name is NOT
-- name_bound in the rule's scope. Mirrors shape_ast's structural walk, but each
-- node contributes its UNDEFINED-variable count instead of a shape signature:
--   * AstVar(start, len) => 1 if name_bound == 0 (undefined), else 0.
--   * AstBin sums lhs + rhs; AstNeg / AstNot descend into the single child;
--     AstIf sums cond + thn + els.
--   * AstCall walks its ARGUMENT list (count_undef_args). The callee name is a
--     RULE name, not a variable — it is NOT checked (see the brick header).
--   * AstField walks its BASE expression. The field name (.b) is a record field
--     name, not a variable — it is NOT checked (only the `a` in a.b counts).
--   * AstNum / AstStr / AstBool / AstErr carry no reference -> 0.
-- Every recursive call threads the same binds (scope) + src. Like eval_ast_env,
-- the recursion walks a strict sub-node of a.node, but a.node is a FIELD of the
-- packed input (not the input), so the structural proof does not fit — this
-- carries the bound + the mandatory native recursion breadcrumb.
rule count_undef_ast
  @intention: "Total undefined-variable references in an AST, given the rule's binding scope"
  @source: vexprparse.intent:32
  input:
    a : UndefAstState
  output:
    out : number
  logic:
    out = match a.node:
      AstNum(value) => 0
      AstBin(op, lhs, rhs) => count_undef_ast(UndefAstState { node: lhs, binds: a.binds, src: a.src }) + count_undef_ast(UndefAstState { node: rhs, binds: a.binds, src: a.src })
      AstNeg(inner) => count_undef_ast(UndefAstState { node: inner, binds: a.binds, src: a.src })
      AstNot(inner) => count_undef_ast(UndefAstState { node: inner, binds: a.binds, src: a.src })
      AstVar(start, len) => if name_bound(NameBoundState { binds: a.binds, src: a.src, q_start: start, q_len: len }) == 0 then 1 else 0
      AstField(base, fstart, flen) => count_undef_ast(UndefAstState { node: base, binds: a.binds, src: a.src })
      AstCall(callee_start, callee_len, args) => count_undef_args(UndefArgsState { args: args, binds: a.binds, src: a.src })
      AstIf(cond, thn, els) => count_undef_ast(UndefAstState { node: cond, binds: a.binds, src: a.src }) + count_undef_ast(UndefAstState { node: thn, binds: a.binds, src: a.src }) + count_undef_ast(UndefAstState { node: els, binds: a.binds, src: a.src })
      AstBool(value) => 0
      AstStr(start, len) => 0
      AstBytes(start, len) => 0
      AstErr => 0
      -- R6a: a variant CONSTRUCT contributes no variable reference of its own
      -- (the concept/variant names are TYPE references, not vars), but each field
      -- VALUE expression is a sub-Ast walked with the SAME binds (scope unchanged).
      AstVariant(cstart, clen, vstart, vlen, fields) => count_undef_vfields(UndefVFieldsState { fields: fields, binds: a.binds, src: a.src })
      -- R6a: a match walks its scrutinee with the current binds, then EACH arm body
      -- with binds EXTENDED by that arm's binders (count_undef_arms scopes them in).
      AstMatch(scrut, arms) => count_undef_ast(UndefAstState { node: scrut, binds: a.binds, src: a.src }) + count_undef_arms(UndefArmsState { arms: arms, binds: a.binds, src: a.src })
  proofs:
    purity:
      reads : [a.node, a.binds, a.src]
      calls : [count_undef_ast, count_undef_args, name_bound, count_undef_vfields, count_undef_arms]
    termination:
      bound : 4000


-- R6a: binds_with_binders prepends every binder of a match arm onto the rule's
-- binding scope, so a binder (e.g. the `head` / `tail` of `Cons(head, tail)`) is
-- treated as already-bound WITHIN that arm's body. Each binder carries only a
-- source span (start, len) — exactly the identity model name_bound reads — so it
-- is consed as a BCons with a DUMMY value (AstNum 0), identical to how
-- param_to_binding conses a parameter that has no RHS. name_bound checks
-- membership order-agnostically, so consing onto the front of `binds` yields
-- exactly the SET {arm binders} ∪ {enclosing scope}. Recurses on the BinderList
-- tail (a field of the packed input), so bound + the native recursion breadcrumb.
concept BindsWithBindersState
  @intention: "A binding scope + a match arm's binder list, to extend the scope with the binders"
  @source: vexprparse.intent:32
  fields:
    binds : Binding
    bs : BinderList


rule binds_with_binders
  @intention: "Extend a binding scope with a match arm's binders (each binder as an already-bound name)"
  @source: vexprparse.intent:32
  input:
    bw : BindsWithBindersState
  output:
    out : Binding
  logic:
    out = match bw.bs:
      BindCons(start, len, rest) => Binding::BCons { name_start: start, name_len: len, value: Ast::AstNum { value: 0 }, rest: binds_with_binders(BindsWithBindersState { binds: bw.binds, bs: rest }) }
      BindNil => bw.binds
  proofs:
    purity:
      reads : [bw.binds, bw.bs]
      calls : [binds_with_binders]
    termination:
      bound : 512


-- R6a: count_undef_vfields — sum count_undef_ast over every field VALUE of a
-- variant construct's VFieldList. The field NAMEs are record-field labels, not
-- variables, so only the `val` Ast of each VFCons is walked. The scope `binds` is
-- threaded UNCHANGED (a variant construct introduces no new bindings). Mutually
-- recursive with count_undef_ast (a field value is itself an Ast). Recurses over
-- the VFieldList tail (a field of the packed input), so bound + breadcrumb.
concept UndefVFieldsState
  @intention: "A variant construct's field list + the rule's bindings (scope) + the source text"
  @source: vexprparse.intent:32
  fields:
    fields : VFieldList
    binds : Binding
    src : text [..256]


rule count_undef_vfields
  @intention: "Total undefined-variable references across every field value of a variant construct"
  @source: vexprparse.intent:32
  input:
    a : UndefVFieldsState
  output:
    out : number
  logic:
    out = match a.fields:
      VFCons(name_start, name_len, val, rest) => count_undef_ast(UndefAstState { node: val, binds: a.binds, src: a.src }) + count_undef_vfields(UndefVFieldsState { fields: rest, binds: a.binds, src: a.src })
      VFNil => 0
  proofs:
    purity:
      reads : [a.fields, a.binds, a.src]
      calls : [count_undef_ast, count_undef_vfields]
    termination:
      bound : 4000


-- R6a: count_undef_arms — for each arm of a match, walk the arm BODY with the
-- scope EXTENDED by that arm's binders (binds_with_binders), then recurse on the
-- rest with the ORIGINAL scope (an arm's binders are in scope ONLY in its own
-- body). This is the load-bearing scoping: `Cons(head, tail) => head + zzz` flags
-- zzz but NOT head/tail. Mutually recursive with count_undef_ast. Recurses over
-- the ArmList tail (a field of the packed input), so bound + breadcrumb.
concept UndefArmsState
  @intention: "A match arm list + the rule's bindings (enclosing scope) + the source text"
  @source: vexprparse.intent:32
  fields:
    arms : ArmList
    binds : Binding
    src : text [..256]


rule count_undef_arms
  @intention: "Total undefined-variable references across every match arm body (arm binders in scope per arm)"
  @source: vexprparse.intent:32
  input:
    a : UndefArmsState
  output:
    out : number
  logic:
    out = match a.arms:
      ArmCons(vstart, vlen, binders, body, rest) => count_undef_ast(UndefAstState { node: body, binds: binds_with_binders(BindsWithBindersState { binds: a.binds, bs: binders }), src: a.src }) + count_undef_arms(UndefArmsState { arms: rest, binds: a.binds, src: a.src })
      ArmNil => 0
  proofs:
    purity:
      reads : [a.arms, a.binds, a.src]
      calls : [count_undef_ast, count_undef_arms, binds_with_binders]
    termination:
      bound : 4000


-- count_undef_binds_ordered's input: the binding list being ITERATED (each
-- binding's RHS is lint-checked) + the PREFIX of bindings already seen earlier in
-- source order (the only scope a RHS may legitimately reference) + the source
-- text. `iter` shrinks each step; `prefix` GROWS each step (front-consed). This is
-- the brick-14 refinement of brick-13's UndefBindsState: brick-13 checked every
-- RHS against the WHOLE binding list (`scope`), which silently accepted
-- use-before-def. Here each RHS is checked against `prefix` (earlier lets only).
concept UndefBindsOrderedState
  @intention: "The bindings being iterated + the prefix of earlier bindings + the source text"
  @source: vexprparse.intent:32
  fields:
    iter : Binding
    prefix : Binding
    src : text [..256]


-- count_undef_binds_ordered: for each binding in `iter`, count_undef_ast on its
-- RHS `value` against `prefix` ONLY (the bindings that appear EARLIER in the
-- list), then recurse on `rest` with `prefix` EXTENDED by THIS binding. Because
-- name_bound checks membership (order-agnostic), the prefix can be built by
-- front-consing the current binding onto `prefix` — that yields exactly the SET of
-- earlier bindings, which is all name_bound needs. lint_rule seeds the walk with
-- `prefix = BNil`.
--
-- This catches USE-BEFORE-DEF that brick-13 missed: `let a = b + 1\nlet b = 2`
-- now flags `b` in a's RHS because `b` is NOT yet in the prefix when a is checked
-- (b is only consed onto the prefix when descending into `rest`, AFTER a's RHS is
-- checked). A SELF-REFERENCE `let x = x + 1` is also flagged: `x` is added to the
-- prefix only on the recursion into `rest`, so x's OWN RHS is checked against a
-- prefix that does NOT contain x -> x is unbound -> counted. A legitimate
-- later-let reference (`let y = x + 1` with x earlier) stays 0 because x is in the
-- prefix by the time y is checked. The final `result` expression still sees ALL
-- bindings (lint_rule passes the full list there, unchanged).
--
-- Recurses over the iterated binding tail (a field of the input), so bound +
-- breadcrumb; `prefix` is rebuilt and `src` threaded unchanged.
rule count_undef_binds_ordered
  @intention: "Undefined-OR-use-before-def references across every binding's RHS (earlier-only scope)"
  @source: vexprparse.intent:32
  input:
    b : UndefBindsOrderedState
  output:
    out : number
  logic:
    out = match b.iter:
      BCons(name_start, name_len, value, rest) => count_undef_ast(UndefAstState { node: value, binds: b.prefix, src: b.src }) + count_undef_binds_ordered(UndefBindsOrderedState { iter: rest, prefix: Binding::BCons { name_start: name_start, name_len: name_len, value: value, rest: b.prefix }, src: b.src })
      BNil => 0
  proofs:
    purity:
      reads : [b.iter, b.prefix, b.src]
      calls : [count_undef_ast, count_undef_binds_ordered]
    termination:
      bound : 4000


-- Brick 16: convert a rule's ParamList into a Binding list so the existing scope
-- machinery (name_bound, count_undef_*) treats every parameter as already-bound.
-- A parameter has no RHS expression, but name_bound only ever reads a binding's
-- NAME span (name_start, name_len) — never its `value` — so each param is consed
-- as a BCons carrying a DUMMY value (AstNum 0). The resulting list is the rule's
-- INITIAL scope: a param `x` is in scope for every let RHS and for the result,
-- exactly like a let that is always already-defined. Structural recursion on the
-- ParamList tail (Phase C), like count_binds on a Binding list.
rule param_to_binding
  @intention: "Convert a parameter list into a Binding list (params as already-bound names)"
  @source: vexprparse.intent:34
  input:
    pl : ParamList
  output:
    out : Binding
  logic:
    out = match pl:
      PCons(name_start, name_len, ty, ty_start, ty_len, rest) => Binding::BCons { name_start: name_start, name_len: name_len, value: Ast::AstNum { value: 0 }, rest: param_to_binding(rest) }
      PNil => Binding::BNil
  proofs:
    purity:
      reads : [pl]
      calls : [param_to_binding]
    termination:
      bound : 512
      structural : pl


-- Brick 16: append_bindings's input — the binding list `a` to prepend onto `b`.
concept BindAppendState
  @intention: "Two binding lists: `a` to be prepended onto `b`"
  @source: vexprparse.intent:34
  fields:
    a : Binding
    b : Binding


-- append_bindings: the binding list with every cell of `a` consed (in order) onto
-- the front of `b`. Used to combine the params-as-bindings with a rule's own let
-- bindings into one scope for the result expression. Because name_bound checks
-- membership (order-agnostic), the relative order of the two lists is irrelevant —
-- the only requirement is that every name from BOTH lists is present. Recurses on
-- the tail of `a` (a FIELD of the packed input, not the input itself), so the
-- structural proof does not fit — this carries the bound + the mandatory native
-- recursion breadcrumb, like count_undef_binds_ordered. The backstop is the finite
-- binding list (bounded by max_nodes).
rule append_bindings
  @intention: "Prepend every binding of `a` onto the front of `b`"
  @source: vexprparse.intent:34
  input:
    ba : BindAppendState
  output:
    out : Binding
  logic:
    out = match ba.a:
      BCons(name_start, name_len, value, rest) => Binding::BCons { name_start: name_start, name_len: name_len, value: value, rest: append_bindings(BindAppendState { a: rest, b: ba.b }) }
      BNil => ba.b
  proofs:
    purity:
      reads : [ba.a, ba.b]
      calls : [append_bindings]
    termination:
      bound : 4000


-- lint_rule's input: one rule declaration + the program source text (the spans
-- index into it). RuleDecl carries no src of its own, so the program source is
-- threaded alongside.
concept LintRuleState
  @intention: "A rule declaration + the program source text"
  @source: vexprparse.intent:32
  fields:
    rd : RuleDecl
    src : text [..256]


-- lint_rule: the undefined-OR-use-before-def count for ONE rule. Take the rule's
-- body Block, split it into its binding list and result expression, then sum:
--   * count_undef_binds_ordered over the bindings, seeded with prefix = BNil so
--     each let's RHS is scoped to the lets that appear EARLIER (proper
--     let-ordering: a forward or self reference in a let RHS is flagged), PLUS
--   * count_undef_ast over the result expression, scoped to the FULL binding list
--     (the result legitimately sees every let in the rule).
-- 0 = the rule is clean (every variable it references is bound by an earlier let,
-- or by any let for the result). Per-rule scope: a rule's bindings are NOT visible
-- to any other rule — block_binds(body) is this rule's binding list and nothing
-- else. Brick-14 refinement of brick-13: the bindings part now threads a growing
-- prefix instead of the whole list, so use-before-def is caught.
--
-- Brick 16 — PARAMETERS as the INITIAL scope. The rule's formal parameters
-- (rd_params) are converted to Bindings (param_to_binding) and used as the BASE
-- scope: a param is in scope for EVERY let RHS (so count_undef_binds_ordered is
-- seeded with prefix = the params, not BNil) AND for the result (so the result's
-- scope is the params APPENDED to the full binding list). A param `x` is therefore
-- treated as already-defined everywhere in the body — like a let that is always
-- already-bound. Note: params are added as the use-before-def prefix BASE, so a
-- later let cannot "use-before-def" a parameter (a param precedes all lets).
rule lint_rule
  @intention: "Number of undefined-OR-use-before-def references in one rule (params in scope; 0 if clean)"
  @source: vexprparse.intent:32
  input:
    lr : LintRuleState
  output:
    out : number
  logic:
    let body = rd_body(lr.rd)
    let binds = block_binds(body)
    let result = block_result(body)
    let pbinds = param_to_binding(rd_params(lr.rd))
    let scope = append_bindings(BindAppendState { a: pbinds, b: binds })
    let undef_in_binds = count_undef_binds_ordered(UndefBindsOrderedState { iter: binds, prefix: pbinds, src: lr.src })
    out = undef_in_binds + count_undef_ast(UndefAstState { node: result, binds: scope, src: lr.src })
  proofs:
    purity:
      reads : [lr.rd, lr.src]
      calls : [rd_body, block_binds, block_result, rd_params, param_to_binding, append_bindings, count_undef_binds_ordered, count_undef_ast]
    termination:
      bound : 16


-- lint_list's input: the rule list being folded + the program source text.
concept LintListState
  @intention: "A rule list + the program source text"
  @source: vexprparse.intent:32
  fields:
    rl : RuleList
    src : text [..256]


-- lint_list: sum lint_rule over every rule in the program. Recurses over the
-- RuleList tail (a field of the input), so bound + breadcrumb; the program source is
-- threaded unchanged so every rule's spans resolve against the same buffer. This
-- is the per-rule scoping check made whole: each rule contributes only its OWN
-- undefined references, because lint_rule reads only that rule's own bindings.
rule lint_list
  @intention: "Total undefined-variable references across every rule in a program"
  @source: vexprparse.intent:32
  input:
    ll : LintListState
  output:
    out : number
  logic:
    out = match ll.rl:
      RCons(head, tail) => lint_rule(LintRuleState { rd: head, src: ll.src }) + lint_list(LintListState { rl: tail, src: ll.src })
      RNil => 0
  proofs:
    purity:
      reads : [ll.rl, ll.src]
      calls : [lint_rule, lint_list]
    termination:
      bound : 4000


-- lint_program: the brick-13 money-shot driver. Tokenize the program source (with
-- indentation), parse the whole rule-decl sequence, and fold lint_rule over it,
-- returning the TOTAL number of undefined-variable references in the program.
-- 0 = the whole program is clean — a real static check written in Verbose, run
-- as native machine code over a parsed Verbose program.
--
--   lint_program("rule f\n  logic:\n    let x = 5\n    out = x + 1") = 0   (x defined)
--   lint_program("rule f\n  logic:\n    let x = 5\n    out = x + y") = 1   (y undefined)
--   lint_program("rule f\n  logic:\n    let x = 1\n    out = x\nrule g\n  logic:\n    out = w") = 1
--                                                  (only g's w; f is clean — per-rule scope)
--
-- NATIVE-ONLY (multi-line source). Takes a ScanState (source + pos) so the source
-- is argv arg 1 and pos is argv arg 2 (always 0).
rule lint_program
  @intention: "Tokenize, parse, and count all undefined-variable references in a program"
  @source: vexprparse.intent:32
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    out = lint_list(LintListState { rl: prog, src: s.source })
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, lint_list]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 15 — linter pass #2: undefined-CALLEE detection (INTER-rule).
--
-- The variable lint (lint_program, brick 13/14) is INTRA-rule: a variable
-- reference resolves against the current rule's own bindings, so each rule is
-- linted in isolation. The callee lint is INTER-rule: an AstCall names a RULE,
-- and a rule may be DEFINED anywhere in the program. Resolving a callee therefore
-- needs the WHOLE program's RuleList, not just the current rule's bindings.
--
-- So this is a SEPARATE pass with its own state shapes (it carries the program's
-- RuleList alongside the source text, NOT the current rule's binds). Keeping it
-- separate from the var/use-before-def walk keeps each pass single-purpose and
-- proves their independence: an arg that is an undefined VARIABLE but a valid
-- CALLEE is counted by lint_program and NOT by lint_callees, and vice versa.
--
-- Callee scope is program-wide and ORDER-AGNOSTIC: a rule may call itself
-- (self-reference of a CALLEE is legal — it is existence, not termination, that
-- is checked) and any other rule regardless of source position (forward calls,
-- mutual recursion). So unlike the let-prefix trick in count_undef_binds_ordered,
-- there is no prefix here: every rule sees the FULL program RuleList.
--
-- The rules:
--   * rule_named        — 1 iff some RuleDecl in the list has a name span
--                         byte-equal to the query span. Mirrors name_bound but
--                         over RuleList + rd name spans.
--   * count_badcall_args — sum count_badcall_ast over an ArgList (nested calls).
--   * count_badcall_ast — walk an Ast, count AstCall whose callee is not rule_named.
--   * count_badcall_binds — sum count_badcall_ast over each binding's RHS.
--   * badcall_rule      — one rule's bad-callee count (binds RHSes + result).
--   * lint_callees_list — fold badcall_rule over the program (iter advances, the
--                         full list `all` stays fixed so every rule sees every rule).
--   * lint_callees      — the driver: tokenize -> parse_program -> lint_callees_list.
-- ============================================================================

-- rule_named's probe: the program's RuleList to search + the source text + the
-- query name's span (q_start, q_len). The callee-resolution analogue of
-- NameBoundState (which searches a Binding list); here the search space is the
-- program's rule declarations.
concept RuleNamedState
  @intention: "A rule list to search + the source text + the query callee name's span"
  @source: vexprparse.intent:33
  fields:
    rules : RuleList
    src : text [..256]
    q_start : number [0, 4000000]
    q_len : number [0, 4000000]


-- rule_named: 1 iff the query span byte-equals some RuleDecl's NAME span in the
-- list, 0 otherwise. Walks the RuleList cons-list; at each RCons it checks the
-- rule name's LENGTH equals the query length AND the bytes match (name_eq); on a
-- match it returns 1, else recurses into `tail`. RNil (end) returns 0 (no rule of
-- that name). Mirrors name_bound, but reads the rule head's name span via
-- rd_name_start / rd_name_len instead of a binding's name fields. Recurses over
-- the RuleList tail, which is a FIELD of the input (not the input), so bound +
-- breadcrumb, like name_bound / lint_list.
rule rule_named
  @intention: "1 if a callee name span matches some rule's name in the program, 0 otherwise"
  @source: vexprparse.intent:33
  input:
    st : RuleNamedState
  output:
    out : number
  logic:
    out = match st.rules:
      RCons(head, tail) => if rd_name_len(head) == st.q_len and name_eq(NameEqState { src: st.src, a_start: rd_name_start(head), b_start: st.q_start, len: st.q_len, off: 0 }) == 1 then 1 else rule_named(RuleNamedState { rules: tail, src: st.src, q_start: st.q_start, q_len: st.q_len })
      RNil => 0
  proofs:
    purity:
      reads : [st.rules, st.src, st.q_start, st.q_len]
      calls : [rd_name_len, rd_name_start, name_eq, rule_named]
    termination:
      bound : 4000


-- count_badcall_args's input: the argument list to walk + the program's RuleList
-- (the scope every AstCall callee is resolved against) + the source text. Mirrors
-- UndefArgsState but carries `rules` instead of `binds`.
concept BadCallArgsState
  @intention: "A call-argument list + the program rule list (callee scope) + the source text"
  @source: vexprparse.intent:33
  fields:
    args : ArgList
    rules : RuleList
    src : text [..256]


-- The Ast-walking input: the AST node + the program's RuleList (callee scope) +
-- src. Same shape as UndefAstState but carries `rules` instead of `binds` — this
-- is the load-bearing difference between the two passes: var-lint carries the
-- rule's bindings, callee-lint carries the whole program's rules.
concept BadCallState
  @intention: "An Ast node + the program rule list (callee scope) + the source text"
  @source: vexprparse.intent:33
  fields:
    node : Ast
    rules : RuleList
    src : text [..256]


-- count_badcall_args: sum count_badcall_ast over every argument of a call's
-- ArgList. Mutually recursive with count_badcall_ast (a call's arguments are
-- themselves Asts that may contain more calls — this is how NESTED calls like
-- g(h(1)) get walked: g's existence is checked at the AstCall node, then its
-- argument h(1) is recursed into here). Recurses over the ArgList tail (a field of
-- the input), so bound + breadcrumb. Threads the same rules (scope) + src down.
rule count_badcall_args
  @intention: "Total undefined-callee references across every argument of a call"
  @source: vexprparse.intent:33
  input:
    a : BadCallArgsState
  output:
    out : number
  logic:
    out = match a.args:
      ArgCons(head, tail) => count_badcall_ast(BadCallState { node: head, rules: a.rules, src: a.src }) + count_badcall_args(BadCallArgsState { args: tail, rules: a.rules, src: a.src })
      ArgNil => 0
  proofs:
    purity:
      reads : [a.args, a.rules, a.src]
      calls : [count_badcall_ast, count_badcall_args]
    termination:
      bound : 4000


-- count_badcall_ast: walk an Ast and count the AstCall references whose callee
-- name is NOT rule_named in the program. Mirrors count_undef_ast's structural
-- walk, but the node that contributes is AstCall (not AstVar), checked against the
-- program's rules (not the rule's bindings):
--   * AstCall(callee_start, callee_len, args) => (1 if rule_named == 0, the callee
--     does not exist) PLUS count_badcall_args over the arguments (so a nested call
--     inside an argument — g(h(1)) — is also checked). Parenthesized because there
--     is no operator precedence in Verbose: the `if ... then 1 else 0` is the
--     leftmost summand, the args walk the second.
--   * AstBin sums lhs + rhs; AstNeg / AstNot descend; AstIf sums cond + thn + els;
--     AstField walks its base (the field name is not a callee).
--   * AstVar / AstNum / AstStr / AstBool / AstErr carry no callee -> 0. (An AstVar
--     is a VARIABLE reference; that is the other pass's concern.)
-- Every recursive call threads the same rules (scope) + src. a.node is a FIELD of
-- the packed input (not the input), so bound + mandatory native recursion breadcrumb.
rule count_badcall_ast
  @intention: "Total undefined-callee references in an AST, given the program's rule list"
  @source: vexprparse.intent:33
  input:
    a : BadCallState
  output:
    out : number
  logic:
    out = match a.node:
      AstNum(value) => 0
      AstBin(op, lhs, rhs) => count_badcall_ast(BadCallState { node: lhs, rules: a.rules, src: a.src }) + count_badcall_ast(BadCallState { node: rhs, rules: a.rules, src: a.src })
      AstNeg(inner) => count_badcall_ast(BadCallState { node: inner, rules: a.rules, src: a.src })
      AstNot(inner) => count_badcall_ast(BadCallState { node: inner, rules: a.rules, src: a.src })
      AstVar(start, len) => 0
      AstField(base, fstart, flen) => count_badcall_ast(BadCallState { node: base, rules: a.rules, src: a.src })
      AstCall(callee_start, callee_len, args) => (if rule_named(RuleNamedState { rules: a.rules, src: a.src, q_start: callee_start, q_len: callee_len }) == 0 then 1 else 0) + count_badcall_args(BadCallArgsState { args: args, rules: a.rules, src: a.src })
      AstIf(cond, thn, els) => count_badcall_ast(BadCallState { node: cond, rules: a.rules, src: a.src }) + count_badcall_ast(BadCallState { node: thn, rules: a.rules, src: a.src }) + count_badcall_ast(BadCallState { node: els, rules: a.rules, src: a.src })
      AstBool(value) => 0
      AstStr(start, len) => 0
      AstBytes(start, len) => 0
      AstErr => 0
      -- R6a: a variant construct names a TYPE, not a callee — only its field VALUE
      -- expressions can contain calls, so walk them via count_badcall_vfields.
      AstVariant(cstart, clen, vstart, vlen, fields) => count_badcall_vfields(BadCallVFieldsState { fields: fields, rules: a.rules, src: a.src })
      -- R6a: a match has no callee of its own — walk the scrutinee then every arm
      -- body. Arm binders don't affect callee resolution (callees are program-wide),
      -- so count_badcall_arms just threads the same rules into each arm body.
      AstMatch(scrut, arms) => count_badcall_ast(BadCallState { node: scrut, rules: a.rules, src: a.src }) + count_badcall_arms(BadCallArmsState { arms: arms, rules: a.rules, src: a.src })
  proofs:
    purity:
      reads : [a.node, a.rules, a.src]
      calls : [count_badcall_ast, count_badcall_args, rule_named, count_badcall_vfields, count_badcall_arms]
    termination:
      bound : 4000


-- R6a: count_badcall_vfields — sum count_badcall_ast over every field value of a
-- variant construct (a nested call in a field value is checked). Threads the same
-- program RuleList (callee scope). Mutually recursive with count_badcall_ast.
concept BadCallVFieldsState
  @intention: "A variant construct's field list + the program rule list (callee scope) + the source text"
  @source: vexprparse.intent:33
  fields:
    fields : VFieldList
    rules : RuleList
    src : text [..256]


rule count_badcall_vfields
  @intention: "Total undefined-callee references across every field value of a variant construct"
  @source: vexprparse.intent:33
  input:
    a : BadCallVFieldsState
  output:
    out : number
  logic:
    out = match a.fields:
      VFCons(name_start, name_len, val, rest) => count_badcall_ast(BadCallState { node: val, rules: a.rules, src: a.src }) + count_badcall_vfields(BadCallVFieldsState { fields: rest, rules: a.rules, src: a.src })
      VFNil => 0
  proofs:
    purity:
      reads : [a.fields, a.rules, a.src]
      calls : [count_badcall_ast, count_badcall_vfields]
    termination:
      bound : 4000


-- R6a: count_badcall_arms — sum count_badcall_ast over every match arm body. Arm
-- binders are variable bindings, not callee names, so callee scope (the program
-- RuleList) is threaded unchanged into each arm body. Mutually recursive with
-- count_badcall_ast. Recurses over the ArmList tail (a field of the input).
concept BadCallArmsState
  @intention: "A match arm list + the program rule list (callee scope) + the source text"
  @source: vexprparse.intent:33
  fields:
    arms : ArmList
    rules : RuleList
    src : text [..256]


rule count_badcall_arms
  @intention: "Total undefined-callee references across every match arm body"
  @source: vexprparse.intent:33
  input:
    a : BadCallArmsState
  output:
    out : number
  logic:
    out = match a.arms:
      ArmCons(vstart, vlen, binders, body, rest) => count_badcall_ast(BadCallState { node: body, rules: a.rules, src: a.src }) + count_badcall_arms(BadCallArmsState { arms: rest, rules: a.rules, src: a.src })
      ArmNil => 0
  proofs:
    purity:
      reads : [a.arms, a.rules, a.src]
      calls : [count_badcall_ast, count_badcall_arms]
    termination:
      bound : 4000


-- count_badcall_binds's input: the binding list whose RHSes are walked + the
-- program's RuleList (callee scope) + the source text. Unlike the var pass there
-- is no prefix: callee scope is program-wide and order-agnostic, so EVERY RHS sees
-- the FULL program rule list. (A let RHS may legitimately call a rule defined
-- later in the file, or call the rule it lives in.)
concept BadCallBindsState
  @intention: "A binding list + the program rule list (callee scope) + the source text"
  @source: vexprparse.intent:33
  fields:
    binds : Binding
    rules : RuleList
    src : text [..256]


-- count_badcall_binds: for each binding in the list, count_badcall_ast on its RHS
-- `value` against the FULL program rule list, then recurse on `rest`. The whole
-- program's rules are visible to every RHS (no prefix trick — callees are not
-- ordered like lets). Recurses over the binding tail (a field of the input), so
-- bound + breadcrumb; rules + src threaded unchanged.
rule count_badcall_binds
  @intention: "Total undefined-callee references across every binding's RHS"
  @source: vexprparse.intent:33
  input:
    b : BadCallBindsState
  output:
    out : number
  logic:
    out = match b.binds:
      BCons(name_start, name_len, value, rest) => count_badcall_ast(BadCallState { node: value, rules: b.rules, src: b.src }) + count_badcall_binds(BadCallBindsState { binds: rest, rules: b.rules, src: b.src })
      BNil => 0
  proofs:
    purity:
      reads : [b.binds, b.rules, b.src]
      calls : [count_badcall_ast, count_badcall_binds]
    termination:
      bound : 4000


-- badcall_rule's input: ONE rule declaration being checked + the FULL program
-- RuleList (so the checked rule may call itself or any other rule) + the source
-- text. The full list is threaded here, not the iterating tail — every rule
-- resolves its callees against every rule.
concept BadCallRuleState
  @intention: "A rule declaration + the full program rule list + the source text"
  @source: vexprparse.intent:33
  fields:
    rd : RuleDecl
    rules : RuleList
    src : text [..256]


-- badcall_rule: the undefined-callee count for ONE rule. Split the body Block into
-- its binding list and result expression, then sum:
--   * count_badcall_binds over the bindings (every let RHS's calls), PLUS
--   * count_badcall_ast over the result expression's calls.
-- Both halves resolve callees against the SAME full program RuleList `br.rules` —
-- callee scope is program-wide, so there is no per-let ordering and no prefix.
-- 0 = the rule calls only rules that exist. A rule calling ITSELF is clean (the
-- rule's own name is in `br.rules`). A rule calling a rule defined later is clean.
rule badcall_rule
  @intention: "Number of undefined-callee references in one rule (0 if all callees exist)"
  @source: vexprparse.intent:33
  input:
    br : BadCallRuleState
  output:
    out : number
  logic:
    let body = rd_body(br.rd)
    let binds = block_binds(body)
    let result = block_result(body)
    let bad_in_binds = count_badcall_binds(BadCallBindsState { binds: binds, rules: br.rules, src: br.src })
    out = bad_in_binds + count_badcall_ast(BadCallState { node: result, rules: br.rules, src: br.src })
  proofs:
    purity:
      reads : [br.rd, br.rules, br.src]
      calls : [rd_body, block_binds, block_result, count_badcall_binds, count_badcall_ast]
    termination:
      bound : 16


-- lint_callees_list's input: the rule list being ITERATED (`iter` advances each
-- step, one rule checked per step) + the FULL program rule list (`all`, fixed, so
-- every rule resolves callees against every rule) + the source text. The split
-- between `iter` and `all` is what makes callee scope program-wide: badcall_rule
-- always receives `all`, never the shrinking `iter`.
concept LintCalleesState
  @intention: "The rule list being iterated + the full program rule list + the source text"
  @source: vexprparse.intent:33
  fields:
    iter : RuleList
    all : RuleList
    src : text [..256]


-- lint_callees_list: sum badcall_rule over every rule in the program. Recurses
-- over `iter` (a field of the input), so bound + breadcrumb; `all` and `src` are
-- threaded unchanged so every rule sees the same full program rule list and the
-- same source buffer. Total undefined-callee references across the program.
rule lint_callees_list
  @intention: "Total undefined-callee references across every rule in a program"
  @source: vexprparse.intent:33
  input:
    lc : LintCalleesState
  output:
    out : number
  logic:
    out = match lc.iter:
      RCons(head, tail) => badcall_rule(BadCallRuleState { rd: head, rules: lc.all, src: lc.src }) + lint_callees_list(LintCalleesState { iter: tail, all: lc.all, src: lc.src })
      RNil => 0
  proofs:
    purity:
      reads : [lc.iter, lc.all, lc.src]
      calls : [badcall_rule, lint_callees_list]
    termination:
      bound : 4000


-- lint_callees: the brick-15 money-shot driver. Tokenize the program source (with
-- indentation), parse the whole rule-decl sequence into a RuleList, then fold
-- badcall_rule over it with `iter = all = the parsed program` so every rule
-- resolves its callees against the entire program. Returns the TOTAL number of
-- undefined-callee references (calls to rules that do not exist). 0 = every call
-- in the program names a rule that exists.
--
--   lint_callees("rule f\n  logic:\n    out = f(1)") = 0   (f calls itself; f exists)
--   lint_callees("rule f\n  logic:\n    out = h(1)") = 1   (h is not a rule)
--   lint_callees("rule f\n  logic:\n    out = g(h(1))\nrule g\n  logic:\n    out = 2") = 1
--                                          (g exists; h does not — nested-call resolution)
--
-- NATIVE-ONLY (multi-line source). Takes a ScanState (source + pos): source is
-- argv arg 1, pos is argv arg 2 (always 0). Independent of lint_program: an arg
-- that is an undefined VAR but a valid callee is 0 here, 1 there.
rule lint_callees
  @intention: "Tokenize, parse, and count all undefined-callee references in a program"
  @source: vexprparse.intent:33
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    out = lint_callees_list(LintCalleesState { iter: prog, all: prog, src: s.source })
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, lint_callees_list]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 17: CALL-ARITY checking — the linter's SECOND inter-rule pass.
--
-- The callee pass (brick 15) asks "does the called rule EXIST?". This pass asks
-- the next question: "does the call pass the RIGHT NUMBER OF ARGUMENTS?". A call
-- `add(1)` to a rule `rule add(x, y)` is well-formed for the callee pass (add
-- exists) but WRONG here (1 argument supplied, 2 parameters declared). The
-- headline driver returns the total number of call sites whose argument count
-- does not match the called rule's parameter count.
--
-- ONLY EXISTING RULES ARE CHECKED. An undefined callee is the callee pass's
-- concern, not this one: if a call names a rule that does not exist, this pass
-- contributes 0 for that call (you cannot compare against an arity that is not
-- there). So the two passes are PROVABLY INDEPENDENT — `g(1, 2)` with g
-- undefined lints 1 under the callee pass and 0 here; `add(1)` with add a real
-- 2-param rule lints 0 under the callee pass and 1 here.
--
-- PROGRAM-WIDE, ORDER-AGNOSTIC SCOPE — identical to the callee pass: a call may
-- target a rule defined anywhere (forward, self, mutual). So the structure
-- mirrors the callee pass exactly: a membership-style probe over the program's
-- RuleList, an Ast/ArgList mutual walk, a per-rule split (binds + result), and
-- an iter/all fold over the program.
--
-- THE SENTINEL. rule_arity returns a NOT-FOUND sentinel of 1000000 (one million)
-- when no rule of the query name exists. A negative sentinel would be wrong: a
-- `number` field defaults to the range [0, i32::MAX], and the optimizer's
-- interval arithmetic could dead-eliminate a branch testing a negative value.
-- 1000000 is safely inside the field range, far above any real parameter count,
-- and the `found == 1000000` test is exact.
--
-- The rules:
--   * arg_list_len      — the number of arguments in a call's ArgList (mirrors
--                         param_list_len over ParamList).
--   * rule_arity        — the parameter count of the FIRST rule whose name span
--                         byte-equals the query span, or the 1000000 sentinel.
--                         Mirrors rule_named's RuleList walk but returns the arity.
--   * arity_mismatch    — 0/1 for ONE call: 0 if the callee is undefined OR the
--                         arg count matches; 1 if the callee exists and the count
--                         differs. A helper so the AstCall arm evaluates rule_arity
--                         exactly once (no inline double-evaluation).
--   * count_badarity_args — sum count_badarity_ast over an ArgList (nested calls).
--   * count_badarity_ast  — walk an Ast; at AstCall add arity_mismatch for THIS
--                           call, then recurse into the arguments.
--   * count_badarity_binds — sum count_badarity_ast over each binding's RHS.
--   * badarity_rule     — one rule's arity-mismatch count (binds RHSes + result).
--   * lint_arity_list   — fold badarity_rule over the program (iter advances,
--                         the full list `all` stays fixed).
--   * lint_arity        — the driver: tokenize -> parse_program -> lint_arity_list.
-- ============================================================================

-- arg_list_len: the number of arguments in a call's ArgList. Structural recursion
-- on the ArgCons tail (Phase C), the exact mirror of param_list_len over ParamList:
-- ArgCons contributes 1 + the tail's length, ArgNil is 0. Takes the bare ArgList
-- as input (no wrapper state) — same shape as param_list_len.
rule arg_list_len
  @intention: "Number of arguments in a call's argument list"
  @source: vexprparse.intent:35
  input:
    al : ArgList
  output:
    out : number
  logic:
    out = match al:
      ArgCons(head, tail) => 1 + arg_list_len(tail)
      ArgNil => 0
  proofs:
    purity:
      reads : [al]
      calls : [arg_list_len]
    termination:
      bound : 512
      structural : al


-- rule_arity's probe: the program's RuleList to search + the source text + the
-- query callee name's span (q_start, q_len). The arity-resolution analogue of
-- RuleNamedState — same fields, different return (an arity instead of a 0/1
-- membership flag).
concept RuleArityState
  @intention: "A rule list to search + the source text + the query callee name's span"
  @source: vexprparse.intent:35
  fields:
    rules : RuleList
    src : text [..256]
    q_start : number [0, 4000000]
    q_len : number [0, 4000000]


-- rule_arity: the parameter count of the FIRST rule whose NAME span byte-equals
-- the query span, or the 1000000 NOT-FOUND sentinel if no rule matches. Walks the
-- RuleList exactly like rule_named (same RCons/RNil cons-walk, same length-then-
-- bytes name_eq guard), but on a match it returns param_list_len(rd_params(head))
-- instead of 1, and on RNil it returns the sentinel instead of 0. The sentinel is
-- 1000000 (NOT -1) so the optimizer's interval arithmetic over the default
-- [0, i32::MAX] field range cannot dead-eliminate a negative-test branch. Recurses
-- over the RuleList tail (a field of the input), so bound + native breadcrumb.
rule rule_arity
  @intention: "Parameter count of the rule matching a callee name span, or 1000000 if none"
  @source: vexprparse.intent:35
  input:
    st : RuleArityState
  output:
    out : number
  logic:
    out = match st.rules:
      RCons(head, tail) => if rd_name_len(head) == st.q_len and name_eq(NameEqState { src: st.src, a_start: rd_name_start(head), b_start: st.q_start, len: st.q_len, off: 0 }) == 1 then param_list_len(rd_params(head)) else rule_arity(RuleArityState { rules: tail, src: st.src, q_start: st.q_start, q_len: st.q_len })
      RNil => 1000000
  proofs:
    purity:
      reads : [st.rules, st.src, st.q_start, st.q_len]
      calls : [rd_name_len, rd_name_start, name_eq, param_list_len, rd_params, rule_arity]
    termination:
      bound : 4000


-- arity_mismatch's input: ONE call's callee name span (callee_start, callee_len)
-- + that call's ArgList + the program's RuleList (the scope the callee is resolved
-- against) + the source text. Packs everything the per-call arity decision needs.
concept MismatchState
  @intention: "A call's callee span + its argument list + the program rule list + the source text"
  @source: vexprparse.intent:35
  fields:
    rules : RuleList
    src : text [..256]
    callee_start : number [0, 4000000]
    callee_len : number [0, 4000000]
    args : ArgList


-- arity_mismatch: 0/1 for ONE call. Resolve the callee's declared arity via
-- rule_arity (evaluated ONCE here, then bound to `found` — this is why this is a
-- helper rule and not an inline expression in the AstCall arm: an inline form
-- would have to call rule_arity twice). Then:
--   * found == 1000000 (callee does not exist) => 0. An undefined callee is the
--     callee pass's job; arity skips it.
--   * else compare the supplied argument count (arg_list_len) to `found`: equal
--     => 0 (well-formed call), different => 1 (arity mismatch).
-- No recursion of its own; it is a leaf decision summed by count_badarity_ast.
rule arity_mismatch
  @intention: "1 if a call to an existing rule supplies the wrong number of arguments, else 0"
  @source: vexprparse.intent:35
  input:
    m : MismatchState
  output:
    out : number
  logic:
    let found = rule_arity(RuleArityState { rules: m.rules, src: m.src, q_start: m.callee_start, q_len: m.callee_len })
    out = if found == 1000000 then 0 else (if arg_list_len(m.args) == found then 0 else 1)
  proofs:
    purity:
      reads : [m.rules, m.src, m.callee_start, m.callee_len, m.args]
      calls : [rule_arity, arg_list_len]
    termination:
      bound : 16


-- count_badarity_args's input: the argument list to walk + the program's RuleList
-- (callee scope) + the source text. Mirrors BadCallArgsState exactly.
concept BadArityArgsState
  @intention: "A call-argument list + the program rule list (callee scope) + the source text"
  @source: vexprparse.intent:35
  fields:
    args : ArgList
    rules : RuleList
    src : text [..256]


-- The Ast-walking input: the AST node + the program's RuleList (callee scope) +
-- src. Mirrors BadCallState exactly.
concept BadArityState
  @intention: "An Ast node + the program rule list (callee scope) + the source text"
  @source: vexprparse.intent:35
  fields:
    node : Ast
    rules : RuleList
    src : text [..256]


-- count_badarity_args: sum count_badarity_ast over every argument of a call's
-- ArgList. Mutually recursive with count_badarity_ast — a nested call like h(1)
-- inside g(h(1)) is recursed into here (h's own arity is then checked at its
-- AstCall node). Recurses over the ArgList tail (a field of the input), so bound +
-- breadcrumb; rules (scope) + src threaded unchanged. Mirrors count_badcall_args.
rule count_badarity_args
  @intention: "Total arity-mismatch references across every argument of a call"
  @source: vexprparse.intent:35
  input:
    a : BadArityArgsState
  output:
    out : number
  logic:
    out = match a.args:
      ArgCons(head, tail) => count_badarity_ast(BadArityState { node: head, rules: a.rules, src: a.src }) + count_badarity_args(BadArityArgsState { args: tail, rules: a.rules, src: a.src })
      ArgNil => 0
  proofs:
    purity:
      reads : [a.args, a.rules, a.src]
      calls : [count_badarity_ast, count_badarity_args]
    termination:
      bound : 4000


-- count_badarity_ast: walk an Ast and count the AstCall sites whose argument count
-- does not match the called rule's parameter count. Mirrors count_badcall_ast's
-- structural walk; the ONLY behavioral difference is the AstCall arm:
--   * AstCall(callee_start, callee_len, args) => arity_mismatch for THIS call (0 if
--     the callee is undefined or the count matches, 1 if it exists and differs)
--     PLUS count_badarity_args over the arguments (so a nested call's own arity is
--     also checked). The two summands are the per-call decision and the args walk.
--   * AstBin sums lhs + rhs; AstNeg / AstNot descend; AstIf sums cond + thn + els;
--     AstField walks its base. AstVar / AstNum / AstStr / AstBool / AstErr carry no
--     call -> 0.
-- a.node is a FIELD of the packed input (not the input), so bound + native breadcrumb.
rule count_badarity_ast
  @intention: "Total arity-mismatch references in an AST, given the program's rule list"
  @source: vexprparse.intent:35
  input:
    a : BadArityState
  output:
    out : number
  logic:
    out = match a.node:
      AstNum(value) => 0
      AstBin(op, lhs, rhs) => count_badarity_ast(BadArityState { node: lhs, rules: a.rules, src: a.src }) + count_badarity_ast(BadArityState { node: rhs, rules: a.rules, src: a.src })
      AstNeg(inner) => count_badarity_ast(BadArityState { node: inner, rules: a.rules, src: a.src })
      AstNot(inner) => count_badarity_ast(BadArityState { node: inner, rules: a.rules, src: a.src })
      AstVar(start, len) => 0
      AstField(base, fstart, flen) => count_badarity_ast(BadArityState { node: base, rules: a.rules, src: a.src })
      AstCall(callee_start, callee_len, args) => arity_mismatch(MismatchState { rules: a.rules, src: a.src, callee_start: callee_start, callee_len: callee_len, args: args }) + count_badarity_args(BadArityArgsState { args: args, rules: a.rules, src: a.src })
      AstIf(cond, thn, els) => count_badarity_ast(BadArityState { node: cond, rules: a.rules, src: a.src }) + count_badarity_ast(BadArityState { node: thn, rules: a.rules, src: a.src }) + count_badarity_ast(BadArityState { node: els, rules: a.rules, src: a.src })
      AstBool(value) => 0
      AstStr(start, len) => 0
      AstBytes(start, len) => 0
      AstErr => 0
      -- R6a: a variant construct is not a call — only its field VALUE expressions
      -- can contain arity-checked calls, so walk them via count_badarity_vfields.
      AstVariant(cstart, clen, vstart, vlen, fields) => count_badarity_vfields(BadArityVFieldsState { fields: fields, rules: a.rules, src: a.src })
      -- R6a: a match has no call of its own — walk the scrutinee then every arm
      -- body. Arm binders don't affect arity resolution (callees are program-wide).
      AstMatch(scrut, arms) => count_badarity_ast(BadArityState { node: scrut, rules: a.rules, src: a.src }) + count_badarity_arms(BadArityArmsState { arms: arms, rules: a.rules, src: a.src })
  proofs:
    purity:
      reads : [a.node, a.rules, a.src]
      calls : [count_badarity_ast, count_badarity_args, arity_mismatch, count_badarity_vfields, count_badarity_arms]
    termination:
      bound : 4000


-- R6a: count_badarity_vfields — sum count_badarity_ast over every field value of a
-- variant construct (a nested call's arity is checked). Threads the same program
-- RuleList. Mutually recursive with count_badarity_ast. Mirrors count_badcall_vfields.
concept BadArityVFieldsState
  @intention: "A variant construct's field list + the program rule list (callee scope) + the source text"
  @source: vexprparse.intent:35
  fields:
    fields : VFieldList
    rules : RuleList
    src : text [..256]


rule count_badarity_vfields
  @intention: "Total arity-mismatch references across every field value of a variant construct"
  @source: vexprparse.intent:35
  input:
    a : BadArityVFieldsState
  output:
    out : number
  logic:
    out = match a.fields:
      VFCons(name_start, name_len, val, rest) => count_badarity_ast(BadArityState { node: val, rules: a.rules, src: a.src }) + count_badarity_vfields(BadArityVFieldsState { fields: rest, rules: a.rules, src: a.src })
      VFNil => 0
  proofs:
    purity:
      reads : [a.fields, a.rules, a.src]
      calls : [count_badarity_ast, count_badarity_vfields]
    termination:
      bound : 4000


-- R6a: count_badarity_arms — sum count_badarity_ast over every match arm body. Arm
-- binders don't affect arity resolution, so the program RuleList is threaded
-- unchanged into each arm body. Mirrors count_badcall_arms.
concept BadArityArmsState
  @intention: "A match arm list + the program rule list (callee scope) + the source text"
  @source: vexprparse.intent:35
  fields:
    arms : ArmList
    rules : RuleList
    src : text [..256]


rule count_badarity_arms
  @intention: "Total arity-mismatch references across every match arm body"
  @source: vexprparse.intent:35
  input:
    a : BadArityArmsState
  output:
    out : number
  logic:
    out = match a.arms:
      ArmCons(vstart, vlen, binders, body, rest) => count_badarity_ast(BadArityState { node: body, rules: a.rules, src: a.src }) + count_badarity_arms(BadArityArmsState { arms: rest, rules: a.rules, src: a.src })
      ArmNil => 0
  proofs:
    purity:
      reads : [a.arms, a.rules, a.src]
      calls : [count_badarity_ast, count_badarity_arms]
    termination:
      bound : 4000


-- count_badarity_binds's input: the binding list whose RHSes are walked + the
-- program's RuleList (callee scope) + the source text. No prefix — callee scope is
-- program-wide and order-agnostic, so every RHS sees the FULL program rule list.
-- Mirrors BadCallBindsState exactly.
concept BadArityBindsState
  @intention: "A binding list + the program rule list (callee scope) + the source text"
  @source: vexprparse.intent:35
  fields:
    binds : Binding
    rules : RuleList
    src : text [..256]


-- count_badarity_binds: for each binding in the list, count_badarity_ast on its
-- RHS `value` against the FULL program rule list, then recurse on `rest`. Recurses
-- over the binding tail (a field of the input), so bound + breadcrumb; rules + src
-- threaded unchanged. Mirrors count_badcall_binds.
rule count_badarity_binds
  @intention: "Total arity-mismatch references across every binding's RHS"
  @source: vexprparse.intent:35
  input:
    b : BadArityBindsState
  output:
    out : number
  logic:
    out = match b.binds:
      BCons(name_start, name_len, value, rest) => count_badarity_ast(BadArityState { node: value, rules: b.rules, src: b.src }) + count_badarity_binds(BadArityBindsState { binds: rest, rules: b.rules, src: b.src })
      BNil => 0
  proofs:
    purity:
      reads : [b.binds, b.rules, b.src]
      calls : [count_badarity_ast, count_badarity_binds]
    termination:
      bound : 4000


-- badarity_rule's input: ONE rule declaration being checked + the FULL program
-- RuleList (so the checked rule's calls resolve against every rule) + the source
-- text. Mirrors BadCallRuleState exactly.
concept BadArityRuleState
  @intention: "A rule declaration + the full program rule list + the source text"
  @source: vexprparse.intent:35
  fields:
    rd : RuleDecl
    rules : RuleList
    src : text [..256]


-- badarity_rule: the arity-mismatch count for ONE rule. Split the body Block into
-- its binding list and result expression, then sum:
--   * count_badarity_binds over the bindings (every let RHS's calls), PLUS
--   * count_badarity_ast over the result expression's calls.
-- Both halves resolve callees against the SAME full program RuleList `br.rules`.
-- 0 = every call in this rule supplies the right number of arguments (or names a
-- rule that does not exist, which arity skips). Mirrors badcall_rule.
rule badarity_rule
  @intention: "Number of arity-mismatch references in one rule (0 if every call's arity is right)"
  @source: vexprparse.intent:35
  input:
    br : BadArityRuleState
  output:
    out : number
  logic:
    let body = rd_body(br.rd)
    let binds = block_binds(body)
    let result = block_result(body)
    let bad_in_binds = count_badarity_binds(BadArityBindsState { binds: binds, rules: br.rules, src: br.src })
    out = bad_in_binds + count_badarity_ast(BadArityState { node: result, rules: br.rules, src: br.src })
  proofs:
    purity:
      reads : [br.rd, br.rules, br.src]
      calls : [rd_body, block_binds, block_result, count_badarity_binds, count_badarity_ast]
    termination:
      bound : 16


-- lint_arity_list's input: the rule list being ITERATED (`iter` advances each step,
-- one rule checked per step) + the FULL program rule list (`all`, fixed, so every
-- rule resolves its calls against every rule) + the source text. The iter/all split
-- makes callee scope program-wide, exactly like LintCalleesState.
concept LintArityState
  @intention: "The rule list being iterated + the full program rule list + the source text"
  @source: vexprparse.intent:35
  fields:
    iter : RuleList
    all : RuleList
    src : text [..256]


-- lint_arity_list: sum badarity_rule over every rule in the program. Recurses over
-- `iter` (a field of the input), so bound + breadcrumb; `all` and `src` are threaded
-- unchanged so every rule sees the same full program rule list and the same source
-- buffer. Total arity-mismatch references across the program. Mirrors lint_callees_list.
rule lint_arity_list
  @intention: "Total arity-mismatch references across every rule in a program"
  @source: vexprparse.intent:35
  input:
    la : LintArityState
  output:
    out : number
  logic:
    out = match la.iter:
      RCons(head, tail) => badarity_rule(BadArityRuleState { rd: head, rules: la.all, src: la.src }) + lint_arity_list(LintArityState { iter: tail, all: la.all, src: la.src })
      RNil => 0
  proofs:
    purity:
      reads : [la.iter, la.all, la.src]
      calls : [badarity_rule, lint_arity_list]
    termination:
      bound : 4000


-- lint_arity: the brick-17 money-shot driver. Tokenize the program source (with
-- indentation), parse the whole rule-decl sequence into a RuleList, then fold
-- badarity_rule over it with `iter = all = the parsed program` so every rule
-- resolves its calls' arities against the entire program. Returns the TOTAL number
-- of call sites whose argument count does not match the called rule's parameter
-- count (calls to non-existent rules are skipped — the callee pass's job). 0 =
-- every call to an existing rule supplies the right number of arguments.
--
--   lint_arity("rule add(x, y)\n  logic:\n    out = x + y\nrule f\n  logic:\n    out = add(1, 2)") = 0
--                                          (2 args supplied, 2 params declared)
--   lint_arity("rule add(x, y)\n  logic:\n    out = x + y\nrule f\n  logic:\n    out = add(1)") = 1
--                                          (1 arg supplied, 2 params declared)
--   lint_arity("rule f\n  logic:\n    out = g(1, 2)") = 0
--                                          (g undefined — arity skips it; the callee pass counts it)
--   lint_arity("rule f(n)\n  logic:\n    out = f(n)") = 0   (self-call, correct arity)
--   lint_arity("rule f(n)\n  logic:\n    out = f(n, n)") = 1 (self-call, wrong arity)
--
-- NATIVE-ONLY (multi-line source). Takes a ScanState (source + pos): source is
-- argv arg 1, pos is argv arg 2 (always 0). Independent of lint_callees and
-- lint_program: a call to a missing rule is counted there, not here.
rule lint_arity
  @intention: "Tokenize, parse, and count all arity-mismatch references in a program"
  @source: vexprparse.intent:35
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    out = lint_arity_list(LintArityState { iter: prog, all: prog, src: s.source })
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, lint_arity_list]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 19: a TYPE CHECKER in Verbose — the static pendant of brick 18's
-- interpreter. Where eval_ast_env computes a VALUE for an AST, type_of_env
-- computes a TYPE for it: a small type lattice {number, bool, ERROR} encoded as
-- non-negative codes (0 = number, 1 = bool, 3 = ERROR; 2 is reserved for a future
-- `text` brick). The checker MIRRORS the interpreter's recursive shape exactly —
-- same dispatch over the Ast variants, same per-rule fold over the program, same
-- type-environment threading through let-blocks — but propagates type codes
-- instead of numbers. type_check(source) returns the total number of type errors
-- (ill-typed let RHSs + ill-typed rule results) across the whole program.
--
-- WHY NON-NEGATIVE CODES. The optimizer's default field range is [0, i32::MAX],
-- so a -1 sentinel would let interval arithmetic dead-eliminate any `x < 0`
-- branch. Every type code here is >= 0, and the bin/if classifiers compare
-- against the literal codes 0/1/3 directly, never against a negative marker.
--
-- THE TYPE ENVIRONMENT. We REUSE the brick-10 Env concept as the TYPE env: each
-- ECons stores a name span and, in `val`, the bound name's TYPE code (instead of
-- its numeric value). env_lookup works UNCHANGED — it returns the stored `val`
-- (now a type code) on a match, or 0 on an unbound name. 0 = number is exactly
-- the right default: an unannotated PARAMETER is treated as number, matching the
-- interpreter's all-numbers world. build_tenv mirrors build_env: it folds the
-- let-bindings in source order, typing each RHS against the env built so far (so
-- `let b = 1 < 2` then `out = if b ...` sees b : bool), consing (name span, RHS
-- type) onto the front.
--
-- TYPING RULES (v1).
--   AstNum  => number ; AstBool => bool ; AstStr => text (brick 30) ;
--   AstErr / AstField => ERROR.
--   AstVar  => env_lookup (the stored type code; 0 = number for unbound params).
--   AstCall => number (every rule returns number in the interpreter's world).
--   AstNeg(e)  => number if type(e) = number, else ERROR.
--   AstNot(e)  => bool   if type(e) = bool,   else ERROR.
--   AstBin(op, l, r) with lt = type(l), rt = type(r):
--     arithmetic (+ - * / %): number if lt = rt = number, else ERROR.
--     comparison (== != < > <= >=): bool if lt = rt = number, else ERROR.
--        (v1: numbers only; bool comparison is a FUTURE brick.)
--     logic (and / or): bool if lt = rt = bool, else ERROR.
--   AstIf(c, t, e): if type(c) = bool AND type(t) = type(e) AND type(t) != ERROR
--                   then type(t), else ERROR.
--
-- TERMINATION. type_of_env + build_tenv (and the per-rule tcheck_binds) form a
-- recursive group/text SCC exactly like the interpreter's eval_ast_env +
-- build_env: each recursive call walks a strict sub-node / shorter tail, but that
-- shrinking value is a FIELD of a packed input concept (not the input itself), so
-- the `structural` proof does not fit. Like the interpreter rules they carry
-- bound-only termination and ACCEPT the mandatory native recursion breadcrumb.
-- The backstops are identical: finite Env / binding / rule lists and a finite AST
-- bounded by max_nodes, so every recursion strictly shrinks toward a leaf / Nil.
-- ============================================================================

-- type_of_env's input: the AST node to type, the TYPE environment (name span ->
-- type code) to resolve variable references against, and the source text the
-- name spans index into. Mirrors the interpreter's EvalEnvArg minus the program
-- (calls type to number unconditionally here, so no program threading is needed).
concept TypeArg
  @intention: "An Ast node + the type environment + the source text + the program + the concept list, for computing its type code"
  @source: vexprparse.intent:37
  fields:
    node : Ast
    tenv : Env
    src : text [..256]
    prog : RuleList
    concepts : ConceptList


-- bin_type's input: the binary operator code plus the ALREADY-COMPUTED type codes
-- of the two operands. A flat number-classifier (no recursion, no group field):
-- type_of_env types lhs and rhs first, then hands the (op, lt, rt) triple here.
concept BinTypeState
  @intention: "A binary op code + the two operand type codes, for classifying the result type"
  @source: vexprparse.intent:37
  fields:
    op : number [0, 64]
    lt : number [0, 4000000]
    rt : number [0, 4000000]


-- if_type's input: the type codes of an if's condition, then-branch, and
-- else-branch. A flat classifier (no recursion): type_of_env types all three
-- sub-expressions first, then hands the triple here for the well-typedness check.
concept IfTypeState
  @intention: "The condition/then/else type codes of an if, for classifying the result type"
  @source: vexprparse.intent:37
  fields:
    ct : number [0, 4000000]
    tt : number [0, 4000000]
    et : number [0, 4000000]


-- bin_type: classify the result type of a binary operation from its op code and
-- its two operand type codes (computed by type_of_env before the call). Arithmetic
-- ops require both operands number and yield number; ORDERING comparisons
-- (<, >, <=, >=) require both number and yield bool (ordering booleans is not
-- meaningful); EQUALITY (==, !=) accepts two operands of the SAME comparable type
-- — number==number OR bool==bool — and yields bool (brick 29; text==text is still
-- ERROR — a string literal is typed text since brick 30, but text supports no
-- operations); logic ops require both bool and yield bool. Any
-- mismatch => ERROR (3), and an unknown op also => ERROR. NON-recursive: a flat
-- nested-if classifier, bounded by 8 (it never recurses; the bound is the trivial
-- leaf budget).
rule bin_type
  @intention: "Result type code of a binary op given its operand type codes (3 = ill-typed)"
  @source: vexprparse.intent:37
  input:
    b : BinTypeState
  output:
    out : number
  logic:
    out = if b.op == 13 then (if b.lt == 0 and b.rt == 0 then 0 else 3) else if b.op == 14 then (if b.lt == 0 and b.rt == 0 then 0 else 3) else if b.op == 15 then (if b.lt == 0 and b.rt == 0 then 0 else 3) else if b.op == 16 then (if b.lt == 0 and b.rt == 0 then 0 else 3) else if b.op == 17 then (if b.lt == 0 and b.rt == 0 then 0 else 3) else if b.op == 1 then (if b.lt == b.rt and (b.lt == 0 or b.lt == 1) then 1 else 3) else if b.op == 6 then (if b.lt == b.rt and (b.lt == 0 or b.lt == 1) then 1 else 3) else if b.op == 19 then (if b.lt == 0 and b.rt == 0 then 1 else 3) else if b.op == 20 then (if b.lt == 0 and b.rt == 0 then 1 else 3) else if b.op == 5 then (if b.lt == 0 and b.rt == 0 then 1 else 3) else if b.op == 4 then (if b.lt == 0 and b.rt == 0 then 1 else 3) else if b.op == 30 then (if b.lt == 1 and b.rt == 1 then 1 else 3) else if b.op == 31 then (if b.lt == 1 and b.rt == 1 then 1 else 3) else 3
  proofs:
    purity:
      reads : [b.op, b.lt, b.rt]
      calls : []
    termination:
      bound : 128


-- if_type: classify the result type of a conditional from the type codes of its
-- condition, then-branch, and else-branch. Well-typed iff the condition is bool
-- (ct == 1), both branches have the SAME type (tt == et), and that type is not
-- ERROR (tt != 3); the result type is then that branch type. Any failure => ERROR
-- (3). NON-recursive flat classifier, bounded by 8.
rule if_type
  @intention: "Result type code of an if given its sub-expression type codes (3 = ill-typed)"
  @source: vexprparse.intent:37
  input:
    i : IfTypeState
  output:
    out : number
  logic:
    out = if i.ct == 1 and i.tt == i.et and i.tt != 3 then i.tt else 3
  proofs:
    purity:
      reads : [i.ct, i.tt, i.et]
      calls : []
    termination:
      bound : 8


-- call_result_type (brick 33): the TYPE of a call's RESULT. Resolves the callee's
-- declared return type (rd_return_type(find_rule(...))) and maps the brick-33
-- "unannotated" sentinel (9) back to number (0). So a call to an annotated rule
-- types as that rule's declared type (0/1/2), and a call to an unannotated or
-- undefined rule (find_rule's RNil sentinel has return_type 0) types as number.
-- This is exactly brick 32's behavior once the sentinel is accounted for; it lives
-- in its own rule so the return-vs-body check (brick 33, in tcheck_rule) can read
-- the RAW sentinel (9) while type_of_env keeps typing calls as number.
rule call_result_type
  @intention: "The result type code of a call, mapping the unannotated sentinel to number"
  @source: vexprparse.intent:51
  input:
    c : CallRetState
  output:
    out : number
  logic:
    let rt = rd_return_type(find_rule(FindRuleState { rules: c.prog, src: c.src, q_start: c.callee_start, q_len: c.callee_len }))
    out = if rt == 9 then 0 else rt
  proofs:
    purity:
      reads : [c.prog, c.src, c.callee_start, c.callee_len]
      calls : [rd_return_type, find_rule]
    termination:
      bound : 64


-- type_of_env: the dispatch. Mirrors eval_ast_env's match STRUCTURE arm-for-arm
-- but returns a TYPE code instead of a value. Leaves: AstNum => number (0),
-- AstBool => bool (1), AstStr => text (2, brick 30 — a string literal is a
-- first-class text value, so a `text` parameter accepts it; text supports no
-- operations, so arithmetic/ordering/logic/equality on text all remain ERROR via
-- bin_type), AstErr / AstField => ERROR (3, fields still not typed), AstCall =>
-- the callee's DECLARED return type via call_result_type (brick 32/33:
-- rd_return_type(find_rule(prog, callee span)) with the brick-33 "unannotated"
-- sentinel 9 mapped back to number 0, so an undefined or unannotated callee
-- resolves to number). AstVar resolves its name in the type env
-- via env_lookup (the stored type code; 0 = number for unbound params). The unary
-- and binary forms recurse on their sub-nodes, threading the same tenv + src down,
-- then classify: AstNeg requires a number operand (else ERROR), AstNot a bool
-- operand (else ERROR), AstBin delegates to bin_type with the two recursively
-- computed operand types, AstIf delegates to if_type with the three recursively
-- computed sub-types. Bound-only termination + the native recursion breadcrumb:
-- each recursive call walks a strict sub-node of t.node, but t.node is a FIELD of
-- the packed input (not the input), so the `structural` proof does not fit — same
-- as eval_ast_env (see the header).
rule type_of_env
  @intention: "Compute an AST's type code, resolving variable references against a type environment"
  @source: vexprparse.intent:37
  input:
    t : TypeArg
  output:
    out : number
  logic:
    out = match t.node:
      AstNum(value) => 0
      AstBin(op, lhs, rhs) => bin_type(BinTypeState { op: op, lt: type_of_env(TypeArg { node: lhs, tenv: t.tenv, src: t.src, prog: t.prog, concepts: t.concepts }), rt: type_of_env(TypeArg { node: rhs, tenv: t.tenv, src: t.src, prog: t.prog, concepts: t.concepts }) })
      AstNeg(inner) => if type_of_env(TypeArg { node: inner, tenv: t.tenv, src: t.src, prog: t.prog, concepts: t.concepts }) == 0 then 0 else 3
      AstNot(inner) => if type_of_env(TypeArg { node: inner, tenv: t.tenv, src: t.src, prog: t.prog, concepts: t.concepts }) == 1 then 1 else 3
      AstVar(start, len) => env_lookup(EnvLookState { env: t.tenv, src: t.src, q_start: start, q_len: len })
      AstField(base, fstart, flen) => 3
      AstCall(callee_start, callee_len, args) => call_result_type(CallRetState { prog: t.prog, src: t.src, callee_start: callee_start, callee_len: callee_len })
      AstIf(cond, thn, els) => if_type(IfTypeState { ct: type_of_env(TypeArg { node: cond, tenv: t.tenv, src: t.src, prog: t.prog, concepts: t.concepts }), tt: type_of_env(TypeArg { node: thn, tenv: t.tenv, src: t.src, prog: t.prog, concepts: t.concepts }), et: type_of_env(TypeArg { node: els, tenv: t.tenv, src: t.src, prog: t.prog, concepts: t.concepts }) })
      AstBool(value) => 1
      AstStr(start, len) => 2
      AstBytes(start, len) => 4
      AstErr => 3
      -- R6b: a variant construction's type is its CONCEPT (resolve the concept-name
      -- span against the ConceptList -> 1000+index, or ERROR if the concept is unknown).
      AstVariant(cstart, clen, vstart, vlen, fields) => resolve_type(ResolveTypeState { concepts: t.concepts, src: t.src, ty_start: cstart, ty_len: clen })
      -- R6b: a match types its scrutinee (must be a concept code >= 1000, else ERROR),
      -- reads that concept's VariantList (concept_at_index on code - 1000), then folds
      -- the arm-body types via arms_type. `code - 1000` is computed only on the >= 1000
      -- branch, so the ConceptAtState index is always >= 0. 7777 (no arms) -> ERROR.
      AstMatch(scrut, arms) => if type_of_env(TypeArg { node: scrut, tenv: t.tenv, src: t.src, prog: t.prog, concepts: t.concepts }) < 1000 then 3 else (if arms_type(ArmsTypeState { arms: arms, vlist: cd_variants(concept_at_index(ConceptAtState { concepts: t.concepts, idx: type_of_env(TypeArg { node: scrut, tenv: t.tenv, src: t.src, prog: t.prog, concepts: t.concepts }) - 1000 })), tenv: t.tenv, src: t.src, prog: t.prog, concepts: t.concepts }) == 7777 then 3 else arms_type(ArmsTypeState { arms: arms, vlist: cd_variants(concept_at_index(ConceptAtState { concepts: t.concepts, idx: type_of_env(TypeArg { node: scrut, tenv: t.tenv, src: t.src, prog: t.prog, concepts: t.concepts }) - 1000 })), tenv: t.tenv, src: t.src, prog: t.prog, concepts: t.concepts }))
  proofs:
    purity:
      reads : [t.node, t.tenv, t.src, t.prog, t.concepts]
      calls : [type_of_env, env_lookup, bin_type, if_type, call_result_type, resolve_type, arms_type, cd_variants, concept_at_index]
    termination:
      bound : 4000


-- build_tenv's input: the remaining binding list, the type env built so far, and
-- the source text (each binding's RHS is TYPED against tenv_so_far, and AstVar
-- references in it resolve via src). Mirror of the interpreter's BuildEnvArg minus
-- the program field (type_of_env types calls to number without it).
concept BuildTArg
  @intention: "Remaining bindings + the type env built so far + the source text + the program + the concept list"
  @source: vexprparse.intent:37
  fields:
    binds : Binding
    tenv : Env
    src : text [..256]
    prog : RuleList
    concepts : ConceptList


-- build_tenv: fold the binding list (in source order) into a TYPE env. For each
-- BCons, compute the binding's RHS TYPE (type_of_env against the env built so far,
-- so `let b = 1 < 2` then `let c = b` sees b : bool), cons (name span, RHS type)
-- onto the FRONT, and recurse on the rest with the extended env. BNil returns the
-- accumulated env unchanged. Front-consing gives last-binding-wins shadowing in
-- env_lookup, exactly as build_env does for values. Bound-only termination + the
-- native recursion breadcrumb (packed input; the shrinking binding tail is a
-- field, not the input — see the header).
rule build_tenv
  @intention: "Fold a binding list into a type environment, typing each RHS against the env so far"
  @source: vexprparse.intent:37
  input:
    bt : BuildTArg
  output:
    out : Env
  logic:
    out = match bt.binds:
      BCons(name_start, name_len, value, rest) => build_tenv(BuildTArg { binds: rest, tenv: Env::ECons { name_start: name_start, name_len: name_len, val: type_of_env(TypeArg { node: value, tenv: bt.tenv, src: bt.src, prog: bt.prog, concepts: bt.concepts }), rest: bt.tenv }, src: bt.src, prog: bt.prog, concepts: bt.concepts })
      BNil => bt.tenv
  proofs:
    purity:
      reads : [bt.binds, bt.tenv, bt.src, bt.prog, bt.concepts]
      calls : [build_tenv, type_of_env]
    termination:
      bound : 4000


-- tcheck_binds's input: the remaining binding list, the type env built so far, and
-- the source text. Mirrors build_tenv's threading but counts ill-typed RHSs rather
-- than accumulating an env.
concept TCheckBindsState
  @intention: "Remaining bindings + the type env built so far + the source text + the program + the concept list, for counting ill-typed RHSs"
  @source: vexprparse.intent:37
  fields:
    binds : Binding
    tenv : Env
    src : text [..256]
    prog : RuleList
    concepts : ConceptList


-- tcheck_binds: count the let RHSs whose TYPE is ERROR (3), threading the GROWING
-- type env so a let referencing an earlier one sees its type (e.g. `let b = 1 < 2`
-- then `let c = b and (2 < 3)` — c sees b : bool). For each BCons: type the RHS
-- against the env so far, add 1 to the count iff that type is ERROR, then recurse
-- on the rest with the env extended by (name span, RHS type) — exactly build_tenv's
-- extension step. The RHS type is computed twice (once for the count, once to
-- extend the env); type_of_env is pure, so the duplicate is correctness-neutral.
-- BNil contributes 0. Bound-only termination + the native recursion breadcrumb.
rule tcheck_binds
  @intention: "Count the let RHSs in a binding list whose type is ill-typed (ERROR)"
  @source: vexprparse.intent:37
  input:
    tb : TCheckBindsState
  output:
    out : number
  logic:
    out = match tb.binds:
      BCons(name_start, name_len, value, rest) => (if type_of_env(TypeArg { node: value, tenv: tb.tenv, src: tb.src, prog: tb.prog, concepts: tb.concepts }) == 3 then 1 else 0) + tcheck_binds(TCheckBindsState { binds: rest, tenv: Env::ECons { name_start: name_start, name_len: name_len, val: type_of_env(TypeArg { node: value, tenv: tb.tenv, src: tb.src, prog: tb.prog, concepts: tb.concepts }), rest: tb.tenv }, src: tb.src, prog: tb.prog, concepts: tb.concepts })
      BNil => 0
  proofs:
    purity:
      reads : [tb.binds, tb.tenv, tb.src, tb.prog, tb.concepts]
      calls : [type_of_env, tcheck_binds]
    termination:
      bound : 4000


-- tcheck_rule's input: one parsed rule declaration + the program source text.
concept TCheckRuleState
  @intention: "A parsed rule declaration + the program source text + the program + the concept list, for type-checking it"
  @source: vexprparse.intent:37
  fields:
    rd : RuleDecl
    src : text [..256]
    prog : RuleList
    concepts : ConceptList


-- tcheck_rule: type-check ONE rule. Split the body into its binding list and final
-- out-expression; build the FULL type env from all the lets (build_tenv over an
-- empty start env); count the ill-typed let RHSs (tcheck_binds, which threads the
-- same growing env so each RHS is typed in the right scope); type the result
-- expression against the full env; the rule's error count is the bad-bind count
-- plus 1 iff the result itself is ill-typed. Brick 33 adds a return-vs-body check:
-- if the rule DECLARES a return type (ret != 9, the "unannotated" sentinel) and the
-- body is well-typed (result_ty != 3) but its type disagrees with the declared
-- return (ret != result_ty), that's +1. An UNANNOTATED rule (ret == 9) is never
-- flagged for a non-number body, preserving bricks 29/30. Plain rule (uses `let`),
-- mirroring lint_rule's body-split shape. bound 4000 (it calls into the recursive
-- checker SCC, so it carries the SCC's bound rather than a trivial leaf budget).
rule tcheck_rule
  @intention: "Number of type errors in one rule (ill-typed let RHSs + ill-typed result; 0 if well-typed)"
  @source: vexprparse.intent:37
  input:
    tr : TCheckRuleState
  output:
    out : number
  logic:
    let body = rd_body(tr.rd)
    let binds = block_binds(body)
    let result = block_result(body)
    let start_env = field_concept_tenv(FieldConceptTenvState { fields: rd_input(tr.rd), concepts: tr.concepts, src: tr.src })
    let tenv = build_tenv(BuildTArg { binds: binds, tenv: start_env, src: tr.src, prog: tr.prog, concepts: tr.concepts })
    let bad_binds = tcheck_binds(TCheckBindsState { binds: binds, tenv: start_env, src: tr.src, prog: tr.prog, concepts: tr.concepts })
    let result_ty = type_of_env(TypeArg { node: result, tenv: tenv, src: tr.src, prog: tr.prog, concepts: tr.concepts })
    let ret = rd_return_type(tr.rd)
    let declared_out = resolve_type(ResolveTypeState { concepts: tr.concepts, src: tr.src, ty_start: rd_out_ty_start(tr.rd), ty_len: rd_out_ty_len(tr.rd) })
    out = bad_binds + (if result_ty == 3 then 1 else 0) + (if ret != 9 and result_ty != 3 and ret != result_ty then 1 else 0) + (if declared_out >= 1000 and result_ty != 3 and declared_out != result_ty then 1 else 0)
  proofs:
    purity:
      reads : [tr.rd, tr.src, tr.prog, tr.concepts]
      calls : [rd_body, block_binds, block_result, rd_input, field_concept_tenv, build_tenv, tcheck_binds, type_of_env, rd_return_type, resolve_type, rd_out_ty_start, rd_out_ty_len]
    termination:
      bound : 4000


-- tcheck_list's input: the rule list being folded + the program source text.
-- Mirrors LintCalleesState minus the `all` program field (this pass needs no
-- inter-rule resolution — each rule is type-checked in isolation).
concept TCheckListState
  @intention: "A rule list (iterated) + the program source text + the full program + the concept list, for folding the type check"
  @source: vexprparse.intent:37
  fields:
    iter : RuleList
    src : text [..256]
    prog : RuleList
    concepts : ConceptList


-- tcheck_list: fold tcheck_rule over the program, summing each rule's type-error
-- count. Mirror of lint_callees_list. Bound-only termination + the native
-- recursion breadcrumb (the shrinking rule-list tail is a field of the packed
-- input, not the input itself).
rule tcheck_list
  @intention: "Total number of type errors across every rule in a program"
  @source: vexprparse.intent:37
  input:
    tl : TCheckListState
  output:
    out : number
  logic:
    out = match tl.iter:
      RCons(head, tail) => tcheck_rule(TCheckRuleState { rd: head, src: tl.src, prog: tl.prog, concepts: tl.concepts }) + tcheck_list(TCheckListState { iter: tail, src: tl.src, prog: tl.prog, concepts: tl.concepts })
      RNil => 0
  proofs:
    purity:
      reads : [tl.iter, tl.src, tl.prog, tl.concepts]
      calls : [tcheck_rule, tcheck_list]
    termination:
      bound : 4000


-- type_check: the brick-19 money-shot driver. Tokenize the program source (with
-- indentation), parse the whole rule-decl sequence into a RuleList, then fold the
-- type check over it. Returns the TOTAL number of type errors (ill-typed let RHSs
-- + ill-typed rule results) in the program. 0 = every let RHS and every rule
-- result is well-typed.
--
--   type_check("rule f\n  logic:\n    out = 1 + 2")          = 0  (number + number)
--   type_check("rule f\n  logic:\n    out = 1 + (2 < 3)")    = 1  (number + bool)
--   type_check("rule f\n  logic:\n    out = if 5 then 1 else 2")        = 1 (non-bool cond)
--   type_check("rule f\n  logic:\n    out = if 1 < 2 then 3 else 4")    = 0 (bool cond, num branches)
--   type_check("rule f\n  logic:\n    let b = 1 < 2\n    out = if b then 1 else 2") = 0
--            (THE SHOWCASE: b is inferred bool from its RHS, so using it as a
--             condition is well-typed — proves the TYPE ENVIRONMENT works)
--   type_check("rule f\n  logic:\n    let n = 5\n    out = if n then 1 else 2")     = 1
--            (n is number, used as condition -> error: the type env distinguishes
--             it from the bool case above)
--   type_check("rule f\n  logic:\n    out = (1 < 2) and (3 < 4)")       = 0  (bool and bool)
--   type_check("rule f\n  logic:\n    out = (1 < 2) and 3")             = 1  (and with a number)
--
-- NATIVE-ONLY (multi-line source). Takes a ScanState (source + pos): source is
-- argv arg 1, pos is argv arg 2 (always 0). Independent of the lint passes — a
-- type-correct program with an undefined callee lints 1 there and 0 here.
rule type_check
  @intention: "Tokenize, parse, and count all type errors in a program"
  @source: vexprparse.intent:37
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let concepts = parse_concepts(ProgramState { cell: toks, src: s.source })
    out = tcheck_list(TCheckListState { iter: prog, prog: prog, src: s.source, concepts: concepts })
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, parse_concepts, tcheck_list]
    termination:
      bound : 256


-- ============================================================================
-- BRICK R6b: the CONCEPT-AWARE type lattice. type_code_of_span maps every
-- non-scalar type NAME to 0 (lossy), so a `head : Token` payload field would type
-- as number and the checker would unsoundly accept `head + 1`. R6b stores type
-- SPANS (FCons/PCons/MkRule, the representation fix above) and resolves them here,
-- at check time, against the parsed ConceptList. A type code is now scalar {0,1,2},
-- ERROR 3, OR a CONCEPT code 1000 + concept_index (CONCEPT_BASE = 1000, clear of
-- the scalar codes). resolve_type is the ONE place a type NAME becomes a code.
-- ============================================================================

-- resolve_type's input: the parsed concept list + the source + a type-name span.
concept ResolveTypeState
  @intention: "A concept list + the source text + a type-name span, for resolving it to a type code"
  @source: vexprparse.intent:62
  fields:
    concepts : ConceptList
    src : text [..256]
    ty_start : number [0, 4000000]
    ty_len : number [0, 4000000]


-- find_concept_index's input: a concept list + source + a query name span + the
-- running 0-based index. Mirror of find_concept (R1) but RETURNS the position so the
-- concept code 1000 + index can be recovered back to the concept at match time.
concept FindConceptIdxState
  @intention: "A concept list + the source + a query name span + the running index, for finding a concept's position"
  @source: vexprparse.intent:62
  fields:
    concepts : ConceptList
    src : text [..256]
    q_start : number [0, 4000000]
    q_len : number [0, 4000000]
    idx : number [0, 4000000]


-- concept_at_index's input: a concept list + a 0-based index. The inverse of
-- find_concept_index: from a concept CODE's index back to its Concept (so AstMatch
-- can read the scrutinee concept's VariantList).
concept ConceptAtState
  @intention: "A concept list + a 0-based index, for fetching the concept at that position"
  @source: vexprparse.intent:62
  fields:
    concepts : ConceptList
    idx : number [0, 4000000]


-- find a variant by name within a concept's VariantList (the scrutinee concept's
-- variants), to read its payload field list / confirm the arm's variant exists.
concept FindVariantState
  @intention: "A variant list + the source + a query variant-name span, for locating one variant"
  @source: vexprparse.intent:65
  fields:
    variants : VariantList
    src : text [..256]
    q_start : number [0, 4000000]
    q_len : number [0, 4000000]


-- bind_binders's input: an arm's positional binder list + the matched variant's
-- payload field list (walked in step) + the type env to extend + the concept list +
-- the source. Each binder binds to its payload field's RESOLVED type — so a `Token`
-- payload field gives the binder the Token concept code, not number.
concept BindBindersState
  @intention: "An arm's binders + the variant payload fields + the env to extend + the concept list + the source"
  @source: vexprparse.intent:65
  fields:
    binders : BinderList
    fields : FieldList
    tenv : Env
    concepts : ConceptList
    src : text [..256]


-- field_concept_tenv's input: a field list (a rule's declared input fields) + the
-- concept list + the source. Seeds the type env with the CONCEPT-typed input fields
-- (a `toks : TokenList` input becomes toks -> TokenList code) so a match scrutinee
-- that reads an input field resolves to its concept. Scalar fields are skipped
-- (they keep env_lookup's number default), so scalar-only rules seed an EMPTY env —
-- byte-identical to the pre-R6b behaviour.
concept FieldConceptTenvState
  @intention: "A rule's input field list + the concept list + the source, for seeding the type env with concept-typed fields"
  @source: vexprparse.intent:62
  fields:
    fields : FieldList
    concepts : ConceptList
    src : text [..256]


-- arm_body_type's input: one match arm (variant-name span + binders + body) + the
-- scrutinee concept's VariantList + the enclosing type env + source + program +
-- concept list. Types ONE arm body with the binders bound to their payload types.
concept ArmBodyTypeState
  @intention: "One match arm + the scrutinee concept's variants + the type env + source + program + concept list"
  @source: vexprparse.intent:65
  fields:
    vstart : number [0, 4000000]
    vlen : number [0, 4000000]
    binders : BinderList
    body : Ast
    vlist : VariantList
    tenv : Env
    src : text [..256]
    prog : RuleList
    concepts : ConceptList


-- arms_type's input: a match arm list + the scrutinee concept's VariantList + the
-- type env + source + program + concept list. Folds the per-arm types into the
-- common arm type (all equal and non-ERROR -> that code; otherwise ERROR).
concept ArmsTypeState
  @intention: "A match arm list + the scrutinee concept's variants + the type env + source + program + concept list"
  @source: vexprparse.intent:65
  fields:
    arms : ArmList
    vlist : VariantList
    tenv : Env
    src : text [..256]
    prog : RuleList
    concepts : ConceptList


-- resolve_type: map a type-name span to a code. number/bool/text resolve to 0/1/2
-- EXACTLY as type_code_of_span did (the scalar fast-path stays byte-identical: tc is
-- type_code_of_span's result, isnum is its own "number" byte check so a concept name
-- — which type_code_of_span also returns 0 for — is NOT mistaken for number). Any
-- other name is looked up in the ConceptList: found -> 1000 + index (a concept code),
-- not found -> 3 (ERROR). This is the ONLY name->code site; everything downstream
-- compares codes. byte_at is a primitive (not a callee), like type_code_of_span.
rule resolve_type
  @intention: "Resolve a type-name span to a code: number/bool/text -> 0/1/2, known concept -> 1000+index, else ERROR (3)"
  @source: vexprparse.intent:62
  input:
    r : ResolveTypeState
  output:
    out : number
  logic:
    let tc = type_code_of_span(SpanCheck { src: r.src, start: r.ty_start, len: r.ty_len })
    let isnum = if r.ty_len == 6 and (byte_at(r.src, r.ty_start) == 110 and (byte_at(r.src, r.ty_start + 1) == 117 and (byte_at(r.src, r.ty_start + 2) == 109 and (byte_at(r.src, r.ty_start + 3) == 98 and (byte_at(r.src, r.ty_start + 4) == 101 and byte_at(r.src, r.ty_start + 5) == 114))))) then 1 else 0
    let idx = find_concept_index(FindConceptIdxState { concepts: r.concepts, src: r.src, q_start: r.ty_start, q_len: r.ty_len, idx: 0 })
    out = if isnum == 1 then 0 else (if tc == 1 then 1 else (if tc == 2 then 2 else (if idx == 999999 then 3 else 1000 + idx)))
  proofs:
    purity:
      reads : [r.concepts, r.src, r.ty_start, r.ty_len]
      calls : [type_code_of_span, find_concept_index]
    termination:
      bound : 64


-- find_concept_index: the 0-based position of the concept whose name byte-equals the
-- query span, walking front-to-back with a running index; 999999 ("not found") at
-- CNil. Mirror of find_concept but returning the position. Bound-only termination +
-- the native recursion breadcrumb (the shrinking list tail is a field of the input).
rule find_concept_index
  @intention: "The 0-based position of the concept whose name matches the query span (999999 if none)"
  @source: vexprparse.intent:62
  input:
    fci : FindConceptIdxState
  output:
    out : number
  logic:
    out = match fci.concepts:
      CCons(head, tail) => if cd_name_len(head) == fci.q_len and name_eq(NameEqState { src: fci.src, a_start: cd_name_start(head), b_start: fci.q_start, len: fci.q_len, off: 0 }) == 1 then fci.idx else find_concept_index(FindConceptIdxState { concepts: tail, src: fci.src, q_start: fci.q_start, q_len: fci.q_len, idx: fci.idx + 1 })
      CNil => 999999
  proofs:
    purity:
      reads : [fci.concepts, fci.src, fci.q_start, fci.q_len, fci.idx]
      calls : [cd_name_len, cd_name_start, name_eq, find_concept_index]
    termination:
      bound : 4000


-- concept_at_index: the Concept at the given 0-based position (walk the tail idx
-- times). idx is always >= 0 at every call: the entry value is `code - 1000` computed
-- only on the >= 1000 branch (so >= 0), and the recursive `idx - 1` is reached only
-- when idx != 0 (so idx >= 1). Out-of-range walks to CNil -> sentinel empty concept
-- (VarNil variants) — the AstMatch guard then yields ERROR. Bound-only + breadcrumb.
rule concept_at_index
  @intention: "The concept at the given 0-based position of a concept list (sentinel empty concept if out of range)"
  @source: vexprparse.intent:62
  input:
    ca : ConceptAtState
  output:
    out : Concept
  logic:
    out = match ca.concepts:
      CCons(head, tail) => if ca.idx == 0 then head else concept_at_index(ConceptAtState { concepts: tail, idx: ca.idx - 1 })
      CNil => Concept::MkConcept { name_start: 0, name_len: 0, fields: FieldList::FNil, variants: VariantList::VarNil }
  proofs:
    purity:
      reads : [ca.concepts, ca.idx]
      calls : [concept_at_index]
    termination:
      bound : 4000


-- variant_present: 1 iff a variant whose name byte-equals the query span exists in
-- the list. Lets arm_body_type distinguish "found, empty payload" (a bare variant
-- like Eof) from "variant not found" (an ill-formed arm -> ERROR). Bound + breadcrumb.
rule variant_present
  @intention: "1 if a variant whose name matches the query span exists in the list, 0 otherwise"
  @source: vexprparse.intent:65
  input:
    fv : FindVariantState
  output:
    out : number
  logic:
    out = match fv.variants:
      VarCons(name_start, name_len, payload, rest) => if name_len == fv.q_len and name_eq(NameEqState { src: fv.src, a_start: name_start, b_start: fv.q_start, len: fv.q_len, off: 0 }) == 1 then 1 else variant_present(FindVariantState { variants: rest, src: fv.src, q_start: fv.q_start, q_len: fv.q_len })
      VarNil => 0
  proofs:
    purity:
      reads : [fv.variants, fv.src, fv.q_start, fv.q_len]
      calls : [name_eq, variant_present]
    termination:
      bound : 4000


-- variant_payload: the payload FieldList of the variant whose name matches the query
-- span (FNil if none / a bare variant). Mirror of variant_present. Bound + breadcrumb.
rule variant_payload
  @intention: "The payload field list of the variant whose name matches the query span (FNil if none)"
  @source: vexprparse.intent:65
  input:
    fv : FindVariantState
  output:
    out : FieldList
  logic:
    out = match fv.variants:
      VarCons(name_start, name_len, payload, rest) => if name_len == fv.q_len and name_eq(NameEqState { src: fv.src, a_start: name_start, b_start: fv.q_start, len: fv.q_len, off: 0 }) == 1 then payload else variant_payload(FindVariantState { variants: rest, src: fv.src, q_start: fv.q_start, q_len: fv.q_len })
      VarNil => FieldList::FNil
  proofs:
    purity:
      reads : [fv.variants, fv.src, fv.q_start, fv.q_len]
      calls : [name_eq, variant_payload]
    termination:
      bound : 4000


-- bind_binders: extend the type env by binding each positional arm binder to its
-- payload field's RESOLVED type (walking binders and payload fields in step). A
-- `Cons(h, t)` arm over payload `(head : Token, tail : TokenList)` binds h -> Token
-- code, t -> TokenList code, so the arm body types soundly (h + 1 is then ERROR).
-- BindNil returns the env unchanged. Bound-only termination + breadcrumb (the
-- shrinking binder/field tails are fields of the packed input).
rule bind_binders
  @intention: "Extend a type env by binding each match-arm binder to its payload field's resolved type"
  @source: vexprparse.intent:65
  input:
    bb : BindBindersState
  output:
    out : Env
  logic:
    out = match bb.binders:
      BindCons(start, len, rest) => Env::ECons { name_start: start, name_len: len, val: resolve_type(ResolveTypeState { concepts: bb.concepts, src: bb.src, ty_start: fl_head_ty_start(bb.fields), ty_len: fl_head_ty_len(bb.fields) }), rest: bind_binders(BindBindersState { binders: rest, fields: fl_tail(bb.fields), tenv: bb.tenv, concepts: bb.concepts, src: bb.src }) }
      BindNil => bb.tenv
  proofs:
    purity:
      reads : [bb.binders, bb.fields, bb.tenv, bb.concepts, bb.src]
      calls : [resolve_type, fl_head_ty_start, fl_head_ty_len, bind_binders, fl_tail]
    termination:
      bound : 4000


-- field_concept_tenv: fold a rule's input field list into a START type env holding
-- ONLY the concept-typed fields (resolve_type >= 1000). Scalar fields are skipped, so
-- a scalar-only rule produces ENil — the pre-R6b start env — keeping every existing
-- type-check result unchanged. Bound-only termination + breadcrumb.
rule field_concept_tenv
  @intention: "Seed a type env from a rule's input fields, binding only the concept-typed ones to their concept code"
  @source: vexprparse.intent:62
  input:
    fct : FieldConceptTenvState
  output:
    out : Env
  logic:
    out = match fct.fields:
      FCons(name_start, name_len, ty, ty_start, ty_len, rest) => if resolve_type(ResolveTypeState { concepts: fct.concepts, src: fct.src, ty_start: ty_start, ty_len: ty_len }) >= 1000 then Env::ECons { name_start: name_start, name_len: name_len, val: resolve_type(ResolveTypeState { concepts: fct.concepts, src: fct.src, ty_start: ty_start, ty_len: ty_len }), rest: field_concept_tenv(FieldConceptTenvState { fields: rest, concepts: fct.concepts, src: fct.src }) } else field_concept_tenv(FieldConceptTenvState { fields: rest, concepts: fct.concepts, src: fct.src })
      FNil => Env::ENil
  proofs:
    purity:
      reads : [fct.fields, fct.concepts, fct.src]
      calls : [resolve_type, field_concept_tenv]
    termination:
      bound : 4000


-- arm_body_type: the type code of ONE match arm body. If the arm's variant is not in
-- the scrutinee concept's VariantList -> ERROR (3, an ill-formed arm). Otherwise bind
-- the arm's binders to the variant payload's field types and type the body against
-- that extended env. Part of the type_of_env SCC (it calls type_of_env). Bound-only.
rule arm_body_type
  @intention: "The type code of one match arm body (binders bound to payload types; ERROR if variant absent)"
  @source: vexprparse.intent:65
  input:
    ab : ArmBodyTypeState
  output:
    out : number
  logic:
    out = if variant_present(FindVariantState { variants: ab.vlist, src: ab.src, q_start: ab.vstart, q_len: ab.vlen }) == 0 then 3 else type_of_env(TypeArg { node: ab.body, tenv: bind_binders(BindBindersState { binders: ab.binders, fields: variant_payload(FindVariantState { variants: ab.vlist, src: ab.src, q_start: ab.vstart, q_len: ab.vlen }), tenv: ab.tenv, concepts: ab.concepts, src: ab.src }), src: ab.src, prog: ab.prog, concepts: ab.concepts })
  proofs:
    purity:
      reads : [ab.vstart, ab.vlen, ab.binders, ab.body, ab.vlist, ab.tenv, ab.src, ab.prog, ab.concepts]
      calls : [variant_present, type_of_env, bind_binders, variant_payload]
    termination:
      bound : 4000


-- arms_type: the COMMON type code across every arm of a match (the match's type). For
-- each arm, type its body (arm_body_type); the match types iff every arm has the SAME
-- non-ERROR type, else ERROR (3). 7777 is the "no arm seen yet" sentinel (clear of
-- every real type code) returned at ArmNil; the caller maps a leftover 7777 (empty
-- match) to ERROR. Folds right: the last arm seeds the expected type, earlier arms
-- must agree. Part of the type_of_env SCC; bound-only termination + breadcrumb.
rule arms_type
  @intention: "The common type code across all match arms (that code if all agree and non-ERROR, else ERROR; 7777 if no arms)"
  @source: vexprparse.intent:65
  input:
    at : ArmsTypeState
  output:
    out : number
  logic:
    out = match at.arms:
      ArmCons(vstart, vlen, binders, body, rest) => if arms_type(ArmsTypeState { arms: rest, vlist: at.vlist, tenv: at.tenv, src: at.src, prog: at.prog, concepts: at.concepts }) == 7777 then arm_body_type(ArmBodyTypeState { vstart: vstart, vlen: vlen, binders: binders, body: body, vlist: at.vlist, tenv: at.tenv, src: at.src, prog: at.prog, concepts: at.concepts }) else (if arm_body_type(ArmBodyTypeState { vstart: vstart, vlen: vlen, binders: binders, body: body, vlist: at.vlist, tenv: at.tenv, src: at.src, prog: at.prog, concepts: at.concepts }) == arms_type(ArmsTypeState { arms: rest, vlist: at.vlist, tenv: at.tenv, src: at.src, prog: at.prog, concepts: at.concepts }) and arm_body_type(ArmBodyTypeState { vstart: vstart, vlen: vlen, binders: binders, body: body, vlist: at.vlist, tenv: at.tenv, src: at.src, prog: at.prog, concepts: at.concepts }) != 3 then arm_body_type(ArmBodyTypeState { vstart: vstart, vlen: vlen, binders: binders, body: body, vlist: at.vlist, tenv: at.tenv, src: at.src, prog: at.prog, concepts: at.concepts }) else 3)
      ArmNil => 7777
  proofs:
    purity:
      reads : [at.arms, at.vlist, at.tenv, at.src, at.prog, at.concepts]
      calls : [arms_type, arm_body_type]
    termination:
      bound : 4000


-- ============================================================================
-- BRICK 21: CALL-SITE ARGUMENT TYPE checking — where the parser (brick 20 typed
-- params) and the type checker (brick 19) finally meet.
--
-- The callee pass (brick 15) asks "does the called rule EXIST?". The arity pass
-- (brick 17) asks "does it pass the RIGHT NUMBER of arguments?". This pass asks
-- the next question: "does each argument's TYPE match the callee's DECLARED
-- parameter type?". A call `f(1 < 2)` to a rule `rule f(x : number)` is well-formed
-- for the callee pass (f exists) and the arity pass (1 arg, 1 param) but WRONG
-- here — a bool argument flows into a number parameter.
--
-- ORTHOGONAL to brick 19's type_check. An argument whose OWN type is already
-- ERROR (3) is brick 19's concern and is SKIPPED here (no double-counting — the
-- same discipline that keeps lint_arity from re-flagging what lint_callees flags).
-- A WELL-typed argument of the WRONG type (a bool where a number is declared) is
-- exactly what this pass catches.
--
-- TYPING THE ARGUMENT. The caller's type env is seeded with the caller's OWN
-- params' declared types (param_to_tenv) THEN extended with its let bindings
-- (build_tenv), so an argument that references a typed param of the caller is
-- typed correctly. THE SHOWCASE: `rule g(b : bool) ... out = f(b)` with
-- `rule f(x : number)` flags `b` — b is bool by g's declaration, passed to f's
-- number param.
--
-- THE LOCKSTEP. Per call, walk the argument list and the callee's parameter list
-- together (argtype_args). For each (arg, param) pair, count a mismatch iff the
-- param EXISTS (phead_ty != 9) AND the arg's type differs from the param's type
-- AND the arg's type is not ERROR (3). When one list runs out, pairing stops —
-- count mismatches are lint_arity's concern, not this pass's. Untyped params
-- default to number (0) — brick 20's convention — so a bool passed to an untyped
-- param IS flagged (documented behaviour).
--
-- CALLEE RESOLUTION. find_rule (brick 18) resolves the callee name span against
-- the whole program; on no match it returns the SENTINEL MkRule with PNil params,
-- so an undefined callee yields no pairs and no arg-type errors (lint_callees
-- flags the missing callee separately). A call's RESULT type stays number (0):
-- there is no return-type syntax yet, so type_of_env's AstCall arm is unchanged —
-- this brick adds a SEPARATE counting pass, it does NOT touch type_of_env.
--
-- TERMINATION. argtype_ast + argtype_args + argtype_binds form a recursive
-- group/text SCC (like the interpreter's eval_ast_env + the type checker's
-- type_of_env), calling into type_of_env. Each recursive call walks a strict
-- sub-node / shorter tail, but that shrinking value is a FIELD of a packed input
-- concept (not the input itself), so the `structural` proof does not fit — they
-- carry bound-only termination and ACCEPT the mandatory native recursion
-- breadcrumb. The backstops are the same: finite Env / binding / param / rule
-- lists and a finite AST bounded by max_nodes.
-- ============================================================================

-- param_to_tenv: convert a rule's ParamList into a TYPE env (Env), storing each
-- parameter's DECLARED type code in the entry's `val` slot. Mirror of brick 16's
-- param_to_binding, but for the type checker: where param_to_binding consed a
-- dummy AstNum value (it only ever needed the NAME span), this carries the type
-- code so an argument referencing a typed param of the CALLER resolves to that
-- param's declared type via env_lookup. The resulting env is the rule's INITIAL
-- type scope, then build_tenv extends it with the lets. Structural recursion on
-- the PCons tail (Phase C), like param_to_binding / param_list_len.
rule param_to_tenv
  @intention: "Convert a parameter list into a type environment (params at their declared types)"
  @source: vexprparse.intent:39
  input:
    pl : ParamList
  output:
    out : Env
  logic:
    out = match pl:
      PCons(name_start, name_len, ty, ty_start, ty_len, rest) => Env::ECons { name_start: name_start, name_len: name_len, val: ty, rest: param_to_tenv(rest) }
      PNil => Env::ENil
  proofs:
    purity:
      reads : [pl]
      calls : [param_to_tenv]
    termination:
      bound : 4000
      structural : pl


-- phead_ty: the DECLARED type code of the HEAD parameter of a ParamList — or the
-- sentinel 9 (no such param) when the list is empty. The lockstep walk in
-- argtype_args uses 9 to detect "the callee has no more parameters", so the extra
-- arguments of an over-long call are NOT paired (their count mismatch is
-- lint_arity's concern). Distinguishable from every real type code (0/1/2).
-- Non-recursive accessor, like rl_head_params.
rule phead_ty
  @intention: "The declared type code of a parameter list's head param (sentinel 9 if empty)"
  @source: vexprparse.intent:39
  input:
    pl : ParamList
  output:
    out : number
  logic:
    out = match pl:
      PCons(name_start, name_len, ty, ty_start, ty_len, rest) => ty
      PNil => 9
  proofs:
    purity:
      reads : [pl]
      calls : []
    termination:
      bound : 16


-- ptail: the TAIL of a ParamList (the parameters after the head) — or PNil when
-- the list is empty. The other half of the lockstep: argtype_args advances the
-- param list with ptail in step with the argument tail, so the n-th argument is
-- paired with the n-th parameter. Non-recursive accessor, like rl_head_params.
rule ptail
  @intention: "The tail of a parameter list (PNil if empty)"
  @source: vexprparse.intent:39
  input:
    pl : ParamList
  output:
    out : ParamList
  logic:
    out = match pl:
      PCons(name_start, name_len, ty, ty_start, ty_len, rest) => rest
      PNil => ParamList::PNil
  proofs:
    purity:
      reads : [pl]
      calls : []
    termination:
      bound : 16


-- argtype_args's input: the call's argument list to walk in LOCKSTEP with the
-- callee's parameter list, plus the caller's type env (so each argument is typed
-- in the caller's scope), the source text, and the program rule list (so a nested
-- call inside an argument resolves its own callee). The two lists advance together
-- (args via the ArgCons tail, params via ptail).
concept ArgTypeArgsState
  @intention: "A call's argument list + the callee's param list + caller type env + source + program"
  @source: vexprparse.intent:39
  fields:
    args : ArgList
    params : ParamList
    tenv : Env
    src : text [..256]
    prog : RuleList


-- The Ast-walking input: the AST node to walk for call sites, the caller's type
-- env (used to type each argument), the source text, and the program rule list
-- (callee scope for find_rule). Same shape as brick 19's TypeArg plus a `prog`
-- field — argtype needs the program to resolve each call's callee, where the
-- type checker only ever typed calls to number.
concept ArgTypeState
  @intention: "An Ast node + caller type env + source text + program rule list, for the arg-type walk"
  @source: vexprparse.intent:39
  fields:
    node : Ast
    tenv : Env
    src : text [..256]
    prog : RuleList


-- argtype_binds's input: the binding list whose RHSes are walked for call sites,
-- the type env built so far (each RHS is typed against it, and a later let's RHS
-- sees an earlier let's type), the source text, and the program rule list. Mirror
-- of brick 19's BuildTArg/TCheckBindsState shape plus `prog`.
concept ArgTypeBindsState
  @intention: "A binding list + the type env so far + source text + program rule list, for the arg-type walk"
  @source: vexprparse.intent:39
  fields:
    binds : Binding
    tenv : Env
    src : text [..256]
    prog : RuleList


-- argtype_rule's input: ONE parsed rule declaration + the FULL program rule list
-- (so each call resolves its callee against every rule) + the program source text.
concept ArgTypeRuleState
  @intention: "A rule declaration + the full program rule list + the source text, for arg-type checking it"
  @source: vexprparse.intent:39
  fields:
    rd : RuleDecl
    prog : RuleList
    src : text [..256]


-- argtype_list's input: the rule list being ITERATED (`iter` advances each step,
-- one rule checked per step) + the FULL program rule list (`all`, fixed, so every
-- call resolves its callee against every rule) + the source text. The iter/all
-- split mirrors lint_callees_list: argtype_rule always receives `all`, never the
-- shrinking `iter`, so callee resolution stays program-wide.
concept ArgTypeListState
  @intention: "The rule list being iterated + the full program rule list + the source text"
  @source: vexprparse.intent:39
  fields:
    iter : RuleList
    all : RuleList
    src : text [..256]


-- argtype_args: walk a call's argument list in LOCKSTEP with the callee's
-- parameter list, summing three contributions per (arg, param) pair:
--   * the MISMATCH count for this pair: 1 iff the param exists (phead_ty != 9)
--     AND the argument's type (typed against the caller's env) differs from the
--     param's declared type AND the argument's type is not ERROR (3 — that is
--     brick 19's concern, skipped here to avoid double-counting). Parenthesized
--     because Verbose has no operator precedence: the `if ... then 1 else 0` is
--     the leftmost summand. type_of_env(head) appears three times — it is pure,
--     so the repetition is correctness-neutral.
--   * argtype_ast over the argument itself, so a NESTED call inside an argument
--     (f(g(1 < 2))) has its own call sites checked.
--   * argtype_args over the tails: the argument tail paired with ptail(params),
--     advancing both lists one step.
-- ArgNil ends the walk (0). When the param list runs out first, phead_ty returns
-- 9, so the extra arguments contribute no mismatch (their count is lint_arity's
-- concern). a.args is a FIELD of the packed input, so bound + native breadcrumb.
rule argtype_args
  @intention: "Total arg-type mismatches across a call's arguments, paired against the callee's params"
  @source: vexprparse.intent:39
  input:
    a : ArgTypeArgsState
  output:
    out : number
  logic:
    out = match a.args:
      ArgCons(head, tail) => (if phead_ty(a.params) != 9 and type_of_env(TypeArg { node: head, tenv: a.tenv, src: a.src, prog: a.prog, concepts: ConceptList::CNil }) != phead_ty(a.params) and type_of_env(TypeArg { node: head, tenv: a.tenv, src: a.src, prog: a.prog, concepts: ConceptList::CNil }) != 3 then 1 else 0) + argtype_ast(ArgTypeState { node: head, tenv: a.tenv, src: a.src, prog: a.prog }) + argtype_args(ArgTypeArgsState { args: tail, params: ptail(a.params), tenv: a.tenv, src: a.src, prog: a.prog })
      ArgNil => 0
  proofs:
    purity:
      reads : [a.args, a.params, a.tenv, a.src, a.prog]
      calls : [phead_ty, type_of_env, argtype_ast, ptail, argtype_args]
    termination:
      bound : 4000


-- argtype_ast: walk an Ast and count, at EVERY call site, the arguments whose type
-- mismatches the callee's declared parameter type. Mirrors count_badcall_ast's
-- structural walk, but the load-bearing arm is AstCall:
--   * AstCall(callee_start, callee_len, args) => argtype_args over the call's
--     arguments, paired against the callee's params. The callee is resolved with
--     find_rule (the sentinel MkRule on no match has PNil params -> no pairs ->
--     no errors, so an undefined callee is silently skipped here — lint_callees
--     flags it). rd_params reads the matched rule's parameter list.
--   * AstBin sums lhs + rhs; AstNeg / AstNot descend; AstIf sums cond + thn + els;
--     AstField walks its base (the field name carries no call).
--   * AstVar / AstNum / AstStr / AstBool / AstErr carry no call site -> 0.
-- Every recursive call threads the same tenv (caller scope) + src + prog. a.node
-- is a FIELD of the packed input, so bound + the mandatory native breadcrumb.
rule argtype_ast
  @intention: "Total arg-type mismatches in an AST, resolving each call's callee against the program"
  @source: vexprparse.intent:39
  input:
    a : ArgTypeState
  output:
    out : number
  logic:
    out = match a.node:
      AstNum(value) => 0
      AstBool(value) => 0
      AstVar(start, len) => 0
      AstStr(start, len) => 0
      AstBytes(start, len) => 0
      AstErr => 0
      -- R3 stub: real handling in R6/R7 (no arg-type mismatch counted without R6).
      AstVariant(cstart, clen, vstart, vlen, fields) => 0
      AstMatch(scrut, arms) => 0
      AstBin(op, lhs, rhs) => argtype_ast(ArgTypeState { node: lhs, tenv: a.tenv, src: a.src, prog: a.prog }) + argtype_ast(ArgTypeState { node: rhs, tenv: a.tenv, src: a.src, prog: a.prog })
      AstNeg(inner) => argtype_ast(ArgTypeState { node: inner, tenv: a.tenv, src: a.src, prog: a.prog })
      AstNot(inner) => argtype_ast(ArgTypeState { node: inner, tenv: a.tenv, src: a.src, prog: a.prog })
      AstField(base, fstart, flen) => argtype_ast(ArgTypeState { node: base, tenv: a.tenv, src: a.src, prog: a.prog })
      AstIf(cond, thn, els) => argtype_ast(ArgTypeState { node: cond, tenv: a.tenv, src: a.src, prog: a.prog }) + argtype_ast(ArgTypeState { node: thn, tenv: a.tenv, src: a.src, prog: a.prog }) + argtype_ast(ArgTypeState { node: els, tenv: a.tenv, src: a.src, prog: a.prog })
      AstCall(callee_start, callee_len, args) => argtype_args(ArgTypeArgsState { args: args, params: rd_params(find_rule(FindRuleState { rules: a.prog, src: a.src, q_start: callee_start, q_len: callee_len })), tenv: a.tenv, src: a.src, prog: a.prog })
  proofs:
    purity:
      reads : [a.node, a.tenv, a.src, a.prog]
      calls : [argtype_ast, argtype_args, rd_params, find_rule]
    termination:
      bound : 4000


-- argtype_binds: for each binding in the list, walk its RHS for call sites
-- (argtype_ast against the type env built SO FAR), then recurse on the rest with
-- the env extended by (name span, RHS type) — so a later let's RHS references an
-- earlier let at its inferred type, exactly build_tenv's extension step. The RHS
-- type for the env extension is computed via type_of_env (pure). BNil contributes
-- 0. b.binds is a FIELD of the packed input, so bound + native breadcrumb.
rule argtype_binds
  @intention: "Total arg-type mismatches across every binding's RHS, threading the growing type env"
  @source: vexprparse.intent:39
  input:
    a : ArgTypeBindsState
  output:
    out : number
  logic:
    out = match a.binds:
      BCons(name_start, name_len, value, rest) => argtype_ast(ArgTypeState { node: value, tenv: a.tenv, src: a.src, prog: a.prog }) + argtype_binds(ArgTypeBindsState { binds: rest, tenv: Env::ECons { name_start: name_start, name_len: name_len, val: type_of_env(TypeArg { node: value, tenv: a.tenv, src: a.src, prog: a.prog, concepts: ConceptList::CNil }), rest: a.tenv }, src: a.src, prog: a.prog })
      BNil => 0
  proofs:
    purity:
      reads : [a.binds, a.tenv, a.src, a.prog]
      calls : [argtype_ast, type_of_env, argtype_binds]
    termination:
      bound : 4000


-- argtype_rule: the arg-type mismatch count for ONE rule. Seed the type env with
-- the rule's OWN params at their declared types (param_to_tenv), so an argument
-- referencing a caller param is typed correctly. Split the body into its bindings
-- and result; build the FULL env from the lets on top of the param env
-- (build_tenv); count call-site arg-type mismatches in the let RHSs (argtype_binds
-- threading the same growing env starting from the param env) PLUS in the result
-- expression (argtype_ast against the full env). Both halves resolve callees
-- against the FULL program list `a.prog`. Plain rule (uses `let`), mirroring
-- tcheck_rule's body-split shape. bound 4000 (it calls into the recursive SCC).
rule argtype_rule
  @intention: "Number of call-site arg-type mismatches in one rule (0 if every argument fits its param)"
  @source: vexprparse.intent:39
  input:
    a : ArgTypeRuleState
  output:
    out : number
  logic:
    let params = rd_params(a.rd)
    let ptenv = param_to_tenv(params)
    let body = rd_body(a.rd)
    let binds = block_binds(body)
    let result = block_result(body)
    let full_tenv = build_tenv(BuildTArg { binds: binds, tenv: ptenv, src: a.src, prog: a.prog, concepts: ConceptList::CNil })
    let in_binds = argtype_binds(ArgTypeBindsState { binds: binds, tenv: ptenv, src: a.src, prog: a.prog })
    out = in_binds + argtype_ast(ArgTypeState { node: result, tenv: full_tenv, src: a.src, prog: a.prog })
  proofs:
    purity:
      reads : [a.rd, a.prog, a.src]
      calls : [rd_params, param_to_tenv, rd_body, block_binds, block_result, build_tenv, argtype_binds, argtype_ast]
    termination:
      bound : 4000


-- argtype_list: fold argtype_rule over the program, summing each rule's arg-type
-- mismatch count. Mirror of lint_callees_list: `iter` advances each step (a field
-- of the packed input, so bound + breadcrumb), while `all` and `src` are threaded
-- unchanged so every rule resolves its callees against the same full program.
rule argtype_list
  @intention: "Total call-site arg-type mismatches across every rule in a program"
  @source: vexprparse.intent:39
  input:
    a : ArgTypeListState
  output:
    out : number
  logic:
    out = match a.iter:
      RCons(head, tail) => argtype_rule(ArgTypeRuleState { rd: head, prog: a.all, src: a.src }) + argtype_list(ArgTypeListState { iter: tail, all: a.all, src: a.src })
      RNil => 0
  proofs:
    purity:
      reads : [a.iter, a.all, a.src]
      calls : [argtype_rule, argtype_list]
    termination:
      bound : 4000


-- argtype_check: the brick-21 money-shot driver. Tokenize the program source (with
-- indentation), parse the whole rule-decl sequence into a RuleList, then fold the
-- arg-type check over it with `iter = all = the parsed program` so every call
-- resolves its callee against the entire program. Returns the TOTAL number of
-- call-site arguments whose type does NOT match the callee's declared parameter
-- type. 0 = every argument fits its parameter's type.
--
--   argtype_check("rule main\n  logic:\n    out = f(5)\nrule f(x : number)\n  logic:\n    out = x")       = 0
--            (number arg to number param)
--   argtype_check("rule main\n  logic:\n    out = f(1 < 2)\nrule f(x : number)\n  logic:\n    out = x")    = 1
--            (bool arg to number param)
--   argtype_check("rule main\n  logic:\n    out = f(1 < 2)\nrule f(x : bool)\n  logic:\n    out = if x then 1 else 0") = 0
--            (bool arg to bool param)
--   argtype_check("rule g(b : bool)\n  logic:\n    out = f(b)\nrule f(x : number)\n  logic:\n    out = x") = 1
--            (THE SHOWCASE: b is bool by g's declaration, passed to f's number param)
--   argtype_check("rule g(b : number)\n  logic:\n    out = f(b)\nrule f(x : number)\n  logic:\n    out = x") = 0
--            (b is number — the well-typed version of the showcase)
--   argtype_check("rule main\n  logic:\n    out = add(5, 1 < 2)\nrule add(x : number, y : number)\n  logic:\n    out = x + y") = 1
--            (two args, the second a bool against a number param)
--   argtype_check("rule main\n  logic:\n    out = add(1 < 2, 3 < 4)\nrule add(x : number, y : number)\n  logic:\n    out = x + y") = 2
--            (both args bool against number params)
--   argtype_check("rule main\n  logic:\n    out = f(g(1 < 2))\nrule f(x : number)\n  logic:\n    out = x\nrule g(y : number)\n  logic:\n    out = y") = 1
--            (g's arg 1<2 is bool vs g's number param; f's arg g(...) is number(0) -> ok)
--   argtype_check("rule main\n  logic:\n    out = h(1 < 2)")                                              = 0
--            (h does not exist -> sentinel PNil params -> no pair; lint_callees flags h)
--
-- NATIVE-ONLY (multi-line source). Takes a ScanState (source + pos): source is
-- argv arg 1, pos is argv arg 2 (always 0). Orthogonal to brick 19's type_check —
-- an argument that is itself ill-typed is type_check's concern (skipped here), a
-- well-typed argument of the wrong type is this pass's concern (skipped there).
rule argtype_check
  @intention: "Tokenize, parse, and count all call-site arguments whose type mismatches the callee's param"
  @source: vexprparse.intent:39
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    out = argtype_list(ArgTypeListState { iter: prog, all: prog, src: s.source })
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, argtype_list]
    termination:
      bound : 256


-- ============================================================================
-- BRICK R6d: the PURITY VERIFIER — the self-hosted verifier's core. R5 parsed each
-- rule's `proofs:` into a Proofs { reads : NameList, calls : NameList, ... }. R6d
-- makes the self-hosted checker VERIFY the purity half of that proof: the body may
-- only CALL rules it declares in `calls:` and only READ inputs it declares in
-- `reads:`. Termination verification (arg-pattern analysis) is genuinely harder and
-- is DEFERRED to a follow-on brick — R6d is the purity half.
--
-- Two per-rule checks, each a count of VIOLATIONS (0 = clean):
--   * undeclared_calls — every AstCall whose callee RESOLVES to a defined rule
--     (rule_named == 1) but is NOT in the rule's declared `calls:` list. Primitives
--     (length / byte_at / concat / ...) don't resolve to a defined rule, so they are
--     naturally exempt; self-recursion resolves, so it MUST be declared.
--   * undeclared_reads — every AstVar whose head-ident is the rule's INPUT name (the
--     first `input:` field), is NOT a local (let / param / match binder), and is NOT
--     in the declared `reads:` list. A read `s.source` reaches its head-ident `s`
--     through AstField(AstVar(s), ...) -> AstVar(s), so descending the field base is
--     exactly the head-ident test; declared `[s]` (head-ident spans, R5's storage)
--     admits `s.anything`.
-- Both reuse R6a's body-walk shape (Ast / args / vfields / arms recursion, match
-- binders scoped in per arm via binds_with_binders) and the single new membership
-- helper name_in_namelist (the NameList analogue of name_bound).
-- ============================================================================

-- name_in_namelist's probe: the purity NameList to search + the source text + the
-- query name's HEAD-ident span. The NameList analogue of NameBoundState (which
-- searches a Binding) / RuleNamedState (which searches a RuleList).
concept NameInListState
  @intention: "A purity reads/calls name-list to search + the source text + the query name's head-ident span"
  @source: vexprparse.intent:30
  fields:
    names : NameList
    src : text [..256]
    q_start : number [0, 4000000]
    q_len : number [0, 4000000]


-- name_in_namelist: 1 iff the query span byte-equals some entry's head-ident span in
-- the NameList, 0 otherwise. Walks the NmCons cons-list; at each entry it checks the
-- entry's LENGTH equals the query length AND the bytes match (name_eq); on a match it
-- returns 1, else recurses into `rest`. NmNil (end) returns 0 (not declared). Exact
-- mirror of name_bound / rule_named, reading a NameList entry's (start, len) span
-- instead of a binding / rule name. Recurses over the NmCons tail (a field of the
-- packed input, not the input), so bound + the native recursion breadcrumb.
rule name_in_namelist
  @intention: "1 if a name span matches some entry's head-ident in a purity name-list, 0 otherwise"
  @source: vexprparse.intent:30
  input:
    st : NameInListState
  output:
    out : number
  logic:
    out = match st.names:
      NmCons(start, len, rest) => if len == st.q_len and name_eq(NameEqState { src: st.src, a_start: start, b_start: st.q_start, len: len, off: 0 }) == 1 then 1 else name_in_namelist(NameInListState { names: rest, src: st.src, q_start: st.q_start, q_len: st.q_len })
      NmNil => 0
  proofs:
    purity:
      reads : [st.names, st.src, st.q_start, st.q_len]
      calls : [name_eq, name_in_namelist]
    termination:
      bound : 4000


-- ---------------------------------------------------------------------------
-- calls check: walk the body and count AstCall callees that RESOLVE to a defined
-- rule (rule_named == 1) yet are ABSENT from the declared `calls:` NameList. Same
-- 5-rule walk family as count_badcall_* (ast / args / vfields / arms / binds), but
-- each state carries the declared `calls` NameList alongside the program RuleList.
-- ---------------------------------------------------------------------------

concept UndeclCallState
  @intention: "An Ast node + the program rule list + the declared calls list + the source text"
  @source: vexprparse.intent:30
  fields:
    node : Ast
    rules : RuleList
    calls : NameList
    src : text [..256]


concept UndeclCallArgsState
  @intention: "A call-argument list + the program rule list + the declared calls list + the source text"
  @source: vexprparse.intent:30
  fields:
    args : ArgList
    rules : RuleList
    calls : NameList
    src : text [..256]


concept UndeclCallVFieldsState
  @intention: "A variant construct's field list + the program rule list + the declared calls list + the source text"
  @source: vexprparse.intent:30
  fields:
    fields : VFieldList
    rules : RuleList
    calls : NameList
    src : text [..256]


concept UndeclCallArmsState
  @intention: "A match arm list + the program rule list + the declared calls list + the source text"
  @source: vexprparse.intent:30
  fields:
    arms : ArmList
    rules : RuleList
    calls : NameList
    src : text [..256]


concept UndeclCallBindsState
  @intention: "A binding list + the program rule list + the declared calls list + the source text"
  @source: vexprparse.intent:30
  fields:
    binds : Binding
    rules : RuleList
    calls : NameList
    src : text [..256]


-- count_undecl_call_args: sum count_undecl_call_ast over every argument of a call.
-- Mutually recursive with count_undecl_call_ast (a nested call in an argument is
-- checked). Threads rules + declared calls + src unchanged.
rule count_undecl_call_args
  @intention: "Total undeclared-call references across every argument of a call"
  @source: vexprparse.intent:30
  input:
    a : UndeclCallArgsState
  output:
    out : number
  logic:
    out = match a.args:
      ArgCons(head, tail) => count_undecl_call_ast(UndeclCallState { node: head, rules: a.rules, calls: a.calls, src: a.src }) + count_undecl_call_args(UndeclCallArgsState { args: tail, rules: a.rules, calls: a.calls, src: a.src })
      ArgNil => 0
  proofs:
    purity:
      reads : [a.args, a.rules, a.calls, a.src]
      calls : [count_undecl_call_ast, count_undecl_call_args]
    termination:
      bound : 4000


-- count_undecl_call_ast: walk an Ast and count each AstCall whose callee RESOLVES to
-- a defined rule (rule_named == 1) but is NOT in the declared `calls:` list
-- (name_in_namelist == 0). Same structural walk as count_badcall_ast, but the
-- AstCall predicate is "resolves AND undeclared" instead of "does not resolve".
-- Primitives (length / byte_at / ...) fail rule_named, so they contribute 0 (exempt);
-- self-recursion passes rule_named, so it must be declared. Threads rules + declared
-- calls + src down every branch. a.node is a FIELD of the packed input, so bound +
-- the native recursion breadcrumb.
rule count_undecl_call_ast
  @intention: "Total undeclared-call references in an AST (callee resolves but is not in `calls:`)"
  @source: vexprparse.intent:30
  input:
    a : UndeclCallState
  output:
    out : number
  logic:
    out = match a.node:
      AstNum(value) => 0
      AstBin(op, lhs, rhs) => count_undecl_call_ast(UndeclCallState { node: lhs, rules: a.rules, calls: a.calls, src: a.src }) + count_undecl_call_ast(UndeclCallState { node: rhs, rules: a.rules, calls: a.calls, src: a.src })
      AstNeg(inner) => count_undecl_call_ast(UndeclCallState { node: inner, rules: a.rules, calls: a.calls, src: a.src })
      AstNot(inner) => count_undecl_call_ast(UndeclCallState { node: inner, rules: a.rules, calls: a.calls, src: a.src })
      AstVar(start, len) => 0
      AstField(base, fstart, flen) => count_undecl_call_ast(UndeclCallState { node: base, rules: a.rules, calls: a.calls, src: a.src })
      AstCall(callee_start, callee_len, args) => (if rule_named(RuleNamedState { rules: a.rules, src: a.src, q_start: callee_start, q_len: callee_len }) == 1 and name_in_namelist(NameInListState { names: a.calls, src: a.src, q_start: callee_start, q_len: callee_len }) == 0 then 1 else 0) + count_undecl_call_args(UndeclCallArgsState { args: args, rules: a.rules, calls: a.calls, src: a.src })
      AstIf(cond, thn, els) => count_undecl_call_ast(UndeclCallState { node: cond, rules: a.rules, calls: a.calls, src: a.src }) + count_undecl_call_ast(UndeclCallState { node: thn, rules: a.rules, calls: a.calls, src: a.src }) + count_undecl_call_ast(UndeclCallState { node: els, rules: a.rules, calls: a.calls, src: a.src })
      AstBool(value) => 0
      AstStr(start, len) => 0
      AstBytes(start, len) => 0
      AstErr => 0
      AstVariant(cstart, clen, vstart, vlen, fields) => count_undecl_call_vfields(UndeclCallVFieldsState { fields: fields, rules: a.rules, calls: a.calls, src: a.src })
      AstMatch(scrut, arms) => count_undecl_call_ast(UndeclCallState { node: scrut, rules: a.rules, calls: a.calls, src: a.src }) + count_undecl_call_arms(UndeclCallArmsState { arms: arms, rules: a.rules, calls: a.calls, src: a.src })
  proofs:
    purity:
      reads : [a.node, a.rules, a.calls, a.src]
      calls : [count_undecl_call_ast, count_undecl_call_args, rule_named, name_in_namelist, count_undecl_call_vfields, count_undecl_call_arms]
    termination:
      bound : 4000


-- count_undecl_call_vfields: sum count_undecl_call_ast over every field VALUE of a
-- variant construct. Mutually recursive with count_undecl_call_ast.
rule count_undecl_call_vfields
  @intention: "Total undeclared-call references across every field value of a variant construct"
  @source: vexprparse.intent:30
  input:
    a : UndeclCallVFieldsState
  output:
    out : number
  logic:
    out = match a.fields:
      VFCons(name_start, name_len, val, rest) => count_undecl_call_ast(UndeclCallState { node: val, rules: a.rules, calls: a.calls, src: a.src }) + count_undecl_call_vfields(UndeclCallVFieldsState { fields: rest, rules: a.rules, calls: a.calls, src: a.src })
      VFNil => 0
  proofs:
    purity:
      reads : [a.fields, a.rules, a.calls, a.src]
      calls : [count_undecl_call_ast, count_undecl_call_vfields]
    termination:
      bound : 4000


-- count_undecl_call_arms: sum count_undecl_call_ast over every match arm body. Arm
-- binders don't affect callee resolution (callees are program-wide), so the program
-- RuleList + declared calls are threaded unchanged. Mutually recursive with
-- count_undecl_call_ast.
rule count_undecl_call_arms
  @intention: "Total undeclared-call references across every match arm body"
  @source: vexprparse.intent:30
  input:
    a : UndeclCallArmsState
  output:
    out : number
  logic:
    out = match a.arms:
      ArmCons(vstart, vlen, binders, body, rest) => count_undecl_call_ast(UndeclCallState { node: body, rules: a.rules, calls: a.calls, src: a.src }) + count_undecl_call_arms(UndeclCallArmsState { arms: rest, rules: a.rules, calls: a.calls, src: a.src })
      ArmNil => 0
  proofs:
    purity:
      reads : [a.arms, a.rules, a.calls, a.src]
      calls : [count_undecl_call_ast, count_undecl_call_arms]
    termination:
      bound : 4000


-- count_undecl_call_binds: for each binding, count_undecl_call_ast on its RHS `value`
-- against the full program RuleList + declared calls, then recurse on `rest`. Every
-- let RHS sees the same declared calls (no ordering). Recurses over the binding tail.
rule count_undecl_call_binds
  @intention: "Total undeclared-call references across every binding's RHS"
  @source: vexprparse.intent:30
  input:
    b : UndeclCallBindsState
  output:
    out : number
  logic:
    out = match b.binds:
      BCons(name_start, name_len, value, rest) => count_undecl_call_ast(UndeclCallState { node: value, rules: b.rules, calls: b.calls, src: b.src }) + count_undecl_call_binds(UndeclCallBindsState { binds: rest, rules: b.rules, calls: b.calls, src: b.src })
      BNil => 0
  proofs:
    purity:
      reads : [b.binds, b.rules, b.calls, b.src]
      calls : [count_undecl_call_ast, count_undecl_call_binds]
    termination:
      bound : 4000


-- undeclared_calls's input: ONE rule declaration + the FULL program RuleList (so a
-- callee resolves against every rule, self included) + the source text. Same shape
-- as BadCallRuleState.
concept UndeclCallRuleState
  @intention: "A rule declaration + the full program rule list + the source text"
  @source: vexprparse.intent:30
  fields:
    rd : RuleDecl
    rules : RuleList
    src : text [..256]


-- undeclared_calls: the undeclared-call count for ONE rule. Split the body into its
-- bindings and result, read the declared `calls:` list off the rule's Proofs
-- (prf_calls . rd_proofs), then sum count_undecl_call_binds over the let RHSes and
-- count_undecl_call_ast over the result — both resolving callees against the full
-- program and checking membership in the SAME declared list. 0 = every defined-rule
-- callee the body invokes is declared.
rule undeclared_calls
  @intention: "Number of calls to defined rules a rule makes but does not declare in `calls:` (0 if clean)"
  @source: vexprparse.intent:30
  input:
    uc : UndeclCallRuleState
  output:
    out : number
  logic:
    let body = rd_body(uc.rd)
    let binds = block_binds(body)
    let result = block_result(body)
    let declared = prf_calls(rd_proofs(uc.rd))
    let bad_in_binds = count_undecl_call_binds(UndeclCallBindsState { binds: binds, rules: uc.rules, calls: declared, src: uc.src })
    out = bad_in_binds + count_undecl_call_ast(UndeclCallState { node: result, rules: uc.rules, calls: declared, src: uc.src })
  proofs:
    purity:
      reads : [uc.rd, uc.rules, uc.src]
      calls : [rd_body, block_binds, block_result, prf_calls, rd_proofs, count_undecl_call_binds, count_undecl_call_ast]
    termination:
      bound : 64


-- ---------------------------------------------------------------------------
-- reads check: walk the body threading the INPUT NAME (the first `input:` field) +
-- the local scope (params + lets, extended per match arm with the arm's binders).
-- An AstVar whose span byte-equals the input name, is NOT bound as a local, and is
-- NOT in the declared `reads:` list is one undeclared read. A field access `s.f`
-- reaches its head-ident `s` via AstField -> AstVar(s), so descending the base is
-- exactly the head-ident test. Same walk family as count_undecl_call_* but the state
-- carries the declared `reads` list + the input name span + the binding scope.
-- ---------------------------------------------------------------------------

concept UndeclReadState
  @intention: "An Ast node + the local binding scope + the declared reads list + the input-name span + the source text"
  @source: vexprparse.intent:30
  fields:
    node : Ast
    binds : Binding
    reads : NameList
    in_start : number
    in_len : number
    src : text [..256]


concept UndeclReadArgsState
  @intention: "A call-argument list + the local scope + the declared reads list + the input-name span + the source text"
  @source: vexprparse.intent:30
  fields:
    args : ArgList
    binds : Binding
    reads : NameList
    in_start : number
    in_len : number
    src : text [..256]


concept UndeclReadVFieldsState
  @intention: "A variant construct's field list + the local scope + the declared reads list + the input-name span + the source text"
  @source: vexprparse.intent:30
  fields:
    fields : VFieldList
    binds : Binding
    reads : NameList
    in_start : number
    in_len : number
    src : text [..256]


concept UndeclReadArmsState
  @intention: "A match arm list + the local scope + the declared reads list + the input-name span + the source text"
  @source: vexprparse.intent:30
  fields:
    arms : ArmList
    binds : Binding
    reads : NameList
    in_start : number
    in_len : number
    src : text [..256]


concept UndeclReadBindsState
  @intention: "The bindings being iterated + the full local scope + the declared reads list + the input-name span + the source text"
  @source: vexprparse.intent:30
  fields:
    iter : Binding
    scope : Binding
    reads : NameList
    in_start : number
    in_len : number
    src : text [..256]


-- count_undecl_read_args: sum count_undecl_read_ast over every argument of a call.
-- Mutually recursive with count_undecl_read_ast. Threads scope + reads + input name
-- + src unchanged.
rule count_undecl_read_args
  @intention: "Total undeclared-read references across every argument of a call"
  @source: vexprparse.intent:30
  input:
    a : UndeclReadArgsState
  output:
    out : number
  logic:
    out = match a.args:
      ArgCons(head, tail) => count_undecl_read_ast(UndeclReadState { node: head, binds: a.binds, reads: a.reads, in_start: a.in_start, in_len: a.in_len, src: a.src }) + count_undecl_read_args(UndeclReadArgsState { args: tail, binds: a.binds, reads: a.reads, in_start: a.in_start, in_len: a.in_len, src: a.src })
      ArgNil => 0
  proofs:
    purity:
      reads : [a.args, a.binds, a.reads, a.in_start, a.in_len, a.src]
      calls : [count_undecl_read_ast, count_undecl_read_args]
    termination:
      bound : 4000


-- count_undecl_read_ast: walk an Ast and count each AstVar that is an UNDECLARED
-- input read: its span byte-equals the input name (in_start, in_len), it is NOT a
-- local (name_bound over the scope == 0), and its head-ident is NOT in the declared
-- `reads:` list (name_in_namelist == 0). AstField descends into its base (reaching
-- the head-ident AstVar), so `s.source` is checked at its `s`. AstCall walks its
-- args; a callee name is not a variable. AstMatch walks the scrutinee then each arm
-- body with the scope EXTENDED by that arm's binders (count_undecl_read_arms).
-- a.node is a FIELD of the packed input, so bound + the native recursion breadcrumb.
rule count_undecl_read_ast
  @intention: "Total undeclared input-reads in an AST (head-ident is the input, not a local, not in `reads:`)"
  @source: vexprparse.intent:30
  input:
    a : UndeclReadState
  output:
    out : number
  logic:
    out = match a.node:
      AstNum(value) => 0
      AstBin(op, lhs, rhs) => count_undecl_read_ast(UndeclReadState { node: lhs, binds: a.binds, reads: a.reads, in_start: a.in_start, in_len: a.in_len, src: a.src }) + count_undecl_read_ast(UndeclReadState { node: rhs, binds: a.binds, reads: a.reads, in_start: a.in_start, in_len: a.in_len, src: a.src })
      AstNeg(inner) => count_undecl_read_ast(UndeclReadState { node: inner, binds: a.binds, reads: a.reads, in_start: a.in_start, in_len: a.in_len, src: a.src })
      AstNot(inner) => count_undecl_read_ast(UndeclReadState { node: inner, binds: a.binds, reads: a.reads, in_start: a.in_start, in_len: a.in_len, src: a.src })
      AstVar(start, len) => if len == a.in_len and (name_eq(NameEqState { src: a.src, a_start: a.in_start, b_start: start, len: len, off: 0 }) == 1 and (name_bound(NameBoundState { binds: a.binds, src: a.src, q_start: start, q_len: len }) == 0 and name_in_namelist(NameInListState { names: a.reads, src: a.src, q_start: start, q_len: len }) == 0)) then 1 else 0
      AstField(base, fstart, flen) => count_undecl_read_ast(UndeclReadState { node: base, binds: a.binds, reads: a.reads, in_start: a.in_start, in_len: a.in_len, src: a.src })
      AstCall(callee_start, callee_len, args) => count_undecl_read_args(UndeclReadArgsState { args: args, binds: a.binds, reads: a.reads, in_start: a.in_start, in_len: a.in_len, src: a.src })
      AstIf(cond, thn, els) => count_undecl_read_ast(UndeclReadState { node: cond, binds: a.binds, reads: a.reads, in_start: a.in_start, in_len: a.in_len, src: a.src }) + count_undecl_read_ast(UndeclReadState { node: thn, binds: a.binds, reads: a.reads, in_start: a.in_start, in_len: a.in_len, src: a.src }) + count_undecl_read_ast(UndeclReadState { node: els, binds: a.binds, reads: a.reads, in_start: a.in_start, in_len: a.in_len, src: a.src })
      AstBool(value) => 0
      AstStr(start, len) => 0
      AstBytes(start, len) => 0
      AstErr => 0
      AstVariant(cstart, clen, vstart, vlen, fields) => count_undecl_read_vfields(UndeclReadVFieldsState { fields: fields, binds: a.binds, reads: a.reads, in_start: a.in_start, in_len: a.in_len, src: a.src })
      AstMatch(scrut, arms) => count_undecl_read_ast(UndeclReadState { node: scrut, binds: a.binds, reads: a.reads, in_start: a.in_start, in_len: a.in_len, src: a.src }) + count_undecl_read_arms(UndeclReadArmsState { arms: arms, binds: a.binds, reads: a.reads, in_start: a.in_start, in_len: a.in_len, src: a.src })
  proofs:
    purity:
      reads : [a.node, a.binds, a.reads, a.in_start, a.in_len, a.src]
      calls : [count_undecl_read_ast, count_undecl_read_args, name_eq, name_bound, name_in_namelist, count_undecl_read_vfields, count_undecl_read_arms]
    termination:
      bound : 4000


-- count_undecl_read_vfields: sum count_undecl_read_ast over every field VALUE of a
-- variant construct (the scope is threaded unchanged — a variant construct binds
-- nothing). Mutually recursive with count_undecl_read_ast.
rule count_undecl_read_vfields
  @intention: "Total undeclared input-reads across every field value of a variant construct"
  @source: vexprparse.intent:30
  input:
    a : UndeclReadVFieldsState
  output:
    out : number
  logic:
    out = match a.fields:
      VFCons(name_start, name_len, val, rest) => count_undecl_read_ast(UndeclReadState { node: val, binds: a.binds, reads: a.reads, in_start: a.in_start, in_len: a.in_len, src: a.src }) + count_undecl_read_vfields(UndeclReadVFieldsState { fields: rest, binds: a.binds, reads: a.reads, in_start: a.in_start, in_len: a.in_len, src: a.src })
      VFNil => 0
  proofs:
    purity:
      reads : [a.fields, a.binds, a.reads, a.in_start, a.in_len, a.src]
      calls : [count_undecl_read_ast, count_undecl_read_vfields]
    termination:
      bound : 4000


-- count_undecl_read_arms: for each match arm, walk the arm BODY with the scope
-- EXTENDED by that arm's binders (binds_with_binders — a binder is a local, so an
-- input-named binder shadows the input and is NOT flagged in that arm), then recurse
-- on the rest with the ORIGINAL scope. Mutually recursive with count_undecl_read_ast.
rule count_undecl_read_arms
  @intention: "Total undeclared input-reads across every match arm body (arm binders scoped in as locals)"
  @source: vexprparse.intent:30
  input:
    a : UndeclReadArmsState
  output:
    out : number
  logic:
    out = match a.arms:
      ArmCons(vstart, vlen, binders, body, rest) => count_undecl_read_ast(UndeclReadState { node: body, binds: binds_with_binders(BindsWithBindersState { binds: a.binds, bs: binders }), reads: a.reads, in_start: a.in_start, in_len: a.in_len, src: a.src }) + count_undecl_read_arms(UndeclReadArmsState { arms: rest, binds: a.binds, reads: a.reads, in_start: a.in_start, in_len: a.in_len, src: a.src })
      ArmNil => 0
  proofs:
    purity:
      reads : [a.arms, a.binds, a.reads, a.in_start, a.in_len, a.src]
      calls : [count_undecl_read_ast, count_undecl_read_arms, binds_with_binders]
    termination:
      bound : 4000


-- count_undecl_read_binds: for each binding in `iter`, count_undecl_read_ast on its
-- RHS `value` against the FULL local scope (params + all lets), then recurse on the
-- rest. The input name is never a param or let, so scope membership never masks an
-- input read; a let referencing another let is masked (that other let is in scope).
-- Ordering is irrelevant to input-read detection, so the full scope is threaded.
rule count_undecl_read_binds
  @intention: "Total undeclared input-reads across every binding's RHS"
  @source: vexprparse.intent:30
  input:
    b : UndeclReadBindsState
  output:
    out : number
  logic:
    out = match b.iter:
      BCons(name_start, name_len, value, rest) => count_undecl_read_ast(UndeclReadState { node: value, binds: b.scope, reads: b.reads, in_start: b.in_start, in_len: b.in_len, src: b.src }) + count_undecl_read_binds(UndeclReadBindsState { iter: rest, scope: b.scope, reads: b.reads, in_start: b.in_start, in_len: b.in_len, src: b.src })
      BNil => 0
  proofs:
    purity:
      reads : [b.iter, b.scope, b.reads, b.in_start, b.in_len, b.src]
      calls : [count_undecl_read_ast, count_undecl_read_binds]
    termination:
      bound : 4000


-- undeclared_reads's input: ONE rule declaration + the source text. RuleDecl carries
-- its own input FieldList + Proofs, so no program list is needed (reads are a local
-- property). Same shape as LintRuleState.
concept UndeclReadRuleState
  @intention: "A rule declaration + the source text"
  @source: vexprparse.intent:30
  fields:
    rd : RuleDecl
    src : text [..256]


-- undeclared_reads: the undeclared-read count for ONE rule. Build the local scope as
-- lint_rule does — params converted to bindings (param_to_binding), appended in front
-- of the body's own lets — read the declared `reads:` off the Proofs (prf_reads .
-- rd_proofs), and recover the INPUT NAME span from the first `input:` field
-- (fl_head_start / fl_head_len . rd_input). Then sum count_undecl_read_binds over the
-- let RHSes and count_undecl_read_ast over the result, both checking each input read
-- against the SAME declared list. 0 = every input the body reads is declared.
rule undeclared_reads
  @intention: "Number of input fields a rule reads but does not declare in `reads:` (0 if clean)"
  @source: vexprparse.intent:30
  input:
    ur : UndeclReadRuleState
  output:
    out : number
  logic:
    let body = rd_body(ur.rd)
    let binds = block_binds(body)
    let result = block_result(body)
    let pbinds = param_to_binding(rd_params(ur.rd))
    let scope = append_bindings(BindAppendState { a: pbinds, b: binds })
    let declared = prf_reads(rd_proofs(ur.rd))
    let infl = rd_input(ur.rd)
    let in_start = fl_head_start(infl)
    let in_len = fl_head_len(infl)
    let bad_in_binds = count_undecl_read_binds(UndeclReadBindsState { iter: binds, scope: scope, reads: declared, in_start: in_start, in_len: in_len, src: ur.src })
    out = bad_in_binds + count_undecl_read_ast(UndeclReadState { node: result, binds: scope, reads: declared, in_start: in_start, in_len: in_len, src: ur.src })
  proofs:
    purity:
      reads : [ur.rd, ur.src]
      calls : [rd_body, block_binds, block_result, param_to_binding, rd_params, append_bindings, prf_reads, rd_proofs, rd_input, fl_head_start, fl_head_len, count_undecl_read_binds, count_undecl_read_ast]
    termination:
      bound : 64


-- ---------------------------------------------------------------------------
-- wiring + gate driver
-- ---------------------------------------------------------------------------

-- purity_errors's input: ONE rule declaration + the FULL program RuleList (for the
-- calls check's callee resolution) + the source text.
concept PurityRuleState
  @intention: "A rule declaration + the full program rule list + the source text"
  @source: vexprparse.intent:30
  fields:
    rd : RuleDecl
    prog : RuleList
    src : text [..256]


-- purity_errors: the total purity-proof violations for ONE rule — undeclared_calls
-- (defined-rule calls not in `calls:`) plus undeclared_reads (input fields not in
-- `reads:`). 0 = the rule's declared purity proof matches its body.
rule purity_errors
  @intention: "Total purity-proof violations (undeclared calls + undeclared reads) for one rule"
  @source: vexprparse.intent:30
  input:
    pr : PurityRuleState
  output:
    out : number
  logic:
    out = undeclared_calls(UndeclCallRuleState { rd: pr.rd, rules: pr.prog, src: pr.src }) + undeclared_reads(UndeclReadRuleState { rd: pr.rd, src: pr.src })
  proofs:
    purity:
      reads : [pr.rd, pr.prog, pr.src]
      calls : [undeclared_calls, undeclared_reads]
    termination:
      bound : 16


-- purity_list's input: the rule list being ITERATED + the FULL program rule list
-- (`all`, so every rule's calls resolve against every rule) + the source text. The
-- iter/all split mirrors lint_callees_list.
concept PurityListState
  @intention: "The rule list being iterated + the full program rule list + the source text"
  @source: vexprparse.intent:30
  fields:
    iter : RuleList
    all : RuleList
    src : text [..256]


-- purity_list: sum purity_errors over every rule in the program. Recurses over `iter`
-- (a field of the input), so bound + the native recursion breadcrumb; `all` and `src`
-- are threaded unchanged. Total purity-proof violations across the program.
rule purity_list
  @intention: "Total purity-proof violations across every rule in a program"
  @source: vexprparse.intent:30
  input:
    pl : PurityListState
  output:
    out : number
  logic:
    out = match pl.iter:
      RCons(head, tail) => purity_errors(PurityRuleState { rd: head, prog: pl.all, src: pl.src }) + purity_list(PurityListState { iter: tail, all: pl.all, src: pl.src })
      RNil => 0
  proofs:
    purity:
      reads : [pl.iter, pl.all, pl.src]
      calls : [purity_errors, purity_list]
    termination:
      bound : 4000


-- count_purity_errors: the R6d money-shot driver. Tokenize the program source, parse
-- the whole rule-decl sequence ONCE, then fold purity_errors over it with iter = all
-- = the parsed program so every rule resolves its callees against the whole program.
-- Returns the TOTAL number of purity-proof violations — 0 iff every rule's declared
-- `reads:` / `calls:` matches its body. This is the self-hosted verifier's core
-- (the durable artifact), run as native machine code over a parsed Verbose program.
-- NATIVE-ONLY (multi-line source): source is argv arg 1, pos is argv arg 2 (0).
rule count_purity_errors
  @intention: "Tokenize, parse, and count all purity-proof (reads/calls) violations in a program"
  @source: vexprparse.intent:30
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    out = purity_list(PurityListState { iter: prog, all: prog, src: s.source })
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, purity_list]
    termination:
      bound : 256


-- ============================================================================
-- TERMINATION VERIFIER: the checker's LAST proof surface. R5 parsed each rule's
-- termination block into Proofs { term_kind, term_bound, term_field_start/len };
-- R6d verified purity; this brick VERIFIES the structural/decreasing/increasing
-- kinds against the body's SELF-recursive call sites (self-recursion only —
-- verbosec's Phase C per-rule checks are also self-shaped; mutual recursion is
-- out of scope, noted). For each rule with term_kind in {1, 2, 3}, walk the body
-- (the same match/variant walk family as count_undecl_call_*) finding every
-- AstCall whose callee span byte-equals the rule's OWN name span. At each such
-- site the FIRST argument must match the declared pattern:
--   * decreasing : f (kind 2) — the arg is a record construction (slice-1 parse:
--     AstVariant with cstart == vstart) whose field named f has value
--     AstBin(14, AstField(AstVar(<input>), f), AstNum k) with k >= 1 — literally
--     `<input>.f - k`. Any other shape at f, or f absent, is one violation.
--   * increasing : f (kind 3) — symmetric with op 13 (`<input>.f + k`, k >= 1).
--   * structural : p (kind 1) — the arg is AstVar(b) where b is a binder
--     introduced by an ENCLOSING match arm whose scrutinee is AstVar(<input>).
--     The binder set threads down the walk (extended per qualifying arm via
--     binds_with_binders, like the R6d reads-check's arm scoping); recursing on
--     the WHOLE input (or any non-binder) is one violation.
--   * bound-only (kind 0) — never flagged, even for recursive rules: parity with
--     verbosec, which warns (stderr breadcrumb) but does not refuse. A rule with
--     no self-call passes vacuously under any kind.
-- Non-literal k (e.g. `s.n - s.m`) is a violation — honest scope, matching
-- verbosec's own literal-step Phase C check. One walker family threads
-- (rule-name span, input-param span, term_kind, term-field span, structural
-- binder set, src); the per-rule driver term_errors reads the input-param name
-- from the first `input:` field (fl_head_* over rd_input — the same source the
-- R6d reads-check used) and the field name from prf_term_field_start/len.
-- ============================================================================

-- The Ast-walk state: the node under inspection + everything the per-site check
-- needs, threaded unchanged down the walk. rn_start/rn_len = the enclosing
-- rule's NAME span (self-call detection); kind = the declared term_kind;
-- in_start/in_len = the input param's name span; tf_start/tf_len = the declared
-- termination FIELD span (0/0 for structural, unused there); sbinds = the
-- structural binder set (binders of enclosing matches ON the input). Shared by
-- count_term_ast (the walker) and the per-site shape helpers (term_arg_ok /
-- term_step_ok / term_base_ok / term_var_is_input), which read subsets of it.
concept TermAstState
  @intention: "An Ast node + the rule-name span + termination kind/field + input span + structural binder set + source"
  @source: vexprparse.intent:67
  fields:
    node : Ast
    rn_start : number
    rn_len : number
    kind : number
    in_start : number
    in_len : number
    tf_start : number
    tf_len : number
    sbinds : Binding
    src : text [..256]


concept TermArgsState
  @intention: "A call-argument list + the threaded termination-check state"
  @source: vexprparse.intent:67
  fields:
    args : ArgList
    rn_start : number
    rn_len : number
    kind : number
    in_start : number
    in_len : number
    tf_start : number
    tf_len : number
    sbinds : Binding
    src : text [..256]


concept TermVFieldsState
  @intention: "A variant construct's field list + the threaded termination-check state"
  @source: vexprparse.intent:67
  fields:
    fields : VFieldList
    rn_start : number
    rn_len : number
    kind : number
    in_start : number
    in_len : number
    tf_start : number
    tf_len : number
    sbinds : Binding
    src : text [..256]


-- The arm-walk state carries one extra flag: ext = 1 iff the ENCLOSING match's
-- scrutinee is AstVar(<input>), so each arm's body walk knows whether that arm's
-- binders enter the structural binder set (term_arm_scope).
concept TermArmsState
  @intention: "A match arm list + whether the match scrutinizes the input + the threaded termination-check state"
  @source: vexprparse.intent:67
  fields:
    arms : ArmList
    ext : number
    rn_start : number
    rn_len : number
    kind : number
    in_start : number
    in_len : number
    tf_start : number
    tf_len : number
    sbinds : Binding
    src : text [..256]


concept TermBindsState
  @intention: "A let-binding list + the threaded termination-check state"
  @source: vexprparse.intent:67
  fields:
    binds : Binding
    rn_start : number
    rn_len : number
    kind : number
    in_start : number
    in_len : number
    tf_start : number
    tf_len : number
    sbinds : Binding
    src : text [..256]


concept TermScopeState
  @intention: "A structural binder set + an arm's binders + whether the arm's match scrutinizes the input"
  @source: vexprparse.intent:67
  fields:
    ext : number
    binds : Binding
    bs : BinderList


-- term_var_is_input: 1 iff the node is an AstVar whose span byte-equals the
-- input param's name span. Serves two sites: the AstMatch scrutinee test (does
-- this match scrutinize the input? -> arm binders enter the structural set) and
-- term_base_ok's base test (is the stepped field read off the input?). Reads
-- only node + the input span + src from the threaded state.
rule term_var_is_input
  @intention: "1 if the AST node is a variable reference to the input param, 0 otherwise"
  @source: vexprparse.intent:67
  input:
    a : TermAstState
  output:
    out : number
  logic:
    out = match a.node:
      AstNum(value) => 0
      AstBin(op, lhs, rhs) => 0
      AstNeg(inner) => 0
      AstNot(inner) => 0
      AstVar(start, len) => if len == a.in_len and name_eq(NameEqState { src: a.src, a_start: a.in_start, b_start: start, len: len, off: 0 }) == 1 then 1 else 0
      AstField(base, fstart, flen) => 0
      AstCall(callee_start, callee_len, args) => 0
      AstIf(cond, thn, els) => 0
      AstBool(value) => 0
      AstStr(start, len) => 0
      AstBytes(start, len) => 0
      AstErr => 0
      AstVariant(cstart, clen, vstart, vlen, fields) => 0
      AstMatch(scrut, arms) => 0
  proofs:
    purity:
      reads : [a.node, a.in_start, a.in_len, a.src]
      calls : [name_eq]
    termination:
      bound : 16


-- term_knum_ok: 1 iff the node is a LITERAL number >= 1 — the k of a valid
-- `input.f - k` / `input.f + k` termination step. A non-literal step (another
-- field, a call, an expression) is 0: the checker cannot prove it positive, so
-- it is a violation — honest scope, matching verbosec's literal-step Phase C.
rule term_knum_ok
  @intention: "1 if the AST node is a literal number >= 1 (a provable termination step), 0 otherwise"
  @source: vexprparse.intent:67
  input:
    n : Ast
  output:
    out : number
  logic:
    out = match n:
      AstNum(value) => if value >= 1 then 1 else 0
      AstBin(op, lhs, rhs) => 0
      AstNeg(inner) => 0
      AstNot(inner) => 0
      AstVar(start, len) => 0
      AstField(base, fstart, flen) => 0
      AstCall(callee_start, callee_len, args) => 0
      AstIf(cond, thn, els) => 0
      AstBool(value) => 0
      AstStr(start, len) => 0
      AstBytes(start, len) => 0
      AstErr => 0
      AstVariant(cstart, clen, vstart, vlen, fields) => 0
      AstMatch(scrut, arms) => 0
  proofs:
    purity:
      reads : [n]
      calls : []
    termination:
      bound : 16


-- term_base_ok: 1 iff the node is AstField(AstVar(<input>), <term field>) — the
-- `input.f` half of a decreasing/increasing step. The field span must byte-equal
-- the declared termination field (tf_start/tf_len); the base must be the input
-- param itself (term_var_is_input).
rule term_base_ok
  @intention: "1 if the AST node reads the declared termination field off the input param, 0 otherwise"
  @source: vexprparse.intent:67
  input:
    a : TermAstState
  output:
    out : number
  logic:
    out = match a.node:
      AstNum(value) => 0
      AstBin(op, lhs, rhs) => 0
      AstNeg(inner) => 0
      AstNot(inner) => 0
      AstVar(start, len) => 0
      AstField(base, fstart, flen) => if flen == a.tf_len and name_eq(NameEqState { src: a.src, a_start: a.tf_start, b_start: fstart, len: flen, off: 0 }) == 1 then term_var_is_input(TermAstState { node: base, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src }) else 0
      AstCall(callee_start, callee_len, args) => 0
      AstIf(cond, thn, els) => 0
      AstBool(value) => 0
      AstStr(start, len) => 0
      AstBytes(start, len) => 0
      AstErr => 0
      AstVariant(cstart, clen, vstart, vlen, fields) => 0
      AstMatch(scrut, arms) => 0
  proofs:
    purity:
      reads : [a.node, a.rn_start, a.rn_len, a.kind, a.in_start, a.in_len, a.tf_start, a.tf_len, a.sbinds, a.src]
      calls : [name_eq, term_var_is_input]
    termination:
      bound : 16


-- term_step_ok: 1 iff the node is the full declared step — AstBin whose op
-- matches the kind (kind 2 -> op 14 `-`, kind 3 -> op 13 `+`), whose lhs is
-- `input.f` (term_base_ok) and whose rhs is a literal k >= 1 (term_knum_ok).
rule term_step_ok
  @intention: "1 if the AST node is the declared decreasing/increasing step `input.f -/+ k` with literal k >= 1"
  @source: vexprparse.intent:67
  input:
    a : TermAstState
  output:
    out : number
  logic:
    out = match a.node:
      AstNum(value) => 0
      AstBin(op, lhs, rhs) => if ((a.kind == 2 and op == 14) or (a.kind == 3 and op == 13)) and term_base_ok(TermAstState { node: lhs, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src }) == 1 then term_knum_ok(rhs) else 0
      AstNeg(inner) => 0
      AstNot(inner) => 0
      AstVar(start, len) => 0
      AstField(base, fstart, flen) => 0
      AstCall(callee_start, callee_len, args) => 0
      AstIf(cond, thn, els) => 0
      AstBool(value) => 0
      AstStr(start, len) => 0
      AstBytes(start, len) => 0
      AstErr => 0
      AstVariant(cstart, clen, vstart, vlen, fields) => 0
      AstMatch(scrut, arms) => 0
  proofs:
    purity:
      reads : [a.node, a.rn_start, a.rn_len, a.kind, a.in_start, a.in_len, a.tf_start, a.tf_len, a.sbinds, a.src]
      calls : [term_base_ok, term_knum_ok]
    termination:
      bound : 16


-- term_vfield_ok: seek the DECLARED termination field in a record construction's
-- field list; when found, its value must be the declared step (term_step_ok).
-- Reaching VFNil means the field is ABSENT from the construction -> 0 (the
-- recursion does not visibly step that field, so the proof does not hold).
-- Other fields are unconstrained (skipped by the recursion on rest).
rule term_vfield_ok
  @intention: "1 if a record construction's declared termination field carries the declared step, 0 otherwise"
  @source: vexprparse.intent:67
  input:
    a : TermVFieldsState
  output:
    out : number
  logic:
    out = match a.fields:
      VFCons(name_start, name_len, val, rest) => if name_len == a.tf_len and name_eq(NameEqState { src: a.src, a_start: a.tf_start, b_start: name_start, len: name_len, off: 0 }) == 1 then term_step_ok(TermAstState { node: val, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src }) else term_vfield_ok(TermVFieldsState { fields: rest, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src })
      VFNil => 0
  proofs:
    purity:
      reads : [a.fields, a.rn_start, a.rn_len, a.kind, a.in_start, a.in_len, a.tf_start, a.tf_len, a.sbinds, a.src]
      calls : [name_eq, term_step_ok, term_vfield_ok]
    termination:
      bound : 64


-- term_arg_ok: the per-call-site argument check, dispatched on the arg's shape
-- and the declared kind. structural (kind 1): the arg must be AstVar(b) with b
-- in the structural binder set (name_bound over sbinds — the input itself is
-- NOT in the set, so recursing on the whole input fails). decreasing/increasing
-- (kinds 2/3): the arg must be a record construction whose declared field steps
-- (term_vfield_ok). Every other shape fails the declared pattern -> 0.
rule term_arg_ok
  @intention: "1 if a self-recursive call's first argument matches the declared termination pattern"
  @source: vexprparse.intent:67
  input:
    a : TermAstState
  output:
    out : number
  logic:
    out = match a.node:
      AstNum(value) => 0
      AstBin(op, lhs, rhs) => 0
      AstNeg(inner) => 0
      AstNot(inner) => 0
      AstVar(start, len) => if a.kind == 1 then name_bound(NameBoundState { binds: a.sbinds, src: a.src, q_start: start, q_len: len }) else 0
      AstField(base, fstart, flen) => 0
      AstCall(callee_start, callee_len, args) => 0
      AstIf(cond, thn, els) => 0
      AstBool(value) => 0
      AstStr(start, len) => 0
      AstBytes(start, len) => 0
      AstErr => 0
      AstVariant(cstart, clen, vstart, vlen, fields) => if a.kind == 1 then 0 else term_vfield_ok(TermVFieldsState { fields: fields, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src })
      AstMatch(scrut, arms) => 0
  proofs:
    purity:
      reads : [a.node, a.rn_start, a.rn_len, a.kind, a.in_start, a.in_len, a.tf_start, a.tf_len, a.sbinds, a.src]
      calls : [name_bound, term_vfield_ok]
    termination:
      bound : 64


-- term_head_ok: check the FIRST argument of a self-recursive call (the toy
-- grammar's rules are single-arg; multi-arg checks the list head). A self-call
-- with NO argument (ArgNil) cannot exhibit the declared descent -> 0 (violation
-- for kinds 1/2/3; kind 0 never reaches here).
rule term_head_ok
  @intention: "1 if a self-recursive call's argument list head matches the declared termination pattern"
  @source: vexprparse.intent:67
  input:
    a : TermArgsState
  output:
    out : number
  logic:
    out = match a.args:
      ArgCons(head, tail) => term_arg_ok(TermAstState { node: head, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src })
      ArgNil => 0
  proofs:
    purity:
      reads : [a.args, a.rn_start, a.rn_len, a.kind, a.in_start, a.in_len, a.tf_start, a.tf_len, a.sbinds, a.src]
      calls : [term_arg_ok]
    termination:
      bound : 16


-- term_arm_scope: the structural binder set an arm's BODY walks under. ext = 1
-- (the enclosing match scrutinizes the input) extends the set with the arm's
-- binders (binds_with_binders, the same helper the R6d reads-check scopes arms
-- with); ext = 0 threads the set unchanged (a match on anything else introduces
-- no structural descent).
rule term_arm_scope
  @intention: "Extend the structural binder set with an arm's binders iff the match scrutinizes the input"
  @source: vexprparse.intent:67
  input:
    t : TermScopeState
  output:
    out : Binding
  logic:
    out = if t.ext == 1 then binds_with_binders(BindsWithBindersState { binds: t.binds, bs: t.bs }) else t.binds
  proofs:
    purity:
      reads : [t.ext, t.binds, t.bs]
      calls : [binds_with_binders]
    termination:
      bound : 16


-- count_term_args: sum count_term_ast over every argument of a call (a nested
-- self-call inside an argument is still checked). Mutually recursive with
-- count_term_ast, like count_undecl_call_args.
rule count_term_args
  @intention: "Total termination-pattern violations across every argument of a call"
  @source: vexprparse.intent:67
  input:
    a : TermArgsState
  output:
    out : number
  logic:
    out = match a.args:
      ArgCons(head, tail) => count_term_ast(TermAstState { node: head, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src }) + count_term_args(TermArgsState { args: tail, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src })
      ArgNil => 0
  proofs:
    purity:
      reads : [a.args, a.rn_start, a.rn_len, a.kind, a.in_start, a.in_len, a.tf_start, a.tf_len, a.sbinds, a.src]
      calls : [count_term_ast, count_term_args]
    termination:
      bound : 4000


-- count_term_ast: the termination walk. Same structural walk as
-- count_undecl_call_ast (if/bin/neg/not/field/call-args/variant-fields/
-- match-arms), but the AstCall predicate is SELF-recursion (callee span
-- byte-equals the enclosing rule's name span) and the per-site check is the
-- declared arg pattern (term_head_ok): a self-call whose head arg fails the
-- pattern is one violation. The call's arguments are still walked (a nested
-- self-call inside the constructed record is checked too). AstMatch walks the
-- scrutinee, then the arms with ext = "scrutinee is the input" so qualifying
-- arms extend the structural binder set. a.node is a FIELD of the packed input,
-- so bound + the native recursion breadcrumb.
rule count_term_ast
  @intention: "Total termination-pattern violations in an AST (self-calls whose argument breaks the declared descent)"
  @source: vexprparse.intent:67
  input:
    a : TermAstState
  output:
    out : number
  logic:
    out = match a.node:
      AstNum(value) => 0
      AstBin(op, lhs, rhs) => count_term_ast(TermAstState { node: lhs, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src }) + count_term_ast(TermAstState { node: rhs, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src })
      AstNeg(inner) => count_term_ast(TermAstState { node: inner, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src })
      AstNot(inner) => count_term_ast(TermAstState { node: inner, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src })
      AstVar(start, len) => 0
      AstField(base, fstart, flen) => count_term_ast(TermAstState { node: base, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src })
      AstCall(callee_start, callee_len, args) => (if callee_len == a.rn_len and name_eq(NameEqState { src: a.src, a_start: a.rn_start, b_start: callee_start, len: callee_len, off: 0 }) == 1 then (if term_head_ok(TermArgsState { args: args, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src }) == 1 then 0 else 1) else 0) + count_term_args(TermArgsState { args: args, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src })
      AstIf(cond, thn, els) => count_term_ast(TermAstState { node: cond, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src }) + count_term_ast(TermAstState { node: thn, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src }) + count_term_ast(TermAstState { node: els, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src })
      AstBool(value) => 0
      AstStr(start, len) => 0
      AstBytes(start, len) => 0
      AstErr => 0
      AstVariant(cstart, clen, vstart, vlen, fields) => count_term_vfields(TermVFieldsState { fields: fields, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src })
      AstMatch(scrut, arms) => count_term_ast(TermAstState { node: scrut, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src }) + count_term_arms(TermArmsState { arms: arms, ext: term_var_is_input(TermAstState { node: scrut, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src }), rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src })
  proofs:
    purity:
      reads : [a.node, a.rn_start, a.rn_len, a.kind, a.in_start, a.in_len, a.tf_start, a.tf_len, a.sbinds, a.src]
      calls : [count_term_ast, count_term_args, count_term_vfields, count_term_arms, name_eq, term_head_ok, term_var_is_input]
    termination:
      bound : 4000


-- count_term_vfields: sum count_term_ast over every field VALUE of a variant
-- construct (a nested self-call inside a constructed field is checked at its
-- own site). Mutually recursive with count_term_ast.
rule count_term_vfields
  @intention: "Total termination-pattern violations across every field value of a variant construct"
  @source: vexprparse.intent:67
  input:
    a : TermVFieldsState
  output:
    out : number
  logic:
    out = match a.fields:
      VFCons(name_start, name_len, val, rest) => count_term_ast(TermAstState { node: val, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src }) + count_term_vfields(TermVFieldsState { fields: rest, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src })
      VFNil => 0
  proofs:
    purity:
      reads : [a.fields, a.rn_start, a.rn_len, a.kind, a.in_start, a.in_len, a.tf_start, a.tf_len, a.sbinds, a.src]
      calls : [count_term_ast, count_term_vfields]
    termination:
      bound : 4000


-- count_term_arms: for each match arm, walk the arm BODY under the binder set
-- term_arm_scope selects (extended by this arm's binders iff the enclosing
-- match scrutinizes the input — ext, computed once at the AstMatch site), then
-- recurse on the rest with the ORIGINAL set and the SAME ext (every arm of one
-- match shares the scrutinee). Mutually recursive with count_term_ast.
rule count_term_arms
  @intention: "Total termination-pattern violations across every match arm body (binders scoped per arm)"
  @source: vexprparse.intent:67
  input:
    a : TermArmsState
  output:
    out : number
  logic:
    out = match a.arms:
      ArmCons(vstart, vlen, binders, body, rest) => count_term_ast(TermAstState { node: body, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: term_arm_scope(TermScopeState { ext: a.ext, binds: a.sbinds, bs: binders }), src: a.src }) + count_term_arms(TermArmsState { arms: rest, ext: a.ext, rn_start: a.rn_start, rn_len: a.rn_len, kind: a.kind, in_start: a.in_start, in_len: a.in_len, tf_start: a.tf_start, tf_len: a.tf_len, sbinds: a.sbinds, src: a.src })
      ArmNil => 0
  proofs:
    purity:
      reads : [a.arms, a.ext, a.rn_start, a.rn_len, a.kind, a.in_start, a.in_len, a.tf_start, a.tf_len, a.sbinds, a.src]
      calls : [count_term_ast, count_term_arms, term_arm_scope]
    termination:
      bound : 4000


-- count_term_binds: sum count_term_ast over every let-binding's RHS (a
-- self-call in a let RHS is a call site like any other; at the top level of a
-- rule body no match encloses it, so the structural binder set is whatever the
-- driver seeded — the empty set).
rule count_term_binds
  @intention: "Total termination-pattern violations across every binding's RHS"
  @source: vexprparse.intent:67
  input:
    b : TermBindsState
  output:
    out : number
  logic:
    out = match b.binds:
      BCons(name_start, name_len, value, rest) => count_term_ast(TermAstState { node: value, rn_start: b.rn_start, rn_len: b.rn_len, kind: b.kind, in_start: b.in_start, in_len: b.in_len, tf_start: b.tf_start, tf_len: b.tf_len, sbinds: b.sbinds, src: b.src }) + count_term_binds(TermBindsState { binds: rest, rn_start: b.rn_start, rn_len: b.rn_len, kind: b.kind, in_start: b.in_start, in_len: b.in_len, tf_start: b.tf_start, tf_len: b.tf_len, sbinds: b.sbinds, src: b.src })
      BNil => 0
  proofs:
    purity:
      reads : [b.binds, b.rn_start, b.rn_len, b.kind, b.in_start, b.in_len, b.tf_start, b.tf_len, b.sbinds, b.src]
      calls : [count_term_ast, count_term_binds]
    termination:
      bound : 4000


-- term_errors's input: ONE rule declaration + the source text. Self-recursion is
-- detected against the rule's OWN name span, so no program RuleList is needed
-- (termination is a local property, like reads). Same shape as UndeclReadRuleState.
concept TermRuleState
  @intention: "A rule declaration + the source text"
  @source: vexprparse.intent:67
  fields:
    rd : RuleDecl
    src : text [..256]


-- term_errors: the termination-proof violation count for ONE rule. Read the
-- declared kind off the Proofs; kind 0 (bound-only) passes unconditionally —
-- parity with verbosec, which breadcrumbs but never refuses a bound-only
-- recursive rule. For kinds 1/2/3, walk the let RHSes and the result expression
-- with the rule's name span (self-call detection), the input param's name span
-- (fl_head_* over rd_input — the same source the R6d reads-check used), the
-- declared field span, and an EMPTY structural binder set (no match encloses
-- the body's top level). A rule with no self-call passes vacuously (the walk
-- finds no site to flag).
rule term_errors
  @intention: "Total termination-proof violations for one rule (0 if the declared descent holds at every self-call)"
  @source: vexprparse.intent:67
  input:
    tr : TermRuleState
  output:
    out : number
  logic:
    let prf = rd_proofs(tr.rd)
    let kind = prf_term_kind(prf)
    let body = rd_body(tr.rd)
    let binds = block_binds(body)
    let result = block_result(body)
    let rn_start = rd_name_start(tr.rd)
    let rn_len = rd_name_len(tr.rd)
    let infl = rd_input(tr.rd)
    let in_start = fl_head_start(infl)
    let in_len = fl_head_len(infl)
    let tf_start = prf_term_field_start(prf)
    let tf_len = prf_term_field_len(prf)
    let bad_in_binds = count_term_binds(TermBindsState { binds: binds, rn_start: rn_start, rn_len: rn_len, kind: kind, in_start: in_start, in_len: in_len, tf_start: tf_start, tf_len: tf_len, sbinds: Binding::BNil, src: tr.src })
    out = if kind == 0 then 0 else bad_in_binds + count_term_ast(TermAstState { node: result, rn_start: rn_start, rn_len: rn_len, kind: kind, in_start: in_start, in_len: in_len, tf_start: tf_start, tf_len: tf_len, sbinds: Binding::BNil, src: tr.src })
  proofs:
    purity:
      reads : [tr.rd, tr.src]
      calls : [rd_proofs, prf_term_kind, rd_body, block_binds, block_result, rd_name_start, rd_name_len, rd_input, fl_head_start, fl_head_len, prf_term_field_start, prf_term_field_len, count_term_binds, count_term_ast]
    termination:
      bound : 64


concept TermListState
  @intention: "The rule list being iterated + the source text"
  @source: vexprparse.intent:67
  fields:
    iter : RuleList
    src : text [..256]


-- term_list: sum term_errors over every rule in the program. Recurses over
-- `iter` (a field of the input), so bound + the native recursion breadcrumb.
rule term_list
  @intention: "Total termination-proof violations across every rule in a program"
  @source: vexprparse.intent:67
  input:
    tl : TermListState
  output:
    out : number
  logic:
    out = match tl.iter:
      RCons(head, tail) => term_errors(TermRuleState { rd: head, src: tl.src }) + term_list(TermListState { iter: tail, src: tl.src })
      RNil => 0
  proofs:
    purity:
      reads : [tl.iter, tl.src]
      calls : [term_errors, term_list]
    termination:
      bound : 4000


-- count_term_errors: the termination-verifier gate driver. Tokenize the program
-- source, parse the whole rule-decl sequence ONCE, then fold term_errors over
-- it. Returns the TOTAL number of termination-proof violations — 0 iff every
-- rule's declared structural/decreasing/increasing descent holds at every
-- self-recursive call site (bound-only rules pass by policy). With this the
-- self-hosted checker verifies ALL FOUR proof surfaces: lints, sound types,
-- purity, termination. NATIVE-ONLY (multi-line source): source is argv arg 1,
-- pos is argv arg 2 (0). Mirrors count_purity_errors.
rule count_term_errors
  @intention: "Tokenize, parse, and count all termination-proof violations in a program"
  @source: vexprparse.intent:67
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    out = term_list(TermListState { iter: prog, src: s.source })
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, term_list]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 22: the FULL PIPELINE — the self-hosting compiler's main(). Every prior
-- driver (lint_program, lint_callees, lint_arity, type_check, argtype_check)
-- tokenizes and parses the source on its OWN, then runs one analysis. This driver
-- tokenizes and parses the program EXACTLY ONCE, then runs ALL of them over the
-- single shared RuleList. That is the consolidation: one front end, every check,
-- in one pass over one AST. The return value is the TOTAL diagnostic count across
-- all five analyses — 0 iff the program passes every check the compiler knows how
-- to make.
--
-- The five analyses, summed over the same parsed `prog`:
--   * lint_list           — undefined variables AND use-before-def (brick 13/14).
--   * lint_callees_list   — calls to rules that do not exist (brick 15).
--   * lint_arity_list     — calls with the wrong number of arguments (brick 17).
--   * tcheck_list         — ill-typed expressions, {number,bool} system (brick 19).
--   * argtype_list        — call args whose type mismatches the declared param (brick 21).
-- Each list-rule already takes a RuleList; check_program just hands them all the
-- same one. The categories are orthogonal by construction (an undefined callee is
-- not an arity error; an arg that is itself ill-typed is type_check's, not
-- argtype's) so the sum double-counts nothing — every diagnostic is one unit.
--
--   check_program("rule add(x : number, y : number)\n  logic:\n    out = x + y\nrule main\n  logic:\n    out = add(1, 2)") = 0
--            (clean: callee exists, arity 2/2, args number/number, no undef, well-typed)
--   check_program("rule f\n  logic:\n    out = x + y")                = 2   (x and y undefined)
--   check_program("rule f\n  logic:\n    out = 1 + (2 < 3)")          = 1   (number + bool)
--   check_program("rule main\n  logic:\n    out = g(1)")              = 1   (g does not exist)
--   check_program("rule f(a)\n  logic:\n    out = 1\nrule main\n  logic:\n    out = f(1, 2)") = 1  (arity 1 vs 2)
--   check_program("rule f(x : number)\n  logic:\n    out = z\nrule main\n  logic:\n    out = f(1 < 2)") = 2
--            (z undefined in f, AND a bool arg to f's number param — two categories at once)
--
-- NATIVE-ONLY (multi-line source). Takes a ScanState (source + pos): source is
-- argv arg 1, pos is argv arg 2 (always 0). This is the closest thing yet to a
-- "verbosec written in Verbose" entry point — lex, parse, and verify, in one call.
rule check_program
  @intention: "Tokenize, parse once, run all five analyses, and return the total diagnostic count"
  @source: vexprparse.intent:40
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let concepts = parse_concepts(ProgramState { cell: toks, src: s.source })
    let e_undef = lint_list(LintListState { rl: prog, src: s.source })
    let e_callee = lint_callees_list(LintCalleesState { iter: prog, all: prog, src: s.source })
    let e_arity = lint_arity_list(LintArityState { iter: prog, all: prog, src: s.source })
    let e_type = tcheck_list(TCheckListState { iter: prog, prog: prog, src: s.source, concepts: concepts })
    let e_argtype = argtype_list(ArgTypeListState { iter: prog, all: prog, src: s.source })
    out = e_undef + e_callee + e_arity + e_type + e_argtype
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, parse_concepts, lint_list, lint_callees_list, lint_arity_list, tcheck_list, argtype_list]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 23: a STRUCTURED diagnostic. Brick 22's check_program returns the TOTAL
-- error count over the whole program — a single number. This brick LOCALIZES the
-- first failure: which rule (by 0-based index, source order) and which CATEGORY of
-- error it is. The category is decided per rule by `rule_category`, in a fixed
-- precedence order (the FIRST failing analysis wins, so a rule with several
-- problems reports exactly one — the earliest in this list):
--   0 = clean (no diagnostics)
--   1 = undefined variable / use-before-def      (lint_rule)
--   2 = undefined callee                          (badcall_rule)
--   3 = wrong arity                               (badarity_rule)
--   4 = ill-typed expression                      (tcheck_rule)
--   5 = call-argument type mismatch               (argtype_rule)
-- `find_diag` then walks the program with a running index and returns the FIRST
-- rule whose category != 0, as a Diag { rule_index, category }. A clean program
-- yields Diag { rule_index: 9999, category: 0 } (9999 = "no bad rule"). The two
-- drivers `first_bad_rule` / `first_bad_category` expose the two fields to argv.
-- The five per-rule analyses are reused verbatim from bricks 13-21; this brick
-- only composes them, the same way check_program composes the five list-rules.
-- ============================================================================

-- rule_category's input: ONE parsed rule declaration + the FULL program rule list
-- (`prog`, so the rule's calls resolve against every rule for the callee / arity /
-- arg-type passes) + the source text. Same shape as BadCallRuleState / ArgTypeRuleState
-- but named generically because it feeds ALL five per-rule analyses, not one.
concept RuleCatState
  @intention: "A rule declaration + the full program rule list + the source text + the concept list, for categorizing its first error"
  @source: vexprparse.intent:41
  fields:
    rd : RuleDecl
    prog : RuleList
    src : text [..256]
    concepts : ConceptList


-- find_diag's input: the rule list being ITERATED (`iter` advances each step, one
-- rule categorized per step) + the FULL program rule list (`all`, fixed, so each
-- rule's calls resolve against every rule) + the source text + the running 0-based
-- index of the rule at the head of `iter`. The iter/all split mirrors
-- lint_callees_list / argtype_list: rule_category always receives `all`, never the
-- shrinking `iter` tail. `idx` is the source position reported in the Diag.
concept FindDiagState
  @intention: "The rule list being walked + the full program + the source + the running rule index + the concept list"
  @source: vexprparse.intent:41
  fields:
    iter : RuleList
    all : RuleList
    src : text [..256]
    idx : number [0, 4000000]
    concepts : ConceptList


-- rule_category: the FIRST failing category of ONE rule, in the fixed precedence
-- order documented above. A flat if/else chain of calls to the five per-rule
-- analyses — NON-recursive (each per-rule rule is itself recursive, but this rule
-- just calls them in order and returns the first nonzero category's code). The
-- precedence is purely the source order of the chain: lint (1) before callee (2)
-- before arity (3) before type (4) before arg-type (5). bound is a termination
-- BUDGET for the non-recursive if-chain (the verifier counts the actual operation
-- count of the chain, not a recursion depth); 1024 comfortably exceeds it.
rule rule_category
  @intention: "The first failing analysis category of one rule (precedence-ordered), 0 if clean"
  @source: vexprparse.intent:41
  input:
    rc : RuleCatState
  output:
    out : number
  logic:
    out = if lint_rule(LintRuleState { rd: rc.rd, src: rc.src }) > 0 then 1 else if badcall_rule(BadCallRuleState { rd: rc.rd, rules: rc.prog, src: rc.src }) > 0 then 2 else if badarity_rule(BadArityRuleState { rd: rc.rd, rules: rc.prog, src: rc.src }) > 0 then 3 else if tcheck_rule(TCheckRuleState { rd: rc.rd, src: rc.src, prog: rc.prog, concepts: rc.concepts }) > 0 then 4 else if argtype_rule(ArgTypeRuleState { rd: rc.rd, prog: rc.prog, src: rc.src }) > 0 then 5 else 0
  proofs:
    purity:
      reads : [rc.rd, rc.prog, rc.src, rc.concepts]
      calls : [lint_rule, badcall_rule, badarity_rule, tcheck_rule, argtype_rule]
    termination:
      bound : 1024


-- find_diag: walk the program rule list, categorizing each rule, and return the
-- FIRST one whose category > 0 as MkDiag(idx, category); on RNil (every rule
-- clean) return the sentinel MkDiag(9999, 0). Recurses on the tail with idx+1,
-- mirroring find_rule's front-to-back walk but returning a Diag GROUP VALUE rather
-- than a RuleDecl (same group-return ABI). rule_category is called twice per
-- failing head — once for the guard, once for the reported value — which is fine
-- because it is pure (no effects, same inputs => same number). Bound-only
-- termination + the native recursion breadcrumb (the shrinking `iter` tail is a
-- field of the packed input, not the input itself).
rule find_diag
  @intention: "The first rule (by index) whose category is nonzero, as a Diag; sentinel MkDiag(9999,0) if all clean"
  @source: vexprparse.intent:41
  input:
    fd : FindDiagState
  output:
    out : Diag
  logic:
    out = match fd.iter:
      RCons(head, tail) => if rule_category(RuleCatState { rd: head, prog: fd.all, src: fd.src, concepts: fd.concepts }) > 0 then Diag::MkDiag { rule_index: fd.idx, category: rule_category(RuleCatState { rd: head, prog: fd.all, src: fd.src, concepts: fd.concepts }), span_start: 9999, span_len: 0 } else find_diag(FindDiagState { iter: tail, all: fd.all, src: fd.src, idx: fd.idx + 1, concepts: fd.concepts })
      RNil => Diag::MkDiag { rule_index: 9999, category: 0, span_start: 9999, span_len: 0 }
  proofs:
    purity:
      reads : [fd.iter, fd.all, fd.src, fd.idx, fd.concepts]
      calls : [rule_category, find_diag]
    termination:
      bound : 4000


-- diag_index: the rule index of a Diag. Bare-group accessor, same idiom as
-- rd_body / block_binds (input is a bare group value `d : Diag`).
rule diag_index
  @intention: "The 0-based rule index carried by a Diag"
  @source: vexprparse.intent:41
  input:
    d : Diag
  output:
    out : number
  logic:
    out = match d:
      MkDiag(rule_index, category, span_start, span_len) => rule_index
  proofs:
    purity:
      reads : [d]
      calls : []
    termination:
      bound : 16


-- diag_cat: the error category of a Diag. Mirror of diag_index.
rule diag_cat
  @intention: "The error category code carried by a Diag"
  @source: vexprparse.intent:41
  input:
    d : Diag
  output:
    out : number
  logic:
    out = match d:
      MkDiag(rule_index, category, span_start, span_len) => category
  proofs:
    purity:
      reads : [d]
      calls : []
    termination:
      bound : 16


-- diag_span_start: the offending name's start byte offset carried by a Diag (brick
-- 26). 9999 for non-located diagnostics (categories 2-5, every sentinel). Mirror of
-- diag_index, reading the third field.
rule diag_span_start
  @intention: "The offending name's start byte offset carried by a Diag (9999 if not located)"
  @source: vexprparse.intent:44
  input:
    d : Diag
  output:
    out : number
  logic:
    out = match d:
      MkDiag(rule_index, category, span_start, span_len) => span_start
  proofs:
    purity:
      reads : [d]
      calls : []
    termination:
      bound : 16


-- diag_span_len: the offending name's byte length carried by a Diag (brick 26). 0
-- for non-located diagnostics. Mirror of diag_span_start, reading the fourth field.
rule diag_span_len
  @intention: "The offending name's byte length carried by a Diag (0 if not located)"
  @source: vexprparse.intent:44
  input:
    d : Diag
  output:
    out : number
  logic:
    out = match d:
      MkDiag(rule_index, category, span_start, span_len) => span_len
  proofs:
    purity:
      reads : [d]
      calls : []
    termination:
      bound : 16


-- ----------------------------------------------------------------------------
-- BRICK 23 DRIVERS. Both tokenize + parse the source ONCE (same front end as
-- check_program), run find_diag over the parsed program, and expose ONE field of
-- the resulting Diag to argv. NATIVE-ONLY (multi-line source). Take a ScanState
-- (source + pos): source is argv arg 1, pos is argv arg 2 (always 0).
--
-- Category codes (precedence order — first failing analysis wins per rule):
--   0 = clean   1 = undef-var/use-before-def   2 = undef-callee
--   3 = arity   4 = ill-typed                  5 = arg-type-mismatch
--
-- Worked examples (index, category):
--   clean      "rule add(x : number, y : number)\n  logic:\n    out = x + y\nrule main\n  logic:\n    out = add(1, 2)" -> 9999, 0
--   undef r1   "rule a\n  logic:\n    out = 1\nrule b\n  logic:\n    out = x"          -> 1, 1
--   callee r0  "rule main\n  logic:\n    out = g(1)"                                   -> 0, 2
--   arity r1   "rule f(a)\n  logic:\n    out = 1\nrule main\n  logic:\n    out = f(1, 2)" -> 1, 3
--   type r0    "rule f\n  logic:\n    out = 1 + (2 < 3)"                               -> 0, 4
--   argtype r0 "rule main\n  logic:\n    out = f(1 < 2)\nrule f(x : number)\n  logic:\n    out = x" -> 0, 5
--   precedence "rule f(x : number)\n  logic:\n    out = z\nrule main\n  logic:\n    out = f(1 < 2)" -> 0, 1
--              (rule f at index 0 has undefined z => category 1 wins over main's arg-type at index 1)
--   ordering   "rule a\n  logic:\n    out = 1\nrule b\n  logic:\n    out = 2\nrule c\n  logic:\n    out = w" -> 2, 1
rule first_bad_rule
  @intention: "Tokenize, parse, find the first diagnostic, and return its 0-based rule index (9999 if clean)"
  @source: vexprparse.intent:41
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let concepts = parse_concepts(ProgramState { cell: toks, src: s.source })
    let d = find_diag(FindDiagState { iter: prog, all: prog, src: s.source, idx: 0, concepts: concepts })
    out = diag_index(d)
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, parse_concepts, find_diag, diag_index]
    termination:
      bound : 256


-- first_bad_category: the companion of first_bad_rule — same front end and same
-- find_diag walk, but returns the Diag's CATEGORY rather than its index (0 if the
-- program is clean). Together the two drivers report the (where, what) pair of the
-- program's first diagnostic.
rule first_bad_category
  @intention: "Tokenize, parse, find the first diagnostic, and return its error category (0 if clean)"
  @source: vexprparse.intent:41
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let concepts = parse_concepts(ProgramState { cell: toks, src: s.source })
    let d = find_diag(FindDiagState { iter: prog, all: prog, src: s.source, idx: 0, concepts: concepts })
    out = diag_cat(d)
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, parse_concepts, find_diag, diag_cat]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 24: report ALL diagnostics, not just the first. Brick 23's find_diag stops
-- at the FIRST failing rule and returns one Diag. This brick walks the WHOLE program
-- and builds a DiagList — a cons-list with ONE Diag per (rule, failing-category)
-- pair. A rule that is undefined-AND-ill-typed yields TWO entries (category 1 then
-- category 4); a clean rule contributes nothing. Within a rule the categories appear
-- in ascending order (1..5); rules appear in source order. The result is the full
-- categorized report.
--
-- The five per-rule analyses (each takes one RuleDecl, returns a count; >0 means that
-- category is present in that rule) are reused verbatim from bricks 13-21 — the same
-- five rule_category composes in brick 23, but here EVERY nonzero category is kept,
-- not just the first:
--   1 = undef-var/use-before-def   (lint_rule)
--   2 = undef-callee               (badcall_rule)
--   3 = arity                      (badarity_rule)
--   4 = ill-typed                  (tcheck_rule)
--   5 = arg-type-mismatch          (argtype_rule)
--
-- GRANULARITY (document carefully — this is the key distinction from brick 22):
-- diag_count counts (rule, category) PAIRS, NOT individual problems. A rule with TWO
-- undefined variables is ONE diag (category 1 is present once), whereas brick 22's
-- check_program counts it as 2 (it sums the raw per-analysis counts). So
-- all_diags_count <= check_program in general; they coincide only when no rule has
-- multiple instances of one category. This is intentional: DiagList is a CATEGORIZED
-- report (where + what-kind), check_program is a raw problem TALLY.
-- ============================================================================

-- rule_diags's input: ONE parsed rule declaration + the FULL program rule list
-- (`prog`, so the rule's calls resolve against every rule for the callee / arity /
-- arg-type passes) + the source text + the rule's 0-based index (`idx`, stamped into
-- each Diag this rule produces). Same shape as RuleCatState (brick 23) but carries
-- the index so rule_diags can construct Diags directly instead of leaving the index
-- to the caller.
concept RuleDiagsState
  @intention: "A rule declaration + the full program + the source + the rule's 0-based index + the concept list, for listing all its diagnostics"
  @source: vexprparse.intent:42
  fields:
    rd : RuleDecl
    prog : RuleList
    src : text [..256]
    idx : number [0, 4000000]
    concepts : ConceptList


-- prog_diags's input: the rule list being ITERATED (`iter` advances each step, one
-- rule's diags appended per step) + the FULL program rule list (`all`, fixed, so each
-- rule's calls resolve against every rule) + the source + the running 0-based index of
-- the rule at the head of `iter`. The iter/all split mirrors find_diag's FindDiagState
-- and lint_callees_list / argtype_list: rule_diags always receives `all`, never the
-- shrinking `iter` tail.
concept ProgDiagsState
  @intention: "The rule list being walked + the full program + the source + the running rule index + the concept list, for the whole-program diagnostic list"
  @source: vexprparse.intent:42
  fields:
    iter : RuleList
    all : RuleList
    src : text [..256]
    idx : number [0, 4000000]
    concepts : ConceptList


-- diag_append's input: two DiagLists. Standard cons-list append concatenates the
-- diags of one rule (`a`) in front of the diags of the rest of the program (`b`),
-- preserving order. Same shape as any binary list operation.
concept DiagAppendState
  @intention: "Two diagnostic lists to concatenate (the head rule's diags in front of the rest's)"
  @source: vexprparse.intent:42
  fields:
    a : DiagList
    b : DiagList


-- diag_nth's input: a DiagList + a 0-based index `n`. nth_diag_rule / nth_diag_cat
-- walk `n` cells in and read one field off the head Diag (rule index / category),
-- returning a sentinel when n runs past the end of the list.
concept DiagNthState
  @intention: "A diagnostic list + a 0-based index, for reading the n-th diagnostic's rule index or category"
  @source: vexprparse.intent:42
  fields:
    list : DiagList
    n : number [0, 4000000]


-- rule_diags: the DiagList of ALL failing categories for ONE rule, in ASCENDING
-- category order (1,2,3,4,5). NON-recursive — it just calls the five per-rule
-- analyses and conses a Diag for each nonzero one. The trick to get ascending order
-- out of a head-conses-onto-front cons-list is to build the TAIL FIRST: d5 is the
-- innermost (category 5), then d4 conses category 4 onto d5, ... d1 conses category 1
-- onto d2. So when category 1 is present it ends up at the FRONT and category 5 at the
-- back — exactly source/ascending order. Each per-rule analysis returns a COUNT; >0
-- means that category is present (once, regardless of how many instances — see the
-- granularity note above). bound is a termination BUDGET for the non-recursive
-- let-chain (the verifier counts the chain's actual operation count, which is large
-- here because each guard calls a recursive analysis); start at 1024 and raise if the
-- verifier reports the bound is short.
-- Brick 26: the category-1 (undef-var) Diag now carries the offending name's SPAN.
-- usp = undef_span_rule(...) is computed ONCE above the d5..d1 chain (cheap + pure;
-- only USED when category 1 fires); d1's MkDiag fills span_start/span_len from usp via
-- span_start(usp) / span_len(usp).
-- Brick 27: the category-2 (undef-callee) Diag now ALSO carries the offending callee
-- name's SPAN. csp = badcall_span_rule(...) is computed ONCE above the chain (same
-- cheap + pure shape as usp; only USED when category 2 fires); d2's MkDiag fills its
-- span from span_start(csp) / span_len(csp).
-- Brick 28: the category-3 (arity-mismatch) Diag now ALSO carries the offending
-- call's callee name SPAN. asp = badarity_span_rule(...) is computed ONCE above the
-- chain (same cheap + pure shape as usp/csp; only USED when category 3 fires); d3's
-- MkDiag fills its span from span_start(asp) / span_len(asp). Categories 4/5 (d4/d5)
-- and every sentinel keep span_start: 9999, span_len: 0 ("not located") — those
-- analyses are whole-rule type properties with no single-token name span (AstBin /
-- AstNum carry no source span), so they stay unlocated.
rule rule_diags
  @intention: "The diagnostic list of one rule: one Diag per failing category, ascending order (1..5), empty if clean"
  @source: vexprparse.intent:42
  input:
    rds : RuleDiagsState
  output:
    out : DiagList
  logic:
    let usp = undef_span_rule(UndefSpanRuleState { rd: rds.rd, src: rds.src })
    let csp = badcall_span_rule(BadCallSpanRuleState { rd: rds.rd, rules: rds.prog, src: rds.src })
    let asp = badarity_span_rule(BadAritySpanRuleState { rd: rds.rd, rules: rds.prog, src: rds.src })
    let d5 = if argtype_rule(ArgTypeRuleState { rd: rds.rd, prog: rds.prog, src: rds.src }) > 0 then DiagList::DCons { diag: Diag::MkDiag { rule_index: rds.idx, category: 5, span_start: 9999, span_len: 0 }, rest: DiagList::DNil } else DiagList::DNil
    let d4 = if tcheck_rule(TCheckRuleState { rd: rds.rd, src: rds.src, prog: rds.prog, concepts: rds.concepts }) > 0 then DiagList::DCons { diag: Diag::MkDiag { rule_index: rds.idx, category: 4, span_start: 9999, span_len: 0 }, rest: d5 } else d5
    let d3 = if badarity_rule(BadArityRuleState { rd: rds.rd, rules: rds.prog, src: rds.src }) > 0 then DiagList::DCons { diag: Diag::MkDiag { rule_index: rds.idx, category: 3, span_start: span_start(asp), span_len: span_len(asp) }, rest: d4 } else d4
    let d2 = if badcall_rule(BadCallRuleState { rd: rds.rd, rules: rds.prog, src: rds.src }) > 0 then DiagList::DCons { diag: Diag::MkDiag { rule_index: rds.idx, category: 2, span_start: span_start(csp), span_len: span_len(csp) }, rest: d3 } else d3
    let d1 = if lint_rule(LintRuleState { rd: rds.rd, src: rds.src }) > 0 then DiagList::DCons { diag: Diag::MkDiag { rule_index: rds.idx, category: 1, span_start: span_start(usp), span_len: span_len(usp) }, rest: d2 } else d2
    out = d1
  proofs:
    purity:
      reads : [rds.rd, rds.prog, rds.src, rds.idx, rds.concepts]
      calls : [argtype_rule, tcheck_rule, badarity_rule, badcall_rule, lint_rule, undef_span_rule, badcall_span_rule, badarity_span_rule, span_start, span_len]
    termination:
      bound : 1024


-- diag_append: standard cons-list append. Walks `a`, re-consing each diag in order
-- onto the result of appending the rest of `a` to `b`; when `a` is exhausted (DNil)
-- the result is `b`. Preserves order: a's diags come out before b's. Recurses on a's
-- tail. Bound-only termination + the native recursion breadcrumb (the shrinking `a`
-- tail is a field of the packed input, not the input itself).
rule diag_append
  @intention: "Concatenate two diagnostic lists, the first's diags in front of the second's, order-preserving"
  @source: vexprparse.intent:42
  input:
    da : DiagAppendState
  output:
    out : DiagList
  logic:
    out = match da.a:
      DCons(diag, rest) => DiagList::DCons { diag: diag, rest: diag_append(DiagAppendState { a: rest, b: da.b }) }
      DNil => da.b
  proofs:
    purity:
      reads : [da.a, da.b]
      calls : [diag_append]
    termination:
      bound : 4000


-- prog_diags: walk the whole program, building each rule's DiagList (rule_diags) and
-- appending it IN FRONT of the diags of the rest of the program (prog_diags on the
-- tail). The running index `idx` is the 0-based source position of the head rule; it
-- advances by 1 on each tail recursion so each rule's Diags carry the right index.
-- The append-then-recurse shape keeps program order: rule 0's diags first, then rule
-- 1's, etc. On RNil (no more rules) the report is DNil. Recurses on the tail; calls
-- diag_append + rule_diags per step. Bound-only termination + the native recursion
-- breadcrumb.
rule prog_diags
  @intention: "The whole program's diagnostic list: each rule's diags in source order, ascending category within a rule"
  @source: vexprparse.intent:42
  input:
    pds : ProgDiagsState
  output:
    out : DiagList
  logic:
    out = match pds.iter:
      RCons(head, tail) => diag_append(DiagAppendState { a: rule_diags(RuleDiagsState { rd: head, prog: pds.all, src: pds.src, idx: pds.idx, concepts: pds.concepts }), b: prog_diags(ProgDiagsState { iter: tail, all: pds.all, src: pds.src, idx: pds.idx + 1, concepts: pds.concepts }) })
      RNil => DiagList::DNil
  proofs:
    purity:
      reads : [pds.iter, pds.all, pds.src, pds.idx, pds.concepts]
      calls : [diag_append, rule_diags, prog_diags]
    termination:
      bound : 4000


-- diag_count: the LENGTH of a DiagList — the number of (rule, category) pairs in the
-- report. 0 = a fully clean program. NOT the same as check_program's count (which
-- tallies raw problems): a rule with two undefined variables adds 1 here (category 1
-- present once) but 2 to check_program. Bare-group input (`dl : DiagList`), same idiom
-- as count_cells over a TokenList. Recurses on the tail; bound-only termination + the
-- native recursion breadcrumb.
rule diag_count
  @intention: "The number of diagnostics in a report (rule-category pairs, not raw problem instances)"
  @source: vexprparse.intent:42
  input:
    dl : DiagList
  output:
    out : number
  logic:
    out = match dl:
      DCons(diag, rest) => 1 + diag_count(rest)
      DNil => 0
  proofs:
    purity:
      reads : [dl]
      calls : [diag_count]
    termination:
      bound : 4000


-- nth_diag_rule: the rule index of the n-th diagnostic (0-based), or the sentinel
-- 9999 if n runs past the end of the report. Walks n cells in: when n reaches 0,
-- read diag_index off the head; otherwise recurse on the tail with n-1. The 9999
-- sentinel matches brick 23's "no bad rule" convention. Recurses on the tail; calls
-- diag_index at the base. Bound-only termination + the native recursion breadcrumb.
rule nth_diag_rule
  @intention: "The rule index of the n-th diagnostic in a report (sentinel 9999 if out of bounds)"
  @source: vexprparse.intent:42
  input:
    dn : DiagNthState
  output:
    out : number
  logic:
    out = match dn.list:
      DCons(diag, rest) => if dn.n == 0 then diag_index(diag) else nth_diag_rule(DiagNthState { list: rest, n: dn.n - 1 })
      DNil => 9999
  proofs:
    purity:
      reads : [dn.list, dn.n]
      calls : [diag_index, nth_diag_rule]
    termination:
      bound : 4000


-- nth_diag_cat: the category of the n-th diagnostic (0-based), or the sentinel 0 if
-- n runs past the end of the report (0 = "clean / no category", matching brick 23's
-- category convention). Mirror of nth_diag_rule, reading diag_cat instead. Recurses
-- on the tail; calls diag_cat at the base. Bound-only termination + the native
-- recursion breadcrumb.
rule nth_diag_cat
  @intention: "The error category of the n-th diagnostic in a report (sentinel 0 if out of bounds)"
  @source: vexprparse.intent:42
  input:
    dn : DiagNthState
  output:
    out : number
  logic:
    out = match dn.list:
      DCons(diag, rest) => if dn.n == 0 then diag_cat(diag) else nth_diag_cat(DiagNthState { list: rest, n: dn.n - 1 })
      DNil => 0
  proofs:
    purity:
      reads : [dn.list, dn.n]
      calls : [diag_cat, nth_diag_cat]
    termination:
      bound : 4000


-- nth_diag_span_start: the offending name's start byte offset of the n-th diagnostic
-- (brick 26), or the sentinel 9999 if n runs past the end of the report (matching the
-- "not located" convention). Mirror of nth_diag_rule, reading diag_span_start instead.
-- Recurses on the tail; calls diag_span_start at the base.
rule nth_diag_span_start
  @intention: "The offending name's start byte offset of the n-th diagnostic (sentinel 9999 if out of bounds)"
  @source: vexprparse.intent:44
  input:
    dn : DiagNthState
  output:
    out : number
  logic:
    out = match dn.list:
      DCons(diag, rest) => if dn.n == 0 then diag_span_start(diag) else nth_diag_span_start(DiagNthState { list: rest, n: dn.n - 1 })
      DNil => 9999
  proofs:
    purity:
      reads : [dn.list, dn.n]
      calls : [diag_span_start, nth_diag_span_start]
    termination:
      bound : 4000


-- nth_diag_span_len: the offending name's byte length of the n-th diagnostic (brick
-- 26), or 0 if n runs past the end of the report. Mirror of nth_diag_span_start,
-- reading diag_span_len. Recurses on the tail; calls diag_span_len at the base.
rule nth_diag_span_len
  @intention: "The offending name's byte length of the n-th diagnostic (0 if out of bounds)"
  @source: vexprparse.intent:44
  input:
    dn : DiagNthState
  output:
    out : number
  logic:
    out = match dn.list:
      DCons(diag, rest) => if dn.n == 0 then diag_span_len(diag) else nth_diag_span_len(DiagNthState { list: rest, n: dn.n - 1 })
      DNil => 0
  proofs:
    purity:
      reads : [dn.list, dn.n]
      calls : [diag_span_len, nth_diag_span_len]
    termination:
      bound : 4000


-- ----------------------------------------------------------------------------
-- BRICK 24 DRIVERS. All three tokenize + parse the source ONCE (same front end as
-- check_program / first_bad_rule), build the whole-program DiagList via prog_diags,
-- and expose one observable to argv. NATIVE-ONLY (multi-line source). Take a ScanState
-- (source + pos): source is argv arg 1, pos is argv arg 2. For all_diags_count, pos is
-- ignored (always 0); for the nth_diag_at_* drivers, pos DOUBLES as the index n.
--
-- Category codes (a rule may carry SEVERAL, in ascending order):
--   1 = undef-var/use-before-def   2 = undef-callee   3 = arity
--   4 = ill-typed                  5 = arg-type-mismatch
--
-- WORKED EXAMPLES (granularity is the headline — counts are rule-category PAIRS):
--   clean       "rule add(x : number, y : number)\n  logic:\n    out = x + y\nrule main\n  logic:\n    out = add(1, 2)"
--                 all_diags_count = 0   (every rule clean)
--   granularity "rule f\n  logic:\n    out = x + y"
--                 all_diags_count = 1   (TWO undefined vars, but ONE category-1 diag);
--                 nth_diag_at_rule n=0 -> 0, nth_diag_at_cat n=0 -> 1.
--                 CONTRAST: check_program on the SAME source = 2 (it tallies x and y
--                 separately). all_diags_count <= check_program, always.
--   two-cats    "rule f\n  logic:\n    out = z + (1 < 2)"
--                 all_diags_count = 2   (undef z => cat 1, number+bool => cat 4, ONE rule);
--                 nth(0) = (rule 0, cat 1), nth(1) = (rule 0, cat 4).
--   two-rules   "rule a\n  logic:\n    out = x\nrule b\n  logic:\n    out = y"
--                 all_diags_count = 2; nth(0) = (0, 1), nth(1) = (1, 1).
--   quad        "rule f(a : number)\n  logic:\n    out = z + 1\nrule main\n  logic:\n    out = f(1 < 2, 3) + g(9)"
--                 all_diags_count = 4 (undef z in rule 0 => (0,1); rule 1 has undefined
--                 callee g => (1,2), arity 2-vs-1 on f => (1,3), bool arg to f's number
--                 param => (1,5)); nth(0)=(0,1), nth(1)=(1,2), nth(2)=(1,3), nth(3)=(1,5).
rule all_diags_count
  @intention: "Tokenize, parse once, and return the number of diagnostics (rule-category pairs) in the whole program"
  @source: vexprparse.intent:42
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let concepts = parse_concepts(ProgramState { cell: toks, src: s.source })
    out = diag_count(prog_diags(ProgDiagsState { iter: prog, all: prog, src: s.source, idx: 0, concepts: concepts }))
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, parse_concepts, diag_count, prog_diags]
    termination:
      bound : 256


-- nth_diag_at_rule: the rule index of the n-th diagnostic, where n is taken from
-- argv arg 2 (s.pos doubles as the index). Front end + prog_diags identical to
-- all_diags_count; nth_diag_rule reads the n-th cell. 9999 if n is out of bounds.
rule nth_diag_at_rule
  @intention: "Tokenize, parse, build the diagnostic list, and return the n-th diagnostic's rule index (n from argv)"
  @source: vexprparse.intent:42
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let concepts = parse_concepts(ProgramState { cell: toks, src: s.source })
    out = nth_diag_rule(DiagNthState { list: prog_diags(ProgDiagsState { iter: prog, all: prog, src: s.source, idx: 0, concepts: concepts }), n: s.pos })
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : [begin_tokenize, parse_program, parse_concepts, nth_diag_rule, prog_diags]
    termination:
      bound : 256


-- nth_diag_at_cat: the companion of nth_diag_at_rule — same front end and same
-- prog_diags, but returns the n-th diagnostic's CATEGORY (0 if n is out of bounds).
-- Together the two drivers expose the (where, what-kind) pair of any diagnostic in the
-- complete report, indexed by n from argv.
rule nth_diag_at_cat
  @intention: "Tokenize, parse, build the diagnostic list, and return the n-th diagnostic's error category (n from argv)"
  @source: vexprparse.intent:42
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let concepts = parse_concepts(ProgramState { cell: toks, src: s.source })
    out = nth_diag_cat(DiagNthState { list: prog_diags(ProgDiagsState { iter: prog, all: prog, src: s.source, idx: 0, concepts: concepts }), n: s.pos })
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : [begin_tokenize, parse_program, parse_concepts, nth_diag_cat, prog_diags]
    termination:
      bound : 256


-- ----------------------------------------------------------------------------
-- BRICK 26 DRIVERS. The LOCATED full report. Same front end + prog_diags as the
-- brick-24 nth_diag_at_* drivers, but expose the n-th diagnostic's SOURCE SPAN so the
-- report says WHERE, not just which-rule / what-kind. Only undefined-variable
-- diagnostics (category 1) carry a real span; every other category (2-5) and every
-- out-of-bounds n reads the sentinel (start 9999, len 0): "not located". NATIVE-ONLY
-- (multi-line source). ScanState: source is argv arg 1, n is argv arg 2 (s.pos).
--
-- WORKED EXAMPLES (spans are whitespace-dependent; the LEN and the sentinel are stable):
--   single undef "rule f\n  logic:\n    out = foo + 1"
--                 nth_diag_at_span_start n=0 -> 26 (offset of foo), n=0 len -> 3.
--                 Cross-check: undef_span_start_of on the SAME source = 26 too.
--   quad         "rule f(a : number)\n  logic:\n    out = z + 1\nrule main\n  logic:\n    out = f(1 < 2, 3) + g(9)"
--                 diag 0 = (rule 0, cat 1, LOCATED): span_len n=0 -> 1 (z is one char),
--                 span_start n=0 -> offset of z. diag 1/2/3 = cats 2/3/5, span SENTINEL:
--                 span_start n=1 -> 9999, span_len n=1 -> 0 (NOT located).
--   clean        "rule add(x : number, y : number)\n  logic:\n    out = x + y\nrule main\n  logic:\n    out = add(1, 2)"
--                 empty list: span_start n=0 -> 9999, span_len n=0 -> 0.
rule nth_diag_at_span_start
  @intention: "Tokenize, parse, build the diagnostic list, and return the n-th diagnostic's offending-name start offset (n from argv)"
  @source: vexprparse.intent:44
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let concepts = parse_concepts(ProgramState { cell: toks, src: s.source })
    out = nth_diag_span_start(DiagNthState { list: prog_diags(ProgDiagsState { iter: prog, all: prog, src: s.source, idx: 0, concepts: concepts }), n: s.pos })
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : [begin_tokenize, parse_program, parse_concepts, nth_diag_span_start, prog_diags]
    termination:
      bound : 256


-- nth_diag_at_span_len: companion of nth_diag_at_span_start — same front end and same
-- prog_diags, but returns the n-th diagnostic's offending-name byte LENGTH (0 if n is
-- out of bounds or the diagnostic is not located). Together the two drivers expose the
-- (start, len) span of any located diagnostic in the complete report, indexed by n.
rule nth_diag_at_span_len
  @intention: "Tokenize, parse, build the diagnostic list, and return the n-th diagnostic's offending-name byte length (n from argv)"
  @source: vexprparse.intent:44
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let concepts = parse_concepts(ProgramState { cell: toks, src: s.source })
    out = nth_diag_span_len(DiagNthState { list: prog_diags(ProgDiagsState { iter: prog, all: prog, src: s.source, idx: 0, concepts: concepts }), n: s.pos })
  proofs:
    purity:
      reads : [s.source, s.pos]
      calls : [begin_tokenize, parse_program, parse_concepts, nth_diag_span_len, prog_diags]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 25: column-level location for undefined variables. Bricks 13/14 COUNTED
-- undefined-variable references (lint_rule -> a number); this brick walks the SAME
-- traversal in the SAME scope discipline but returns the (start, len) SPAN of the
-- FIRST unbound AstVar — the byte range a diagnostic points at. The undef_span_*
-- family mirrors count_undef_* arm-for-arm, swapping "+ (sum)" for span_or
-- ("first non-sentinel wins"). The sentinel for "no undefined variable here" is
-- MkSpan(9999, 0); span_or treats start == 9999 as "empty".
--
-- TRAVERSAL ORDER (must match count_undef exactly so the FIRST span found is the
-- first count_undef would have tallied):
--   * within a rule: the let-bindings' RHSs (source order, ordered/prefix scope)
--     come BEFORE the result expression — undef_span_rule does in_binds first.
--   * within an expression: left-to-right — AstBin lhs before rhs, AstIf cond
--     before thn before els, AstCall args head before tail. span_or(a, b) returns
--     a unless a is the sentinel, so the leftmost real span wins.
--   * across rules: program order (undef_span_list head before tail).
--
-- The observables the drivers expose:
--   * undef_span_start_of -> the byte offset of the first unbound name (9999 if none)
--   * undef_span_len_of   -> its byte length (0 if none)
--   * undef_span_char     -> byte_at(source, start) = the first character of the name
--     ('x'=120, 'y'=121, 'z'=122, 'w'=119, 'a'=97, 'b'=98, 'f'=102, 'q'=113); on the
--     sentinel start 9999, byte_at is out of bounds and ABORTS (sys_exit(1)) — the
--     native byte_at is fail-closed on OOB, so a clean program has no first byte to
--     point at. Test cleanliness via undef_span_start_of (== 9999), not the char.
-- ============================================================================

-- span_start: the start byte offset of a Span. Bare-group accessor, same idiom as
-- diag_index / rd_body (input is a bare group value `s : Span`).
rule span_start
  @intention: "The start byte offset carried by a Span"
  @source: vexprparse.intent:43
  input:
    s : Span
  output:
    out : number
  logic:
    out = match s:
      MkSpan(start, len) => start
  proofs:
    purity:
      reads : [s]
      calls : []
    termination:
      bound : 16


-- span_len: the byte length of a Span. Mirror of span_start.
rule span_len
  @intention: "The byte length carried by a Span"
  @source: vexprparse.intent:43
  input:
    s : Span
  output:
    out : number
  logic:
    out = match s:
      MkSpan(start, len) => len
  proofs:
    purity:
      reads : [s]
      calls : []
    termination:
      bound : 16


-- span_or's input: two candidate Spans. The "first non-sentinel" combinator that
-- replaces the "+ (sum)" of the count version: in count_undef, two subtrees'
-- counts ADD; here the first subtree's span WINS unless it is the empty sentinel,
-- in which case the second is taken. This is what makes the leftmost undefined
-- variable the reported one.
concept SpanOrState
  @intention: "Two candidate Spans, to pick the first non-sentinel"
  @source: vexprparse.intent:43
  fields:
    a : Span
    b : Span


-- span_or: pick the first non-sentinel Span. The sentinel is MkSpan(9999, 0); a
-- start of 9999 means "no span here", so when so.a is the sentinel we fall through
-- to so.b (which may itself be the sentinel — span_or composes associatively).
rule span_or
  @intention: "The first of two Spans that is not the no-result sentinel (start 9999)"
  @source: vexprparse.intent:43
  input:
    so : SpanOrState
  output:
    out : Span
  logic:
    out = if span_start(so.a) == 9999 then so.b else so.a
  proofs:
    purity:
      reads : [so.a, so.b]
      calls : [span_start]
    termination:
      bound : 32


-- undef_span_ast's input: one Ast node + the rule's binding scope + the source
-- text (spans index into it). Same triple as UndefAstState (the count version);
-- the only difference is the RETURN type (Span, not number).
concept UndefSpanAstState
  @intention: "An Ast node + the binding scope + the source text, for locating its first undefined variable"
  @source: vexprparse.intent:43
  fields:
    node : Ast
    binds : Binding
    src : text [..256]


-- undef_span_ast: walk an Ast and return the SPAN of the first AstVar reference
-- whose name is NOT name_bound in the scope. Mirrors count_undef_ast arm-for-arm:
--   * AstVar(start, len) => the span (start, len) if unbound, else the sentinel.
--   * AstBin walks lhs THEN rhs via span_or (lhs wins on a tie — left-to-right).
--   * AstNeg/AstNot/AstField recurse into their single child.
--   * AstCall walks its ARGUMENT list (undef_span_args); the callee name is a
--     callee-resolution concern (brick 15), not a variable reference, so it is
--     not probed here — identical to count_undef_ast.
--   * AstIf walks cond, thn, els left-to-right via nested span_or.
--   * leaves (AstNum/AstBool/AstStr/AstErr) have no variable => the sentinel.
-- Mutually recursive with undef_span_args. Bound-only termination + the mandatory
-- native recursion breadcrumb (the shrinking node is a FIELD of the packed input,
-- not the input itself — same posture as count_undef_ast / shape_ast).
rule undef_span_ast
  @intention: "The span of the first undefined-variable reference inside an Ast (sentinel MkSpan(9999,0) if none)"
  @source: vexprparse.intent:43
  input:
    a : UndefSpanAstState
  output:
    out : Span
  logic:
    out = match a.node:
      AstNum(value) => Span::MkSpan { start: 9999, len: 0 }
      AstBool(value) => Span::MkSpan { start: 9999, len: 0 }
      AstStr(start, len) => Span::MkSpan { start: 9999, len: 0 }
      AstBytes(start, len) => Span::MkSpan { start: 9999, len: 0 }
      AstErr => Span::MkSpan { start: 9999, len: 0 }
      -- R6a: locate the first undefined variable inside a variant construct's field
      -- VALUES (the names are type references, not vars), scope unchanged.
      AstVariant(cstart, clen, vstart, vlen, fields) => undef_span_vfields(UndefSpanVFieldsState { fields: fields, binds: a.binds, src: a.src })
      -- R6a: scrutinee first, then each arm body with the scope EXTENDED by the
      -- arm's binders (a binder is never "undefined" inside its own arm).
      AstMatch(scrut, arms) => span_or(SpanOrState { a: undef_span_ast(UndefSpanAstState { node: scrut, binds: a.binds, src: a.src }), b: undef_span_arms(UndefSpanArmsState { arms: arms, binds: a.binds, src: a.src }) })
      AstVar(start, len) => if name_bound(NameBoundState { binds: a.binds, src: a.src, q_start: start, q_len: len }) == 0 then Span::MkSpan { start: start, len: len } else Span::MkSpan { start: 9999, len: 0 }
      AstBin(op, lhs, rhs) => span_or(SpanOrState { a: undef_span_ast(UndefSpanAstState { node: lhs, binds: a.binds, src: a.src }), b: undef_span_ast(UndefSpanAstState { node: rhs, binds: a.binds, src: a.src }) })
      AstNeg(inner) => undef_span_ast(UndefSpanAstState { node: inner, binds: a.binds, src: a.src })
      AstNot(inner) => undef_span_ast(UndefSpanAstState { node: inner, binds: a.binds, src: a.src })
      AstField(base, fstart, flen) => undef_span_ast(UndefSpanAstState { node: base, binds: a.binds, src: a.src })
      AstCall(callee_start, callee_len, args) => undef_span_args(UndefSpanArgsState { args: args, binds: a.binds, src: a.src })
      AstIf(cond, thn, els) => span_or(SpanOrState { a: span_or(SpanOrState { a: undef_span_ast(UndefSpanAstState { node: cond, binds: a.binds, src: a.src }), b: undef_span_ast(UndefSpanAstState { node: thn, binds: a.binds, src: a.src }) }), b: undef_span_ast(UndefSpanAstState { node: els, binds: a.binds, src: a.src }) })
  proofs:
    purity:
      reads : [a.node, a.binds, a.src]
      calls : [name_bound, span_or, undef_span_ast, undef_span_args, undef_span_vfields, undef_span_arms]
    termination:
      bound : 4000


-- R6a: undef_span_vfields — the span of the first undefined variable across a
-- variant construct's field VALUES (head field before tail, via span_or). Span
-- mirror of count_undef_vfields. Mutually recursive with undef_span_ast.
concept UndefSpanVFieldsState
  @intention: "A variant construct's field list + the binding scope + the source text, for locating its first undefined variable"
  @source: vexprparse.intent:43
  fields:
    fields : VFieldList
    binds : Binding
    src : text [..256]


rule undef_span_vfields
  @intention: "The span of the first undefined-variable reference across a variant construct's field values (sentinel if none)"
  @source: vexprparse.intent:43
  input:
    a : UndefSpanVFieldsState
  output:
    out : Span
  logic:
    out = match a.fields:
      VFCons(name_start, name_len, val, rest) => span_or(SpanOrState { a: undef_span_ast(UndefSpanAstState { node: val, binds: a.binds, src: a.src }), b: undef_span_vfields(UndefSpanVFieldsState { fields: rest, binds: a.binds, src: a.src }) })
      VFNil => Span::MkSpan { start: 9999, len: 0 }
  proofs:
    purity:
      reads : [a.fields, a.binds, a.src]
      calls : [span_or, undef_span_ast, undef_span_vfields]
    termination:
      bound : 4000


-- R6a: undef_span_arms — the span of the first undefined variable across a match's
-- arm bodies (each scoped with its own binders via binds_with_binders; the first
-- arm wins via span_or). Span mirror of count_undef_arms. The binder scoping is
-- load-bearing: an arm binder is never reported as undefined inside its own body.
concept UndefSpanArmsState
  @intention: "A match arm list + the enclosing binding scope + the source text, for locating its first undefined variable"
  @source: vexprparse.intent:43
  fields:
    arms : ArmList
    binds : Binding
    src : text [..256]


rule undef_span_arms
  @intention: "The span of the first undefined-variable reference across a match's arm bodies (arm binders in scope; sentinel if none)"
  @source: vexprparse.intent:43
  input:
    a : UndefSpanArmsState
  output:
    out : Span
  logic:
    out = match a.arms:
      ArmCons(vstart, vlen, binders, body, rest) => span_or(SpanOrState { a: undef_span_ast(UndefSpanAstState { node: body, binds: binds_with_binders(BindsWithBindersState { binds: a.binds, bs: binders }), src: a.src }), b: undef_span_arms(UndefSpanArmsState { arms: rest, binds: a.binds, src: a.src }) })
      ArmNil => Span::MkSpan { start: 9999, len: 0 }
  proofs:
    purity:
      reads : [a.arms, a.binds, a.src]
      calls : [span_or, undef_span_ast, undef_span_arms, binds_with_binders]
    termination:
      bound : 4000


-- undef_span_args's input: a call's argument list + the rule's binding scope + the
-- source text. Same triple as UndefArgsState (the count version), Span return.
concept UndefSpanArgsState
  @intention: "A call's argument list + the binding scope + the source text, for locating its first undefined variable"
  @source: vexprparse.intent:43
  fields:
    args : ArgList
    binds : Binding
    src : text [..256]


-- undef_span_args: walk a call's ArgList, returning the span of the first undefined
-- variable found across its arguments (head before tail, via span_or). Mirrors
-- count_undef_args; mutually recursive with undef_span_ast (a call's arguments are
-- themselves Asts). Bound-only termination + the native recursion breadcrumb (the
-- shrinking `args` tail is a field of the packed input).
rule undef_span_args
  @intention: "The span of the first undefined-variable reference across a call's arguments (sentinel if none)"
  @source: vexprparse.intent:43
  input:
    a : UndefSpanArgsState
  output:
    out : Span
  logic:
    out = match a.args:
      ArgCons(head, tail) => span_or(SpanOrState { a: undef_span_ast(UndefSpanAstState { node: head, binds: a.binds, src: a.src }), b: undef_span_args(UndefSpanArgsState { args: tail, binds: a.binds, src: a.src }) })
      ArgNil => Span::MkSpan { start: 9999, len: 0 }
  proofs:
    purity:
      reads : [a.args, a.binds, a.src]
      calls : [span_or, undef_span_ast, undef_span_args]
    termination:
      bound : 4000


-- undef_span_binds's input: the binding list being ITERATED + the PREFIX of earlier
-- bindings (the use-before-def scope) + the source text. Same triple as
-- UndefBindsOrderedState (the count version), Span return.
concept UndefSpanBindsState
  @intention: "The binding list being walked + the prefix of earlier bindings + the source text, for use-before-def location"
  @source: vexprparse.intent:43
  fields:
    iter : Binding
    prefix : Binding
    src : text [..256]


-- undef_span_binds: for each binding in `iter`, locate the first undefined variable
-- in its RHS expression scoped to the PREFIX of bindings that appear EARLIER (proper
-- let-ordering: a forward or self reference in a let RHS is flagged). Mirrors
-- count_undef_binds_ordered: the prefix grows by the current binding before
-- recursing on the tail, so the next binding sees this one but not vice versa. The
-- current binding's RHS is checked BEFORE the tail (source order), via span_or.
-- Bound-only termination + the native recursion breadcrumb (the shrinking `iter`
-- tail is a field of the packed input).
rule undef_span_binds
  @intention: "The span of the first undefined-OR-use-before-def variable across a binding list's RHSs (sentinel if none)"
  @source: vexprparse.intent:43
  input:
    a : UndefSpanBindsState
  output:
    out : Span
  logic:
    out = match a.iter:
      BCons(name_start, name_len, value, rest) => span_or(SpanOrState { a: undef_span_ast(UndefSpanAstState { node: value, binds: a.prefix, src: a.src }), b: undef_span_binds(UndefSpanBindsState { iter: rest, prefix: Binding::BCons { name_start: name_start, name_len: name_len, value: value, rest: a.prefix }, src: a.src }) })
      BNil => Span::MkSpan { start: 9999, len: 0 }
  proofs:
    purity:
      reads : [a.iter, a.prefix, a.src]
      calls : [span_or, undef_span_ast, undef_span_binds]
    termination:
      bound : 4000


-- undef_span_rule's input: one rule declaration + the program source text. Same
-- shape as LintRuleState (the count version), Span return.
concept UndefSpanRuleState
  @intention: "A rule declaration + the program source text, for locating its first undefined variable"
  @source: vexprparse.intent:43
  fields:
    rd : RuleDecl
    src : text [..256]


-- undef_span_rule: the span of the first undefined-OR-use-before-def variable in ONE
-- rule. Mirrors lint_rule: build the scope (params as the base prefix; params
-- appended to the full binding list for the result), then check the bindings'
-- ordered RHSs FIRST, then the result expression — span_or keeps the in_binds span
-- if there is one (the let RHSs precede the result in source order). Bound-only
-- termination + the native recursion breadcrumb.
rule undef_span_rule
  @intention: "The span of the first undefined-OR-use-before-def reference in one rule (params in scope; sentinel if clean)"
  @source: vexprparse.intent:43
  input:
    a : UndefSpanRuleState
  output:
    out : Span
  logic:
    let body = rd_body(a.rd)
    let binds = block_binds(body)
    let result = block_result(body)
    let pbinds = param_to_binding(rd_params(a.rd))
    let scope = append_bindings(BindAppendState { a: pbinds, b: binds })
    let in_binds = undef_span_binds(UndefSpanBindsState { iter: binds, prefix: pbinds, src: a.src })
    out = span_or(SpanOrState { a: in_binds, b: undef_span_ast(UndefSpanAstState { node: result, binds: scope, src: a.src }) })
  proofs:
    purity:
      reads : [a.rd, a.src]
      calls : [rd_body, block_binds, block_result, rd_params, param_to_binding, append_bindings, undef_span_binds, span_or, undef_span_ast]
    termination:
      bound : 4000


-- undef_span_list's input: the rule list being folded + the program source text.
-- Same shape as LintListState (the count version), Span return.
concept UndefSpanListState
  @intention: "A rule list + the program source text, for locating the program's first undefined variable"
  @source: vexprparse.intent:43
  fields:
    rl : RuleList
    src : text [..256]


-- undef_span_list: the span of the first undefined-OR-use-before-def variable across
-- every rule in the program, in program order. Mirrors lint_list: the head rule is
-- checked BEFORE the tail (via span_or), so the earliest rule's earliest undefined
-- variable wins. Bound-only termination + the native recursion breadcrumb (the
-- shrinking `rl` tail is a field of the packed input).
rule undef_span_list
  @intention: "The span of the program's first undefined-variable reference, in program order (sentinel if clean)"
  @source: vexprparse.intent:43
  input:
    a : UndefSpanListState
  output:
    out : Span
  logic:
    out = match a.rl:
      RCons(head, tail) => span_or(SpanOrState { a: undef_span_rule(UndefSpanRuleState { rd: head, src: a.src }), b: undef_span_list(UndefSpanListState { rl: tail, src: a.src }) })
      RNil => Span::MkSpan { start: 9999, len: 0 }
  proofs:
    purity:
      reads : [a.rl, a.src]
      calls : [span_or, undef_span_rule, undef_span_list]
    termination:
      bound : 4000


-- ----------------------------------------------------------------------------
-- BRICK 27: the undefined-CALLEE span family. Mirrors the count_badcall_* family
-- (brick "category 2") arm-for-arm, swapping "+ (sum)" for span_or and returning
-- the offending callee NAME span instead of a count. Where count_badcall returns
-- "how many call sites name a rule that does not exist", badcall_span returns the
-- SPAN of the FIRST such callee — in the same traversal order count_badcall sums:
-- binds before result, left-to-right within an expression, and (the load-bearing
-- arm) the OUTER call's callee BEFORE descending into its args. The sentinel for
-- "no bad callee here" is MkSpan(9999, 0); span_or treats start == 9999 as empty.
--
-- This is the analogue of the brick-25 undef_span_* family, but SIMPLER on the
-- rule level: undefined-callee scope is program-wide, so badcall_span_rule does
-- NOT build a param scope or thread a binding prefix — it just checks the binds
-- then the result, both against the same program RuleList (exactly as badcall_rule
-- does for the count). The Ast/args/binds walkers mirror their count_badcall twins.
-- ----------------------------------------------------------------------------


-- badcall_span_ast's input: one Ast node + the program's RuleList (callee scope) +
-- the source text (spans index into it). Same triple as BadCallState (the count
-- version); the only difference is the RETURN type (Span, not number).
concept BadCallSpanState
  @intention: "An Ast node + the program rule list (callee scope) + the source text, for locating its first undefined callee"
  @source: vexprparse.intent:45
  fields:
    node : Ast
    rules : RuleList
    src : text [..256]


-- badcall_span_args's input: a call's argument list + the program's RuleList
-- (callee scope) + the source text. Mirrors BadCallArgsState; Span return.
concept BadCallSpanArgsState
  @intention: "A call-argument list + the program rule list (callee scope) + the source text, for locating its first undefined callee"
  @source: vexprparse.intent:45
  fields:
    args : ArgList
    rules : RuleList
    src : text [..256]


-- badcall_span_binds's input: the binding list whose RHSes are walked + the
-- program's RuleList (callee scope) + the source text. Mirrors BadCallBindsState;
-- Span return. As with the count version there is no prefix — callee scope is
-- program-wide, so every RHS sees the FULL program rule list.
concept BadCallSpanBindsState
  @intention: "A binding list + the program rule list (callee scope) + the source text, for locating its first undefined callee"
  @source: vexprparse.intent:45
  fields:
    binds : Binding
    rules : RuleList
    src : text [..256]


-- badcall_span_rule's input: ONE rule declaration + the FULL program RuleList (the
-- checked rule may call itself or any other rule) + the source text. Mirrors
-- BadCallRuleState; Span return.
concept BadCallSpanRuleState
  @intention: "A rule declaration + the full program rule list + the source text, for locating its first undefined callee"
  @source: vexprparse.intent:45
  fields:
    rd : RuleDecl
    rules : RuleList
    src : text [..256]


-- badcall_span_ast: walk an Ast and return the SPAN of the first AstCall whose
-- callee name is NOT rule_named in the program. Mirrors count_badcall_ast's
-- structural walk, swapping "+ (sum)" for span_or:
--   * AstCall(callee_start, callee_len, args) => if the callee does NOT exist
--     (rule_named == 0) report ITS name span IMMEDIATELY (MkSpan(callee_start,
--     callee_len)); only if the callee EXISTS descend into the args via
--     badcall_span_args. This "callee before args" order matches count_badcall and
--     reports the OUTER/first undefined callee (e.g. in g(h(1)) with g undefined,
--     g's span wins; with g defined and h undefined, we descend and h's span wins).
--   * AstBin walks lhs THEN rhs via span_or (lhs wins on a tie — left-to-right).
--   * AstNeg / AstNot / AstField descend into their single child.
--   * AstIf walks cond, thn, els left-to-right via nested span_or.
--   * AstVar / AstNum / AstStr / AstBool / AstErr carry no callee -> sentinel.
-- Mutually recursive with badcall_span_args. a.node is a FIELD of the packed input
-- (not the input), so bound + the mandatory native recursion breadcrumb.
rule badcall_span_ast
  @intention: "The span of the first undefined-callee reference in an AST, given the program's rule list (sentinel if clean)"
  @source: vexprparse.intent:45
  input:
    a : BadCallSpanState
  output:
    out : Span
  logic:
    out = match a.node:
      AstNum(value) => Span::MkSpan { start: 9999, len: 0 }
      AstBool(value) => Span::MkSpan { start: 9999, len: 0 }
      AstVar(start, len) => Span::MkSpan { start: 9999, len: 0 }
      AstStr(start, len) => Span::MkSpan { start: 9999, len: 0 }
      AstBytes(start, len) => Span::MkSpan { start: 9999, len: 0 }
      AstErr => Span::MkSpan { start: 9999, len: 0 }
      -- R6a: locate the first undefined callee inside a variant construct's field
      -- VALUES (a variant names a type, not a callee).
      AstVariant(cstart, clen, vstart, vlen, fields) => badcall_span_vfields(BadCallSpanVFieldsState { fields: fields, rules: a.rules, src: a.src })
      -- R6a: scrutinee first, then arm bodies (binders don't affect callee scope).
      AstMatch(scrut, arms) => span_or(SpanOrState { a: badcall_span_ast(BadCallSpanState { node: scrut, rules: a.rules, src: a.src }), b: badcall_span_arms(BadCallSpanArmsState { arms: arms, rules: a.rules, src: a.src }) })
      AstBin(op, lhs, rhs) => span_or(SpanOrState { a: badcall_span_ast(BadCallSpanState { node: lhs, rules: a.rules, src: a.src }), b: badcall_span_ast(BadCallSpanState { node: rhs, rules: a.rules, src: a.src }) })
      AstNeg(inner) => badcall_span_ast(BadCallSpanState { node: inner, rules: a.rules, src: a.src })
      AstNot(inner) => badcall_span_ast(BadCallSpanState { node: inner, rules: a.rules, src: a.src })
      AstField(base, fstart, flen) => badcall_span_ast(BadCallSpanState { node: base, rules: a.rules, src: a.src })
      AstCall(callee_start, callee_len, args) => if rule_named(RuleNamedState { rules: a.rules, src: a.src, q_start: callee_start, q_len: callee_len }) == 0 then Span::MkSpan { start: callee_start, len: callee_len } else badcall_span_args(BadCallSpanArgsState { args: args, rules: a.rules, src: a.src })
      AstIf(cond, thn, els) => span_or(SpanOrState { a: span_or(SpanOrState { a: badcall_span_ast(BadCallSpanState { node: cond, rules: a.rules, src: a.src }), b: badcall_span_ast(BadCallSpanState { node: thn, rules: a.rules, src: a.src }) }), b: badcall_span_ast(BadCallSpanState { node: els, rules: a.rules, src: a.src }) })
  proofs:
    purity:
      reads : [a.node, a.rules, a.src]
      calls : [rule_named, span_or, badcall_span_ast, badcall_span_args, badcall_span_vfields, badcall_span_arms]
    termination:
      bound : 4000


-- R6a: badcall_span_vfields — the span of the first undefined callee across a
-- variant construct's field values. Span mirror of count_badcall_vfields.
concept BadCallSpanVFieldsState
  @intention: "A variant construct's field list + the program rule list (callee scope) + the source text, for locating its first undefined callee"
  @source: vexprparse.intent:45
  fields:
    fields : VFieldList
    rules : RuleList
    src : text [..256]


rule badcall_span_vfields
  @intention: "The span of the first undefined callee across a variant construct's field values (sentinel if clean)"
  @source: vexprparse.intent:45
  input:
    a : BadCallSpanVFieldsState
  output:
    out : Span
  logic:
    out = match a.fields:
      VFCons(name_start, name_len, val, rest) => span_or(SpanOrState { a: badcall_span_ast(BadCallSpanState { node: val, rules: a.rules, src: a.src }), b: badcall_span_vfields(BadCallSpanVFieldsState { fields: rest, rules: a.rules, src: a.src }) })
      VFNil => Span::MkSpan { start: 9999, len: 0 }
  proofs:
    purity:
      reads : [a.fields, a.rules, a.src]
      calls : [span_or, badcall_span_ast, badcall_span_vfields]
    termination:
      bound : 4000


-- R6a: badcall_span_arms — the span of the first undefined callee across a match's
-- arm bodies. Span mirror of count_badcall_arms (binders don't affect callee scope).
concept BadCallSpanArmsState
  @intention: "A match arm list + the program rule list (callee scope) + the source text, for locating its first undefined callee"
  @source: vexprparse.intent:45
  fields:
    arms : ArmList
    rules : RuleList
    src : text [..256]


rule badcall_span_arms
  @intention: "The span of the first undefined callee across a match's arm bodies (sentinel if clean)"
  @source: vexprparse.intent:45
  input:
    a : BadCallSpanArmsState
  output:
    out : Span
  logic:
    out = match a.arms:
      ArmCons(vstart, vlen, binders, body, rest) => span_or(SpanOrState { a: badcall_span_ast(BadCallSpanState { node: body, rules: a.rules, src: a.src }), b: badcall_span_arms(BadCallSpanArmsState { arms: rest, rules: a.rules, src: a.src }) })
      ArmNil => Span::MkSpan { start: 9999, len: 0 }
  proofs:
    purity:
      reads : [a.arms, a.rules, a.src]
      calls : [span_or, badcall_span_ast, badcall_span_arms]
    termination:
      bound : 4000


-- badcall_span_args: walk a call's ArgList, returning the span of the first
-- undefined callee found across its arguments (head before tail, via span_or).
-- Mirrors count_badcall_args; mutually recursive with badcall_span_ast (a call's
-- arguments are themselves Asts that may contain more calls). Recurses over the
-- tail (a field of the input), so bound + breadcrumb; rules + src threaded down.
rule badcall_span_args
  @intention: "The span of the first undefined callee across every argument of a call (sentinel if clean)"
  @source: vexprparse.intent:45
  input:
    a : BadCallSpanArgsState
  output:
    out : Span
  logic:
    out = match a.args:
      ArgCons(head, tail) => span_or(SpanOrState { a: badcall_span_ast(BadCallSpanState { node: head, rules: a.rules, src: a.src }), b: badcall_span_args(BadCallSpanArgsState { args: tail, rules: a.rules, src: a.src }) })
      ArgNil => Span::MkSpan { start: 9999, len: 0 }
  proofs:
    purity:
      reads : [a.args, a.rules, a.src]
      calls : [span_or, badcall_span_ast, badcall_span_args]
    termination:
      bound : 4000


-- badcall_span_binds: for each binding in the list, locate the first undefined
-- callee in its RHS `value` (against the FULL program rule list), then recurse on
-- `rest`. The current binding's RHS is checked BEFORE the tail (source order), via
-- span_or. Mirrors count_badcall_binds; no prefix (callee scope is program-wide).
-- Recurses over the binding tail (a field of the input), so bound + breadcrumb.
rule badcall_span_binds
  @intention: "The span of the first undefined callee across every binding's RHS (sentinel if clean)"
  @source: vexprparse.intent:45
  input:
    a : BadCallSpanBindsState
  output:
    out : Span
  logic:
    out = match a.binds:
      BCons(name_start, name_len, value, rest) => span_or(SpanOrState { a: badcall_span_ast(BadCallSpanState { node: value, rules: a.rules, src: a.src }), b: badcall_span_binds(BadCallSpanBindsState { binds: rest, rules: a.rules, src: a.src }) })
      BNil => Span::MkSpan { start: 9999, len: 0 }
  proofs:
    purity:
      reads : [a.binds, a.rules, a.src]
      calls : [span_or, badcall_span_ast, badcall_span_binds]
    termination:
      bound : 4000


-- badcall_span_rule: the span of the first undefined callee in ONE rule. Mirrors
-- badcall_rule (the count), but SIMPLER than undef_span_rule (the var-span version)
-- because callee scope is program-wide — there is no param scope and no binding
-- prefix to thread. Split the body Block into its binding list and result, then:
--   * badcall_span_binds over the bindings (every let RHS's callees), THEN
--   * badcall_span_ast over the result expression's callees.
-- span_or keeps the in_binds span if there is one (the let RHSs precede the result
-- in source order). Both halves resolve callees against the SAME full program
-- RuleList `a.rules`. Bound-only termination.
--
-- Worked examples (offsets into the source text, 0-based bytes):
--   `rule main\n  logic:\n    out = g(1)`         -> MkSpan(<offset of g>, 1)
--   `rule main\n  logic:\n    out = foobar(1)`    -> MkSpan(<offset of foobar>, 6)
--   `rule f\n  logic:\n    out = z + 1\nrule main\n  logic:\n    out = f(1, 2) + g(9)`
--                                                  -> for rule main: MkSpan(<offset of g>, 1)
--                                                     (f is defined, so f(1, 2) is clean;
--                                                      the result walk descends past f into g)
--   a rule whose every callee exists (incl. self / forward refs) -> MkSpan(9999, 0).
rule badcall_span_rule
  @intention: "The span of the first undefined-callee reference in one rule (callees resolved program-wide; sentinel if clean)"
  @source: vexprparse.intent:45
  input:
    a : BadCallSpanRuleState
  output:
    out : Span
  logic:
    let body = rd_body(a.rd)
    let binds = block_binds(body)
    let result = block_result(body)
    out = span_or(SpanOrState { a: badcall_span_binds(BadCallSpanBindsState { binds: binds, rules: a.rules, src: a.src }), b: badcall_span_ast(BadCallSpanState { node: result, rules: a.rules, src: a.src }) })
  proofs:
    purity:
      reads : [a.rd, a.rules, a.src]
      calls : [rd_body, block_binds, block_result, badcall_span_binds, span_or, badcall_span_ast]
    termination:
      bound : 4000


-- ----------------------------------------------------------------------------
-- BRICK 28: the arity-mismatch span family. Mirrors the count_badarity_* family
-- arm-for-arm, swapping "+ (sum)" for span_or and returning the offending CALL's
-- callee NAME span instead of a count. Where count_badarity counts "how many call
-- sites supply the wrong number of args to an EXISTING rule", badarity_span returns
-- the SPAN of the callee name of the FIRST such call — in the same traversal order
-- count_badarity sums: binds before result, left-to-right within an expression, and
-- (the load-bearing arm) the OUTER call's own arity BEFORE descending into its args.
-- The decision per call reuses arity_mismatch directly (1 iff the callee EXISTS and
-- its declared param count != this call's arg count). The sentinel for "no arity
-- mismatch here" is MkSpan(9999, 0); span_or treats start == 9999 as empty.
--
-- Like badcall_span (brick 27), the rule level is SIMPLE: arity scope is the same
-- program-wide RuleList — badarity_span_rule builds no param scope and threads no
-- binding prefix, it just checks the binds then the result, both against the full
-- program RuleList (exactly as badarity_rule does for the count).
-- ----------------------------------------------------------------------------


-- badarity_span_ast's input: one Ast node + the program's RuleList (callee scope) +
-- the source text (spans index into it). Same triple as BadArityState (the count
-- version); the only difference is the RETURN type (Span, not number).
concept BadAritySpanState
  @intention: "An Ast node + the program rule list (callee scope) + the source text, for locating its first arity-mismatched call"
  @source: vexprparse.intent:46
  fields:
    node : Ast
    rules : RuleList
    src : text [..256]


-- badarity_span_args's input: a call's argument list + the program's RuleList
-- (callee scope) + the source text. Mirrors BadArityArgsState; Span return.
concept BadAritySpanArgsState
  @intention: "A call-argument list + the program rule list (callee scope) + the source text, for locating its first arity-mismatched call"
  @source: vexprparse.intent:46
  fields:
    args : ArgList
    rules : RuleList
    src : text [..256]


-- badarity_span_binds's input: the binding list whose RHSes are walked + the
-- program's RuleList (callee scope) + the source text. Mirrors BadArityBindsState;
-- Span return. As with the count version there is no prefix — arity scope is
-- program-wide, so every RHS sees the FULL program rule list.
concept BadAritySpanBindsState
  @intention: "A binding list + the program rule list (callee scope) + the source text, for locating its first arity-mismatched call"
  @source: vexprparse.intent:46
  fields:
    binds : Binding
    rules : RuleList
    src : text [..256]


-- badarity_span_rule's input: ONE rule declaration + the FULL program RuleList (the
-- checked rule may call itself or any other rule) + the source text. Mirrors
-- BadArityRuleState; Span return.
concept BadAritySpanRuleState
  @intention: "A rule declaration + the full program rule list + the source text, for locating its first arity-mismatched call"
  @source: vexprparse.intent:46
  fields:
    rd : RuleDecl
    rules : RuleList
    src : text [..256]


-- badarity_span_ast: walk an Ast and return the SPAN of the first AstCall whose
-- arity is wrong (callee EXISTS but supplies the wrong number of args). Mirrors
-- count_badarity_ast's structural walk, swapping "+ (sum)" for span_or:
--   * AstCall(callee_start, callee_len, args) => if arity_mismatch == 1 (the callee
--     exists and its declared param count differs from this call's arg count) report
--     ITS callee name span IMMEDIATELY (MkSpan(callee_start, callee_len)); else
--     descend into the args via badarity_span_args. This "this call before args"
--     order matches count_badarity and reports the OUTER/first mismatched call.
--   * AstBin walks lhs THEN rhs via span_or (lhs wins on a tie — left-to-right).
--   * AstNeg / AstNot / AstField descend into their single child.
--   * AstIf walks cond, thn, els left-to-right via nested span_or.
--   * AstVar / AstNum / AstStr / AstBool / AstErr carry no call -> sentinel.
-- Mutually recursive with badarity_span_args. a.node is a FIELD of the packed input
-- (not the input), so bound + the mandatory native recursion breadcrumb.
rule badarity_span_ast
  @intention: "The span of the first arity-mismatched call in an AST, given the program's rule list (sentinel if clean)"
  @source: vexprparse.intent:46
  input:
    a : BadAritySpanState
  output:
    out : Span
  logic:
    out = match a.node:
      AstNum(value) => Span::MkSpan { start: 9999, len: 0 }
      AstBool(value) => Span::MkSpan { start: 9999, len: 0 }
      AstVar(start, len) => Span::MkSpan { start: 9999, len: 0 }
      AstStr(start, len) => Span::MkSpan { start: 9999, len: 0 }
      AstBytes(start, len) => Span::MkSpan { start: 9999, len: 0 }
      AstErr => Span::MkSpan { start: 9999, len: 0 }
      -- R6a: locate the first arity-mismatched call inside a variant construct's
      -- field VALUES (a variant is not a call).
      AstVariant(cstart, clen, vstart, vlen, fields) => badarity_span_vfields(BadAritySpanVFieldsState { fields: fields, rules: a.rules, src: a.src })
      -- R6a: scrutinee first, then arm bodies (binders don't affect arity scope).
      AstMatch(scrut, arms) => span_or(SpanOrState { a: badarity_span_ast(BadAritySpanState { node: scrut, rules: a.rules, src: a.src }), b: badarity_span_arms(BadAritySpanArmsState { arms: arms, rules: a.rules, src: a.src }) })
      AstBin(op, lhs, rhs) => span_or(SpanOrState { a: badarity_span_ast(BadAritySpanState { node: lhs, rules: a.rules, src: a.src }), b: badarity_span_ast(BadAritySpanState { node: rhs, rules: a.rules, src: a.src }) })
      AstNeg(inner) => badarity_span_ast(BadAritySpanState { node: inner, rules: a.rules, src: a.src })
      AstNot(inner) => badarity_span_ast(BadAritySpanState { node: inner, rules: a.rules, src: a.src })
      AstField(base, fstart, flen) => badarity_span_ast(BadAritySpanState { node: base, rules: a.rules, src: a.src })
      AstCall(callee_start, callee_len, args) => if arity_mismatch(MismatchState { rules: a.rules, src: a.src, callee_start: callee_start, callee_len: callee_len, args: args }) == 1 then Span::MkSpan { start: callee_start, len: callee_len } else badarity_span_args(BadAritySpanArgsState { args: args, rules: a.rules, src: a.src })
      AstIf(cond, thn, els) => span_or(SpanOrState { a: span_or(SpanOrState { a: badarity_span_ast(BadAritySpanState { node: cond, rules: a.rules, src: a.src }), b: badarity_span_ast(BadAritySpanState { node: thn, rules: a.rules, src: a.src }) }), b: badarity_span_ast(BadAritySpanState { node: els, rules: a.rules, src: a.src }) })
  proofs:
    purity:
      reads : [a.node, a.rules, a.src]
      calls : [arity_mismatch, span_or, badarity_span_ast, badarity_span_args, badarity_span_vfields, badarity_span_arms]
    termination:
      bound : 4000


-- badarity_span_args: walk a call's ArgList, returning the span of the first
-- arity-mismatched call found across its arguments (head before tail, via span_or).
-- Mirrors count_badarity_args; mutually recursive with badarity_span_ast (a call's
-- arguments are themselves Asts that may contain more calls). Recurses over the
-- tail (a field of the input), so bound + breadcrumb; rules + src threaded down.
rule badarity_span_args
  @intention: "The span of the first arity-mismatched call across every argument of a call (sentinel if clean)"
  @source: vexprparse.intent:46
  input:
    a : BadAritySpanArgsState
  output:
    out : Span
  logic:
    out = match a.args:
      ArgCons(head, tail) => span_or(SpanOrState { a: badarity_span_ast(BadAritySpanState { node: head, rules: a.rules, src: a.src }), b: badarity_span_args(BadAritySpanArgsState { args: tail, rules: a.rules, src: a.src }) })
      ArgNil => Span::MkSpan { start: 9999, len: 0 }
  proofs:
    purity:
      reads : [a.args, a.rules, a.src]
      calls : [span_or, badarity_span_ast, badarity_span_args]
    termination:
      bound : 4000


-- R6a: badarity_span_vfields — the span of the first arity-mismatched call across a
-- variant construct's field values. Span mirror of count_badarity_vfields.
concept BadAritySpanVFieldsState
  @intention: "A variant construct's field list + the program rule list (callee scope) + the source text, for locating its first arity-mismatched call"
  @source: vexprparse.intent:46
  fields:
    fields : VFieldList
    rules : RuleList
    src : text [..256]


rule badarity_span_vfields
  @intention: "The span of the first arity-mismatched call across a variant construct's field values (sentinel if clean)"
  @source: vexprparse.intent:46
  input:
    a : BadAritySpanVFieldsState
  output:
    out : Span
  logic:
    out = match a.fields:
      VFCons(name_start, name_len, val, rest) => span_or(SpanOrState { a: badarity_span_ast(BadAritySpanState { node: val, rules: a.rules, src: a.src }), b: badarity_span_vfields(BadAritySpanVFieldsState { fields: rest, rules: a.rules, src: a.src }) })
      VFNil => Span::MkSpan { start: 9999, len: 0 }
  proofs:
    purity:
      reads : [a.fields, a.rules, a.src]
      calls : [span_or, badarity_span_ast, badarity_span_vfields]
    termination:
      bound : 4000


-- R6a: badarity_span_arms — the span of the first arity-mismatched call across a
-- match's arm bodies. Span mirror of count_badarity_arms (binders don't affect
-- arity scope).
concept BadAritySpanArmsState
  @intention: "A match arm list + the program rule list (callee scope) + the source text, for locating its first arity-mismatched call"
  @source: vexprparse.intent:46
  fields:
    arms : ArmList
    rules : RuleList
    src : text [..256]


rule badarity_span_arms
  @intention: "The span of the first arity-mismatched call across a match's arm bodies (sentinel if clean)"
  @source: vexprparse.intent:46
  input:
    a : BadAritySpanArmsState
  output:
    out : Span
  logic:
    out = match a.arms:
      ArmCons(vstart, vlen, binders, body, rest) => span_or(SpanOrState { a: badarity_span_ast(BadAritySpanState { node: body, rules: a.rules, src: a.src }), b: badarity_span_arms(BadAritySpanArmsState { arms: rest, rules: a.rules, src: a.src }) })
      ArmNil => Span::MkSpan { start: 9999, len: 0 }
  proofs:
    purity:
      reads : [a.arms, a.rules, a.src]
      calls : [span_or, badarity_span_ast, badarity_span_arms]
    termination:
      bound : 4000


-- badarity_span_binds: for each binding in the list, locate the first arity-
-- mismatched call in its RHS `value` (against the FULL program rule list), then
-- recurse on `rest`. The current binding's RHS is checked BEFORE the tail (source
-- order), via span_or. Mirrors count_badarity_binds; no prefix (arity scope is
-- program-wide). Recurses over the binding tail (a field of the input), so bound +
-- breadcrumb.
rule badarity_span_binds
  @intention: "The span of the first arity-mismatched call across every binding's RHS (sentinel if clean)"
  @source: vexprparse.intent:46
  input:
    a : BadAritySpanBindsState
  output:
    out : Span
  logic:
    out = match a.binds:
      BCons(name_start, name_len, value, rest) => span_or(SpanOrState { a: badarity_span_ast(BadAritySpanState { node: value, rules: a.rules, src: a.src }), b: badarity_span_binds(BadAritySpanBindsState { binds: rest, rules: a.rules, src: a.src }) })
      BNil => Span::MkSpan { start: 9999, len: 0 }
  proofs:
    purity:
      reads : [a.binds, a.rules, a.src]
      calls : [span_or, badarity_span_ast, badarity_span_binds]
    termination:
      bound : 4000


-- badarity_span_rule: the span of the first arity-mismatched call in ONE rule.
-- Mirrors badarity_rule (the count), and like badcall_span_rule it is SIMPLER than
-- the var-span family because arity scope is program-wide — there is no param scope
-- and no binding prefix to thread. Split the body Block into its binding list and
-- result, then:
--   * badarity_span_binds over the bindings (every let RHS's calls), THEN
--   * badarity_span_ast over the result expression's calls.
-- span_or keeps the in_binds span if there is one (the let RHSs precede the result
-- in source order). Both halves resolve callees against the SAME full program
-- RuleList `a.rules`. Bound-only termination.
--
-- Worked examples (offsets into the source text, 0-based bytes):
--   `rule f(a)\n  logic:\n    out = 1\nrule main\n  logic:\n    out = f(1, 2)`
--                                                  -> for rule main: MkSpan(<offset of f>, 1)
--                                                     (f exists with 1 param, the call gives 2)
--   `rule foobar(a)\n  ...\n    out = foobar(1, 2)` -> MkSpan(<offset of foobar>, 6)
--   a rule whose every call's arity is right (incl. self / forward refs) -> MkSpan(9999, 0).
rule badarity_span_rule
  @intention: "The span of the first arity-mismatched call in one rule (callees resolved program-wide; sentinel if clean)"
  @source: vexprparse.intent:46
  input:
    a : BadAritySpanRuleState
  output:
    out : Span
  logic:
    let body = rd_body(a.rd)
    let binds = block_binds(body)
    let result = block_result(body)
    out = span_or(SpanOrState { a: badarity_span_binds(BadAritySpanBindsState { binds: binds, rules: a.rules, src: a.src }), b: badarity_span_ast(BadAritySpanState { node: result, rules: a.rules, src: a.src }) })
  proofs:
    purity:
      reads : [a.rd, a.rules, a.src]
      calls : [rd_body, block_binds, block_result, badarity_span_binds, span_or, badarity_span_ast]
    termination:
      bound : 4000


-- ----------------------------------------------------------------------------
-- BRICK 25 DRIVERS. All three tokenize + parse the source ONCE (same front end as
-- lint_program), run undef_span_list over the parsed program, and expose ONE
-- observable of the resulting Span to argv. NATIVE-ONLY (multi-line source). Take a
-- ScanState (source + pos): source is argv arg 1, pos is argv arg 2 (always 0).
--
-- The sentinel: a clean program yields MkSpan(9999, 0). Reading span_start gives
-- 9999 and span_len gives 0 — both are stable "nothing here" values. undef_span_char
-- does byte_at(source, 9999): the native byte_at is FAIL-CLOSED on an out-of-bounds
-- index (jae .abort -> sys_exit(1)), so on a clean program undef_span_char ABORTS
-- with exit status 1 and no stdout rather than printing a value. That is the correct
-- posture for a char accessor: there is no first byte of a name that does not exist,
-- so the only honest answers are "the byte" (a real undefined variable) or "abort"
-- (no undefined variable to point at). Use span_start == 9999 (undef_span_start_of)
-- to test cleanliness; undef_span_char is meaningful ONLY when there IS a diagnostic.
--
-- The char observable: undef_span_char returns byte_at(source, start), i.e. the
-- FIRST byte of the offending name. Worked examples:
--   clean       "rule add(x : number, y : number)\n  logic:\n    out = x + y\nrule main\n  logic:\n    out = add(1, 2)" -> start 9999, len 0, char ABORTS (exit 1, no first byte)
--   undef x     "rule f\n  logic:\n    out = x + y"                  -> char 120 ('x'), len 1 (lhs of +, leftmost)
--   undef y     "rule f\n  logic:\n    out = 1 + y"                  -> char 121 ('y'), len 1 (1 is a leaf, y is the first var)
--   multi-char  "rule f\n  logic:\n    out = foo + 1"               -> char 102 ('f'), len 3 (name "foo")
--   use-bef-def "rule f\n  logic:\n    let p = q + 1\n    let q = 2\n    out = p" -> char 113 ('q'), len 1
--               (q is unbound in p's RHS; binding RHSs are checked before the result)
--   across      "rule a\n  logic:\n    out = 1\nrule b\n  logic:\n    out = zzz"  -> char 122 ('z'), len 3 (rule 1's zzz; rule 0 clean)
--   in arg      "rule main\n  logic:\n    out = f(w)\nrule f(x : number)\n  logic:\n    out = x" -> char 119 ('w'), len 1
--               (w undefined in main; f's param x is in scope only inside f)
-- ----------------------------------------------------------------------------

-- undef_span_start_of: the byte offset of the program's first undefined variable
-- (9999 if clean). Front end + undef_span_list identical to the other two drivers;
-- span_start reads the field off the resulting Span.
rule undef_span_start_of
  @intention: "Tokenize, parse, find the first undefined variable, and return its start byte offset (9999 if clean)"
  @source: vexprparse.intent:43
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    out = span_start(undef_span_list(UndefSpanListState { rl: prog, src: s.source }))
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, span_start, undef_span_list]
    termination:
      bound : 256


-- undef_span_len_of: the byte length of the program's first undefined variable's
-- name (0 if clean). Same front end and undef_span_list as undef_span_start_of;
-- span_len reads the length field.
rule undef_span_len_of
  @intention: "Tokenize, parse, find the first undefined variable, and return its name byte length (0 if clean)"
  @source: vexprparse.intent:43
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    out = span_len(undef_span_list(UndefSpanListState { rl: prog, src: s.source }))
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, span_len, undef_span_list]
    termination:
      bound : 256


-- undef_span_char: the FIRST byte of the offending name — byte_at(source, start).
-- This is the stable, source-independent observable: it does not depend on the byte
-- offset of the name (which shifts with whitespace), only on the name's first
-- character. On the sentinel start 9999, byte_at is out of bounds and the native
-- byte_at ABORTS (sys_exit(1)) rather than returning a value — so this driver is
-- meaningful only when there IS an undefined variable; test cleanliness via
-- undef_span_start_of. Same front end and undef_span_list as the other two drivers.
rule undef_span_char
  @intention: "Tokenize, parse, find the first undefined variable, and return its name's first byte (aborts if clean)"
  @source: vexprparse.intent:43
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    out = byte_at(s.source, span_start(undef_span_list(UndefSpanListState { rl: prog, src: s.source })))
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, span_start, undef_span_list]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 34 — THE PRETTY-PRINTER (the FIRST EMITTER over the real vexpr AST).
--
-- Every brick so far CONSUMED the AST (eval, shape, lint, type check); this one
-- EMITS it back as source text. print_expr walks an Ast and reconstructs a
-- fully-parenthesized rendering — parens are emitted around EVERY AstBin /
-- AstNeg / AstNot / AstIf node, so the parse's precedence and associativity
-- decisions become VISIBLE bytes ("1 + 2 * 3" prints as "(1 + (2 * 3))",
-- "10 - 2 - 3" as "((10 - 2) - 3)"). No precedence-aware minimal-paren logic
-- in v1: the printer's job is to make structure explicit, not pretty-minimal.
--
-- This is the first consumer of the native STREAMING text lowering (the
-- emitter slice, 2026-06-10): print_expr's body is the exact shape that slice
-- exists for — concat(print_expr(lhs), ..., print_expr(rhs)) inside a
-- MatchVariant arm. Natively, NO string is ever materialized: each leaf's
-- bytes are written to stdout in order during the tree walk. The interpreter
-- materializes the same bytes; both agree.
--
-- Span-printing: AstVar / AstField / AstCall names and AstStr literals live as
-- (start, len) SPANS into the original source, so the printer carries the
-- source text alongside the node — PrintState{node, src} — and prints a name
-- via substring(src, start, start + len), an allocation-free pointer slice.
-- AstStr spans INCLUDE both quotes (the Str token records start = opening
-- quote, len = total bytes including both quotes — see the Token declaration),
-- so substring reproduces the literal's source bytes verbatim, quotes and all.
--
-- Operator spelling is factored into op_text (a flat if/else over the AST
-- op-code map at the top of this file) rather than inlined 13 ways in the
-- AstBin arm: a non-recursive text helper called in a tail concat position is
-- legal under the streaming v1 grammar (it joins the callable set as a text
-- member; its bytes stream in order like any other concat arg).
--
-- Argument lists print without extra parens (only Bin/Neg/Not/If parenthesize):
-- f(1, x) round-trips as "f(1, x)". The comma logic needs no lookahead:
-- print_args prints the first argument bare, print_args_rest prefixes every
-- later one with ", "; ArgNil contributes the empty text.
--
-- Termination: print_expr / print_args / print_args_rest walk a strict
-- sub-node at every recursive call, but the node is a FIELD of the packed
-- input (PrintState / PrintArgsState), not the input itself, so the
-- `structural` proof does not fit — bound-only termination + the accepted
-- native recursion breadcrumb, same posture as eval_ast_env (see the
-- TERMINATION section at the top).
--
-- Round-trip property (validated externally, two binary invocations, since
-- the streamed text never exists in memory): for every expression source s,
--   eval_expr(print_source(s)) == eval_expr(s)   (value round-trip)
--   shape(print_source(s))     == shape(s)       (structure round-trip)
-- ============================================================================

concept PrintState
  @intention: "An AST node to print plus the source text its spans index into"
  @source: vexprparse.intent:52
  fields:
    node : Ast
    src : text [..256]


concept PrintArgsState
  @intention: "A call-argument list to print plus the source text its spans index into"
  @source: vexprparse.intent:52
  fields:
    args : ArgList
    src : text [..256]


concept OpSpell
  @intention: "An AST binary-operator code, to be spelled as surface text"
  @source: vexprparse.intent:52
  fields:
    op : number [0, 64]


-- op_text: spell an AST op-code as its surface text, padded with one space on
-- each side (the file's op-code map: arithmetic 13..17, comparison
-- 1/4/5/6/19/20, logical 30/31). Flat if/else over the 13 codes — the same
-- dispatch idiom as eval_ast's AstBin arm, but each leaf is a text literal
-- instead of an arithmetic expression. Unknown code spells "?" (AstErr-style),
-- unreachable for parser-built nodes.
rule op_text
  @intention: "Spell an AST binary-operator code as its space-padded surface text"
  @source: vexprparse.intent:52
  input:
    o : OpSpell
  output:
    out : text
  logic:
    out = if o.op == 13 then " + " else if o.op == 14 then " - " else if o.op == 15 then " * " else if o.op == 16 then " / " else if o.op == 17 then " % " else if o.op == 1 then " == " else if o.op == 6 then " != " else if o.op == 19 then " < " else if o.op == 20 then " > " else if o.op == 5 then " <= " else if o.op == 4 then " >= " else if o.op == 30 then " and " else if o.op == 31 then " or " else "?"
  proofs:
    purity:
      reads : [o.op]
      calls : []
    termination:
      bound : 64


-- print_expr: the emitter. One arm per Ast variant; recursive arms re-wrap the
-- sub-node in a fresh PrintState threading the SAME src down (the eval_ast_env
-- pattern). Number leaves itoa via concat(value); bool leaves spell true/false;
-- span-carrying leaves slice the source; structural nodes parenthesize.
rule print_expr
  @intention: "Reconstruct an AST's source text, fully parenthesized, by recursing on the tree"
  @source: vexprparse.intent:52
  input:
    ps : PrintState
  output:
    out : text
  logic:
    out = match ps.node:
      AstNum(value) => concat(value)
      AstBool(value) => if value == 1 then "true" else "false"
      AstVar(start, len) => substring(ps.src, start, start + len)
      AstStr(start, len) => substring(ps.src, start, start + len)
      AstBytes(start, len) => substring(ps.src, start, start + len)
      AstBin(op, lhs, rhs) => concat("(", print_expr(PrintState { node: lhs, src: ps.src }), op_text(OpSpell { op: op }), print_expr(PrintState { node: rhs, src: ps.src }), ")")
      AstNeg(inner) => concat("(-", print_expr(PrintState { node: inner, src: ps.src }), ")")
      AstNot(inner) => concat("(not ", print_expr(PrintState { node: inner, src: ps.src }), ")")
      AstField(base, fstart, flen) => concat(print_expr(PrintState { node: base, src: ps.src }), ".", substring(ps.src, fstart, fstart + flen))
      AstCall(callee_start, callee_len, args) => concat(substring(ps.src, callee_start, callee_start + callee_len), "(", print_args(PrintArgsState { args: args, src: ps.src }), ")")
      AstIf(cond, thn, els) => concat("(if ", print_expr(PrintState { node: cond, src: ps.src }), " then ", print_expr(PrintState { node: thn, src: ps.src }), " else ", print_expr(PrintState { node: els, src: ps.src }), ")")
      AstErr => "?"
      -- R3 stub: real handling in R6/R7. "?" placeholder (mirror AstErr).
      AstVariant(cstart, clen, vstart, vlen, fields) => "?"
      AstMatch(scrut, arms) => "?"
  proofs:
    purity:
      reads : [ps.node, ps.src]
      calls : [print_expr, print_args, op_text]
    termination:
      bound : 4000


-- print_args: comma-separated argument list, no surrounding parens (the
-- AstCall arm supplies those). First argument prints bare; the rest go
-- through print_args_rest which prefixes each with ", ". ArgNil is the
-- empty text — f() prints as "f()".
rule print_args
  @intention: "Print a call-argument list, comma-separated, first argument bare"
  @source: vexprparse.intent:52
  input:
    pa : PrintArgsState
  output:
    out : text
  logic:
    out = match pa.args:
      ArgCons(head, tail) => concat(print_expr(PrintState { node: head, src: pa.src }), print_args_rest(PrintArgsState { args: tail, src: pa.src }))
      ArgNil => ""
  proofs:
    purity:
      reads : [pa.args, pa.src]
      calls : [print_expr, print_args_rest]
    termination:
      bound : 4000


rule print_args_rest
  @intention: "Print the remaining call arguments, each prefixed with a comma-space"
  @source: vexprparse.intent:52
  input:
    pa : PrintArgsState
  output:
    out : text
  logic:
    out = match pa.args:
      ArgCons(head, tail) => concat(", ", print_expr(PrintState { node: head, src: pa.src }), print_args_rest(PrintArgsState { args: tail, src: pa.src }))
      ArgNil => ""
  proofs:
    purity:
      reads : [pa.args, pa.src]
      calls : [print_expr, print_args_rest]
    termination:
      bound : 4000


-- print_source: the brick-34 driver. Same front end as eval_expr / shape
-- (tokenize, NOT begin_tokenize — an expression is single-line, and sharing
-- the flat tokenizer makes the round-trip checks compare like with like),
-- then hand the root node + the source to the printer. The lets build
-- group/number values only; the single text-producing call sits in the body
-- tail, as the streaming v1 grammar requires.
rule print_source
  @intention: "Tokenize, parse with precedence, and print the AST back as fully-parenthesized source"
  @source: vexprparse.intent:52
  input:
    s : ScanState
  output:
    out : text
  logic:
    let toks = tokenize(ScanState { source: s.source, pos: 0 })
    let parsed = parse_or(ParseState { cell: toks })
    let root = parsed_node(parsed)
    out = print_expr(PrintState { node: root, src: s.source })
  proofs:
    purity:
      reads : [s.source]
      calls : [tokenize, parse_or, parsed_node, print_expr]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 36 — THE FIRST REAL LOWERING (pretty-printer -> code generator). Bricks
-- 34/35 printed the AST back as SOURCE. This brick emits a DIFFERENT target: a
-- stack-machine intermediate language in postfix / RPN form. `1 + 2 * 3` lowers
-- to `1 2 3 * +` — the canonical first IR of a compiler backend: post-order
-- traversal (operands before their operator, the opposite of in-order source),
-- and a form that REQUIRES a stack to evaluate. The streaming lowering carries
-- it exactly as it carried the pretty-printer (post-order concat of self-calls),
-- so this is "the same machine, a new target". Verified end-to-end externally:
-- a stack/RPN evaluator over lower_expr_src(e) yields the SAME number as
-- eval_expr(e) (see the streaming_lower_rpn test). The round-trip-verified
-- subset is the integer-closed grammar: AstNum, AstBool, AstBin (arithmetic /
-- comparison / logical), AstNeg, AstNot, AstIf (lowered to a 3-operand `select`
-- — eager, pushes cond/thn/els). AstVar emits a best-effort `load <name>` token
-- and AstCall/AstField/AstStr emit `?` — valid IL tokens but outside the pure-
-- number RPN evaluator's domain, so the verified inputs avoid them.
-- ============================================================================

-- op_instr: the RPN operator token for an AST binary-operator code — the bare
-- mnemonic plus a trailing space (postfix, no leading space, unlike op_text's
-- infix padding). Arithmetic + - * / %, comparison == != < > <= >=, logical
-- and / or. Unknown code => "? " (unreachable for parser-built nodes).
rule op_instr
  @intention: "Emit the postfix stack-machine mnemonic for an AST binary-operator code"
  @source: vexprparse.intent:54
  input:
    o : OpSpell
  output:
    out : text
  logic:
    out = if o.op == 13 then "+ " else if o.op == 14 then "- " else if o.op == 15 then "* " else if o.op == 16 then "/ " else if o.op == 17 then "% " else if o.op == 1 then "== " else if o.op == 6 then "!= " else if o.op == 19 then "< " else if o.op == 20 then "> " else if o.op == 5 then "<= " else if o.op == 4 then ">= " else if o.op == 30 then "and " else if o.op == 31 then "or " else "? "
  proofs:
    purity:
      reads : [o.op]
      calls : []
    termination:
      bound : 64


-- lower_expr: the code generator. Same shape as print_expr (it reuses PrintState
-- = node + src), but emits POSTFIX stack code instead of parenthesized source.
-- The key difference is ORDER: a binary node emits both operands FIRST, then the
-- operator mnemonic (post-order), so the result is a valid RPN stream a stack
-- machine runs left to right. Number/bool leaves push their literal; AstNeg/AstNot
-- are unary postfix ops; AstIf becomes a 3-operand `select` (cond, thn, els all
-- pushed, then select picks). AstVar lowers to a named `load`; the remaining
-- variants emit `?` (outside the verified integer-closed subset — see the brick
-- header). Streamed by the native backend exactly like print_expr.
rule lower_expr
  @intention: "Lower an AST expression to a postfix stack-machine instruction stream (RPN)"
  @source: vexprparse.intent:54
  input:
    ps : PrintState
  output:
    out : text
  logic:
    out = match ps.node:
      AstNum(value) => concat(value, " ")
      AstBool(value) => concat(value, " ")
      AstBin(op, lhs, rhs) => concat(lower_expr(PrintState { node: lhs, src: ps.src }), lower_expr(PrintState { node: rhs, src: ps.src }), op_instr(OpSpell { op: op }))
      AstNeg(inner) => concat(lower_expr(PrintState { node: inner, src: ps.src }), "neg ")
      AstNot(inner) => concat(lower_expr(PrintState { node: inner, src: ps.src }), "not ")
      AstIf(cond, thn, els) => concat(lower_expr(PrintState { node: cond, src: ps.src }), "if ", lower_expr(PrintState { node: thn, src: ps.src }), "else ", lower_expr(PrintState { node: els, src: ps.src }), "endif ")
      AstVar(start, len) => concat("load ", substring(ps.src, start, start + len), " ")
      AstField(base, fstart, flen) => "? "
      AstCall(callee_start, callee_len, args) => concat(lower_args(PrintArgsState { args: args, src: ps.src }), "call ", substring(ps.src, callee_start, callee_start + callee_len), " ")
      AstStr(start, len) => "? "
      AstBytes(start, len) => "? "
      AstErr => "? "
      -- R3 stub: real handling in R6/R7. "? " placeholder instruction (mirror AstErr).
      AstVariant(cstart, clen, vstart, vlen, fields) => "? "
      AstMatch(scrut, arms) => "? "
  proofs:
    purity:
      reads : [ps.node, ps.src]
      calls : [lower_expr, op_instr, lower_args]
    termination:
      bound : 4000


-- lower_args: stream a call's argument list as IL, in left-to-right order — each
-- argument lowers to ops that leave its value on the stack; the caller then emits
-- `call NAME argc`. No separators (unlike print_args' commas): the stack carries
-- the boundary. ArgNil contributes nothing.
rule lower_args
  @intention: "Lower a call-argument list to IL ops, left to right, one value per arg on the stack"
  @source: vexprparse.intent:54
  input:
    pa : PrintArgsState
  output:
    out : text
  logic:
    out = match pa.args:
      ArgCons(head, tail) => concat(lower_expr(PrintState { node: head, src: pa.src }), lower_args(PrintArgsState { args: tail, src: pa.src }))
      ArgNil => ""
  proofs:
    purity:
      reads : [pa.args, pa.src]
      calls : [lower_expr, lower_args]
    termination:
      bound : 4000


-- lower_expr_src: the brick-36 money-shot driver. Tokenize, parse with precedence,
-- and emit the postfix stack-machine stream for the whole expression. The first
-- Verbose program that compiles an expression to a target OTHER than its source.
--
--   lower_expr_src("1 + 2 * 3")  = "1 2 3 * + "    (push 1, push 2, push 3, mul, add -> 7)
--   lower_expr_src("10 - 2 - 3") = "10 2 - 3 - "   (left-assoc: ((10-2)-3) -> 5)
--
-- NATIVE-ONLY (streaming text). Verified end-to-end: an RPN evaluator over this
-- output yields eval_expr's number (the streaming_lower_rpn test).
rule lower_expr_src
  @intention: "Tokenize, parse, and lower an expression to a postfix stack-machine stream"
  @source: vexprparse.intent:54
  input:
    s : ScanState
  output:
    out : text
  logic:
    let toks = tokenize(ScanState { source: s.source, pos: 0 })
    let parsed = parse_or(ParseState { cell: toks })
    let root = parsed_node(parsed)
    out = lower_expr(PrintState { node: root, src: s.source })
  proofs:
    purity:
      reads : [s.source]
      calls : [tokenize, parse_or, parsed_node, lower_expr]
    termination:
      bound : 256


-- ============================================================================
-- BACKEND BRICK b3 — LOWER A CLOSED EXPRESSION TO REAL x86-64 MACHINE CODE.
-- ============================================================================
-- Brick 36 (lower_expr) lowered an expression to a TEXT RPN stream. b3 lowers
-- the SAME tree to BYTES — actual x86-64 instructions that a CPU executes. It
-- reuses PrintState (node + src) and the same post-order recursion, but each
-- arm emits b"..." opcodes (brick b1) composed with concat / le64 (brick b2)
-- instead of mnemonic text.
--
-- The emitted bytes are a function `fn() -> i64`. It evaluates the expression
-- onto the CPU's own stack (push/pop balanced), leaving the result in rax, and
-- `ret`s — no prologue, no rbp frame. The hardware stack IS the RPN stack.
--
-- Verified subset (branchless + fault-free): AstNum, AstBin with op in
-- {13 `+`, 14 `-`, 15 `*`}, and AstNeg. NO div/mod (idiv can fault), NO
-- comparisons/logic (need setcc), NO `if` (needs computed relative offsets —
-- hard in a streaming byte emitter), NO vars/calls. Those are b3-followups.
-- Any out-of-subset op (16/17/comparisons/logic) or AST variant emits a single
-- int3 trap byte (b"\xcc") so a miscompile faults loudly instead of silently
-- producing wrong bytes. The verified test never feeds an out-of-subset node.
--
-- Instruction selection:
--   AstNum(v)         => mov rax, <v:imm64> (48 B8 + le64 v) ; push rax (50)
--   AstBin(op,l,r)    => <code l> <code r> ; pop rcx (59) ; pop rax (58) ;
--                          op 13 +: add rax, rcx (48 01 C8) ; push rax (50)
--                          op 14 -: sub rax, rcx (48 29 C8) ; push rax
--                          op 15 *: imul rax, rcx (48 0F AF C1) ; push rax
--                          other  : int3 (CC) — trap
--   AstNeg(inner)     => <code inner> ; pop rax (58) ; neg rax (48 F7 D8) ;
--                          push rax (50)
-- pop rcx ; pop rax puts the RIGHT operand in rcx and the LEFT in rax — the
-- right was pushed last, so it is on top. add/sub/imul are non-commutative-safe
-- with this ordering (sub: rax-rcx = left-right, the source order).
--
-- The b1/b2 streaming-bytes path already provides everything: no src/ change.
-- Verified end-to-end externally (streaming_x86_expr_executes): the bytes are
-- mmap'd RWX, called as fn() -> i64, and the returned value == eval_expr(e).

-- x86_expr: the byte-emitting code generator. Same shape as lower_expr (reuses
-- PrintState), but post-order emits x86-64 bytes. The AstBin arm factors the
-- two operand sub-trees out front, then an if/else over the op picks the
-- per-op pop+arith+push byte literal (or the int3 trap for out-of-subset ops).
rule x86_expr
  @intention: "Lower a closed arithmetic AST (num, +/-/*, neg) to executable x86-64 machine code bytes"
  @source: vexprparse.intent:56
  input:
    ps : PrintState
  output:
    out : bytes
  logic:
    out = match ps.node:
      AstNum(value) => concat(b"\x48\xb8", le64(value), b"\x50")
      AstBin(op, lhs, rhs) => concat(x86_expr(PrintState { node: lhs, src: ps.src }), x86_expr(PrintState { node: rhs, src: ps.src }), if op == 13 then b"\x59\x58\x48\x01\xc8\x50" else if op == 14 then b"\x59\x58\x48\x29\xc8\x50" else if op == 15 then b"\x59\x58\x48\x0f\xaf\xc1\x50" else if op == 16 then b"\x59\x58\x48\x99\x48\xf7\xf9\x50" else if op == 17 then b"\x59\x58\x48\x99\x48\xf7\xf9\x48\x89\xd0\x50" else if op == 30 then b"\x59\x58\x48\x85\xc0\x0f\x95\xc0\x48\x85\xc9\x0f\x95\xc1\x20\xc8\x0f\xb6\xc0\x50" else if op == 31 then b"\x59\x58\x48\x85\xc0\x0f\x95\xc0\x48\x85\xc9\x0f\x95\xc1\x08\xc8\x0f\xb6\xc0\x50" else if op == 1 then b"\x59\x58\x48\x39\xc8\x0f\x94\xc0\x0f\xb6\xc0\x50" else if op == 6 then b"\x59\x58\x48\x39\xc8\x0f\x95\xc0\x0f\xb6\xc0\x50" else if op == 19 then b"\x59\x58\x48\x39\xc8\x0f\x9c\xc0\x0f\xb6\xc0\x50" else if op == 20 then b"\x59\x58\x48\x39\xc8\x0f\x9f\xc0\x0f\xb6\xc0\x50" else if op == 5 then b"\x59\x58\x48\x39\xc8\x0f\x9e\xc0\x0f\xb6\xc0\x50" else if op == 4 then b"\x59\x58\x48\x39\xc8\x0f\x9d\xc0\x0f\xb6\xc0\x50" else b"\xcc")
      AstNeg(inner) => concat(x86_expr(PrintState { node: inner, src: ps.src }), b"\x58\x48\xf7\xd8\x50")
      AstNot(inner) => b"\xcc"
      AstVar(start, len) => b"\xcc"
      AstField(base, fstart, flen) => b"\xcc"
      AstCall(callee_start, callee_len, args) => b"\xcc"
      AstStr(start, len) => b"\xcc"
      AstBytes(start, len) => b"\xcc"
      AstBool(value) => b"\xcc"
      AstIf(cond, thn, els) => concat(x86_expr(PrintState { node: cond, src: ps.src }), b"\x58\x48\x85\xc0\x0f\x84", le32(code_size_expr(PrintState { node: thn, src: ps.src }) + 5), x86_expr(PrintState { node: thn, src: ps.src }), b"\xe9", le32(code_size_expr(PrintState { node: els, src: ps.src })), x86_expr(PrintState { node: els, src: ps.src }))
      AstErr => b"\xcc"
      -- R3 stub: real handling in R6/R7. 0xCC (int3 trap) placeholder (mirror AstErr).
      AstVariant(cstart, clen, vstart, vlen, fields) => b"\xcc"
      AstMatch(scrut, arms) => b"\xcc"
  proofs:
    purity:
      reads : [ps.node, ps.src]
      calls : [x86_expr, code_size_expr]
    termination:
      bound : 4000


-- code_size_expr: the EXACT byte count x86_expr(ps) emits for this subtree,
-- computed structurally over the AST (it never calls x86_expr or le32 — pure
-- arithmetic). The `if` arm needs this ahead of time because a streaming
-- emitter writes left-to-right and cannot backpatch a jcc/jmp rel32: it must
-- KNOW the size of each branch to compute the forward jump distance. Every arm
-- below MUST equal the byte length of the corresponding x86_expr arm:
--   AstNum     => 11  (48 b8 + 8-byte imm + 50)
--   +/- op     => l + r + 6   (59 58 48 01/29 c8 50)
--   * op       => l + r + 7   (59 58 48 0f af c1 50)
--   cmp op     => l + r + 12  (59 58 48 39 c8 + setcc 3 + 0f b6 c0 50)
--   unknown op => l + r + 1   (the int3 trap byte b"\xcc")
--   AstNeg     => inner + 5   (58 48 f7 d8 50)
--   AstIf      => cond + 15 + thn + els  (pop 1 + test 3 + jz 6 + jmp 5)
--   out-of-subset leaves => 1  (the int3 trap byte b"\xcc")
-- A mismatch HERE means a wrong jump offset = crash/wrong result, caught by
-- the mmap+exec test (streaming_x86_if_cmp_executes).
rule code_size_expr
  @intention: "Exact byte count x86_expr emits for a subtree (for computing jcc/jmp rel32 offsets)"
  @source: vexprparse.intent:57
  input:
    ps : PrintState
  output:
    out : number
  logic:
    out = match ps.node:
      AstNum(value) => 11
      AstBin(op, lhs, rhs) => code_size_expr(PrintState { node: lhs, src: ps.src }) + code_size_expr(PrintState { node: rhs, src: ps.src }) + (if op == 13 then 6 else if op == 14 then 6 else if op == 15 then 7 else if op == 16 then 8 else if op == 17 then 11 else if op == 30 then 20 else if op == 31 then 20 else if op == 1 then 12 else if op == 6 then 12 else if op == 19 then 12 else if op == 20 then 12 else if op == 5 then 12 else if op == 4 then 12 else 1)
      AstNeg(inner) => code_size_expr(PrintState { node: inner, src: ps.src }) + 5
      AstNot(inner) => 1
      AstVar(start, len) => 1
      AstField(base, fstart, flen) => 1
      AstCall(callee_start, callee_len, args) => 1
      AstStr(start, len) => 1
      AstBytes(start, len) => 1
      AstBool(value) => 1
      AstIf(cond, thn, els) => code_size_expr(PrintState { node: cond, src: ps.src }) + 15 + code_size_expr(PrintState { node: thn, src: ps.src }) + code_size_expr(PrintState { node: els, src: ps.src })
      AstErr => 1
      -- R3 stub: real handling in R6/R7. 1 byte (matches the b"\xcc" trap stub above).
      AstVariant(cstart, clen, vstart, vlen, fields) => 1
      AstMatch(scrut, arms) => 1
  proofs:
    purity:
      reads : [ps.node, ps.src]
      calls : [code_size_expr]
    termination:
      bound : 4000


-- x86_expr_src: the b3 money-shot driver. Tokenize, parse with precedence, lower
-- the root AST to x86-64 bytes, then append `pop rax (58) ; ret (C3)` so the
-- function returns its top-of-stack value in rax. Mirrors lower_expr_src's
-- driver exactly, swapping lower_expr (text) for x86_expr (bytes).
--
--   x86_expr_src("1 + 2") =
--     48 b8 01 ..      mov rax,1 ; push
--     48 b8 02 ..      mov rax,2 ; push
--     59 58 48 01 c8 50  pop rcx ; pop rax ; add rax,rcx ; push
--     58 c3            pop rax ; ret   -> 3
rule x86_expr_src
  @intention: "Tokenize, parse, and lower a closed arithmetic expression to executable x86-64 machine code"
  @source: vexprparse.intent:56
  input:
    s : ScanState
  output:
    out : bytes
  logic:
    let toks = tokenize(ScanState { source: s.source, pos: 0 })
    let parsed = parse_or(ParseState { cell: toks })
    let root = parsed_node(parsed)
    out = concat(x86_expr(PrintState { node: root, src: s.source }), b"\x58\xc3")
  proofs:
    purity:
      reads : [s.source]
      calls : [tokenize, parse_or, parsed_node, x86_expr]
    termination:
      bound : 256


-- ============================================================================
-- BRICK b4b-1 — LOWER A WHOLE NON-RECURSIVE PROGRAM to ONE callable machine-code
-- blob. Brick b3/b4a lowered one closed EXPRESSION (no vars, no calls); this
-- brick lowers a multi-rule PROGRAM to real x86-64: every rule becomes a `proc`
-- with a real `push rbp ; mov rbp, rsp` frame, params loaded from the frame, and
-- real `call rel32` / `ret` between procs. The entry proc (the first rule, 0
-- params) is laid first at offset 0, so the blob mmap'd and called as
-- `fn() -> i64` runs main and returns its result in rax.
--
-- ABI (the contract the test mmap+execs):
--   * Caller at AstCall(callee, args): lower each arg in source order (each
--     leaves its value on the CPU stack), so after the args the top N slots hold
--     arg0 (deepest) .. arg(N-1) (top). Then:
--        call rel32      e8 + le32(rel)   -- rel = procOffset(callee) - (after-call)
--        add rsp, 8*N    48 81 c4 + le32  -- pop the args the caller pushed
--        push rax        50               -- result onto the caller's stack-machine
--   * Proc prologue:  push rbp ; mov rbp, rsp = 55 48 89 e5. After it,
--     [rbp+16] = arg(N-1) (last pushed), arg(N-1-k) at [rbp+16+8*k]. So param i
--     (declaration order, 0-indexed) lives at [rbp + 16 + 8*(N-1-i)].
--   * AstVar(start,len) = load param: push qword [rbp+disp] = ff b5 + le32(disp),
--     disp = 16 + 8*(N-1-i), i = the param index whose name span byte-matches.
--     A var not among the params -> int3 trap (no lets in this brick).
--   * Proc epilogue (body has left its result on the stack):
--        pop rax ; mov rsp, rbp ; pop rbp ; ret = 58 48 89 ec 5d c3.
--
-- Position threading: the ONLY thing needing an absolute offset is a call's
-- rel32. `off` = the absolute byte offset where the current subtree's code
-- begins. AstBin/AstNeg/AstIf thread off to children so a nested call inside a
-- branch reaches its own site; the jz/jmp inside `if` stay self-relative
-- (unchanged from b4a). AstCall computes rel32 = procOffset(callee) -
-- (off + code_size(args) + 5).
--
-- NON-RECURSIVE only (a proc calling itself or a cycle is b4b-2). Lets are a
-- later brick (a let-bearing body traps via the AstVar path — a let-bound name
-- is not a param). div/mod/logic stay out (same trap byte as b4a).
-- VERBOSE-ONLY: reuses the b1/b2 streaming-bytes path (bytes concat + le32/le64);
-- no src/ change. Verified end-to-end by streaming_x86_program_executes: the
-- blob is mmap'd RWX, called at offset 0 (the entry proc), and the returned i64
-- == eval_main(program) == the hand value.
-- ============================================================================

-- ByteGenState: the program-aware codegen state. `node` is the subtree to lower,
-- `src` the source text (for resolving var/callee name spans), `off` the absolute
-- byte offset where this subtree's code begins (only consumed to compute a call's
-- rel32), `params` the CURRENT proc's formal parameters (to map a var name to its
-- frame slot), `prog` the whole program (to resolve a callee name to its proc
-- offset).
concept ByteGenState
  @intention: "A subtree to lower to machine code + source + absolute offset + the current proc's params + lets + the program"
  @source: vexprparse.intent:56
  fields:
    node : Ast
    src : text [..256]
    off : number
    params : ParamList
    lets : Binding
    prog : RuleList
    concepts : ConceptList
    sizes : ProcSizeList


-- ByteGenArgs: the same codegen state but over a call's ARGUMENT list. Each arg
-- is lowered with x86_node in source order; `off` threads so arg(k) starts at the
-- offset just past arg(0)..arg(k-1)'s code (so a nested call inside an arg lands
-- its rel32 correctly).
concept ByteGenArgs
  @intention: "A call's argument list to lower + source + running offset + the current proc's params + lets + the program"
  @source: vexprparse.intent:56
  fields:
    args : ArgList
    src : text [..256]
    off : number
    params : ParamList
    lets : Binding
    prog : RuleList
    concepts : ConceptList
    sizes : ProcSizeList


-- ParamIndexState: a parameter list to scan for a name span, plus the source and
-- the query span (a var reference) and the index reached so far. Returns the
-- 0-based declaration-order index of the matching parameter, or -1 if the name is
-- not a parameter of the current proc.
concept ParamIndexState
  @intention: "A parameter list + source + a query name span + the index reached, to find a param's position"
  @source: vexprparse.intent:56
  fields:
    params : ParamList
    src : text [..256]
    q_start : number [0, 4000000]
    q_len : number [0, 4000000]
    idx : number


-- LetIndexState: a binding list to scan for a name span, plus the source and the
-- query span (a var reference) and the index reached so far. Returns the 0-based
-- source-order index of the matching let binding, or -1 if the name is not a let
-- of the current proc. Same shape as ParamIndexState but over a Binding cons-list.
concept LetIndexState
  @intention: "A binding list + source + a query name span + the index reached, to find a let's position"
  @source: vexprparse.intent:56
  fields:
    binds : Binding
    src : text [..256]
    q_start : number [0, 4000000]
    q_len : number [0, 4000000]
    idx : number


-- ProcOffState: the program to walk + a running byte offset + the callee name
-- span being resolved. proc_offset accumulates proc_size over the procs BEFORE
-- the named one; the entry proc is at 0.
concept ProcOffState
  @intention: "A rule list + running byte offset + a callee name span, to resolve a proc's blob offset"
  @source: vexprparse.intent:56
  fields:
    rules : RuleList
    src : text [..256]
    acc : number
    q_start : number [0, 4000000]
    q_len : number [0, 4000000]
    concepts : ConceptList
    sizes : ProcSizeList


-- ProcGenState: one rule to lower to a proc + its absolute blob offset + the
-- whole program (so the body's calls resolve other procs).
concept ProcGenState
  @intention: "A rule to lower to a proc + its blob offset + the program"
  @source: vexprparse.intent:56
  fields:
    rd : RuleDecl
    src : text [..256]
    off : number
    prog : RuleList
    concepts : ConceptList
    sizes : ProcSizeList


-- ProgGenState: the whole program to lower to a blob + the running blob offset of
-- the next proc + the program itself (callees resolve against it).
concept ProgGenState
  @intention: "A rule list to lower to a blob + the running blob offset + the program for callee resolution"
  @source: vexprparse.intent:56
  fields:
    rules : RuleList
    src : text [..256]
    off : number
    prog : RuleList
    concepts : ConceptList
    sizes : ProcSizeList


-- param_index: the 0-based declaration-order index of the parameter whose name
-- span byte-matches the query span, or -1 if none. The length check guards
-- name_eq (which assumes equal lengths), exactly like find_rule / env_lookup.
rule param_index
  @intention: "The 0-based index of the parameter matching a name span, or -1 if not a parameter"
  @source: vexprparse.intent:56
  input:
    pi : ParamIndexState
  output:
    out : number
  logic:
    out = match pi.params:
      PCons(name_start, name_len, ty, ty_start, ty_len, rest) => if name_len == pi.q_len and name_eq(NameEqState { src: pi.src, a_start: name_start, b_start: pi.q_start, len: pi.q_len, off: 0 }) == 1 then pi.idx else param_index(ParamIndexState { params: rest, src: pi.src, q_start: pi.q_start, q_len: pi.q_len, idx: pi.idx + 1 })
      PNil => 0 - 1
  proofs:
    purity:
      reads : [pi.params, pi.src, pi.q_start, pi.q_len, pi.idx]
      calls : [name_eq, param_index]
    termination:
      bound : 512


-- let_index: the 0-based source-order index of the let binding whose name span
-- byte-matches the query span, or -1 if none. The length check guards name_eq
-- (which assumes equal lengths), exactly like param_index / name_bound. A let at
-- index j lives in the frame slot [rbp - 8*(j+1)] (below rbp; the params are at
-- positive disp above rbp), so the codegen uses this index to compute the let's
-- negative displacement.
rule let_index
  @intention: "The 0-based index of the let binding matching a name span, or -1 if not a let"
  @source: vexprparse.intent:56
  input:
    li : LetIndexState
  output:
    out : number
  logic:
    out = match li.binds:
      BCons(name_start, name_len, value, rest) => if name_len == li.q_len and name_eq(NameEqState { src: li.src, a_start: name_start, b_start: li.q_start, len: li.q_len, off: 0 }) == 1 then li.idx else let_index(LetIndexState { binds: rest, src: li.src, q_start: li.q_start, q_len: li.q_len, idx: li.idx + 1 })
      BNil => 0 - 1
  proofs:
    purity:
      reads : [li.binds, li.src, li.q_start, li.q_len, li.idx]
      calls : [name_eq, let_index]
    termination:
      bound : 512


-- let_rhs (records-arc slice 3): the RHS VALUE Ast of the let binding whose name
-- span byte-matches the query span, or the sentinel Ast::AstErr if the name is not
-- a let of the current proc. Exact mirror of let_index (same BCons walk, same
-- name_eq guard), but returns the binding's `value` Ast instead of its index. The
-- codegen uses this to resolve a let-bound record's CONCEPT at COMPILE time: for
-- `let s = Foo { ... }` the binding's value is AstVariant(Foo, ...), so AstField
-- reads the concept from the RHS without any runtime tag.
rule let_rhs
  @intention: "The RHS value Ast of the let binding matching a name span, or AstErr if not a let of the proc"
  @source: vexprparse.intent:56
  input:
    li : LetIndexState
  output:
    out : Ast
  logic:
    out = match li.binds:
      BCons(name_start, name_len, value, rest) => if name_len == li.q_len and name_eq(NameEqState { src: li.src, a_start: name_start, b_start: li.q_start, len: li.q_len, off: 0 }) == 1 then value else let_rhs(LetIndexState { binds: rest, src: li.src, q_start: li.q_start, q_len: li.q_len, idx: li.idx + 1 })
      BNil => Ast::AstErr
  proofs:
    purity:
      reads : [li.binds, li.src, li.q_start, li.q_len, li.idx]
      calls : [name_eq, let_rhs]
    termination:
      bound : 512


-- ast_is_variant / ast_variant_cstart / ast_variant_clen (records-arc slice 3):
-- shallow readers of an AstVariant node (a `Concept::Variant { ... }` / record
-- construction). Used by static_concept_of's let branch on the RESULT of let_rhs
-- (slice 4 — the readers date from slice 3, whose AstField gate they served
-- directly): if the let's RHS is a construction, its concept-name span (cstart,
-- clen) resolves the concept at compile time (find_concept_index), so the field's
-- payload slot is known statically. A non-AstVariant RHS yields 0 / not-a-variant,
-- so the resolver returns -1 and the codegen keeps the int3 fallback. (Slice 3's
-- ast_is_var / ast_var_start / ast_var_len readers were deleted in slice 4: the
-- resolver's AstVar match arm binds the span directly.)
rule ast_is_variant
  @intention: "1 if the AST node is an AstVariant (a record/variant construction), 0 otherwise"
  @source: vexprparse.intent:56
  input:
    n : Ast
  output:
    out : number
  logic:
    out = match n:
      AstNum(value) => 0
      AstBin(op, lhs, rhs) => 0
      AstNeg(inner) => 0
      AstNot(inner) => 0
      AstVar(start, len) => 0
      AstField(base, fstart, flen) => 0
      AstCall(callee_start, callee_len, args) => 0
      AstStr(start, len) => 0
      AstBytes(start, len) => 0
      AstBool(value) => 0
      AstIf(cond, thn, els) => 0
      AstErr => 0
      AstVariant(cstart, clen, vstart, vlen, fields) => 1
      AstMatch(scrut, arms) => 0
  proofs:
    purity:
      reads : [n]
      calls : []
    termination:
      bound : 16


rule ast_variant_cstart
  @intention: "The concept-name start-byte of an AstVariant node, or 0 if the node is not an AstVariant"
  @source: vexprparse.intent:56
  input:
    n : Ast
  output:
    out : number
  logic:
    out = match n:
      AstNum(value) => 0
      AstBin(op, lhs, rhs) => 0
      AstNeg(inner) => 0
      AstNot(inner) => 0
      AstVar(start, len) => 0
      AstField(base, fstart, flen) => 0
      AstCall(callee_start, callee_len, args) => 0
      AstStr(start, len) => 0
      AstBytes(start, len) => 0
      AstBool(value) => 0
      AstIf(cond, thn, els) => 0
      AstErr => 0
      AstVariant(cstart, clen, vstart, vlen, fields) => cstart
      AstMatch(scrut, arms) => 0
  proofs:
    purity:
      reads : [n]
      calls : []
    termination:
      bound : 16


rule ast_variant_clen
  @intention: "The concept-name byte-length of an AstVariant node, or 0 if the node is not an AstVariant"
  @source: vexprparse.intent:56
  input:
    n : Ast
  output:
    out : number
  logic:
    out = match n:
      AstNum(value) => 0
      AstBin(op, lhs, rhs) => 0
      AstNeg(inner) => 0
      AstNot(inner) => 0
      AstVar(start, len) => 0
      AstField(base, fstart, flen) => 0
      AstCall(callee_start, callee_len, args) => 0
      AstStr(start, len) => 0
      AstBytes(start, len) => 0
      AstBool(value) => 0
      AstIf(cond, thn, els) => 0
      AstErr => 0
      AstVariant(cstart, clen, vstart, vlen, fields) => clen
      AstMatch(scrut, arms) => 0
  proofs:
    purity:
      reads : [n]
      calls : []
    termination:
      bound : 16


-- ============================================================================
-- Records-arc slice 4 — the UNIFIED STATIC CONCEPT RESOLVER. Slice 3 gated
-- AstField emission on one ad-hoc shape (base = AstVar whose LET RHS is an
-- AstVariant). The self-source's real shape is a rule reading its INPUT record
-- (`rule f(s : Foo)` ... `s.field`) and chained access (`o.inner.b`), so slice 4
-- replaces the gate with ONE recursive compile-time resolver: static_concept_of
-- maps a field-access base expression to its record concept's 0-based index
-- (or -1 when unresolvable).
--   * AstVar: a TYPED param resolves through its PCons declared-type span (an
--     UNTYPED param stays -1 — the compiler NEVER infers a param's concept from
--     call sites); not a param -> slice 3's let check (a let whose RHS is a
--     construction resolves via the RHS's concept-name span — that branch IS
--     slice 3's gate, so let-bound cases resolve identically).
--   * AstVariant: a construction resolves via its own concept-name span.
--   * AstField: recurse on the base; the accessed field's FCons declared-type
--     span (R6b) names the field's record concept — CHAINED access.
--   * anything else -> -1 (int3 in the emitter, the honest out-of-scope trap).
-- find_concept_index's not-found sentinel (999999) is translated to -1, so
-- `static_concept_of(base) >= 0` is THE resolvability test — x86_node and
-- code_size_node share the call VERBATIM (the two-pass drift edge).
-- ============================================================================

-- FieldTyConceptState: a field list to walk by field NAME + the source + the
-- query name span + the concept list the matched field's DECLARED-TYPE span is
-- resolved against. Same walk shape as FieldIdxState, plus `concepts`.
concept FieldTyConceptState
  @intention: "A field list + source + a query field-name span + the concept list, for resolving a field's declared-type concept"
  @source: vexprparse.intent:56
  fields:
    fields : FieldList
    src : text [..256]
    q_start : number [0, 4000000]
    q_len : number [0, 4000000]
    concepts : ConceptList


-- StaticConceptState: a field-access base expression + the source + the current
-- proc's params and lets + the concept list — everything static_concept_of needs
-- to resolve the base's record concept at COMPILE time. Mirror of ByteGenState
-- minus the emission-only fields (off, prog).
concept StaticConceptState
  @intention: "A base expression + source + the proc's params + lets + the concept list, for compile-time concept resolution"
  @source: vexprparse.intent:56
  fields:
    node : Ast
    src : text [..256]
    params : ParamList
    lets : Binding
    concepts : ConceptList


-- field_concept_of (records-arc slice 4): the minimal ty-span helper. Walk a
-- FieldList for the field whose NAME byte-matches the query span (the
-- field_index_of walk), but instead of the field's position return the concept
-- INDEX its DECLARED-TYPE span (FCons ty_start/ty_len, R6b) resolves to — or -1
-- when the field is missing OR its type is not a known concept (a scalar
-- number/bool/text field resolves to no concept; an untyped param's empty ty
-- span matches no concept name — both honest -1). Serves PARAMS too:
-- params_to_fields (R4) converts a ParamList one-for-one preserving the ty
-- spans, so this one walker covers `s : Foo` (param) and `inner : Foo` (field).
rule field_concept_of
  @intention: "The concept index a named field's declared-type span resolves to, or -1 (missing field / non-concept type)"
  @source: vexprparse.intent:56
  input:
    ftc : FieldTyConceptState
  output:
    out : number
  logic:
    out = match ftc.fields:
      FCons(name_start, name_len, ty, ty_start, ty_len, rest) => if name_len == ftc.q_len and name_eq(NameEqState { src: ftc.src, a_start: name_start, b_start: ftc.q_start, len: ftc.q_len, off: 0 }) == 1 then (if find_concept_index(FindConceptIdxState { concepts: ftc.concepts, src: ftc.src, q_start: ty_start, q_len: ty_len, idx: 0 }) == 999999 then 0 - 1 else find_concept_index(FindConceptIdxState { concepts: ftc.concepts, src: ftc.src, q_start: ty_start, q_len: ty_len, idx: 0 })) else field_concept_of(FieldTyConceptState { fields: rest, src: ftc.src, q_start: ftc.q_start, q_len: ftc.q_len, concepts: ftc.concepts })
      FNil => 0 - 1
  proofs:
    purity:
      reads : [ftc.fields, ftc.src, ftc.q_start, ftc.q_len, ftc.concepts]
      calls : [name_eq, find_concept_index, field_concept_of]
    termination:
      bound : 4000


-- static_concept_of (records-arc slice 4): resolve a field-access base
-- expression to its record concept's 0-based index at COMPILE time, or -1 when
-- the base is out of the compilable subset. The three resolving arms:
--   AstVar — param first (typed param -> its PCons ty span via the
--     params_to_fields + field_concept_of walk; untyped -> -1, never inferred),
--     else the let branch (RHS a construction -> its concept span, slice 3's
--     check verbatim).
--   AstVariant — field access directly on a construction: its own concept span.
--   AstField — CHAINED access: recurse on the base, then resolve the accessed
--     field's declared-type span within the base concept's FieldList.
-- Everything else is -1. Recursion is on a sub-part of the packed input's Ast
-- field, so bound-only termination + the native recursion breadcrumb, exactly
-- like the other packed-input walkers (code_size_node / let_rhs / ...).
rule static_concept_of
  @intention: "Resolve a field-access base expression to its record concept's 0-based index at compile time, or -1"
  @source: vexprparse.intent:56
  input:
    sc : StaticConceptState
  output:
    out : number
  logic:
    out = match sc.node:
      AstNum(value) => 0 - 1
      AstBin(op, lhs, rhs) => 0 - 1
      AstNeg(inner) => 0 - 1
      AstNot(inner) => 0 - 1
      AstVar(start, len) => if param_index(ParamIndexState { params: sc.params, src: sc.src, q_start: start, q_len: len, idx: 0 }) >= 0 then field_concept_of(FieldTyConceptState { fields: params_to_fields(sc.params), src: sc.src, q_start: start, q_len: len, concepts: sc.concepts }) else (if ast_is_variant(let_rhs(LetIndexState { binds: sc.lets, src: sc.src, q_start: start, q_len: len, idx: 0 })) == 1 then (if find_concept_index(FindConceptIdxState { concepts: sc.concepts, src: sc.src, q_start: ast_variant_cstart(let_rhs(LetIndexState { binds: sc.lets, src: sc.src, q_start: start, q_len: len, idx: 0 })), q_len: ast_variant_clen(let_rhs(LetIndexState { binds: sc.lets, src: sc.src, q_start: start, q_len: len, idx: 0 })), idx: 0 }) == 999999 then 0 - 1 else find_concept_index(FindConceptIdxState { concepts: sc.concepts, src: sc.src, q_start: ast_variant_cstart(let_rhs(LetIndexState { binds: sc.lets, src: sc.src, q_start: start, q_len: len, idx: 0 })), q_len: ast_variant_clen(let_rhs(LetIndexState { binds: sc.lets, src: sc.src, q_start: start, q_len: len, idx: 0 })), idx: 0 })) else 0 - 1)
      AstField(base, fstart, flen) => if static_concept_of(StaticConceptState { node: base, src: sc.src, params: sc.params, lets: sc.lets, concepts: sc.concepts }) >= 0 then field_concept_of(FieldTyConceptState { fields: cd_fields(concept_at_index(ConceptAtState { concepts: sc.concepts, idx: static_concept_of(StaticConceptState { node: base, src: sc.src, params: sc.params, lets: sc.lets, concepts: sc.concepts }) })), src: sc.src, q_start: fstart, q_len: flen, concepts: sc.concepts }) else 0 - 1
      AstCall(callee_start, callee_len, args) => 0 - 1
      AstStr(start, len) => 0 - 1
      AstBytes(start, len) => 0 - 1
      AstBool(value) => 0 - 1
      AstIf(cond, thn, els) => 0 - 1
      AstErr => 0 - 1
      AstVariant(cstart, clen, vstart, vlen, fields) => if find_concept_index(FindConceptIdxState { concepts: sc.concepts, src: sc.src, q_start: cstart, q_len: clen, idx: 0 }) == 999999 then 0 - 1 else find_concept_index(FindConceptIdxState { concepts: sc.concepts, src: sc.src, q_start: cstart, q_len: clen, idx: 0 })
      AstMatch(scrut, arms) => 0 - 1
  proofs:
    purity:
      reads : [sc.node, sc.src, sc.params, sc.lets, sc.concepts]
      calls : [param_index, field_concept_of, params_to_fields, ast_is_variant, let_rhs, ast_variant_cstart, ast_variant_clen, find_concept_index, static_concept_of, cd_fields, concept_at_index]
    termination:
      bound : 8000


-- ============================================================================
-- BRICK R7a — ARENA SETUP + VariantConstruct machine-code emit. The stack machine
-- gains a heap: a variant VALUE is its arena INDEX (a Number flowing on the stack
-- unchanged). The arena is mmap'd once in the ELF _start trampoline (elf_program_src)
-- with base in r15 and node count in r14 (both callee-saved — the procs never touch
-- them, so they survive every call/ret). entry_size = 8*(max_payload_fields+1): an
-- 8-byte (padded) tag slot + one 8-byte slot per payload field, uniform per node.
-- tag = variant_tag (concept_index*256 + variant_index, self-computed from the
-- ConceptList threaded through the codegen state's `concepts` field). MATCH dispatch
-- is R7b (AstMatch still traps).
-- ============================================================================

-- ByteGenVFields: a variant construction's field-init list to lower — same fields as
-- ByteGenState but over a VFieldList. x86_vfields walks it in source order, emitting
-- each field value's push and threading `off` so a nested call inside a field lands
-- its rel32 correctly (mirror of ByteGenArgs / x86_args).
concept ByteGenVFields
  @intention: "A variant construction's field-init list to lower + source + offset + params + lets + program + concepts"
  @source: vexprparse.intent:64
  fields:
    fields : VFieldList
    src : text [..256]
    off : number
    params : ParamList
    lets : Binding
    prog : RuleList
    concepts : ConceptList
    sizes : ProcSizeList


-- VPopState: the remaining variant fields to pop off the CPU stack + the payload slot
-- the next pop stores into (counting DOWN from n-1). The first pop takes the top of
-- stack (field[n-1]) into slot n-1, so field j lands in slot j.
concept VPopState
  @intention: "The remaining variant fields to pop + the payload slot the next pop stores into"
  @source: vexprparse.intent:64
  fields:
    rem : VFieldList
    slot : number


-- vfield_len: the number of fields in a variant construction's VFieldList (cons-walk
-- like arg_list_len). The payload arity = the number of pop+store pairs the suffix emits.
rule vfield_len
  @intention: "Number of fields in a variant construction's field-init list"
  @source: vexprparse.intent:64
  input:
    fl : VFieldList
  output:
    out : number
  logic:
    out = match fl:
      VFCons(name_start, name_len, val, rest) => 1 + vfield_len(rest)
      VFNil => 0
  proofs:
    purity:
      reads : [fl]
      calls : [vfield_len]
    termination:
      bound : 512
      structural : fl


-- max_variant_fields: the maximum payload arity across a concept's VariantList (the
-- widest variant). Used to size the arena entry uniformly (every node is entry_size).
rule max_variant_fields
  @intention: "The maximum payload field count across a concept's variants"
  @source: vexprparse.intent:64
  input:
    vl : VariantList
  output:
    out : number
  logic:
    out = match vl:
      VarCons(name_start, name_len, payload, rest) => max(field_list_len(payload), max_variant_fields(rest))
      VarNil => 0
  proofs:
    purity:
      reads : [vl]
      calls : [field_list_len, max_variant_fields]
    termination:
      bound : 4000
      structural : vl


-- concept_arena_arity (records-arc slice 3): the arena payload arity of ONE concept
-- = the larger of its max variant payload arity (a sum-type) and its record field
-- count (a bare record). A sum-type has fields = FNil (arity 0 from the record side);
-- a record has variants = VarNil (arity 0 from the variant side); so the max is the
-- right per-concept arena width for either shape. Records construct into the SAME
-- node arena as variants (a record parses to AstVariant(Foo, Foo, fields)), so its
-- fields need payload slots too — this is why max_payload_fields must count them.
rule concept_arena_arity
  @intention: "The arena payload arity of one concept: max of its variant payload arity and its record field count"
  @source: vexprparse.intent:64
  input:
    c : Concept
  output:
    out : number
  logic:
    out = max(max_variant_fields(cd_variants(c)), field_list_len(cd_fields(c)))
  proofs:
    purity:
      reads : [c]
      calls : [max_variant_fields, cd_variants, field_list_len, cd_fields]
    termination:
      bound : 16


-- max_payload_fields: the maximum payload arity across EVERY concept in the program's
-- ConceptList (per concept: max of its variant arity and its record field count, via
-- concept_arena_arity). entry_size = 8 * (this + 1): one 8-byte (padded) tag slot plus
-- one 8-byte slot per payload field, uniform for all nodes (variant AND record).
rule max_payload_fields
  @intention: "The maximum payload field count across all concepts (variant payload arity or record field count)"
  @source: vexprparse.intent:64
  input:
    cl : ConceptList
  output:
    out : number
  logic:
    out = match cl:
      CCons(head, tail) => max(concept_arena_arity(head), max_payload_fields(tail))
      CNil => 0
  proofs:
    purity:
      reads : [cl]
      calls : [concept_arena_arity, max_payload_fields]
    termination:
      bound : 4000
      structural : cl


-- program_uses_arena: 1 iff any concept in the ConceptList needs the node arena —
-- either a sum-type (declares >0 variants) OR a bare record (declares >0 fields).
-- Both construct into the arena (a record `Foo { .. }` parses to AstVariant(Foo, Foo,
-- fields), which the R7a emit stores into r15+r14*entry_size just like a variant). The
-- ELF trampoline emits the mmap arena prologue only when this is 1, so a program with
-- NO concepts (a pure scalar rule) stays byte-identical (no mmap prologue). Renamed
-- from program_uses_variants in records-arc slice 3 (records need the arena too).
rule program_uses_arena
  @intention: "1 if the program declares any concept needing the arena (a variant OR a record), 0 otherwise"
  @source: vexprparse.intent:64
  input:
    cl : ConceptList
  output:
    out : number
  logic:
    out = match cl:
      CCons(head, tail) => if variant_list_len(cd_variants(head)) > 0 then 1 else if field_list_len(cd_fields(head)) > 0 then 1 else program_uses_arena(tail)
      CNil => 0
  proofs:
    purity:
      reads : [cl]
      calls : [variant_list_len, cd_variants, field_list_len, cd_fields, program_uses_arena]
    termination:
      bound : 4000
      structural : cl


-- ============================================================================
-- Text values arc slice 2 — program_uses_text: does the program need the
-- embedded source? 1 iff any AstStr literal appears anywhere in any rule body
-- (lets included), OR any AstCall whose callee spells byte_at / length /
-- substring (the three span primitives — dispatch shares span_is_* with eval
-- and x86_node VERBATIM). Mirror of program_uses_arena's role: the ELF appends
-- the interpreted source bytes at the file end ONLY when this is 1, so a
-- text-free program stays byte-identical. The walk reuses PrintState /
-- PrintArgsState ({node, src} / {args, src}); the vfields / arms / binds /
-- rules legs get their own thin {list, src} concepts below.
-- ============================================================================

concept UsesTextVFields
  @intention: "A variant construction's field list plus the source, for the uses-text walk"
  @source: vexprparse.intent:66
  fields:
    fields : VFieldList
    src : text [..256]


concept UsesTextArms
  @intention: "A match's arm list plus the source, for the uses-text walk"
  @source: vexprparse.intent:66
  fields:
    arms : ArmList
    src : text [..256]


concept UsesTextBinds
  @intention: "A rule's let-binding list plus the source, for the uses-text walk"
  @source: vexprparse.intent:66
  fields:
    binds : Binding
    src : text [..256]


concept UsesTextRules
  @intention: "The program's rule list plus the source, for the uses-text walk"
  @source: vexprparse.intent:66
  fields:
    rules : RuleList
    src : text [..256]


-- ast_uses_text: 1 iff the subtree contains an AstStr OR a call to one of the
-- three text primitives. The AstCall arm checks the callee span FIRST (the
-- same span_is_* calls eval and x86_node dispatch on), then recurses into the
-- arguments; every other structural arm just walks its children left-to-right
-- with early-out ifs. Leaves (num/var/bool/err) are 0.
rule ast_uses_text
  @intention: "1 if a subtree contains a string literal or a text-primitive call, 0 otherwise"
  @source: vexprparse.intent:66
  input:
    ps : PrintState
  output:
    out : number
  logic:
    out = match ps.node:
      AstNum(value) => 0
      AstBool(value) => 0
      AstVar(start, len) => 0
      AstErr => 0
      AstStr(start, len) => 1
      AstBytes(start, len) => 1
      AstBin(op, lhs, rhs) => if ast_uses_text(PrintState { node: lhs, src: ps.src }) == 1 then 1 else ast_uses_text(PrintState { node: rhs, src: ps.src })
      AstNeg(inner) => ast_uses_text(PrintState { node: inner, src: ps.src })
      AstNot(inner) => ast_uses_text(PrintState { node: inner, src: ps.src })
      AstField(base, fstart, flen) => ast_uses_text(PrintState { node: base, src: ps.src })
      AstCall(callee_start, callee_len, args) => if span_is_byte_at(SpanCheck { src: ps.src, start: callee_start, len: callee_len }) == 1 then 1 else if span_is_length(SpanCheck { src: ps.src, start: callee_start, len: callee_len }) == 1 then 1 else if span_is_substring(SpanCheck { src: ps.src, start: callee_start, len: callee_len }) == 1 then 1 else args_use_text(PrintArgsState { args: args, src: ps.src })
      AstIf(cond, thn, els) => if ast_uses_text(PrintState { node: cond, src: ps.src }) == 1 then 1 else if ast_uses_text(PrintState { node: thn, src: ps.src }) == 1 then 1 else ast_uses_text(PrintState { node: els, src: ps.src })
      AstVariant(cstart, clen, vstart, vlen, fields) => vfields_use_text(UsesTextVFields { fields: fields, src: ps.src })
      AstMatch(scrut, arms) => if ast_uses_text(PrintState { node: scrut, src: ps.src }) == 1 then 1 else arms_use_text(UsesTextArms { arms: arms, src: ps.src })
  proofs:
    purity:
      reads : [ps.node, ps.src]
      calls : [ast_uses_text, args_use_text, vfields_use_text, arms_use_text, span_is_byte_at, span_is_length, span_is_substring]
    termination:
      bound : 8000


-- args_use_text: the uses-text walk over a call's argument list. Early-out 1
-- on the first argument whose subtree uses text; ArgNil -> 0.
rule args_use_text
  @intention: "1 if any call argument's subtree uses text, 0 otherwise"
  @source: vexprparse.intent:66
  input:
    pa : PrintArgsState
  output:
    out : number
  logic:
    out = match pa.args:
      ArgCons(head, tail) => if ast_uses_text(PrintState { node: head, src: pa.src }) == 1 then 1 else args_use_text(PrintArgsState { args: tail, src: pa.src })
      ArgNil => 0
  proofs:
    purity:
      reads : [pa.args, pa.src]
      calls : [ast_uses_text, args_use_text]
    termination:
      bound : 8000


-- vfields_use_text: the uses-text walk over a variant construction's field
-- initializers. VFNil -> 0.
rule vfields_use_text
  @intention: "1 if any variant-construction field value's subtree uses text, 0 otherwise"
  @source: vexprparse.intent:66
  input:
    uv : UsesTextVFields
  output:
    out : number
  logic:
    out = match uv.fields:
      VFCons(name_start, name_len, val, rest) => if ast_uses_text(PrintState { node: val, src: uv.src }) == 1 then 1 else vfields_use_text(UsesTextVFields { fields: rest, src: uv.src })
      VFNil => 0
  proofs:
    purity:
      reads : [uv.fields, uv.src]
      calls : [ast_uses_text, vfields_use_text]
    termination:
      bound : 8000


-- arms_use_text: the uses-text walk over a match's arm bodies (binders are
-- name spans, never text values). ArmNil -> 0.
rule arms_use_text
  @intention: "1 if any match arm body's subtree uses text, 0 otherwise"
  @source: vexprparse.intent:66
  input:
    ua : UsesTextArms
  output:
    out : number
  logic:
    out = match ua.arms:
      ArmCons(vstart, vlen, binders, body, rest) => if ast_uses_text(PrintState { node: body, src: ua.src }) == 1 then 1 else arms_use_text(UsesTextArms { arms: rest, src: ua.src })
      ArmNil => 0
  proofs:
    purity:
      reads : [ua.arms, ua.src]
      calls : [ast_uses_text, arms_use_text]
    termination:
      bound : 8000


-- binds_use_text: the uses-text walk over a rule's let bindings (each RHS is
-- a full subtree). BNil -> 0.
rule binds_use_text
  @intention: "1 if any let binding's RHS subtree uses text, 0 otherwise"
  @source: vexprparse.intent:66
  input:
    ub : UsesTextBinds
  output:
    out : number
  logic:
    out = match ub.binds:
      BCons(name_start, name_len, value, rest) => if ast_uses_text(PrintState { node: value, src: ub.src }) == 1 then 1 else binds_use_text(UsesTextBinds { binds: rest, src: ub.src })
      BNil => 0
  proofs:
    purity:
      reads : [ub.binds, ub.src]
      calls : [ast_uses_text, binds_use_text]
    termination:
      bound : 8000


-- program_uses_text: the program-level uses-text gate. Walks every rule's
-- body — let bindings first, then the block result — early-outing on the
-- first hit. RNil -> 0.
rule program_uses_text
  @intention: "1 if any rule body in the program uses a string literal or a text primitive, 0 otherwise"
  @source: vexprparse.intent:66
  input:
    ur : UsesTextRules
  output:
    out : number
  logic:
    out = match ur.rules:
      RCons(head, tail) => if binds_use_text(UsesTextBinds { binds: block_binds(rd_body(head)), src: ur.src }) == 1 then 1 else if ast_uses_text(PrintState { node: block_result(rd_body(head)), src: ur.src }) == 1 then 1 else program_uses_text(UsesTextRules { rules: tail, src: ur.src })
      RNil => 0
  proofs:
    purity:
      reads : [ur.rules, ur.src]
      calls : [binds_use_text, ast_uses_text, program_uses_text, block_binds, rd_body, block_result]
    termination:
      bound : 8000


-- ============================================================================
-- STREAMING slice — mode decision (docs/self-hosting-streaming-design.md).
-- A rule STREAMS iff its block result is text-shaped: AstStr, a concat(...)
-- call, an if/match with a texty arm, or a call to a defined rule whose result
-- is DIRECTLY texty (ONE transitivity level — the callee's result is checked
-- with the SHALLOW walk, which never follows the callee's own calls; a deeper
-- chain degrades to the int3 refusal in x86_node's texty-callee guard, a clean
-- SIGTRAP, never garbage). Streamed procs write their bytes to fd 1 in order
-- during the walk; the ELF trampoline writes only the trailing newline.
-- ============================================================================

concept TextyState
  @intention: "An AST node + source + the program, for the transitive-depth-1 texty test"
  @source: vexprparse.intent:69
  fields:
    node : Ast
    src : text [..256]
    prog : RuleList


concept TextyArms
  @intention: "A match arm list + source + the program, for the texty walk over arm bodies"
  @source: vexprparse.intent:69
  fields:
    arms : ArmList
    src : text [..256]
    prog : RuleList


-- ast_texty_shallow: the DEPTH-0 texty test — no call following at all. AstStr
-- and concat(...) are texty; if/match arms recurse over the same shallow
-- grammar; every other shape (numbers, vars, fields, prims, defined-rule calls)
-- is 0. This is the check ast_is_texty applies to a CALLEE's result: exactly
-- one level of transitivity, verbosec's own streaming v1 bound.
rule ast_texty_shallow
  @intention: "1 if a subtree is text-shaped without following any call (AstStr / concat / if-match of those), 0 otherwise"
  @source: vexprparse.intent:69
  input:
    ps : PrintState
  output:
    out : number
  logic:
    out = match ps.node:
      AstNum(value) => 0
      AstBool(value) => 0
      AstVar(start, len) => 0
      AstErr => 0
      AstStr(start, len) => 1
      AstBytes(start, len) => 1
      AstBin(op, lhs, rhs) => 0
      AstNeg(inner) => 0
      AstNot(inner) => 0
      AstField(base, fstart, flen) => 0
      AstCall(callee_start, callee_len, args) => span_is_concat(SpanCheck { src: ps.src, start: callee_start, len: callee_len })
      AstIf(cond, thn, els) => if ast_texty_shallow(PrintState { node: thn, src: ps.src }) == 1 then 1 else ast_texty_shallow(PrintState { node: els, src: ps.src })
      AstVariant(cstart, clen, vstart, vlen, fields) => 0
      AstMatch(scrut, arms) => arms_texty_shallow(UsesTextArms { arms: arms, src: ps.src })
  proofs:
    purity:
      reads : [ps.node, ps.src]
      calls : [span_is_concat, ast_texty_shallow, arms_texty_shallow]
    termination:
      bound : 8000


-- arms_texty_shallow: the shallow texty walk over a match's arm bodies. Any
-- texty arm makes the whole match texty (mixed number arms stream via itoa).
rule arms_texty_shallow
  @intention: "1 if any match arm body is shallow-texty, 0 otherwise"
  @source: vexprparse.intent:69
  input:
    ua : UsesTextArms
  output:
    out : number
  logic:
    out = match ua.arms:
      ArmCons(vstart, vlen, binders, body, rest) => if ast_texty_shallow(PrintState { node: body, src: ua.src }) == 1 then 1 else arms_texty_shallow(UsesTextArms { arms: rest, src: ua.src })
      ArmNil => 0
  proofs:
    purity:
      reads : [ua.arms, ua.src]
      calls : [ast_texty_shallow, arms_texty_shallow]
    termination:
      bound : 8000


-- ast_is_texty: the transitive-depth-1 texty test. Same grammar as the shallow
-- walk PLUS one level of call transitivity: a call to a defined rule is texty
-- iff that rule's result is SHALLOW-texty (find_rule's sentinel result is
-- AstErr, so an unknown callee is 0). The three span primitives short-circuit:
-- byte_at / length are numbers; substring stays a packed span (value path).
rule ast_is_texty
  @intention: "1 if a subtree is text-shaped with one level of call transitivity, 0 otherwise"
  @source: vexprparse.intent:69
  input:
    ts : TextyState
  output:
    out : number
  logic:
    out = match ts.node:
      AstNum(value) => 0
      AstBool(value) => 0
      AstVar(start, len) => 0
      AstErr => 0
      AstStr(start, len) => 1
      AstBytes(start, len) => 1
      AstBin(op, lhs, rhs) => 0
      AstNeg(inner) => 0
      AstNot(inner) => 0
      AstField(base, fstart, flen) => 0
      AstCall(callee_start, callee_len, args) => if span_is_concat(SpanCheck { src: ts.src, start: callee_start, len: callee_len }) == 1 then 1 else if span_is_byte_at(SpanCheck { src: ts.src, start: callee_start, len: callee_len }) == 1 then 0 else if span_is_length(SpanCheck { src: ts.src, start: callee_start, len: callee_len }) == 1 then 0 else if span_is_substring(SpanCheck { src: ts.src, start: callee_start, len: callee_len }) == 1 then 0 else ast_texty_shallow(PrintState { node: block_result(rd_body(find_rule(FindRuleState { rules: ts.prog, src: ts.src, q_start: callee_start, q_len: callee_len }))), src: ts.src })
      AstIf(cond, thn, els) => if ast_is_texty(TextyState { node: thn, src: ts.src, prog: ts.prog }) == 1 then 1 else ast_is_texty(TextyState { node: els, src: ts.src, prog: ts.prog })
      AstVariant(cstart, clen, vstart, vlen, fields) => 0
      AstMatch(scrut, arms) => arms_is_texty(TextyArms { arms: arms, src: ts.src, prog: ts.prog })
  proofs:
    purity:
      reads : [ts.node, ts.src, ts.prog]
      calls : [span_is_concat, span_is_byte_at, span_is_length, span_is_substring, ast_texty_shallow, block_result, rd_body, find_rule, ast_is_texty, arms_is_texty]
    termination:
      bound : 8000


-- arms_is_texty: the transitive-depth-1 texty walk over a match's arm bodies.
rule arms_is_texty
  @intention: "1 if any match arm body is texty (transitive depth 1), 0 otherwise"
  @source: vexprparse.intent:69
  input:
    ta : TextyArms
  output:
    out : number
  logic:
    out = match ta.arms:
      ArmCons(vstart, vlen, binders, body, rest) => if ast_is_texty(TextyState { node: body, src: ta.src, prog: ta.prog }) == 1 then 1 else arms_is_texty(TextyArms { arms: rest, src: ta.src, prog: ta.prog })
      ArmNil => 0
  proofs:
    purity:
      reads : [ta.arms, ta.src, ta.prog]
      calls : [ast_is_texty, arms_is_texty]
    termination:
      bound : 8000


-- callee_is_texty: is the named callee a rule that EMITS as a streaming proc?
-- MUST equal rule_is_texty of the resolved rule — this is the ABI-consistency
-- predicate: x86_node's value-position guard (int3) and x86_stream_node's
-- call-and-discard dispatch both use it, so every call site either agrees with
-- the callee's proc shape or traps cleanly. Unknown callee -> 0 (sentinel
-- result AstErr).
rule callee_is_texty
  @intention: "1 if the named callee resolves to a rule that emits as a streaming (texty) proc, 0 otherwise"
  @source: vexprparse.intent:69
  input:
    st : FindRuleState
  output:
    out : number
  logic:
    out = ast_is_texty(TextyState { node: block_result(rd_body(find_rule(FindRuleState { rules: st.rules, src: st.src, q_start: st.q_start, q_len: st.q_len }))), src: st.src, prog: st.rules })
  proofs:
    purity:
      reads : [st.rules, st.src, st.q_start, st.q_len]
      calls : [ast_is_texty, block_result, rd_body, find_rule]
    termination:
      bound : 8000


-- rule_is_texty: the per-rule streaming-mode decision — 1 iff the rule's block
-- result is texty (transitive depth 1). x86_proc / proc_size branch on this;
-- a 0 keeps the materializing path byte-for-byte.
rule rule_is_texty
  @intention: "1 if a rule's block result is texty and its proc streams, 0 otherwise"
  @source: vexprparse.intent:69
  input:
    pg : ProcGenState
  output:
    out : number
  logic:
    out = ast_is_texty(TextyState { node: block_result(rd_body(pg.rd)), src: pg.src, prog: pg.prog })
  proofs:
    purity:
      reads : [pg.rd, pg.src, pg.prog]
      calls : [ast_is_texty, block_result, rd_body]
    termination:
      bound : 8000


-- entry_rule_texty: is the ENTRY rule (the first rule — the one the trampoline
-- calls) texty? Selects the trampoline variant: texty -> call + write("\n") +
-- exit(0) (45 B, no itoa print); number -> the b8 itoa trampoline (101 B).
rule entry_rule_texty
  @intention: "1 if the program's entry (first) rule is texty, 0 otherwise"
  @source: vexprparse.intent:69
  input:
    pg : ProgGenState
  output:
    out : number
  logic:
    out = match pg.rules:
      RCons(head, tail) => rule_is_texty(ProcGenState { rd: head, src: pg.src, off: 0, prog: pg.prog, concepts: pg.concepts, sizes: pg.sizes })
      RNil => 0
  proofs:
    purity:
      reads : [pg.rules, pg.src, pg.prog, pg.concepts, pg.sizes]
      calls : [rule_is_texty]
    termination:
      bound : 8000


-- prog_any_texty: 1 iff ANY rule in the program is texty. Gates the shared
-- itoa_proc emission (86 B between the trampoline and the first rule proc, so
-- rule procs see it at blob-origin offset -86) and the source-embedding
-- extension. A texty-free program keeps blob layout byte-identical.
rule prog_any_texty
  @intention: "1 if any rule in the program is texty (streams), 0 otherwise"
  @source: vexprparse.intent:69
  input:
    pg : ProgGenState
  output:
    out : number
  logic:
    out = match pg.rules:
      RCons(head, tail) => if rule_is_texty(ProcGenState { rd: head, src: pg.src, off: 0, prog: pg.prog, concepts: pg.concepts, sizes: pg.sizes }) == 1 then 1 else prog_any_texty(ProgGenState { rules: tail, src: pg.src, off: 0, prog: pg.prog, concepts: pg.concepts, sizes: pg.sizes })
      RNil => 0
  proofs:
    purity:
      reads : [pg.rules, pg.src, pg.prog, pg.concepts, pg.sizes]
      calls : [rule_is_texty, prog_any_texty]
    termination:
      bound : 8000


-- param_ty: the declared TYPE CODE of the parameter whose name span matches the
-- query (0=number, 1=bool, 2=text — brick 20's codes), or -1 if not a param.
-- Mirror of param_index returning `ty` instead of the index. The streaming
-- AstVar arm dispatches on ty == 2: a text param's runtime value is a packed
-- span (start*2^32 + len) that streams via unpack + write; every other var
-- streams through the shared itoa_proc.
rule param_ty
  @intention: "The declared type code of the parameter matching a name span, or -1 if not a parameter"
  @source: vexprparse.intent:69
  input:
    pi : ParamIndexState
  output:
    out : number
  logic:
    out = match pi.params:
      PCons(name_start, name_len, ty, ty_start, ty_len, rest) => if name_len == pi.q_len and name_eq(NameEqState { src: pi.src, a_start: name_start, b_start: pi.q_start, len: pi.q_len, off: 0 }) == 1 then ty else param_ty(ParamIndexState { params: rest, src: pi.src, q_start: pi.q_start, q_len: pi.q_len, idx: pi.idx + 1 })
      PNil => 0 - 1
  proofs:
    purity:
      reads : [pi.params, pi.src, pi.q_start, pi.q_len, pi.idx]
      calls : [name_eq, param_ty]
    termination:
      bound : 512


-- code_size_vfields: the total byte count of lowering a variant's field-value pushes
-- (the sum of each field value's code_size_node). Mirror of code_size_args. Empty -> 0.
rule code_size_vfields
  @intention: "Total byte count of lowering a variant construction's field-value pushes"
  @source: vexprparse.intent:64
  input:
    bgv : ByteGenVFields
  output:
    out : number
  logic:
    out = match bgv.fields:
      VFCons(name_start, name_len, val, rest) => code_size_node(ByteGenState { node: val, src: bgv.src, off: bgv.off, params: bgv.params, lets: bgv.lets, prog: bgv.prog, concepts: bgv.concepts, sizes: bgv.sizes }) + code_size_vfields(ByteGenVFields { fields: rest, src: bgv.src, off: bgv.off, params: bgv.params, lets: bgv.lets, prog: bgv.prog, concepts: bgv.concepts, sizes: bgv.sizes })
      VFNil => 0
  proofs:
    purity:
      reads : [bgv.fields, bgv.src, bgv.off, bgv.params, bgv.lets, bgv.prog, bgv.concepts, bgv.sizes]
      calls : [code_size_node, code_size_vfields]
    termination:
      bound : 8000


-- x86_vfields: emit the field-value pushes of a variant construction, in source order,
-- each leaving its value on the CPU stack (so after all of them field[n-1] is on top).
-- `off` threads so a nested call inside a field lands its rel32 (mirror of x86_args).
rule x86_vfields
  @intention: "Emit a variant construction's field-value pushes in source order"
  @source: vexprparse.intent:64
  input:
    bgv : ByteGenVFields
  output:
    out : bytes
  logic:
    out = match bgv.fields:
      VFCons(name_start, name_len, val, rest) => concat(x86_node(ByteGenState { node: val, src: bgv.src, off: bgv.off, params: bgv.params, lets: bgv.lets, prog: bgv.prog, concepts: bgv.concepts, sizes: bgv.sizes }), x86_vfields(ByteGenVFields { fields: rest, src: bgv.src, off: bgv.off + code_size_node(ByteGenState { node: val, src: bgv.src, off: bgv.off, params: bgv.params, lets: bgv.lets, prog: bgv.prog, concepts: bgv.concepts, sizes: bgv.sizes }), params: bgv.params, lets: bgv.lets, prog: bgv.prog, concepts: bgv.concepts, sizes: bgv.sizes }))
      VFNil => b""
  proofs:
    purity:
      reads : [bgv.fields, bgv.src, bgv.off, bgv.params, bgv.lets, bgv.prog, bgv.concepts, bgv.sizes]
      calls : [x86_node, code_size_node, x86_vfields]
    termination:
      bound : 8000


-- x86_vpops: emit the pop+store block moving each pushed field value from the CPU
-- stack into its arena payload slot. The FIRST pop takes the top of stack (field[n-1])
-- into slot n-1 ([node_addr + 8 + 8*(n-1)]); slot counts DOWN, so field j lands in
-- slot j. Per field: pop rcx (59) ; mov [rax + 8 + 8*slot], rcx (48 89 88 + le32 disp).
rule x86_vpops
  @intention: "Emit pop+store of each variant field value into its arena payload slot"
  @source: vexprparse.intent:64
  input:
    vp : VPopState
  output:
    out : bytes
  logic:
    out = match vp.rem:
      VFCons(name_start, name_len, val, rest) => concat(b"\x59\x48\x89\x88", le32(8 + 8 * vp.slot), x86_vpops(VPopState { rem: rest, slot: vp.slot - 1 }))
      VFNil => b""
  proofs:
    purity:
      reads : [vp.rem, vp.slot]
      calls : [x86_vpops]
    termination:
      bound : 4000


-- ============================================================================
-- BRICK R7b — MatchVariant machine-code emit (tag dispatch + payload bind). The
-- scrutinee leaves an arena INDEX on the stack (R7a). AstMatch pops it, computes
-- node_addr = r15 + index*entry_size, loads the 8-byte tag, and chains cmp/je over
-- the arm tags (resolved from the ConceptList via arm_tag_by_name). At the matched
-- arm, the payload fields at [node_addr + 8 + 8*j] are copied into the arm binders'
-- rbp LET slots; then the arm body runs with those binders in scope, then jmp end.
-- Binders become LOCALS: they are APPENDED to the proc's binding list (after the
-- real lets), so they resolve via let_index to slots BELOW the lets — the real lets
-- keep their slots 0..nlets-1, binders take nlets.. . x86_proc / proc_size widen
-- the frame's `sub rsp` by the TOTAL binder count of the rule body (safe over-reserve;
-- the epilogue's `mov rsp, rbp` frees it). A match-free program is byte-identical.
-- ============================================================================

-- binder_list_len: the number of positional binders in a match arm's BinderList
-- (cons-walk like arg_list_len). The payload arity the arm binds.
rule binder_list_len
  @intention: "Number of positional binders in a match arm's binder list"
  @source: vexprparse.intent:64
  input:
    bl : BinderList
  output:
    out : number
  logic:
    out = match bl:
      BindCons(start, len, rest) => 1 + binder_list_len(rest)
      BindNil => 0
  proofs:
    purity:
      reads : [bl]
      calls : [binder_list_len]
    termination:
      bound : 512
      structural : bl


-- arm_list_len: the number of arms in a match's ArmList (cons-walk). N in the
-- dispatch chain (N cmp/je pairs, 13 bytes each).
rule arm_list_len
  @intention: "Number of arms in a match's arm list"
  @source: vexprparse.intent:64
  input:
    al : ArmList
  output:
    out : number
  logic:
    out = match al:
      ArmCons(vstart, vlen, binders, body, rest) => 1 + arm_list_len(rest)
      ArmNil => 0
  proofs:
    purity:
      reads : [al]
      calls : [arm_list_len]
    termination:
      bound : 512
      structural : al


-- mb_ast: the TOTAL number of match-arm binders anywhere inside an AST subtree
-- (walking every arm of every match, plus recursing into scrutinees / bodies /
-- args / variant fields). x86_proc / proc_size reserve nlets + this many slots for
-- the frame — a safe over-reservation (the maximum simultaneously-live binders
-- along any nesting path never exceeds the total). Mutually recursive with
-- mb_args / mb_vfields / mb_arms (each sub-list carries Ast nodes).
rule mb_ast
  @intention: "Total number of match-arm binders anywhere inside an AST subtree"
  @source: vexprparse.intent:64
  input:
    n : Ast
  output:
    out : number
  logic:
    out = match n:
      AstNum(value) => 0
      AstBin(op, lhs, rhs) => mb_ast(lhs) + mb_ast(rhs)
      AstNeg(inner) => mb_ast(inner)
      AstNot(inner) => mb_ast(inner)
      AstVar(start, len) => 0
      AstField(base, fstart, flen) => 0
      AstCall(callee_start, callee_len, args) => mb_args(args)
      AstStr(start, len) => 0
      AstBytes(start, len) => 0
      AstBool(value) => 0
      AstIf(cond, thn, els) => mb_ast(cond) + mb_ast(thn) + mb_ast(els)
      AstErr => 0
      AstVariant(cstart, clen, vstart, vlen, fields) => mb_vfields(fields)
      AstMatch(scrut, arms) => mb_ast(scrut) + mb_arms(arms)
  proofs:
    purity:
      reads : [n]
      calls : [mb_ast, mb_args, mb_vfields, mb_arms]
    termination:
      bound : 8000


-- mb_args: total match binders across a call's argument list (sum of mb_ast).
rule mb_args
  @intention: "Total match-arm binders across a call's argument list"
  @source: vexprparse.intent:64
  input:
    al : ArgList
  output:
    out : number
  logic:
    out = match al:
      ArgCons(head, tail) => mb_ast(head) + mb_args(tail)
      ArgNil => 0
  proofs:
    purity:
      reads : [al]
      calls : [mb_ast, mb_args]
    termination:
      bound : 8000


-- mb_vfields: total match binders across a variant construction's field values.
rule mb_vfields
  @intention: "Total match-arm binders across a variant construction's field values"
  @source: vexprparse.intent:64
  input:
    fl : VFieldList
  output:
    out : number
  logic:
    out = match fl:
      VFCons(name_start, name_len, val, rest) => mb_ast(val) + mb_vfields(rest)
      VFNil => 0
  proofs:
    purity:
      reads : [fl]
      calls : [mb_ast, mb_vfields]
    termination:
      bound : 8000


-- mb_arms: total match binders across a match's arms = each arm's own binder count
-- PLUS the binders inside its body, summed over all arms.
rule mb_arms
  @intention: "Total match-arm binders across a match's arms (this arm's binders + body binders)"
  @source: vexprparse.intent:64
  input:
    al : ArmList
  output:
    out : number
  logic:
    out = match al:
      ArmCons(vstart, vlen, binders, body, rest) => binder_list_len(binders) + mb_ast(body) + mb_arms(rest)
      ArmNil => 0
  proofs:
    purity:
      reads : [al]
      calls : [binder_list_len, mb_ast, mb_arms]
    termination:
      bound : 8000


-- mb_binds: total match binders across every let-binding's RHS value (a let value
-- may itself contain a match). Added to mb_ast(result) to size a proc's frame.
rule mb_binds
  @intention: "Total match-arm binders across every let-binding's RHS value"
  @source: vexprparse.intent:64
  input:
    b : Binding
  output:
    out : number
  logic:
    out = match b:
      BCons(name_start, name_len, value, rest) => mb_ast(value) + mb_binds(rest)
      BNil => 0
  proofs:
    purity:
      reads : [b]
      calls : [mb_ast, mb_binds]
    termination:
      bound : 8000


-- AppendBindersState: a binding list + a match arm's binders, to APPEND the binders
-- at the TAIL of the list. Unlike binds_with_binders (the checker's PREPEND, which
-- is order-agnostic for name membership), codegen needs the binders AFTER the real
-- lets so let_index gives the real lets indices 0..nlets-1 (their emitted slots) and
-- the binders indices nlets.. (fresh slots reserved by the widened `sub rsp`).
concept AppendBindersState
  @intention: "A binding list + a match arm's binders, to append the binders at the tail"
  @source: vexprparse.intent:64
  fields:
    lets : Binding
    bs : BinderList


-- lets_append_binders: walk `lets` to its end and append `bs` (each binder as a
-- BCons with a dummy AstNum-0 value, reusing binds_with_binders to convert the
-- BinderList tail). The result's name-resolution order is [real lets, then binders],
-- so a binder resolves to slot nlets + its position (below the lets).
rule lets_append_binders
  @intention: "Append a match arm's binders at the tail of a binding list (binders get slots after the lets)"
  @source: vexprparse.intent:64
  input:
    ab : AppendBindersState
  output:
    out : Binding
  logic:
    out = match ab.lets:
      BCons(name_start, name_len, value, rest) => Binding::BCons { name_start: name_start, name_len: name_len, value: value, rest: lets_append_binders(AppendBindersState { lets: rest, bs: ab.bs }) }
      BNil => binds_with_binders(BindsWithBindersState { binds: Binding::BNil, bs: ab.bs })
  proofs:
    purity:
      reads : [ab.lets, ab.bs]
      calls : [lets_append_binders, binds_with_binders]
    termination:
      bound : 4000


-- ArmTagState: the ConceptList + source + an arm's variant-name span + the running
-- concept index. arm_tag_by_name searches every concept for one declaring a variant
-- with that name; the first hit yields cidx*256 + vidx. The interpreter recovers
-- cidx from the scrutinee's tag at runtime (stag/256); at EMIT time we resolve the
-- name against the ConceptList directly (arm variant names are unique per group).
concept ArmTagState
  @intention: "The concept list + source + an arm variant-name span + the running concept index, to resolve an arm's tag"
  @source: vexprparse.intent:64
  fields:
    concepts : ConceptList
    src : text [..256]
    vstart : number [0, 4000000]
    vlen : number [0, 4000000]
    cidx : number


-- arm_tag_by_name: the full identity tag (concept_index*256 + variant_index) of the
-- variant whose name matches the arm's span, searching every concept in order. A
-- variant found in the current concept's list (find_variant_index < 999999) yields
-- the tag; otherwise recurse to the next concept with cidx+1. -1 if no concept
-- declares the name (never reached for a checked program; the cmp would just never hit).
rule arm_tag_by_name
  @intention: "The identity tag of the variant matching an arm's name, searched across all concepts"
  @source: vexprparse.intent:64
  input:
    at : ArmTagState
  output:
    out : number
  logic:
    out = match at.concepts:
      CCons(head, tail) => if find_variant_index(FindVarIdxState { variants: cd_variants(head), src: at.src, q_start: at.vstart, q_len: at.vlen, idx: 0 }) < 999999 then at.cidx * 256 + find_variant_index(FindVarIdxState { variants: cd_variants(head), src: at.src, q_start: at.vstart, q_len: at.vlen, idx: 0 }) else arm_tag_by_name(ArmTagState { concepts: tail, src: at.src, vstart: at.vstart, vlen: at.vlen, cidx: at.cidx + 1 })
      CNil => 0 - 1
  proofs:
    purity:
      reads : [at.concepts, at.src, at.vstart, at.vlen, at.cidx]
      calls : [find_variant_index, cd_variants, arm_tag_by_name]
    termination:
      bound : 4000


-- ArmSizeState: a match arm list + the ByteGen context (src/params/lets/prog/concepts),
-- to sum the arm BLOCK sizes. Each arm block = 14*nbinders (the binder loads) +
-- code_size_node(body, lets-extended-with-binders) + 5 (the jmp end). code_size_arms
-- is the total; the default block's jmp end skips over all of it, and each arm's jmp
-- end skips over the arm blocks AFTER it (= code_size_arms of the rest).
concept ArmSizeState
  @intention: "A match arm list + the ByteGen context, to sum the arm block sizes (binder loads + body + jmp)"
  @source: vexprparse.intent:64
  fields:
    arms : ArmList
    src : text [..256]
    params : ParamList
    lets : Binding
    prog : RuleList
    concepts : ConceptList
    sizes : ProcSizeList


-- code_size_arms: total bytes of all arm blocks. Per arm: 14 bytes per binder (a
-- mov-from-arena + mov-to-slot pair) + the body's code_size_node (sized with the
-- binders appended to the scope so a binder's AstVar is a 6-byte load) + 5 (jmp end).
rule code_size_arms
  @intention: "Total byte count of all match arm blocks (binder loads + body + jmp end)"
  @source: vexprparse.intent:64
  input:
    az : ArmSizeState
  output:
    out : number
  logic:
    out = match az.arms:
      ArmCons(vstart, vlen, binders, body, rest) => 14 * binder_list_len(binders) + code_size_node(ByteGenState { node: body, src: az.src, off: 0, params: az.params, lets: lets_append_binders(AppendBindersState { lets: az.lets, bs: binders }), prog: az.prog, concepts: az.concepts, sizes: az.sizes }) + 5 + code_size_arms(ArmSizeState { arms: rest, src: az.src, params: az.params, lets: az.lets, prog: az.prog, concepts: az.concepts, sizes: az.sizes })
      ArmNil => 0
  proofs:
    purity:
      reads : [az.arms, az.src, az.params, az.lets, az.prog, az.concepts, az.sizes]
      calls : [binder_list_len, code_size_node, lets_append_binders, code_size_arms]
    termination:
      bound : 8000


-- DispatchState: the arm list + the ByteGen context + the running dispatch/arm
-- accounting for the cmp/je chain. `rest_disp` = the dispatch bytes for the arms
-- AFTER the head (13 each), `pre_arms` = the cumulative arm block bytes BEFORE the
-- head. je rel32 for the head = rest_disp + 9 (the default block) + pre_arms (jump
-- forward past the remaining chain, the default, and the earlier arm blocks to the
-- head arm's block).
concept DispatchState
  @intention: "The match arm list + ByteGen context + remaining dispatch bytes + preceding arm block bytes, for the cmp/je chain"
  @source: vexprparse.intent:64
  fields:
    arms : ArmList
    src : text [..256]
    params : ParamList
    lets : Binding
    prog : RuleList
    concepts : ConceptList
    sizes : ProcSizeList
    rest_disp : number
    pre_arms : number


-- x86_dispatch: emit the tag-dispatch chain. Per arm: cmp rcx, arm_tag (48 81 f9 +
-- le32 = 7) ; je arm_block (0f 84 + le32 = 6). rcx holds the scrutinee tag (loaded
-- once by the AstMatch prefix). The je jumps forward to the arm's block; rel is
-- computed self-relatively from rest_disp / pre_arms so it is independent of the
-- match's absolute position.
rule x86_dispatch
  @intention: "Emit a match's tag-dispatch cmp/je chain (one cmp+je per arm, jumping to its block)"
  @source: vexprparse.intent:64
  input:
    ds : DispatchState
  output:
    out : bytes
  logic:
    out = match ds.arms:
      ArmCons(vstart, vlen, binders, body, rest) => concat(b"\x48\x81\xf9", le32(arm_tag_by_name(ArmTagState { concepts: ds.concepts, src: ds.src, vstart: vstart, vlen: vlen, cidx: 0 })), b"\x0f\x84", le32(ds.rest_disp + 9 + ds.pre_arms), x86_dispatch(DispatchState { arms: rest, src: ds.src, params: ds.params, lets: ds.lets, prog: ds.prog, concepts: ds.concepts, sizes: ds.sizes, rest_disp: ds.rest_disp - 13, pre_arms: ds.pre_arms + 14 * binder_list_len(binders) + code_size_node(ByteGenState { node: body, src: ds.src, off: 0, params: ds.params, lets: lets_append_binders(AppendBindersState { lets: ds.lets, bs: binders }), prog: ds.prog, concepts: ds.concepts, sizes: ds.sizes }) + 5 }))
      ArmNil => b""
  proofs:
    purity:
      reads : [ds.arms, ds.src, ds.params, ds.lets, ds.prog, ds.concepts, ds.sizes, ds.rest_disp, ds.pre_arms]
      calls : [arm_tag_by_name, x86_dispatch, binder_list_len, code_size_node, lets_append_binders]
    termination:
      bound : 8000


-- BinderLoadState: a match arm's binders + the payload index j (0-based, for the
-- arena offset 8+8*j) + the base slot (= binding length before the binders, so a
-- binder's frame slot is base_slot + j). Emits the per-binder copy from the arena
-- payload into the binder's rbp let slot.
concept BinderLoadState
  @intention: "A match arm's binders + payload index + base slot, to copy each payload field into its binder slot"
  @source: vexprparse.intent:64
  fields:
    binders : BinderList
    j : number
    base_slot : number


-- x86_binder_loads: for each positional binder, copy the arena payload field into
-- the binder's frame slot. rax holds node_addr (the AstMatch prefix left it there).
-- Per binder: mov rdx, [rax + 8 + 8*j] (48 8b 90 + le32 = 7) ; mov [rbp - 8*(slot+1)],
-- rdx (48 89 95 + le32 = 7), slot = base_slot + j. 14 bytes per binder.
rule x86_binder_loads
  @intention: "Copy each match-arm payload field from the arena into its binder's frame slot"
  @source: vexprparse.intent:64
  input:
    bl : BinderLoadState
  output:
    out : bytes
  logic:
    out = match bl.binders:
      BindCons(start, len, rest) => concat(b"\x48\x8b\x90", le32(8 + 8 * bl.j), b"\x48\x89\x95", le32(0 - 8 * (bl.base_slot + bl.j + 1)), x86_binder_loads(BinderLoadState { binders: rest, j: bl.j + 1, base_slot: bl.base_slot }))
      BindNil => b""
  proofs:
    purity:
      reads : [bl.binders, bl.j, bl.base_slot]
      calls : [x86_binder_loads]
    termination:
      bound : 4000


-- ArmGenState: a match arm list + source + the absolute offset of the current arm
-- block's start (for the arm body's nested-call rel32) + the ByteGen context. Emits
-- each arm block: binder loads, the arm body (with binders in scope), then jmp end.
concept ArmGenState
  @intention: "A match arm list + source + the current arm block's absolute offset + ByteGen context, to emit the arm blocks"
  @source: vexprparse.intent:64
  fields:
    arms : ArmList
    src : text [..256]
    off : number
    params : ParamList
    lets : Binding
    prog : RuleList
    concepts : ConceptList
    sizes : ProcSizeList


-- x86_arms: emit the arm blocks in order. Each block: the binder loads (base_slot =
-- count_binds(ag.lets), so binders land in the slots reserved after the real lets),
-- the arm body lowered with the binders APPENDED to the scope (so its AstVar loads
-- resolve to those slots) and `off` threaded past the binder loads, then jmp end
-- (rel = code_size_arms of the REMAINING arms = the arm blocks after this one).
rule x86_arms
  @intention: "Emit a match's arm blocks: per arm the binder loads, the body, and the jmp to the match end"
  @source: vexprparse.intent:64
  input:
    ag : ArmGenState
  output:
    out : bytes
  logic:
    out = match ag.arms:
      ArmCons(vstart, vlen, binders, body, rest) => concat(x86_binder_loads(BinderLoadState { binders: binders, j: 0, base_slot: count_binds(ag.lets) }), x86_node(ByteGenState { node: body, src: ag.src, off: ag.off + 14 * binder_list_len(binders), params: ag.params, lets: lets_append_binders(AppendBindersState { lets: ag.lets, bs: binders }), prog: ag.prog, concepts: ag.concepts, sizes: ag.sizes }), b"\xe9", le32(code_size_arms(ArmSizeState { arms: rest, src: ag.src, params: ag.params, lets: ag.lets, prog: ag.prog, concepts: ag.concepts, sizes: ag.sizes })), x86_arms(ArmGenState { arms: rest, src: ag.src, off: ag.off + 14 * binder_list_len(binders) + code_size_node(ByteGenState { node: body, src: ag.src, off: 0, params: ag.params, lets: lets_append_binders(AppendBindersState { lets: ag.lets, bs: binders }), prog: ag.prog, concepts: ag.concepts, sizes: ag.sizes }) + 5, params: ag.params, lets: ag.lets, prog: ag.prog, concepts: ag.concepts, sizes: ag.sizes }))
      ArmNil => b""
  proofs:
    purity:
      reads : [ag.arms, ag.src, ag.off, ag.params, ag.lets, ag.prog, ag.concepts, ag.sizes]
      calls : [x86_binder_loads, x86_node, code_size_node, code_size_arms, lets_append_binders, binder_list_len, count_binds, x86_arms]
    termination:
      bound : 8000


-- code_size_node: the EXACT byte count x86_node(bg) emits for a subtree, the
-- program-aware sibling of code_size_expr. Must match x86_node arm-for-arm so
-- the `if` rel32 offsets and call rel32 offsets are correct. New arms vs b4a:
--   AstVar  => 6   (ff b5 + le32 disp)
--   AstCall => code_size_args(args) + 13  (call 5 + add rsp,imm32 7 + push rax 1)
-- AstNum/AstBin/AstNeg/AstIf reproduce code_size_expr byte-for-byte.
rule code_size_node
  @intention: "Exact byte count x86_node emits for a subtree (program-aware: vars load 6 B, calls args+13 B)"
  @source: vexprparse.intent:56
  input:
    bg : ByteGenState
  output:
    out : number
  logic:
    out = match bg.node:
      AstNum(value) => 11
      AstBin(op, lhs, rhs) => code_size_node(ByteGenState { node: lhs, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + code_size_node(ByteGenState { node: rhs, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + (if op == 13 then 6 else if op == 14 then 6 else if op == 15 then 7 else if op == 16 then 8 else if op == 17 then 11 else if op == 30 then 20 else if op == 31 then 20 else if op == 1 then 12 else if op == 6 then 12 else if op == 19 then 12 else if op == 20 then 12 else if op == 5 then 12 else if op == 4 then 12 else 1)
      AstNeg(inner) => code_size_node(ByteGenState { node: inner, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 5
      AstNot(inner) => 1
      AstVar(start, len) => 6
      -- records-arc slice 4: a field access on any STATICALLY-RESOLVABLE base (typed
      -- param / let-bound construction / chained field / direct construction — the
      -- static_concept_of arms) lowers to code_size_node(base) + a FIXED 19-byte
      -- suffix (pop rax 1 + imul rax,rax,E 7 + add rax,r15 3 + mov rax,[rax+disp32] 7
      -- + push rax 1). The suffix length is constant (imm32 forms) regardless of
      -- entry_size / field_index. An unresolvable base keeps the 1-byte int3 fallback.
      -- The resolvability test is the SAME static_concept_of call x86_node makes —
      -- a divergence desyncs every downstream offset (the two-pass sharp edge).
      AstField(base, fstart, flen) => if static_concept_of(StaticConceptState { node: base, src: bg.src, params: bg.params, lets: bg.lets, concepts: bg.concepts }) >= 0 then code_size_node(ByteGenState { node: base, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 19 else 1
      -- Text values slice 2: the three span primitives dispatch BEFORE the real-call
      -- path, on the VERBATIM same span_is_* + arg_list_len conditions as x86_node
      -- (the two-pass drift edge). Constant suffixes: byte_at = 36 (pops + split +
      -- bounds + movabs src_base + movzx + OOB block), length = 4 (pop ; mov eax,eax ;
      -- push), substring = 38 (pops + split + two bounds checks + repack + OOB block).
      -- A wrong arity emits ONLY `push 0` (2 bytes) — oracle parity with eval's
      -- defensive VNum 0, no argument code at all.
      AstCall(callee_start, callee_len, args) => if span_is_byte_at(SpanCheck { src: bg.src, start: callee_start, len: callee_len }) == 1 then (if arg_list_len(args) == 2 then code_size_args(ByteGenArgs { args: args, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 36 else 2) else if span_is_length(SpanCheck { src: bg.src, start: callee_start, len: callee_len }) == 1 then (if arg_list_len(args) == 1 then code_size_args(ByteGenArgs { args: args, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 4 else 2) else if span_is_substring(SpanCheck { src: bg.src, start: callee_start, len: callee_len }) == 1 then (if arg_list_len(args) == 3 then code_size_args(ByteGenArgs { args: args, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 38 else 2) else if span_is_concat(SpanCheck { src: bg.src, start: callee_start, len: callee_len }) == 1 then 1 else if callee_is_texty(FindRuleState { rules: bg.prog, src: bg.src, q_start: callee_start, q_len: callee_len }) == 1 then 1 else code_size_args(ByteGenArgs { args: args, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 13
      -- Text values slice 2: a string literal is one packed-span push —
      -- mov rax, imm64 (10) + push rax (1) = 11, same shape as AstNum.
      AstStr(start, len) => 11
      AstBytes(start, len) => 1
      AstBool(value) => 1
      AstIf(cond, thn, els) => code_size_node(ByteGenState { node: cond, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 15 + code_size_node(ByteGenState { node: thn, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + code_size_node(ByteGenState { node: els, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes })
      AstErr => 1
      -- R7a: a VariantConstruct emits the field-value pushes (code_size_vfields) +
      -- a fixed 25-byte arena-write suffix (mov rax,r14 3 + imul 7 + add rax,r15 3 +
      -- mov qword[rax],tag 7 + push r14 2 + inc r14 3) + 8 bytes per field pop+store.
      AstVariant(cstart, clen, vstart, vlen, fields) => code_size_vfields(ByteGenVFields { fields: fields, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 25 + 8 * vfield_len(fields)
      -- R7b: match = scrut code + 14 (pop rax ; imul rax,rax,E ; add rax,r15 ;
      -- mov rcx,[rax]) + 13 per arm (cmp rcx,tag 7 + je 6) + 9 (default: xor rax,rax 3
      -- + push rax 1 + jmp end 5) + code_size_arms (the arm blocks). Must match x86_node.
      AstMatch(scrut, arms) => code_size_node(ByteGenState { node: scrut, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 14 + 13 * arm_list_len(arms) + 9 + code_size_arms(ArmSizeState { arms: arms, src: bg.src, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes })
  proofs:
    purity:
      reads : [bg.node, bg.src, bg.off, bg.params, bg.lets, bg.prog, bg.concepts, bg.sizes]
      calls : [code_size_node, code_size_args, code_size_vfields, vfield_len, arm_list_len, code_size_arms, static_concept_of, span_is_byte_at, span_is_length, span_is_substring, span_is_concat, callee_is_texty, arg_list_len]
    termination:
      bound : 8000


-- code_size_args: the total byte count of lowering a call's argument list (the
-- sum of each arg's code_size_node). Empty list -> 0.
rule code_size_args
  @intention: "Total byte count of lowering a call's argument list"
  @source: vexprparse.intent:56
  input:
    ag : ByteGenArgs
  output:
    out : number
  logic:
    out = match ag.args:
      ArgCons(head, tail) => code_size_node(ByteGenState { node: head, src: ag.src, off: ag.off, params: ag.params, lets: ag.lets, prog: ag.prog, concepts: ag.concepts, sizes: ag.sizes }) + code_size_args(ByteGenArgs { args: tail, src: ag.src, off: ag.off, params: ag.params, lets: ag.lets, prog: ag.prog, concepts: ag.concepts, sizes: ag.sizes })
      ArgNil => 0
  proofs:
    purity:
      reads : [ag.args, ag.src, ag.off, ag.params, ag.lets, ag.prog, ag.concepts, ag.sizes]
      calls : [code_size_node, code_size_args]
    termination:
      bound : 8000


-- LetGenState: drives the let-store prologue. `rem` is the suffix of bindings
-- still to emit (walked structurally); `all_binds` is the proc's FULL binding list
-- (the unchanging name-resolution env — so a value referencing an EARLIER let
-- resolves correctly, and `let_index` against `all_binds` yields the right
-- absolute source-order slot). `off` is the absolute byte position where the next
-- store sequence begins (threaded so a value's nested call lands its rel32). idx
-- is the source-order index of `rem`'s head (its frame slot is [rbp - 8*(idx+1)]).
concept LetGenState
  @intention: "The remaining lets to emit + the full binding env + source + offset + params + index + the program"
  @source: vexprparse.intent:56
  fields:
    rem : Binding
    all_binds : Binding
    src : text [..256]
    off : number
    params : ParamList
    idx : number
    prog : RuleList
    concepts : ConceptList
    sizes : ProcSizeList


-- code_size_let_stores: the EXACT byte count the let-store prologue emits for a
-- proc's binding list — for each `let NAME = e` it's code_size_node(e) (the value
-- ops) + 1 (pop rax, 58) + 7 (mov [rbp-disp], rax — always-disp32 form 48 89 85
-- + le32). Each value is sized with the FULL binding env (lg.all_binds) so an
-- earlier-let reference resolves identically to the emit pass (a var load is 6 B
-- whether it resolves to a param or a let, so the size is slot-independent). BNil
-- -> 0. Sizes ignore `off`, so 0 is threaded.
rule code_size_let_stores
  @intention: "Exact byte count of the let-store prologue: per let, code_size_node(value) + 8"
  @source: vexprparse.intent:56
  input:
    lg : LetGenState
  output:
    out : number
  logic:
    out = match lg.rem:
      BCons(name_start, name_len, value, rest) => code_size_node(ByteGenState { node: value, src: lg.src, off: 0, params: lg.params, lets: lg.all_binds, prog: lg.prog, concepts: lg.concepts, sizes: lg.sizes }) + 8 + code_size_let_stores(LetGenState { rem: rest, all_binds: lg.all_binds, src: lg.src, off: 0, params: lg.params, idx: lg.idx + 1, prog: lg.prog, concepts: lg.concepts, sizes: lg.sizes })
      BNil => 0
  proofs:
    purity:
      reads : [lg.rem, lg.all_binds, lg.src, lg.params, lg.idx, lg.prog, lg.concepts, lg.sizes]
      calls : [code_size_node, code_size_let_stores]
    termination:
      bound : 8000


-- x86_let_stores: emit the let-store prologue. For each `let NAME = e` in source
-- order: <x86_node(e)> (value pushed) ; pop rax (58) ; mov [rbp - 8*(idx+1)], rax
-- (always-disp32: 48 89 85 + le32 of the NEGATIVE displacement). Each value is
-- lowered against the FULL binding env (lg.all_binds) so an earlier let resolves;
-- `off` is threaded so a value's nested call computes its rel32 against the right
-- site (off advances by code_size_node(value) + 8 per let). The mov's disp is
-- 0 - 8*(idx+1) (a negative slot below rbp), emitted via le32 (two's complement).
rule x86_let_stores
  @intention: "Emit the let-store prologue: per let, value ops + pop rax + mov to its negative frame slot"
  @source: vexprparse.intent:56
  input:
    lg : LetGenState
  output:
    out : bytes
  logic:
    out = match lg.rem:
      BCons(name_start, name_len, value, rest) => concat(x86_node(ByteGenState { node: value, src: lg.src, off: lg.off, params: lg.params, lets: lg.all_binds, prog: lg.prog, concepts: lg.concepts, sizes: lg.sizes }), b"\x58\x48\x89\x85", le32(0 - 8 * (lg.idx + 1)), x86_let_stores(LetGenState { rem: rest, all_binds: lg.all_binds, src: lg.src, off: lg.off + code_size_node(ByteGenState { node: value, src: lg.src, off: lg.off, params: lg.params, lets: lg.all_binds, prog: lg.prog, concepts: lg.concepts, sizes: lg.sizes }) + 8, params: lg.params, idx: lg.idx + 1, prog: lg.prog, concepts: lg.concepts, sizes: lg.sizes }))
      BNil => b""
  proofs:
    purity:
      reads : [lg.rem, lg.all_binds, lg.src, lg.off, lg.params, lg.idx, lg.prog, lg.concepts, lg.sizes]
      calls : [x86_node, code_size_node, x86_let_stores]
    termination:
      bound : 8000


-- proc_size: the exact byte length of one rule's emitted proc =
--   prologue 4 (55 48 89 e5) + body's result-expr code + epilogue 6
--   (58 48 89 ec 5d c3). The body's let-bindings are NOT lowered in this brick
-- (a let-bound name traps via the var path), so the body is the block result only.
-- The `off` passed to code_size_node is irrelevant to a SIZE (sizes don't depend
-- on absolute position), so 0 is used.
rule proc_size
  @intention: "Exact byte length of one rule's emitted proc (prologue 4 + body code + epilogue 6)"
  @source: vexprparse.intent:56
  input:
    pg : ProcGenState
  output:
    out : number
  logic:
    let blk = rd_body(pg.rd)
    let binds = block_binds(blk)
    let result = block_result(blk)
    let nlets = count_binds(binds)
    let nbind = mb_ast(result) + mb_binds(binds)
    let subsize = if nlets + nbind > 0 then 7 else 0
    let storesize = code_size_let_stores(LetGenState { rem: binds, all_binds: binds, src: pg.src, off: 0, params: rule_params_of(pg.rd), idx: 0, prog: pg.prog, concepts: pg.concepts, sizes: pg.sizes })
    out = 4 + subsize + storesize + (if rule_is_texty(pg) == 1 then code_size_stream_node(ByteGenState { node: result, src: pg.src, off: 0, params: rule_params_of(pg.rd), lets: binds, prog: pg.prog, concepts: pg.concepts, sizes: pg.sizes }) + 2 else code_size_node(ByteGenState { node: result, src: pg.src, off: 0, params: rule_params_of(pg.rd), lets: binds, prog: pg.prog, concepts: pg.concepts, sizes: pg.sizes })) + 6
  proofs:
    purity:
      reads : [pg, pg.rd, pg.src, pg.prog, pg.concepts, pg.sizes]
      calls : [rd_body, block_binds, block_result, count_binds, mb_ast, mb_binds, code_size_let_stores, code_size_node, rule_is_texty, code_size_stream_node, rule_params_of]
    termination:
      bound : 8000


-- proc_sizes: the per-rule proc SIZES in rule order — ONE left-to-right pass that
-- calls proc_size exactly once per rule and conses the result. Computed ONCE at the
-- top of x86_program_src / elf_program_src and threaded (like `concepts`) so that
-- proc_offset and ps_total read a cached size instead of re-walking each proc body.
-- This is what turns the emitter's offset accounting from O(N^2 * body) to O(N):
-- proc_size's body-walk now happens N times total, not once per callee-resolution.
-- The list is aligned 1:1 with the RuleList (same order), so proc_offset can shrink
-- both in lockstep. Same RCons/RNil cons shape as RuleList (arena + structural).
rule proc_sizes
  @intention: "Per-rule emitted-proc sizes in rule order — one proc_size pass, cached as a cons-list"
  @source: vexprparse.intent:56
  input:
    pg : ProgGenState
  output:
    out : ProcSizeList
  logic:
    out = match pg.rules:
      RCons(head, tail) => ProcSizeList::PSCons { size: proc_size(ProcGenState { rd: head, src: pg.src, off: 0, prog: pg.prog, concepts: pg.concepts, sizes: pg.sizes }), rest: proc_sizes(ProgGenState { rules: tail, src: pg.src, off: 0, prog: pg.prog, concepts: pg.concepts, sizes: pg.sizes }) }
      RNil => ProcSizeList::PSNil
  proofs:
    purity:
      reads : [pg.rules, pg.src, pg.prog, pg.concepts, pg.sizes]
      calls : [proc_size, proc_sizes]
    termination:
      bound : 8000


-- ps_head: the first proc size in the list (0 for the empty list). Used by
-- proc_offset to add the current proc's size to the running offset without
-- re-calling proc_size.
rule ps_head
  @intention: "The head proc size of a ProcSizeList (0 if empty)"
  @source: vexprparse.intent:56
  input:
    psl : ProcSizeList
  output:
    out : number
  logic:
    out = match psl:
      PSCons(sz, rest) => sz
      PSNil => 0
  proofs:
    purity:
      reads : [psl]
      calls : []
    termination:
      bound : 4


-- ps_tail: the list minus its head (empty stays empty). proc_offset advances this
-- in lockstep with the RuleList tail so the head size always matches the head rule.
rule ps_tail
  @intention: "The tail of a ProcSizeList (empty if already empty)"
  @source: vexprparse.intent:56
  input:
    psl : ProcSizeList
  output:
    out : ProcSizeList
  logic:
    out = match psl:
      PSCons(sz, rest) => rest
      PSNil => ProcSizeList::PSNil
  proofs:
    purity:
      reads : [psl]
      calls : []
    termination:
      bound : 4


-- proc_offset: the absolute blob offset of the proc whose name span matches the
-- query — the sum of proc_size over the procs BEFORE it (the entry proc is at 0).
-- Walks the program accumulating each proc's size into `acc` until the named proc
-- is reached, then returns acc. The size comes from the PRECOMPUTED `po.sizes` list
-- (walked in lockstep with the RuleList via ps_head / ps_tail) — the codegen-dedup
-- change: the same constant offset with NO per-callee-site proc_size body re-walk.
-- A missing callee returns acc (never reached for a well-formed non-recursive
-- program; rel32 would be wrong, caught by mmap+exec).
rule proc_offset
  @intention: "Absolute blob offset of a named proc = sum of the precomputed proc sizes before it"
  @source: vexprparse.intent:56
  input:
    po : ProcOffState
  output:
    out : number
  logic:
    out = match po.rules:
      RCons(head, tail) => if rd_name_len(head) == po.q_len and name_eq(NameEqState { src: po.src, a_start: rd_name_start(head), b_start: po.q_start, len: po.q_len, off: 0 }) == 1 then po.acc else proc_offset(ProcOffState { rules: tail, src: po.src, acc: po.acc + ps_head(po.sizes), q_start: po.q_start, q_len: po.q_len, concepts: po.concepts, sizes: ps_tail(po.sizes) })
      RNil => po.acc
  proofs:
    purity:
      reads : [po.rules, po.src, po.acc, po.q_start, po.q_len, po.concepts, po.sizes]
      calls : [rd_name_len, name_eq, rd_name_start, proc_offset, ps_head, ps_tail]
    termination:
      bound : 8000


-- x86_node: the program-aware byte-emitting code generator. Same post-order shape
-- as x86_expr, but it now lowers AstVar (a frame param load) and AstCall (a real
-- call rel32 + arg cleanup + push result), threading `off` so a nested call's
-- rel32 is computed against its own emission site. AstBin/AstNeg/AstIf reproduce
-- x86_expr's bytes exactly, just over ByteGenState; the if's jz/jmp stay
-- self-relative (computed from code_size_node, the program-aware size).
--   AstVar: push qword [rbp+disp] (ff b5 + le32 disp), disp = 16 + 8*(N-1-i).
--           Not a param -> int3 (cc) — out of subset (no lets here).
--   AstCall: <args in order> ; call rel32 (e8 + le32) ; add rsp,8N (48 81 c4 +
--           le32) ; push rax (50). rel32 = procOffset(callee) - (off + argsize + 5).
rule x86_node
  @intention: "Lower a program AST subtree (num, +/-/*, neg, cmp, if, var, call) to executable x86-64 machine code"
  @source: vexprparse.intent:56
  input:
    bg : ByteGenState
  output:
    out : bytes
  logic:
    out = match bg.node:
      AstNum(value) => concat(b"\x48\xb8", le64(value), b"\x50")
      AstBin(op, lhs, rhs) => concat(x86_node(ByteGenState { node: lhs, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), x86_node(ByteGenState { node: rhs, src: bg.src, off: bg.off + code_size_node(ByteGenState { node: lhs, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), if op == 13 then b"\x59\x58\x48\x01\xc8\x50" else if op == 14 then b"\x59\x58\x48\x29\xc8\x50" else if op == 15 then b"\x59\x58\x48\x0f\xaf\xc1\x50" else if op == 16 then b"\x59\x58\x48\x99\x48\xf7\xf9\x50" else if op == 17 then b"\x59\x58\x48\x99\x48\xf7\xf9\x48\x89\xd0\x50" else if op == 30 then b"\x59\x58\x48\x85\xc0\x0f\x95\xc0\x48\x85\xc9\x0f\x95\xc1\x20\xc8\x0f\xb6\xc0\x50" else if op == 31 then b"\x59\x58\x48\x85\xc0\x0f\x95\xc0\x48\x85\xc9\x0f\x95\xc1\x08\xc8\x0f\xb6\xc0\x50" else if op == 1 then b"\x59\x58\x48\x39\xc8\x0f\x94\xc0\x0f\xb6\xc0\x50" else if op == 6 then b"\x59\x58\x48\x39\xc8\x0f\x95\xc0\x0f\xb6\xc0\x50" else if op == 19 then b"\x59\x58\x48\x39\xc8\x0f\x9c\xc0\x0f\xb6\xc0\x50" else if op == 20 then b"\x59\x58\x48\x39\xc8\x0f\x9f\xc0\x0f\xb6\xc0\x50" else if op == 5 then b"\x59\x58\x48\x39\xc8\x0f\x9e\xc0\x0f\xb6\xc0\x50" else if op == 4 then b"\x59\x58\x48\x39\xc8\x0f\x9d\xc0\x0f\xb6\xc0\x50" else b"\xcc")
      AstNeg(inner) => concat(x86_node(ByteGenState { node: inner, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), b"\x58\x48\xf7\xd8\x50")
      AstNot(inner) => b"\xcc"
      AstVar(start, len) => (if param_index(ParamIndexState { params: bg.params, src: bg.src, q_start: start, q_len: len, idx: 0 }) >= 0 then concat(b"\xff\xb5", le32(16 + 8 * (param_list_len(bg.params) - 1 - param_index(ParamIndexState { params: bg.params, src: bg.src, q_start: start, q_len: len, idx: 0 })))) else if let_index(LetIndexState { binds: bg.lets, src: bg.src, q_start: start, q_len: len, idx: 0 }) >= 0 then concat(b"\xff\xb5", le32(0 - 8 * (let_index(LetIndexState { binds: bg.lets, src: bg.src, q_start: start, q_len: len, idx: 0 }) + 1))) else b"\xcc")
      -- records-arc slice 4: field access via the UNIFIED static resolver. The base
      -- can be a TYPED param (`rule f(s : Foo)` ... s.field — the record-input shape),
      -- a let-bound construction (slice 3's case, now the resolver's let branch), a
      -- CHAINED field access (o.inner.b — the resolver recurses through FCons ty
      -- spans), or a direct construction. x86_node(base) leaves the node's arena
      -- INDEX on the stack; the 19-byte suffix reads the field's payload slot:
      -- pop rax (the index) ; imul rax,rax,entry_size (same E as R7a/R7b) ;
      -- add rax,r15 (node addr) ; mov rax,[rax + 8 + 8*field_index] ; push.
      -- field_index resolves against static_concept_of's concept at COMPILE time
      -- (concept_at_index -> cd_fields -> field_index_of) — no runtime tag. An
      -- unresolvable base keeps int3 (an UNTYPED param stays out BY DESIGN — the
      -- compiler never infers a param's concept from call sites).
      AstField(base, fstart, flen) => (if static_concept_of(StaticConceptState { node: base, src: bg.src, params: bg.params, lets: bg.lets, concepts: bg.concepts }) >= 0 then concat(x86_node(ByteGenState { node: base, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), b"\x58\x48\x69\xc0", le32(8 * (max_payload_fields(bg.concepts) + 1)), b"\x4c\x01\xf8\x48\x8b\x80", le32(8 + 8 * field_index_of(FieldIdxState { fields: cd_fields(concept_at_index(ConceptAtState { concepts: bg.concepts, idx: static_concept_of(StaticConceptState { node: base, src: bg.src, params: bg.params, lets: bg.lets, concepts: bg.concepts }) })), src: bg.src, q_start: fstart, q_len: flen, idx: 0 })), b"\x50") else b"\xcc")
      -- Text values slice 2: the three span primitives dispatch BEFORE the real-call
      -- path, on the VERBATIM same span_is_* + arg_list_len conditions as
      -- code_size_node (the two-pass drift edge). All operate on the packed-span
      -- Number ABI (start*2^32 + len) and scratch only rax/rcx/rdx/rsi — never
      -- r14/r15 (arena) — with no proc calls, so `off` needs no rel32 here.
      --   byte_at(t, i), K = 36: pop rcx (i) ; pop rax (t) ; mov edx, eax (len,
      --     zero-extended) ; shr rax, 32 (start) ; cmp rcx, rdx ; jae +20 (unsigned
      --     covers negative i) ; add rax, rcx ; mov rdx, imm64(src_base = 0x400000 +
      --     blob_end_off — the source bytes elf_program_src appends at the file
      --     end) ; movzx eax, byte [rdx + rax] ; push rax ; jmp +3 ; OOB: xor eax,
      --     eax ; push rax. Oracle parity: eval's defensive VNum 0, never abort.
      --   length(t), K = 4: pop rax ; mov eax, eax (low 32 = len) ; push rax.
      --   substring(t, a, b), K = 38: pop rcx (b) ; pop rdx (a) ; pop rax (t) ;
      --     mov esi, eax (len) ; shr rax, 32 (start) ; cmp rdx, rcx ; ja +21
      --     (a > b) ; cmp rcx, rsi ; ja +16 (b > len) ; add rax, rdx ; shl rax,
      --     32 ; sub rcx, rdx ; or rax, rcx ; push rax ; jmp +3 ; OOB: xor eax,
      --     eax ; push rax. Pure span arithmetic — no memory touch, no src_base.
      -- A wrong arity emits ONLY push 0 (6a 00, 2 bytes) — eval's defensive VNum 0.
      AstCall(callee_start, callee_len, args) => if span_is_byte_at(SpanCheck { src: bg.src, start: callee_start, len: callee_len }) == 1 then (if arg_list_len(args) == 2 then concat(x86_args(ByteGenArgs { args: args, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), b"\x59\x58\x89\xc2\x48\xc1\xe8\x20\x48\x39\xd1\x73\x14\x48\x01\xc8\x48\xba", le64(4194304 + blob_end_off(ProgGenState { rules: bg.prog, src: bg.src, off: 0, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes })), b"\x0f\xb6\x04\x02\x50\xeb\x03\x31\xc0\x50") else b"\x6a\x00") else if span_is_length(SpanCheck { src: bg.src, start: callee_start, len: callee_len }) == 1 then (if arg_list_len(args) == 1 then concat(x86_args(ByteGenArgs { args: args, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), b"\x58\x89\xc0\x50") else b"\x6a\x00") else if span_is_substring(SpanCheck { src: bg.src, start: callee_start, len: callee_len }) == 1 then (if arg_list_len(args) == 3 then concat(x86_args(ByteGenArgs { args: args, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), b"\x59\x5a\x58\x89\xc6\x48\xc1\xe8\x20\x48\x39\xca\x77\x15\x48\x39\xf1\x77\x10\x48\x01\xd0\x48\xc1\xe0\x20\x48\x29\xd1\x48\x09\xc8\x50\xeb\x03\x31\xc0\x50") else b"\x6a\x00") else if span_is_concat(SpanCheck { src: bg.src, start: callee_start, len: callee_len }) == 1 then b"\xcc" else if callee_is_texty(FindRuleState { rules: bg.prog, src: bg.src, q_start: callee_start, q_len: callee_len }) == 1 then b"\xcc" else concat(x86_args(ByteGenArgs { args: args, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), b"\xe8", le32(proc_offset(ProcOffState { rules: bg.prog, src: bg.src, acc: 0, q_start: callee_start, q_len: callee_len, concepts: bg.concepts, sizes: bg.sizes }) - (bg.off + code_size_args(ByteGenArgs { args: args, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 5)), b"\x48\x81\xc4", le32(8 * arg_list_len(args)), b"\x50")
      -- Text values slice 2: a string literal compiles to ONE packed i64 —
      -- (start+1) * 2^32 + (len-2), quotes stripped, the SAME numbers as eval's
      -- VText (the token span includes both quotes; a lone-quote token packs len
      -- 0). mov rax, imm64 ; push rax — 11 bytes, same shape as AstNum.
      AstStr(start, len) => concat(b"\x48\xb8", le64((start + 1) * 4294967296 + (if len >= 2 then len - 2 else 0)), b"\x50")
      AstBytes(start, len) => b"\xcc"
      AstBool(value) => b"\xcc"
      -- Off-threading fix (text values slice 2): the THEN branch starts 10 bytes
      -- after the cond code (pop + test + je = 10), not 15 — the 5-byte
      -- jmp-over-els sits AFTER thn. The els offset (cond + 15 + thn) was already
      -- correct (= 10 + thn + 5). Latent since b4b-1: every prior program's
      -- recursion sat in an ELSE branch, so no call rel32 was ever emitted inside
      -- a THEN branch until word_length — its recursive call landed 5 bytes short
      -- (into the previous proc's epilogue).
      AstIf(cond, thn, els) => concat(x86_node(ByteGenState { node: cond, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), b"\x58\x48\x85\xc0\x0f\x84", le32(code_size_node(ByteGenState { node: thn, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 5), x86_node(ByteGenState { node: thn, src: bg.src, off: bg.off + code_size_node(ByteGenState { node: cond, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 10, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), b"\xe9", le32(code_size_node(ByteGenState { node: els, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes })), x86_node(ByteGenState { node: els, src: bg.src, off: bg.off + code_size_node(ByteGenState { node: cond, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 15 + code_size_node(ByteGenState { node: thn, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }))
      AstErr => b"\xcc"
      -- R7a: a VariantConstruct = arena node allocation. First emit the field-value
      -- pushes (x86_vfields, left-to-right so field[n-1] ends on top of the stack).
      -- Then the arena-write suffix: node_addr = r15 + r14*entry_size (mov rax,r14 ;
      -- imul rax,rax,E ; add rax,r15); write the 8-byte tag (mov qword[rax],tag);
      -- pop each field value into its payload slot [rax + 8 + 8*i] (x86_vpops, popping
      -- top-of-stack into the highest slot first); leave the INDEX on the stack
      -- (push r14 = the variant value); inc r14 (bump the node count). entry_size and
      -- tag are self-computed from the ConceptList threaded through bg.concepts.
      AstVariant(cstart, clen, vstart, vlen, fields) => concat(x86_vfields(ByteGenVFields { fields: fields, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), b"\x4c\x89\xf0\x48\x69\xc0", le32(8 * (max_payload_fields(bg.concepts) + 1)), b"\x4c\x01\xf8\x48\xc7\x00", le32(variant_tag(VariantTagState { concepts: bg.concepts, src: bg.src, cstart: cstart, clen: clen, vstart: vstart, vlen: vlen })), x86_vpops(VPopState { rem: fields, slot: vfield_len(fields) - 1 }), b"\x41\x56\x49\xff\xc6")
      -- R7b: match dispatch. Emit scrut (pushes index); pop rax (58); node_addr =
      -- r15 + index*entry_size (imul rax,rax,E 48 69 c0+le32 ; add rax,r15 4c 01 f8);
      -- load tag mov rcx,[rax] (48 8b 08); the cmp/je dispatch chain (x86_dispatch);
      -- the default block xor rax,rax (48 31 c0) ; push rax (50) ; jmp end (e9+le32,
      -- skips all arm blocks); then the arm blocks (x86_arms). Each arm binds its
      -- payload into the reserved binder slots, runs its body, and jmps to end.
      AstMatch(scrut, arms) => concat(x86_node(ByteGenState { node: scrut, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), b"\x58\x48\x69\xc0", le32(8 * (max_payload_fields(bg.concepts) + 1)), b"\x4c\x01\xf8\x48\x8b\x08", x86_dispatch(DispatchState { arms: arms, src: bg.src, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes, rest_disp: 13 * (arm_list_len(arms) - 1), pre_arms: 0 }), b"\x48\x31\xc0\x50\xe9", le32(code_size_arms(ArmSizeState { arms: arms, src: bg.src, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes })), x86_arms(ArmGenState { arms: arms, src: bg.src, off: bg.off + code_size_node(ByteGenState { node: scrut, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 14 + 13 * arm_list_len(arms) + 9, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }))
  proofs:
    purity:
      reads : [bg.node, bg.src, bg.off, bg.params, bg.lets, bg.prog, bg.concepts, bg.sizes]
      calls : [x86_node, code_size_node, x86_args, code_size_args, param_index, let_index, param_list_len, proc_offset, arg_list_len, x86_vfields, x86_vpops, vfield_len, max_payload_fields, variant_tag, x86_dispatch, x86_arms, code_size_arms, arm_list_len, static_concept_of, field_index_of, cd_fields, concept_at_index, span_is_byte_at, span_is_length, span_is_substring, span_is_concat, callee_is_texty, blob_end_off]
    termination:
      bound : 8000


-- x86_args: lower a call's argument list in source order, threading `off` so each
-- arg's nested calls land their rel32 against the right site. arg(k) begins at
-- off + sum(code_size of arg(0)..arg(k-1)). Empty list -> empty bytes.
rule x86_args
  @intention: "Lower a call's argument list in source order, each value left on the stack"
  @source: vexprparse.intent:56
  input:
    ag : ByteGenArgs
  output:
    out : bytes
  logic:
    out = match ag.args:
      ArgCons(head, tail) => concat(x86_node(ByteGenState { node: head, src: ag.src, off: ag.off, params: ag.params, lets: ag.lets, prog: ag.prog, concepts: ag.concepts, sizes: ag.sizes }), x86_args(ByteGenArgs { args: tail, src: ag.src, off: ag.off + code_size_node(ByteGenState { node: head, src: ag.src, off: ag.off, params: ag.params, lets: ag.lets, prog: ag.prog, concepts: ag.concepts, sizes: ag.sizes }), params: ag.params, lets: ag.lets, prog: ag.prog, concepts: ag.concepts, sizes: ag.sizes }))
      ArgNil => b""
  proofs:
    purity:
      reads : [ag.args, ag.src, ag.off, ag.params, ag.lets, ag.prog, ag.concepts, ag.sizes]
      calls : [x86_node, code_size_node, x86_args]
    termination:
      bound : 8000


-- arg_list_len: the number of arguments in a call's ArgList (cons-walk like
-- param_list_len). Used to size the caller's `add rsp, 8*N` arg cleanup.
rule arg_list_len
  @intention: "Number of arguments in a call's argument list"
  @source: vexprparse.intent:56
  input:
    al : ArgList
  output:
    out : number
  logic:
    out = match al:
      ArgCons(head, tail) => 1 + arg_list_len(tail)
      ArgNil => 0
  proofs:
    purity:
      reads : [al]
      calls : [arg_list_len]
    termination:
      bound : 512
      structural : al


-- x86_proc: one rule -> one machine-code proc. prologue (push rbp ; mov rbp, rsp)
-- + the body result expr lowered at off+4 (the body begins 4 bytes into the proc,
-- after the prologue) with the rule's own params + the program + epilogue
-- (pop rax ; mov rsp, rbp ; pop rbp ; ret). Lets are not lowered in this brick.
rule x86_proc
  @intention: "Lower one rule to a machine-code proc: frame prologue, body, epilogue"
  @source: vexprparse.intent:56
  input:
    pg : ProcGenState
  output:
    out : bytes
  logic:
    let blk = rd_body(pg.rd)
    let binds = block_binds(blk)
    let result = block_result(blk)
    let nlets = count_binds(binds)
    let nbind = mb_ast(result) + mb_binds(binds)
    let subsize = if nlets + nbind > 0 then 7 else 0
    let storesize = code_size_let_stores(LetGenState { rem: binds, all_binds: binds, src: pg.src, off: 0, params: rule_params_of(pg.rd), idx: 0, prog: pg.prog, concepts: pg.concepts, sizes: pg.sizes })
    out = concat(b"\x55\x48\x89\xe5", (if nlets + nbind > 0 then concat(b"\x48\x81\xec", le32(8 * (nlets + nbind))) else b""), x86_let_stores(LetGenState { rem: binds, all_binds: binds, src: pg.src, off: pg.off + 4 + subsize, params: rule_params_of(pg.rd), idx: 0, prog: pg.prog, concepts: pg.concepts, sizes: pg.sizes }), (if rule_is_texty(pg) == 1 then concat(x86_stream_node(ByteGenState { node: result, src: pg.src, off: pg.off + 4 + subsize + storesize, params: rule_params_of(pg.rd), lets: binds, prog: pg.prog, concepts: pg.concepts, sizes: pg.sizes }), b"\x6a\x00") else x86_node(ByteGenState { node: result, src: pg.src, off: pg.off + 4 + subsize + storesize, params: rule_params_of(pg.rd), lets: binds, prog: pg.prog, concepts: pg.concepts, sizes: pg.sizes })), b"\x58\x48\x89\xec\x5d\xc3")
  proofs:
    purity:
      reads : [pg, pg.rd, pg.src, pg.off, pg.prog, pg.concepts, pg.sizes]
      calls : [rd_body, block_binds, block_result, count_binds, mb_ast, mb_binds, code_size_let_stores, x86_let_stores, x86_node, rule_is_texty, x86_stream_node, rule_params_of]
    termination:
      bound : 8000


-- ============================================================================
-- STREAMING slice — the WRITER-mode walk. x86_stream_node is the sibling of
-- x86_node for texty rule bodies: instead of pushing a value it WRITES the
-- node's text reading to fd 1, in order, during the walk — no rope, no buffer,
-- no heap. AstStr -> inline write(1, src_base + start + 1, len - 2); concat ->
-- stream each arg in order; a text param var -> unpack the packed span + write;
-- number shapes -> x86_node eval + pop rax + call itoa_proc (the ONE shared
-- callable elf_program_src lays at blob-origin offset -86, right before the
-- first rule proc); if/match -> x86_node cond/scrutinee + streamed arms (the
-- match default streams NOTHING — jmp end, 5 B, vs the value path's 9); a call
-- to a texty rule -> x86_args + call + arg cleanup, dummy rax DISCARDED (no
-- push). Unsupported v1 shapes (substring-in-stream, unknown vars) -> int3.
-- code_size_stream_node mirrors x86_stream_node ARM-FOR-ARM (the drift edge).
-- ============================================================================

-- code_size_stream_node: the EXACT byte count x86_stream_node emits. The itoa
-- path is code_size_node(node) + 6 (pop rax 1 + call rel32 5); AstStr is a
-- fixed 33 (mov rax,1 7 + mov rdi,1 7 + movabs rsi 10 + mov rdx,imm32 7 +
-- syscall 2); a text-param var is a fixed 42 (push var 6 + pop 1 + mov edx,eax
-- 2 + shr rax,32 4 + movabs rsi 10 + add rsi,rax 3 + mov rax,1 7 + mov rdi,1 7
-- + syscall 2); a texty call is args + 12 (call 5 + add rsp,imm32 7, NO push);
-- if is cond + 15 + streamed arms; match is scrut + 14 + 13/arm + 5 (default
-- jmp only) + the streamed arm blocks.
rule code_size_stream_node
  @intention: "Exact byte count x86_stream_node emits for a subtree (mirrors it arm-for-arm)"
  @source: vexprparse.intent:69
  input:
    bg : ByteGenState
  output:
    out : number
  logic:
    out = match bg.node:
      AstNum(value) => code_size_node(bg) + 6
      AstBin(op, lhs, rhs) => code_size_node(bg) + 6
      AstNeg(inner) => code_size_node(bg) + 6
      AstNot(inner) => 1
      AstVar(start, len) => (if param_index(ParamIndexState { params: bg.params, src: bg.src, q_start: start, q_len: len, idx: 0 }) >= 0 then (if param_ty(ParamIndexState { params: bg.params, src: bg.src, q_start: start, q_len: len, idx: 0 }) == 2 then 42 else code_size_node(bg) + 6) else if let_index(LetIndexState { binds: bg.lets, src: bg.src, q_start: start, q_len: len, idx: 0 }) >= 0 then code_size_node(bg) + 6 else 1)
      AstField(base, fstart, flen) => code_size_node(bg) + 6
      AstStr(start, len) => 33
      AstBytes(start, len) => 1
      AstBool(value) => 1
      AstErr => 1
      AstVariant(cstart, clen, vstart, vlen, fields) => code_size_node(bg) + 6
      AstIf(cond, thn, els) => code_size_node(ByteGenState { node: cond, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 15 + code_size_stream_node(ByteGenState { node: thn, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + code_size_stream_node(ByteGenState { node: els, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes })
      AstMatch(scrut, arms) => code_size_node(ByteGenState { node: scrut, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 14 + 13 * arm_list_len(arms) + 5 + stream_size_arms(ArmSizeState { arms: arms, src: bg.src, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes })
      AstCall(callee_start, callee_len, args) => if span_is_concat(SpanCheck { src: bg.src, start: callee_start, len: callee_len }) == 1 then stream_size_cargs(ByteGenArgs { args: args, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) else if span_is_substring(SpanCheck { src: bg.src, start: callee_start, len: callee_len }) == 1 then 1 else if span_is_byte_at(SpanCheck { src: bg.src, start: callee_start, len: callee_len }) == 1 then code_size_node(bg) + 6 else if span_is_length(SpanCheck { src: bg.src, start: callee_start, len: callee_len }) == 1 then code_size_node(bg) + 6 else if callee_is_texty(FindRuleState { rules: bg.prog, src: bg.src, q_start: callee_start, q_len: callee_len }) == 1 then code_size_args(ByteGenArgs { args: args, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 12 else code_size_node(bg) + 6
  proofs:
    purity:
      reads : [bg, bg.node, bg.src, bg.off, bg.params, bg.lets, bg.prog, bg.concepts, bg.sizes]
      calls : [code_size_node, code_size_stream_node, stream_size_cargs, stream_size_arms, code_size_args, param_index, param_ty, let_index, arm_list_len, span_is_concat, span_is_substring, span_is_byte_at, span_is_length, callee_is_texty]
    termination:
      bound : 8000


-- stream_size_cargs: total bytes of streaming a concat's argument list — the
-- sum of each arg's code_size_stream_node (each arg streams its own reading).
rule stream_size_cargs
  @intention: "Total byte count of streaming a concat's argument list in order"
  @source: vexprparse.intent:69
  input:
    ag : ByteGenArgs
  output:
    out : number
  logic:
    out = match ag.args:
      ArgCons(head, tail) => code_size_stream_node(ByteGenState { node: head, src: ag.src, off: ag.off, params: ag.params, lets: ag.lets, prog: ag.prog, concepts: ag.concepts, sizes: ag.sizes }) + stream_size_cargs(ByteGenArgs { args: tail, src: ag.src, off: ag.off, params: ag.params, lets: ag.lets, prog: ag.prog, concepts: ag.concepts, sizes: ag.sizes })
      ArgNil => 0
  proofs:
    purity:
      reads : [ag.args, ag.src, ag.off, ag.params, ag.lets, ag.prog, ag.concepts, ag.sizes]
      calls : [code_size_stream_node, stream_size_cargs]
    termination:
      bound : 8000


-- stream_size_arms: total bytes of a streamed match's arm blocks. Per arm: 14
-- per binder (the arena-payload loads, same as the value path) + the body's
-- code_size_stream_node (sized with the binders appended to the scope) + 5
-- (jmp end). Mirror of code_size_arms over the streaming walk.
rule stream_size_arms
  @intention: "Total byte count of a streamed match's arm blocks (binder loads + streamed body + jmp end)"
  @source: vexprparse.intent:69
  input:
    az : ArmSizeState
  output:
    out : number
  logic:
    out = match az.arms:
      ArmCons(vstart, vlen, binders, body, rest) => 14 * binder_list_len(binders) + code_size_stream_node(ByteGenState { node: body, src: az.src, off: 0, params: az.params, lets: lets_append_binders(AppendBindersState { lets: az.lets, bs: binders }), prog: az.prog, concepts: az.concepts, sizes: az.sizes }) + 5 + stream_size_arms(ArmSizeState { arms: rest, src: az.src, params: az.params, lets: az.lets, prog: az.prog, concepts: az.concepts, sizes: az.sizes })
      ArmNil => 0
  proofs:
    purity:
      reads : [az.arms, az.src, az.params, az.lets, az.prog, az.concepts, az.sizes]
      calls : [binder_list_len, code_size_stream_node, lets_append_binders, stream_size_arms]
    termination:
      bound : 8000


-- x86_stream_node: the WRITER-mode emitter. Every arm's byte count MUST equal
-- code_size_stream_node's — the two-pass drift edge. The shared itoa call's
-- rel32 targets blob-origin offset -86 (itoa_proc sits right before the first
-- rule proc), so rel32 = -86 - (call_site + 5) = 0 - (off + node_size + 92)
-- with the call at off + node_size + 1 (after the value ops and the pop).
-- src_base for AstStr / text-param writes is the SAME 0x400000 + blob_end_off
-- imm64 the byte_at emit loads — one definition, no drift.
rule x86_stream_node
  @intention: "Stream a texty subtree: write its text reading to fd 1 in order during the walk"
  @source: vexprparse.intent:69
  input:
    bg : ByteGenState
  output:
    out : bytes
  logic:
    out = match bg.node:
      AstNum(value) => concat(x86_node(bg), b"\x58\xe8", le32(0 - (bg.off + code_size_node(bg) + 92)))
      AstBin(op, lhs, rhs) => concat(x86_node(bg), b"\x58\xe8", le32(0 - (bg.off + code_size_node(bg) + 92)))
      AstNeg(inner) => concat(x86_node(bg), b"\x58\xe8", le32(0 - (bg.off + code_size_node(bg) + 92)))
      AstNot(inner) => b"\xcc"
      AstVar(start, len) => (if param_index(ParamIndexState { params: bg.params, src: bg.src, q_start: start, q_len: len, idx: 0 }) >= 0 then (if param_ty(ParamIndexState { params: bg.params, src: bg.src, q_start: start, q_len: len, idx: 0 }) == 2 then concat(b"\xff\xb5", le32(16 + 8 * (param_list_len(bg.params) - 1 - param_index(ParamIndexState { params: bg.params, src: bg.src, q_start: start, q_len: len, idx: 0 }))), b"\x58\x89\xc2\x48\xc1\xe8\x20\x48\xbe", le64(4194304 + blob_end_off(ProgGenState { rules: bg.prog, src: bg.src, off: 0, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes })), b"\x48\x01\xc6\x48\xc7\xc0\x01\x00\x00\x00\x48\xc7\xc7\x01\x00\x00\x00\x0f\x05") else concat(x86_node(bg), b"\x58\xe8", le32(0 - (bg.off + code_size_node(bg) + 92)))) else if let_index(LetIndexState { binds: bg.lets, src: bg.src, q_start: start, q_len: len, idx: 0 }) >= 0 then concat(x86_node(bg), b"\x58\xe8", le32(0 - (bg.off + code_size_node(bg) + 92))) else b"\xcc")
      AstField(base, fstart, flen) => concat(x86_node(bg), b"\x58\xe8", le32(0 - (bg.off + code_size_node(bg) + 92)))
      AstStr(start, len) => concat(b"\x48\xc7\xc0\x01\x00\x00\x00\x48\xc7\xc7\x01\x00\x00\x00\x48\xbe", le64(4194304 + blob_end_off(ProgGenState { rules: bg.prog, src: bg.src, off: 0, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + start + 1), b"\x48\xc7\xc2", le32(if len >= 2 then len - 2 else 0), b"\x0f\x05")
      AstBytes(start, len) => b"\xcc"
      AstBool(value) => b"\xcc"
      AstErr => b"\xcc"
      AstVariant(cstart, clen, vstart, vlen, fields) => concat(x86_node(bg), b"\x58\xe8", le32(0 - (bg.off + code_size_node(bg) + 92)))
      AstIf(cond, thn, els) => concat(x86_node(ByteGenState { node: cond, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), b"\x58\x48\x85\xc0\x0f\x84", le32(code_size_stream_node(ByteGenState { node: thn, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 5), x86_stream_node(ByteGenState { node: thn, src: bg.src, off: bg.off + code_size_node(ByteGenState { node: cond, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 10, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), b"\xe9", le32(code_size_stream_node(ByteGenState { node: els, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes })), x86_stream_node(ByteGenState { node: els, src: bg.src, off: bg.off + code_size_node(ByteGenState { node: cond, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 15 + code_size_stream_node(ByteGenState { node: thn, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }))
      AstMatch(scrut, arms) => concat(x86_node(ByteGenState { node: scrut, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), b"\x58\x48\x69\xc0", le32(8 * (max_payload_fields(bg.concepts) + 1)), b"\x4c\x01\xf8\x48\x8b\x08", x86_stream_dispatch(DispatchState { arms: arms, src: bg.src, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes, rest_disp: 13 * (arm_list_len(arms) - 1), pre_arms: 0 }), b"\xe9", le32(stream_size_arms(ArmSizeState { arms: arms, src: bg.src, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes })), x86_stream_arms(ArmGenState { arms: arms, src: bg.src, off: bg.off + code_size_node(ByteGenState { node: scrut, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 14 + 13 * arm_list_len(arms) + 5, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }))
      AstCall(callee_start, callee_len, args) => if span_is_concat(SpanCheck { src: bg.src, start: callee_start, len: callee_len }) == 1 then x86_stream_cargs(ByteGenArgs { args: args, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) else if span_is_substring(SpanCheck { src: bg.src, start: callee_start, len: callee_len }) == 1 then b"\xcc" else if span_is_byte_at(SpanCheck { src: bg.src, start: callee_start, len: callee_len }) == 1 then concat(x86_node(bg), b"\x58\xe8", le32(0 - (bg.off + code_size_node(bg) + 92))) else if span_is_length(SpanCheck { src: bg.src, start: callee_start, len: callee_len }) == 1 then concat(x86_node(bg), b"\x58\xe8", le32(0 - (bg.off + code_size_node(bg) + 92))) else if callee_is_texty(FindRuleState { rules: bg.prog, src: bg.src, q_start: callee_start, q_len: callee_len }) == 1 then concat(x86_args(ByteGenArgs { args: args, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }), b"\xe8", le32(proc_offset(ProcOffState { rules: bg.prog, src: bg.src, acc: 0, q_start: callee_start, q_len: callee_len, concepts: bg.concepts, sizes: bg.sizes }) - (bg.off + code_size_args(ByteGenArgs { args: args, src: bg.src, off: bg.off, params: bg.params, lets: bg.lets, prog: bg.prog, concepts: bg.concepts, sizes: bg.sizes }) + 5)), b"\x48\x81\xc4", le32(8 * arg_list_len(args))) else concat(x86_node(bg), b"\x58\xe8", le32(0 - (bg.off + code_size_node(bg) + 92)))
  proofs:
    purity:
      reads : [bg, bg.node, bg.src, bg.off, bg.params, bg.lets, bg.prog, bg.concepts, bg.sizes]
      calls : [x86_node, code_size_node, x86_stream_node, code_size_stream_node, x86_stream_cargs, x86_stream_dispatch, x86_stream_arms, stream_size_arms, x86_args, code_size_args, param_index, param_ty, param_list_len, let_index, arm_list_len, max_payload_fields, proc_offset, arg_list_len, blob_end_off, span_is_concat, span_is_substring, span_is_byte_at, span_is_length, callee_is_texty]
    termination:
      bound : 8000


-- x86_stream_cargs: stream a concat's arguments in source order — each arg
-- writes its own text reading (text writes bytes, numbers itoa), so the concat
-- IS just the sequence. `off` threads by each arg's stream size.
rule x86_stream_cargs
  @intention: "Stream a concat's argument list in source order, each arg writing its own reading"
  @source: vexprparse.intent:69
  input:
    ag : ByteGenArgs
  output:
    out : bytes
  logic:
    out = match ag.args:
      ArgCons(head, tail) => concat(x86_stream_node(ByteGenState { node: head, src: ag.src, off: ag.off, params: ag.params, lets: ag.lets, prog: ag.prog, concepts: ag.concepts, sizes: ag.sizes }), x86_stream_cargs(ByteGenArgs { args: tail, src: ag.src, off: ag.off + code_size_stream_node(ByteGenState { node: head, src: ag.src, off: ag.off, params: ag.params, lets: ag.lets, prog: ag.prog, concepts: ag.concepts, sizes: ag.sizes }), params: ag.params, lets: ag.lets, prog: ag.prog, concepts: ag.concepts, sizes: ag.sizes }))
      ArgNil => b""
  proofs:
    purity:
      reads : [ag.args, ag.src, ag.off, ag.params, ag.lets, ag.prog, ag.concepts, ag.sizes]
      calls : [x86_stream_node, code_size_stream_node, x86_stream_cargs]
    termination:
      bound : 8000


-- x86_stream_dispatch: the streamed match's cmp/je chain. Identical shape to
-- x86_dispatch, but the default block is 5 bytes (jmp end only — a streamed
-- default writes nothing) and the arm block sizes come from the STREAM walk:
-- je rel = rest_disp + 5 + pre_arms.
rule x86_stream_dispatch
  @intention: "Emit a streamed match's tag-dispatch cmp/je chain (default block is jmp-only, 5 bytes)"
  @source: vexprparse.intent:69
  input:
    ds : DispatchState
  output:
    out : bytes
  logic:
    out = match ds.arms:
      ArmCons(vstart, vlen, binders, body, rest) => concat(b"\x48\x81\xf9", le32(arm_tag_by_name(ArmTagState { concepts: ds.concepts, src: ds.src, vstart: vstart, vlen: vlen, cidx: 0 })), b"\x0f\x84", le32(ds.rest_disp + 5 + ds.pre_arms), x86_stream_dispatch(DispatchState { arms: rest, src: ds.src, params: ds.params, lets: ds.lets, prog: ds.prog, concepts: ds.concepts, sizes: ds.sizes, rest_disp: ds.rest_disp - 13, pre_arms: ds.pre_arms + 14 * binder_list_len(binders) + code_size_stream_node(ByteGenState { node: body, src: ds.src, off: 0, params: ds.params, lets: lets_append_binders(AppendBindersState { lets: ds.lets, bs: binders }), prog: ds.prog, concepts: ds.concepts, sizes: ds.sizes }) + 5 }))
      ArmNil => b""
  proofs:
    purity:
      reads : [ds.arms, ds.src, ds.params, ds.lets, ds.prog, ds.concepts, ds.sizes, ds.rest_disp, ds.pre_arms]
      calls : [arm_tag_by_name, x86_stream_dispatch, binder_list_len, code_size_stream_node, lets_append_binders]
    termination:
      bound : 8000


-- x86_stream_arms: the streamed match's arm blocks. Per arm: the binder loads
-- (same 14-byte copies as the value path — rax still holds node_addr), the
-- body STREAMED with the binders appended to the scope, then jmp end (rel =
-- stream_size_arms of the remaining arms).
rule x86_stream_arms
  @intention: "Emit a streamed match's arm blocks: binder loads, streamed body, jmp to the match end"
  @source: vexprparse.intent:69
  input:
    ag : ArmGenState
  output:
    out : bytes
  logic:
    out = match ag.arms:
      ArmCons(vstart, vlen, binders, body, rest) => concat(x86_binder_loads(BinderLoadState { binders: binders, j: 0, base_slot: count_binds(ag.lets) }), x86_stream_node(ByteGenState { node: body, src: ag.src, off: ag.off + 14 * binder_list_len(binders), params: ag.params, lets: lets_append_binders(AppendBindersState { lets: ag.lets, bs: binders }), prog: ag.prog, concepts: ag.concepts, sizes: ag.sizes }), b"\xe9", le32(stream_size_arms(ArmSizeState { arms: rest, src: ag.src, params: ag.params, lets: ag.lets, prog: ag.prog, concepts: ag.concepts, sizes: ag.sizes })), x86_stream_arms(ArmGenState { arms: rest, src: ag.src, off: ag.off + 14 * binder_list_len(binders) + code_size_stream_node(ByteGenState { node: body, src: ag.src, off: 0, params: ag.params, lets: lets_append_binders(AppendBindersState { lets: ag.lets, bs: binders }), prog: ag.prog, concepts: ag.concepts, sizes: ag.sizes }) + 5, params: ag.params, lets: ag.lets, prog: ag.prog, concepts: ag.concepts, sizes: ag.sizes }))
      ArmNil => b""
  proofs:
    purity:
      reads : [ag.arms, ag.src, ag.off, ag.params, ag.lets, ag.prog, ag.concepts, ag.sizes]
      calls : [x86_binder_loads, x86_stream_node, code_size_stream_node, stream_size_arms, lets_append_binders, binder_list_len, count_binds, x86_stream_arms]
    termination:
      bound : 8000


-- x86_program: every rule, in source order, as its machine-code proc. Threads a
-- running blob offset (`off`) so each proc knows its own absolute start (needed
-- for its calls' rel32). The entry (first rule) is laid first at offset 0, so the
-- blob called at byte 0 runs main. The next proc's offset = this proc's offset +
-- its proc_size.
rule x86_program
  @intention: "Lower a whole program to one callable machine-code blob, one proc per rule, entry first at offset 0"
  @source: vexprparse.intent:56
  input:
    pg : ProgGenState
  output:
    out : bytes
  logic:
    out = match pg.rules:
      RCons(head, tail) => concat(x86_proc(ProcGenState { rd: head, src: pg.src, off: pg.off, prog: pg.prog, concepts: pg.concepts, sizes: pg.sizes }), x86_program(ProgGenState { rules: tail, src: pg.src, off: pg.off + proc_size(ProcGenState { rd: head, src: pg.src, off: 0, prog: pg.prog, concepts: pg.concepts, sizes: pg.sizes }), prog: pg.prog, concepts: pg.concepts, sizes: pg.sizes }))
      RNil => b""
  proofs:
    purity:
      reads : [pg.rules, pg.src, pg.off, pg.prog, pg.concepts, pg.sizes]
      calls : [x86_proc, x86_program, proc_size]
    termination:
      bound : 8000


-- x86_program_src: the b4b-1 money-shot driver. Tokenize (INDENT/DEDENT — a
-- program is multi-line), parse the whole program, and lower every rule to its
-- machine-code proc, entry first at offset 0. The blob is real x86-64: mmap'd
-- RWX and called as `fn() -> i64` at byte 0, it runs main and returns its result.
--
--   x86_program_src("rule main\n  logic:\n    out = double(add(3, 4))\n
--                    rule add(x, y)\n  logic:\n    out = x + y\n
--                    rule double(x)\n  logic:\n    out = x * 2")
--     -> a blob whose entry (main) computes double(add(3, 4)) = 14.
--
-- NATIVE-ONLY (streaming bytes). Verified by streaming_x86_program_executes:
-- mmap+exec(blob) == eval_main(program).
rule x86_program_src
  @intention: "Tokenize, parse a whole program, and lower it to one callable x86-64 machine-code blob"
  @source: vexprparse.intent:56
  input:
    s : ScanState
  output:
    out : bytes
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let concepts = parse_concepts(ProgramState { cell: toks, src: s.source })
    let sizes = proc_sizes(ProgGenState { rules: prog, src: s.source, off: 0, prog: prog, concepts: concepts, sizes: ProcSizeList::PSNil })
    out = x86_program(ProgGenState { rules: prog, src: s.source, off: 0, prog: prog, concepts: concepts, sizes: sizes })
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, parse_concepts, proc_sizes, x86_program]
    termination:
      bound : 256


-- ============================================================================
-- BRICK b5 — WRAP THE BLOB IN A STANDALONE ELF EXECUTABLE.
-- x86_program (b4b-1) lowers a program to a position-independent machine-code
-- blob whose entry proc is at offset 0 and returns its value in rax. This brick
-- wraps that blob in a minimal static ELF64 + a 17-byte `_start` trampoline so
-- the output is a runnable file: emit it, `chmod +x`, `./a.out`, and the entry
-- proc's value comes back as the process exit code (0..255 — printing arbitrary
-- i64 needs itoa-in-machine-code, a later brick).
-- ============================================================================

-- ps_total: the TOTAL byte length of the whole x86_program blob = sum of every
-- entry in the PRECOMPUTED proc-size list. Replaces the old program_total_size,
-- which re-walked (and re-sized) every proc body; ps_total just folds the cached
-- sizes, so blob_end_off (called at ~6 sites per emit) costs a flat list sum
-- instead of a full program re-sizing each time. Needed to fill the one computed
-- ELF field (p_filesz = p_memsz = 137 + this).
rule ps_total
  @intention: "Total byte length of the whole x86_program blob = sum of the precomputed proc sizes"
  @source: vexprparse.intent:60
  input:
    psl : ProcSizeList
  output:
    out : number
  logic:
    out = match psl:
      PSCons(sz, rest) => sz + ps_total(rest)
      PSNil => 0
  proofs:
    purity:
      reads : [psl]
      calls : [ps_total]
    termination:
      bound : 8000


-- blob_end_off: the file offset where the program blob ENDS = ELF headers (120)
-- + the optional 61-byte mmap arena prologue + the trampoline (101 B for a
-- number entry, 45 B for a texty entry — streaming slice) + the shared
-- itoa_proc (86 B, present iff any rule is texty) + the blob itself. Text
-- values slice 2: this is ALSO the file offset where the embedded source
-- begins, so `src_base = 0x400000 + blob_end_off` is the COMPILE-TIME imm64
-- x86_node's byte_at emit AND x86_stream_node's text writes load — and
-- elf_program_src's pre-append p_filesz. ONE definition for all so they can
-- never drift. A texty-free program keeps the historical 221 + arena + blob.
rule blob_end_off
  @intention: "File offset where the program blob ends: headers + arena? + trampoline variant + itoa? + blob size (= the embedded-source base)"
  @source: vexprparse.intent:66
  input:
    pg : ProgGenState
  output:
    out : number
  logic:
    let entry_params = if param_list_len(rl_head_params(pg.rules)) > 0 then rl_head_params(pg.rules) else fields_to_params(rl_head_input(pg.rules))
    let has_input = if param_list_len(entry_params) > 0 then 1 else 0
    let efields = params_to_fields(entry_params)
    let ecfields = cd_fields(concept_at_index(ConceptAtState { concepts: pg.concepts, idx: find_concept_index(FindConceptIdxState { concepts: pg.concepts, src: pg.src, q_start: fl_head_ty_start(efields), q_len: fl_head_ty_len(efields), idx: 0 }) }))
    let msize = if has_input == 1 and entry_rule_texty(pg) == 0 then (if field_list_has_text(ecfields) == 1 then stdin_marshal_size(ecfields) else argv_marshal_size(ecfields)) else 0
    out = 120 + (if program_uses_arena(pg.concepts) == 1 then 61 else 0) + (if entry_rule_texty(pg) == 1 then 45 else 101) + (if prog_any_texty(pg) == 1 then 86 else 0) + msize + ps_total(pg.sizes)
  proofs:
    purity:
      reads : [pg, pg.rules, pg.src, pg.concepts, pg.sizes]
      calls : [program_uses_arena, entry_rule_texty, prog_any_texty, ps_total, param_list_len, rl_head_params, fields_to_params, rl_head_input, params_to_fields, argv_marshal_size, stdin_marshal_size, field_list_has_text, cd_fields, concept_at_index, find_concept_index, fl_head_ty_start, fl_head_ty_len]
    termination:
      bound : 8000


-- SrcBlobState: the source-append cursor — the interpreted source text plus
-- the byte position of the next 4-byte chunk to emit.
concept SrcBlobState
  @intention: "The interpreted source text plus the emit cursor, for appending the source bytes to the ELF"
  @source: vexprparse.intent:66
  fields:
    src : text [..256]
    pos : number [0, 4000000]


-- src_blob: append the interpreted source BYTES to the ELF, 4 source bytes per
-- le32 word (byte k lands at file offset base+k because le32 writes low byte
-- first), zero-padded past the end of the source up to a 4-byte boundary (the
-- pad is mapped but never indexed — every span keeps start+len <= length(src)).
-- The bytes type has no 1-byte emitter, so this rides the existing le32 path:
-- pack b0 + 256*b1 + 65536*b2 + 16777216*b3 (guards keep the host byte_at in
-- bounds; a missing tail byte contributes 0). Recursion advances pos by 4 and
-- stops at pos >= length(src) — the emitted byte count is exactly
-- 4 * ((length(src) + 3) / 4), the same value elf_program_src adds to p_filesz.
rule src_blob
  @intention: "Append the interpreted source as bytes, one le32 word per 4 source bytes, zero-padded to a 4-byte boundary"
  @source: vexprparse.intent:66
  input:
    sb : SrcBlobState
  output:
    out : bytes
  logic:
    out = if sb.pos >= length(sb.src) then b"" else concat(le32(byte_at(sb.src, sb.pos) + 256 * (if sb.pos + 1 < length(sb.src) then byte_at(sb.src, sb.pos + 1) else 0) + 65536 * (if sb.pos + 2 < length(sb.src) then byte_at(sb.src, sb.pos + 2) else 0) + 16777216 * (if sb.pos + 3 < length(sb.src) then byte_at(sb.src, sb.pos + 3) else 0)), src_blob(SrcBlobState { src: sb.src, pos: sb.pos + 4 }))
  proofs:
    purity:
      reads : [sb.src, sb.pos]
      calls : [src_blob]
    termination:
      bound : 8000


-- elf_program_src: the b5 money-shot driver (b8 prints the result). Tokenize +
-- parse a whole program, then emit a STANDALONE static ELF64 executable wrapping
-- the x86_program blob:
--   [ELF64 header 64 B] [one PT_LOAD program header 56 B] [_start trampoline 101 B]
--   [program blob].
-- Load base = 0x400000; the single PT_LOAD maps the whole file (offset 0) at
-- 0x400000 R+X. Entry = 0x400000 + 120 (the trampoline, right after the 120 bytes
-- of headers). The blob starts at file offset 221 (120 + 101). The only computed
-- field is p_filesz = p_memsz = 221 + program_total_size(prog), emitted via le64.
-- b8: the trampoline `call rel32 = 96` reaches the first proc (221 - 125); the
-- returned i64 in rax is converted to decimal ASCII (with '-' for negatives, "0"
-- for zero) plus a trailing newline into a 32-byte stack buffer via an unsigned
-- div-by-10 loop, written to stdout (sys_write), then sys_exit(0). So ANY i64
-- result is observable on stdout (e.g. fact(10) = 3628800), not just exit codes.
--
--   elf_program_src("rule main\n  logic:\n    out = fact(5)\n
--                    rule fact(n)\n  logic:\n    out = if n == 0 then 1 else n * fact(n - 1)")
--     -> ELF bytes; written to a file, chmod +x, run -> prints "120\n", exits 0.
--
-- NATIVE-ONLY (streaming bytes). Verified by streaming_elf_prints_result: the
-- emitted file's STDOUT (trimmed) == eval_main(program) for arbitrary i64 results.
--
-- STREAMING slice: when the ENTRY rule is texty (rule_is_texty), the trampoline
-- becomes call entry ; write(1, "\n", 1) ; exit(0) — 45 B, rel32 126 (past the
-- 86-B itoa_proc laid between the trampoline and the first rule proc). The
-- itoa_proc (rax -> decimal on fd 1, NO newline, callee-preserves r14/r15) is
-- emitted iff ANY rule is texty; number-only programs keep the 101-B b8
-- trampoline with rel32 96 — byte-identical files. The embedding gate extends
-- to `program_uses_text OR any-texty` so streamed spans always have src bytes.
-- ============================================================================
-- RUNTIME TEXT INPUT — the emitted ELF reads its input from argv, the SAME
-- convention as verbosec's own native binaries: one argv per input FIELD of the
-- ENTRY rule (text raw, number decimal). `./elf "rule a\n..." 0` runs the
-- compiled entry rule on real input. The entry rule takes a SINGLE record param
-- (e.g. `s : ScanState`); the trampoline reads one argv per field of that
-- concept, builds the record in the node arena, and passes its index — exactly
-- the shape verbosec's --run word_length expects.
--
-- The FIXED-region trick keeps the packed-span model intact: argv text lives at
-- a runtime address, so the trampoline mmaps a FIXED region at 0x20000000 and
-- copies the argv bytes there. A text value = pack((0x20000000 - src_base) +
-- bump, len) — the region offset is a COMPILE-TIME constant (src_base is known
-- at emit), so byte_at / length / substring / streaming all keep working with
-- src_base + start.
--
-- Register/stack choreography at _start (after the optional arena prologue,
-- which sets r15=arena base / r14=node count and does NOT touch rsp): r12 saves
-- the entry rsp (argc at [r12], argv[k] at [r12 + 8*(k+1)]) so argv reads stay
-- correct across the field pushes; r13 is the fixed-region bump cursor (offset
-- into 0x20000000). Both r12/r13 are free at _start (arena prologue uses only
-- r15/r14). The marshalling runs BEFORE the `call entry` in the number
-- trampoline, so the call's rel32 (96, +86 with itoa) is UNCHANGED — the call
-- and the first proc both shift by the marshalling size.
-- ============================================================================

concept ArgvMarshalState
  @intention: "A concept field list to marshal from argv + the current arg index + the fixed-region offsets"
  @source: vexprparse.intent:66
  fields:
    fields : FieldList
    idx : number
    region_off : number
    region_base : number


concept FieldPopState
  @intention: "The remaining concept fields to pop + the arena payload slot the next pop stores into"
  @source: vexprparse.intent:66
  fields:
    fields : FieldList
    slot : number


concept ArgvTrampState
  @intention: "The entry concept's fields + source + program + concepts + concept index, to emit the argv trampoline"
  @source: vexprparse.intent:66
  fields:
    fields : FieldList
    src : text [..256]
    prog : RuleList
    concepts : ConceptList
    sizes : ProcSizeList
    cidx : number


-- marshal_fields_size: the exact byte length of the per-field argv marshalling.
-- A text field is 52 B (mov rsi,[r12+disp] 8 + strlen 13 + copy&pack 31); a
-- number field is 65 B (mov rsi,[r12+disp] 8 + atoi 57). One helper used by both
-- the emit (via argv_marshal_size in blob_end_off) and the byte pass, so the
-- trampoline size can never drift from the source-blob base.
rule marshal_fields_size
  @intention: "Byte length of the per-field argv marshalling (text field 52 B, number field 65 B)"
  @source: vexprparse.intent:66
  input:
    fl : FieldList
  output:
    out : number
  logic:
    out = match fl:
      FCons(name_start, name_len, ty, ty_start, ty_len, rest) => (if ty == 2 then 52 else 65) + marshal_fields_size(rest)
      FNil => 0
  proofs:
    purity:
      reads : [fl]
      calls : [marshal_fields_size]
    termination:
      bound : 512
      structural : fl


-- argv_marshal_size: the TOTAL trampoline-marshalling byte length = prologue 88
-- (save r12, argc guard, mmap fixed region, zero r13) + per-field marshalling +
-- arena suffix 25 + 8*nfields (mov rax,r14 3 + imul 7 + add r15 3 + mov tag 7 +
-- pop each field 8 + push r14 2 + inc r14 3). blob_end_off adds this to the
-- source-blob base ONLY when the entry rule has an input, so texty-free /
-- input-free programs stay byte-identical.
rule argv_marshal_size
  @intention: "Total byte length of the argv trampoline marshalling: prologue 88 + per-field + arena suffix 25 + 8*nfields"
  @source: vexprparse.intent:66
  input:
    fl : FieldList
  output:
    out : number
  logic:
    out = 88 + marshal_fields_size(fl) + 25 + 8 * field_list_len(fl)
  proofs:
    purity:
      reads : [fl]
      calls : [marshal_fields_size, field_list_len]
    termination:
      bound : 64


-- x86_marshal_fields: emit the per-field argv reads. For field k, argv[k+1] is at
-- [r12 + 8*(k+2)] (argv[0] is the program name at [r12+8]). A TEXT field: strlen
-- (byte loop scanning for NUL), rep movsb the bytes into the fixed region at the
-- r13 bump, push pack((region_off + bump) << 32 | len), bump += len. A NUMBER
-- field: inline atoi (leading '-' supported), push the value. One push per field,
-- in declaration order, consumed by the arena suffix (x86_field_pops).
rule x86_marshal_fields
  @intention: "Emit per-field argv reads: text field -> strlen+copy+pack packed span; number field -> atoi; one push each"
  @source: vexprparse.intent:66
  input:
    ms : ArgvMarshalState
  output:
    out : bytes
  logic:
    out = match ms.fields:
      FCons(name_start, name_len, ty, ty_start, ty_len, rest) => concat((if ty == 2 then concat(b"\x49\x8b\xb4\x24", le32(8 * (ms.idx + 2)), b"\x31\xc9\x80\x3c\x0e\x00\x74\x05\x48\xff\xc1\xeb\xf5\x49\x8d\xbd", le32(ms.region_base), b"\x51\xf3\xa4\x59\x4c\x89\xe8\x48\x05", le32(ms.region_off), b"\x48\xc1\xe0\x20\x48\x09\xc8\x50\x49\x01\xcd") else concat(b"\x49\x8b\xb4\x24", le32(8 * (ms.idx + 2)), b"\x48\x31\xc0\x45\x31\xdb\x8a\x0e\x80\xf9\x2d\x75\x06\x41\xb3\x01\x48\xff\xc6\x0f\xb6\x0e\x80\xf9\x30\x72\x15\x80\xf9\x39\x77\x10\x48\x6b\xc0\x0a\x48\x83\xe9\x30\x48\x01\xc8\x48\xff\xc6\xeb\xe3\x4d\x85\xdb\x74\x03\x48\xf7\xd8\x50")), x86_marshal_fields(ArgvMarshalState { fields: rest, idx: ms.idx + 1, region_off: ms.region_off, region_base: ms.region_base }))
      FNil => b""
  proofs:
    purity:
      reads : [ms.fields, ms.idx, ms.region_off, ms.region_base]
      calls : [x86_marshal_fields]
    termination:
      bound : 512


-- x86_field_pops: the FieldList sibling of x86_vpops — pop each marshalled field
-- value off the CPU stack into its arena payload slot [rax + 8 + 8*slot]. The
-- first pop takes top-of-stack (the LAST field pushed) into the highest slot, so
-- field j lands in slot j (matching field_index_of). Per field: pop rcx (59) ;
-- mov [rax + 8 + 8*slot], rcx (48 89 88 + le32).
rule x86_field_pops
  @intention: "Emit pop+store of each marshalled field value into its arena payload slot (FieldList variant of x86_vpops)"
  @source: vexprparse.intent:66
  input:
    fp : FieldPopState
  output:
    out : bytes
  logic:
    out = match fp.fields:
      FCons(name_start, name_len, ty, ty_start, ty_len, rest) => concat(b"\x59\x48\x89\x88", le32(8 + 8 * fp.slot), x86_field_pops(FieldPopState { fields: rest, slot: fp.slot - 1 }))
      FNil => b""
  proofs:
    purity:
      reads : [fp.fields, fp.slot]
      calls : [x86_field_pops]
    termination:
      bound : 512


-- x86_argv_marshal: the whole trampoline marshalling. Prologue: mov r12,rsp (save
-- argv base) ; argc guard (argc < 1+nfields -> exit(1)) ; mmap(0x20000000, 1 MiB,
-- RW, MAP_FIXED|PRIVATE|ANON) with MAP_FAILED -> exit(1) ; xor r13 (bump = 0).
-- Then x86_marshal_fields pushes one value per concept field. Then the arena
-- suffix builds a node exactly like x86_node's AstVariant record path: node_addr =
-- r15 + r14*entry_size, write the record tag (concept_index*256), pop each field
-- into its payload slot, push r14 (the node index = the entry's single arg), inc
-- r14. src_base = 0x400000 + blob_end_off is the COMPILE-TIME base; region_off =
-- 0x20000000 - src_base makes every packed argv span resolve to 0x20000000+bump.
rule x86_argv_marshal
  @intention: "Emit the full argv trampoline marshalling: prologue (save argv base, argc guard, mmap fixed region), per-field reads, arena node build, push index"
  @source: vexprparse.intent:66
  input:
    at : ArgvTrampState
  output:
    out : bytes
  logic:
    let src_base = 4194304 + blob_end_off(ProgGenState { rules: at.prog, src: at.src, off: 0, prog: at.prog, concepts: at.concepts, sizes: at.sizes })
    let region_base = 536870912
    let region_off = region_base - src_base
    let nfields = field_list_len(at.fields)
    let entry_size = 8 * (max_payload_fields(at.concepts) + 1)
    let tag = at.cidx * 256
    out = concat(b"\x49\x89\xe4\x49\x8b\x04\x24\x48\x3d", le32(1 + nfields), b"\x7d\x0c\xbf\x01\x00\x00\x00\xb8\x3c\x00\x00\x00\x0f\x05\xb8\x09\x00\x00\x00\xbf\x00\x00\x00\x20\xbe\x00\x00\x10\x00\xba\x03\x00\x00\x00\x41\xba\x32\x00\x00\x00\x49\xc7\xc0\xff\xff\xff\xff\x45\x31\xc9\x0f\x05\x48\x3d\x01\xf0\xff\xff\x72\x0c\xbf\x01\x00\x00\x00\xb8\x3c\x00\x00\x00\x0f\x05\x45\x31\xed", x86_marshal_fields(ArgvMarshalState { fields: at.fields, idx: 0, region_off: region_off, region_base: region_base }), b"\x4c\x89\xf0\x48\x69\xc0", le32(entry_size), b"\x4c\x01\xf8\x48\xc7\x00", le32(tag), x86_field_pops(FieldPopState { fields: at.fields, slot: nfields - 1 }), b"\x41\x56\x49\xff\xc6")
  proofs:
    purity:
      reads : [at.fields, at.src, at.prog, at.concepts, at.sizes, at.cidx]
      calls : [blob_end_off, field_list_len, max_payload_fields, x86_marshal_fields, x86_field_pops]
    termination:
      bound : 64


-- ============================================================================
-- STDIN INPUT CHANNEL — when the entry rule's record has a TEXT field, the
-- emitted ELF reads its source from fd 0 (stdin) instead of argv, so it can
-- process inputs larger than argv's 128 KiB cap (the self-hosted front end's
-- own 846 KB source). The one text field is read to EOF into the MAP_FIXED
-- region at 0x20000000, packed as (region_off, total_bytes). Number fields keep
-- coming from argv, in declaration order among the number fields (argv[1],
-- argv[2], ... — the text field is NOT in argv). Same arena node-build as the
-- argv trampoline. Deterministic channel choice at emit time: entry has a text
-- field -> stdin; otherwise -> argv. See docs/self-hosting-stdin-channel-design.md
-- ============================================================================

-- field_list_has_text: 1 if any field is text (ty == 2), else 0 — the emit-time
-- switch between the stdin trampoline and the argv one.
rule field_list_has_text
  @intention: "1 if the field list contains a text field (ty == 2), 0 otherwise"
  @source: vexprparse.intent:66
  input:
    fl : FieldList
  output:
    out : number
  logic:
    out = match fl:
      FCons(name_start, name_len, ty, ty_start, ty_len, rest) => if ty == 2 then 1 else field_list_has_text(rest)
      FNil => 0
  proofs:
    purity:
      reads : [fl]
      calls : [field_list_has_text]
    termination:
      bound : 512
      structural : fl


-- number_fields_count: how many NON-text fields — only number fields ride argv
-- in the stdin trampoline, so the argc guard is argc >= 1 + number_fields_count.
rule number_fields_count
  @intention: "Count of non-text (number) fields — the argv arity of the stdin trampoline"
  @source: vexprparse.intent:66
  input:
    fl : FieldList
  output:
    out : number
  logic:
    out = match fl:
      FCons(name_start, name_len, ty, ty_start, ty_len, rest) => (if ty == 2 then 0 else 1) + number_fields_count(rest)
      FNil => 0
  proofs:
    purity:
      reads : [fl]
      calls : [number_fields_count]
    termination:
      bound : 512
      structural : fl


concept StdinMarshalState
  @intention: "The remaining concept fields to marshal + the argv index of the next number field + the fixed-region offset"
  @source: vexprparse.intent:66
  fields:
    fields : FieldList
    num_idx : number
    region_off : number


-- stdin_fields_size: byte length of the per-field stdin marshalling. A text
-- field is 13 B (mov eax,region_off 5 + shl rax,32 4 + or rax,r13 3 + push 1);
-- a number field is 65 B (mov rsi,[r12+disp] 8 + inline atoi 57), same as argv.
rule stdin_fields_size
  @intention: "Byte length of per-field stdin marshalling (text field 13 B, number field 65 B)"
  @source: vexprparse.intent:66
  input:
    fl : FieldList
  output:
    out : number
  logic:
    out = match fl:
      FCons(name_start, name_len, ty, ty_start, ty_len, rest) => (if ty == 2 then 13 else 65) + stdin_fields_size(rest)
      FNil => 0
  proofs:
    purity:
      reads : [fl]
      calls : [stdin_fields_size]
    termination:
      bound : 512
      structural : fl


-- stdin_marshal_size: total byte length of the stdin trampoline = prologue 88
-- (save argv base, argc guard, mmap fixed region, zero r13) + read loop 55 +
-- per-field marshalling + arena suffix 25 + 8*nfields. blob_end_off adds this
-- to the source-blob base when the entry rule has a text field, so the call
-- rel32 and blob base stay consistent with the emit.
rule stdin_marshal_size
  @intention: "Total byte length of the stdin trampoline: prologue 88 + read loop 55 + per-field + arena suffix 25 + 8*nfields"
  @source: vexprparse.intent:66
  input:
    fl : FieldList
  output:
    out : number
  logic:
    out = 88 + 55 + stdin_fields_size(fl) + 25 + 8 * field_list_len(fl)
  proofs:
    purity:
      reads : [fl]
      calls : [stdin_fields_size, field_list_len]
    termination:
      bound : 64


-- x86_stdin_fields: emit the per-field marshalling. TEXT field: push the packed
-- span (region_off << 32 | r13) — the whole stdin was read into the region at
-- offset 0, so start = region_off (a compile-time constant) and len = r13 (the
-- read total). NUMBER field: inline atoi of argv[num_idx+1] at [r12+8*(num_idx+2)]
-- (the text field is NOT in argv, so number fields are indexed by number-order).
-- One push per field, declaration order, consumed by the arena suffix.
rule x86_stdin_fields
  @intention: "Emit per-field stdin marshalling: text field -> push packed (region_off, r13); number field -> atoi of the next argv"
  @source: vexprparse.intent:66
  input:
    ms : StdinMarshalState
  output:
    out : bytes
  logic:
    out = match ms.fields:
      FCons(name_start, name_len, ty, ty_start, ty_len, rest) => (if ty == 2 then concat(concat(b"\xb8", le32(ms.region_off), b"\x48\xc1\xe0\x20\x4c\x09\xe8\x50"), x86_stdin_fields(StdinMarshalState { fields: rest, num_idx: ms.num_idx, region_off: ms.region_off })) else concat(concat(b"\x49\x8b\xb4\x24", le32(8 * (ms.num_idx + 2)), b"\x48\x31\xc0\x45\x31\xdb\x8a\x0e\x80\xf9\x2d\x75\x06\x41\xb3\x01\x48\xff\xc6\x0f\xb6\x0e\x80\xf9\x30\x72\x15\x80\xf9\x39\x77\x10\x48\x6b\xc0\x0a\x48\x83\xe9\x30\x48\x01\xc8\x48\xff\xc6\xeb\xe3\x4d\x85\xdb\x74\x03\x48\xf7\xd8\x50"), x86_stdin_fields(StdinMarshalState { fields: rest, num_idx: ms.num_idx + 1, region_off: ms.region_off })))
      FNil => b""
  proofs:
    purity:
      reads : [ms.fields, ms.num_idx, ms.region_off]
      calls : [x86_stdin_fields]
    termination:
      bound : 512


-- x86_stdin_marshal: the whole stdin trampoline. Prologue (88 B): mov r12,rsp
-- (save argv base) ; argc guard (argc < 1+number_fields -> exit(1)) ;
-- mmap(0x20000000, 1 MiB, RW, MAP_FIXED|PRIVATE|ANON) with MAP_FAILED -> exit(1)
-- ; xor r13 (bump = 0). Read loop (55 B): read(0, 0x20000000+r13, 0x100000-r13)
-- until it returns 0 (EOF); rax<0 -> exit(1); r13 += rax; r13 >= 0x100000 ->
-- exit(1) (fail-closed: source bigger than the region). Then x86_stdin_fields
-- pushes one value per field (text = packed span into the region, number = atoi
-- of argv). Then the arena suffix (25 + 8*nfields) builds the entry node exactly
-- like x86_argv_marshal and pushes its index (the entry's single arg).
rule x86_stdin_marshal
  @intention: "Emit the full stdin trampoline: prologue (save argv, argc guard, mmap fixed region), read fd 0 to EOF, per-field marshal, arena node build, push index"
  @source: vexprparse.intent:66
  input:
    at : ArgvTrampState
  output:
    out : bytes
  logic:
    let src_base = 4194304 + blob_end_off(ProgGenState { rules: at.prog, src: at.src, off: 0, prog: at.prog, concepts: at.concepts, sizes: at.sizes })
    let region_base = 536870912
    let region_off = region_base - src_base
    let nfields = field_list_len(at.fields)
    let nnum = number_fields_count(at.fields)
    let entry_size = 8 * (max_payload_fields(at.concepts) + 1)
    let tag = at.cidx * 256
    out = concat(concat(b"\x49\x89\xe4\x49\x8b\x04\x24\x48\x3d", le32(1 + nnum), b"\x7d\x0c\xbf\x01\x00\x00\x00\xb8\x3c\x00\x00\x00\x0f\x05\xb8\x09\x00\x00\x00\xbf\x00\x00\x00\x20\xbe\x00\x00\x10\x00\xba\x03\x00\x00\x00\x41\xba\x32\x00\x00\x00\x49\xc7\xc0\xff\xff\xff\xff\x45\x31\xc9\x0f\x05\x48\x3d\x01\xf0\xff\xff\x72\x0c\xbf\x01\x00\x00\x00\xb8\x3c\x00\x00\x00\x0f\x05\x45\x31\xed\x31\xc0\x31\xff\xbe\x00\x00\x00\x20\x4c\x01\xee\xba\x00\x00\x10\x00\x4c\x29\xea\x0f\x05\x48\x85\xc0\x74\x1c\x78\x0e\x49\x01\xc5\x49\x81\xfd\x00\x00\x10\x00\x73\x02\xeb\xd5\xbf\x01\x00\x00\x00\xb8\x3c\x00\x00\x00\x0f\x05"), x86_stdin_fields(StdinMarshalState { fields: at.fields, num_idx: 0, region_off: region_off }), concat(b"\x4c\x89\xf0\x48\x69\xc0", le32(entry_size), b"\x4c\x01\xf8\x48\xc7\x00", le32(tag)), x86_field_pops(FieldPopState { fields: at.fields, slot: nfields - 1 }), b"\x41\x56\x49\xff\xc6")
  proofs:
    purity:
      reads : [at.fields, at.src, at.prog, at.concepts, at.sizes, at.cidx]
      calls : [blob_end_off, field_list_len, number_fields_count, max_payload_fields, x86_stdin_fields, x86_field_pops]
    termination:
      bound : 64


rule elf_program_src
  @intention: "Tokenize, parse a whole program, and wrap its x86-64 blob in a standalone static ELF64 executable"
  @source: vexprparse.intent:60
  input:
    s : ScanState
  output:
    out : bytes
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let concepts = parse_concepts(ProgramState { cell: toks, src: s.source })
    let sizes = proc_sizes(ProgGenState { rules: prog, src: s.source, off: 0, prog: prog, concepts: concepts, sizes: ProcSizeList::PSNil })
    let uses_var = program_uses_arena(concepts)
    let anytx = prog_any_texty(ProgGenState { rules: prog, src: s.source, off: 0, prog: prog, concepts: concepts, sizes: sizes })
    let entrytx = entry_rule_texty(ProgGenState { rules: prog, src: s.source, off: 0, prog: prog, concepts: concepts, sizes: sizes })
    let uses_text = if program_uses_text(UsesTextRules { rules: prog, src: s.source }) == 1 then 1 else anytx
    let fsz0 = blob_end_off(ProgGenState { rules: prog, src: s.source, off: 0, prog: prog, concepts: concepts, sizes: sizes })
    let fsz = fsz0 + (if uses_text == 1 then 4 * ((length(s.source) + 3) / 4) else 0)
    let entry_params = if param_list_len(rl_head_params(prog)) > 0 then rl_head_params(prog) else fields_to_params(rl_head_input(prog))
    let has_input = if param_list_len(entry_params) > 0 then 1 else 0
    let efields = params_to_fields(entry_params)
    let ecidx = find_concept_index(FindConceptIdxState { concepts: concepts, src: s.source, q_start: fl_head_ty_start(efields), q_len: fl_head_ty_len(efields), idx: 0 })
    out = concat(b"\x7f\x45\x4c\x46\x02\x01\x01\x00\x00\x00\x00\x00\x00\x00\x00\x00\x02\x00\x3e\x00\x01\x00\x00\x00\x78\x00\x40\x00\x00\x00\x00\x00\x40\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x40\x00\x38\x00\x01\x00\x00\x00\x00\x00\x00\x00", b"\x01\x00\x00\x00\x05\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x40\x00\x00\x00\x00\x00\x00\x00\x40\x00\x00\x00\x00\x00", le64(fsz), le64(fsz), b"\x00\x10\x00\x00\x00\x00\x00\x00", (if uses_var == 1 then b"\xb8\x09\x00\x00\x00\x31\xff\xbe\x00\x00\x00\x40\xba\x03\x00\x00\x00\x41\xba\x22\x00\x00\x00\x49\xc7\xc0\xff\xff\xff\xff\x45\x31\xc9\x0f\x05\x48\x3d\x01\xf0\xff\xff\x72\x0c\xbf\x01\x00\x00\x00\xb8\x3c\x00\x00\x00\x0f\x05\x49\x89\xc7\x45\x31\xf6" else b""), (if has_input == 1 and entrytx == 0 then (if field_list_has_text(cd_fields(concept_at_index(ConceptAtState { concepts: concepts, idx: ecidx }))) == 1 then x86_stdin_marshal(ArgvTrampState { fields: cd_fields(concept_at_index(ConceptAtState { concepts: concepts, idx: ecidx })), src: s.source, prog: prog, concepts: concepts, sizes: sizes, cidx: ecidx }) else x86_argv_marshal(ArgvTrampState { fields: cd_fields(concept_at_index(ConceptAtState { concepts: concepts, idx: ecidx })), src: s.source, prog: prog, concepts: concepts, sizes: sizes, cidx: ecidx })) else b""), (if entrytx == 1 then b"\xe8\x7e\x00\x00\x00\x6a\x0a\x48\xc7\xc0\x01\x00\x00\x00\x48\xc7\xc7\x01\x00\x00\x00\x48\x89\xe6\x48\xc7\xc2\x01\x00\x00\x00\x0f\x05\x48\xc7\xc0\x3c\x00\x00\x00\x48\x31\xff\x0f\x05" else concat(b"\xe8", le32(96 + (if anytx == 1 then 86 else 0)), b"\x48\x83\xec\x20\x49\x89\xc1\x48\x8d\x74\x24\x1f\xc6\x06\x0a\x48\x85\xc0\x79\x03\x48\xf7\xd8\x48\xc7\xc1\x0a\x00\x00\x00\x48\x31\xd2\x48\xf7\xf1\x80\xc2\x30\x48\xff\xce\x88\x16\x48\x85\xc0\x75\xed\x4d\x85\xc9\x79\x06\x48\xff\xce\xc6\x06\x2d\x48\x8d\x54\x24\x20\x48\x29\xf2\x48\xc7\xc0\x01\x00\x00\x00\x48\xc7\xc7\x01\x00\x00\x00\x0f\x05\x48\xc7\xc0\x3c\x00\x00\x00\x48\x31\xff\x0f\x05")), (if anytx == 1 then b"\x48\x83\xec\x28\x49\x89\xc1\x48\x8d\x74\x24\x20\x48\x85\xc0\x79\x03\x48\xf7\xd8\x48\xc7\xc1\x0a\x00\x00\x00\x48\x31\xd2\x48\xf7\xf1\x80\xc2\x30\x48\xff\xce\x88\x16\x48\x85\xc0\x75\xed\x4d\x85\xc9\x79\x06\x48\xff\xce\xc6\x06\x2d\x48\x8d\x54\x24\x20\x48\x29\xf2\x48\xc7\xc0\x01\x00\x00\x00\x48\xc7\xc7\x01\x00\x00\x00\x0f\x05\x48\x83\xc4\x28\xc3" else b""), x86_program(ProgGenState { rules: prog, src: s.source, off: 0, prog: prog, concepts: concepts, sizes: sizes }), (if uses_text == 1 then src_blob(SrcBlobState { src: s.source, pos: 0 }) else b""))
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, parse_concepts, proc_sizes, program_uses_arena, prog_any_texty, entry_rule_texty, program_uses_text, blob_end_off, x86_program, src_blob, param_list_len, rl_head_params, fields_to_params, rl_head_input, params_to_fields, find_concept_index, fl_head_ty_start, fl_head_ty_len, x86_argv_marshal, x86_stdin_marshal, field_list_has_text, cd_fields, concept_at_index]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 37 — LOWER A WHOLE PROGRAM to the stack IL (a function -> a routine).
-- Brick 36 lowered one EXPRESSION; this brick lowers every rule to a named
-- routine the IL VM can call. The calling convention: a routine is `proc NAME
-- p1 p2 ... <body ops> ret`; a call site emits its argument ops (left to right,
-- one value each) then `call NAME argc`; the VM pops argc values, binds them to
-- the callee's params by position into a fresh frame, runs the routine, and `ret`
-- pops the frame leaving the return value on the stack. `let` bindings lower to
-- `<value ops> store NAME`, sharing the frame's name->value map with the params,
-- so `load NAME` resolves either. Control flow is the brick-36 structured
-- `if`/`else`/`endif` (lazy — only the taken branch runs), which is what makes
-- RECURSION terminate: factorial's `else n * fact(n-1)` is NOT evaluated when
-- n == 0. Verified end-to-end: an IL VM (frames + call stack + structured if)
-- over lower_program_src(p) yields the SAME number as eval_main(p) — including
-- recursive factorial -> 120 (the streaming_lower_program test).
-- ============================================================================

-- lower_params: the routine header's parameter names, space-separated and bare
-- (the VM binds call args to these by position). PNil -> empty.
rule lower_params
  @intention: "Emit a routine's parameter names, space-separated, for the IL proc header"
  @source: vexprparse.intent:55
  input:
    pp : PrintParamsState
  output:
    out : text
  logic:
    out = match pp.params:
      PCons(name_start, name_len, ty, ty_start, ty_len, rest) => concat(substring(pp.src, name_start, name_start + name_len), " ", lower_params(PrintParamsState { params: rest, src: pp.src }))
      PNil => ""
  proofs:
    purity:
      reads : [pp.params, pp.src]
      calls : [lower_params]
    termination:
      bound : 4000


-- lower_binds: each `let NAME = expr` lowers to the value's ops followed by
-- `store NAME` (the VM pops and binds NAME in the current frame, so a later
-- `load NAME` finds it). Bindings stream in source order, so an earlier let is
-- bound before a later one references it. BNil -> empty.
rule lower_binds
  @intention: "Lower a rule's let-bindings to `<value ops> store NAME` sequences in source order"
  @source: vexprparse.intent:55
  input:
    pb : PrintBindsState
  output:
    out : text
  logic:
    out = match pb.binds:
      BCons(name_start, name_len, value, rest) => concat(lower_expr(PrintState { node: value, src: pb.src }), "store ", substring(pb.src, name_start, name_start + name_len), " ", lower_binds(PrintBindsState { binds: rest, src: pb.src }))
      BNil => ""
  proofs:
    purity:
      reads : [pb.binds, pb.src]
      calls : [lower_expr, lower_binds]
    termination:
      bound : 4000


-- lower_rule: one rule -> one IL routine. `proc NAME <params>` header, then the
-- let-bindings (as store ops), then the out-expression's ops, then `ret`. The
-- `\n` separators keep routines line-delimited so the VM can scan proc headers.
rule lower_rule
  @intention: "Lower one rule declaration to a named IL routine (proc header, body ops, ret)"
  @source: vexprparse.intent:55
  input:
    pr : PrintRuleState
  output:
    out : text
  logic:
    let ns = rd_name_start(pr.rd)
    let nl = rd_name_len(pr.rd)
    let blk = rd_body(pr.rd)
    let binds = block_binds(blk)
    let result = block_result(blk)
    out = concat("proc ", substring(pr.src, ns, ns + nl), " ", lower_params(PrintParamsState { params: rd_params(pr.rd), src: pr.src }), "\n", lower_binds(PrintBindsState { binds: binds, src: pr.src }), lower_expr(PrintState { node: result, src: pr.src }), "ret\n")
  proofs:
    purity:
      reads : [pr.rd, pr.src]
      calls : [rd_name_start, rd_name_len, rd_body, block_binds, block_result, rd_params, lower_params, lower_binds, lower_expr]
    termination:
      bound : 4000


-- lower_program: every rule, in source order, as its IL routine.
rule lower_program
  @intention: "Lower a whole program to its stack-IL routines, one proc per rule"
  @source: vexprparse.intent:55
  input:
    pg : PrintProgState
  output:
    out : text
  logic:
    out = match pg.rules:
      RCons(head, tail) => concat(lower_rule(PrintRuleState { rd: head, src: pg.src }), lower_program(PrintProgState { rules: tail, src: pg.src }))
      RNil => ""
  proofs:
    purity:
      reads : [pg.rules, pg.src]
      calls : [lower_rule, lower_program]
    termination:
      bound : 4000


-- lower_program_src: the brick-37 money-shot driver. Tokenize (with INDENT/DEDENT),
-- parse the whole program, and lower every rule to its IL routine. The first
-- Verbose program that compiles a multi-rule PROGRAM to a target other than its
-- source — a function becomes a callable routine, with params, frames, and
-- recursion-safe control flow.
--
--   lower_program_src("rule main\n  logic:\n    out = fact(5)\nrule fact(n)\n  logic:\n    out = if n == 0 then 1 else n * fact(n - 1)")
--     = "proc main \n5 call fact ret\nproc fact n \nload n 0 == if 1 else load n load n 1 - call fact * endif ret\n"
--   (a call carries no argc — the VM reads the callee proc's param count.) An IL
--   VM running proc main -> 120 (== eval_main of the same program).
--
-- NATIVE-ONLY (streaming text). Verified by the IL VM in streaming_lower_program.
rule lower_program_src
  @intention: "Tokenize, parse, and lower a whole program to its stack-IL routines"
  @source: vexprparse.intent:55
  input:
    s : ScanState
  output:
    out : text
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    out = lower_program(PrintProgState { rules: prog, src: s.source })
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, lower_program]
    termination:
      bound : 256


-- ============================================================================
-- BRICK 35 — PRINT A WHOLE PROGRAM (the full-file emitter half). Brick 34
-- printed one EXPRESSION; this brick prints every layer above it: rule headers
-- (name, typed parameter list, return-type annotation), the `logic:` line, the
-- `let` bindings, and the `out =` result line — with the 2-space / 4-space
-- indentation re-synthesized as text LITERALS ("  logic:\n", "    let ",
-- "    out = "). The target property is the FULL-FILE round-trip: the printed
-- program REPARSES to the same analyses (check_program, count_rules) and the
-- same evaluation (eval_main) as the original source.
--
-- NORMALIZATIONS (deliberate, all semantics-preserving — the printed form is
-- the parse's canonical spelling, not the original bytes):
--   * Untyped params print with an explicit type: brick 20 stores an untyped
--     parameter as ty=0, indistinguishable from an explicit `: number`, so the
--     printer always prints `name : <type>` — `rule f(n)` prints as
--     `rule f(n : number)`. Semantically identical (untyped defaults to
--     number), so every analysis and evaluation round-trips.
--   * Return type: the brick-33 sentinel 9 (UNANNOTATED) prints NOTHING;
--     0/1/2 print ` : number` / ` : bool` / ` : text`.
--   * PNil prints NO parens: `rule f()` normalizes to `rule f` (the parser
--     stores both as PNil, so the distinction is already gone at parse time).
--   * Expressions print fully parenthesized (brick 34's printer, reused).
--   * A bare final expression prints in the `out = ` form (the parser already
--     normalizes: block_result is the result expression either way).
--   * Indentation is re-synthesized: `logic:` at 2 spaces, statements at 4.
-- IDEMPOTENCE follows: print(parse(print(parse(s)))) == print(parse(s)),
-- because the printed form is already in canonical spelling.
--
-- Streaming posture: this grows the brick-34 text member set (print_expr /
-- print_args / print_args_rest / op_text) by six more members. Every text-SCC
-- call sits in a tail concat position; the lets in print_rule and the driver
-- build number/group values only (accessor calls — rd_*, block_*,
-- begin_tokenize, parse_program — none of which are text members), as the
-- streaming v1 grammar requires. ty_text / ret_text are non-recursive leaf
-- helpers like op_text; print_binds / print_params_rest / print_program are
-- cons-walk recursions like print_args_rest; print_rule / print_params are
-- non-recursive composers. Termination: bound-only + the accepted native
-- recursion breadcrumb (the list is a FIELD of the packed input, so
-- `structural` does not fit — print_expr's posture).
-- ============================================================================

concept TySpell
  @intention: "A declared type code, to be spelled as surface text"
  @source: vexprparse.intent:53
  fields:
    ty : number [0, 16]


concept PrintParamsState
  @intention: "A parameter list to print plus the source text its spans index into"
  @source: vexprparse.intent:53
  fields:
    params : ParamList
    src : text [..256]


concept PrintBindsState
  @intention: "A let-binding list to print plus the source text its spans index into"
  @source: vexprparse.intent:53
  fields:
    binds : Binding
    src : text [..256]


concept PrintRuleState
  @intention: "A rule declaration to print plus the source text its spans index into"
  @source: vexprparse.intent:53
  fields:
    rd : RuleDecl
    src : text [..256]


concept PrintProgState
  @intention: "A rule list to print plus the source text its spans index into"
  @source: vexprparse.intent:53
  fields:
    rules : RuleList
    src : text [..256]


-- ty_text: spell a type code as its surface text — the sibling of op_text
-- (flat if/else over the brick-19 code map: 0=number, 1=bool, 2=text).
-- Unknown code spells "?" (unreachable for parser-built params).
rule ty_text
  @intention: "Spell a declared type code as its surface text"
  @source: vexprparse.intent:53
  input:
    t : TySpell
  output:
    out : text
  logic:
    out = if t.ty == 0 then "number" else if t.ty == 1 then "bool" else if t.ty == 2 then "text" else "?"
  proofs:
    purity:
      reads : [t.ty]
      calls : []
    termination:
      bound : 64


-- ret_text: the return-type annotation, or nothing. The brick-33 sentinel 9
-- (UNANNOTATED) contributes the empty text; an explicit code prints
-- " : <type>". The ty_text call inside concat is a tail text position —
-- legal under the streaming v1 grammar, like op_text in print_expr's AstBin.
rule ret_text
  @intention: "Spell a rule's return-type annotation, empty for the unannotated sentinel"
  @source: vexprparse.intent:53
  input:
    t : TySpell
  output:
    out : text
  logic:
    out = if t.ty == 9 then "" else concat(" : ", ty_text(TySpell { ty: t.ty }))
  proofs:
    purity:
      reads : [t.ty]
      calls : [ty_text]
    termination:
      bound : 64


-- print_params: the full parameter list including parens. PNil prints NOTHING
-- (no parens — `rule f()` normalizes to `rule f`); PCons opens the paren,
-- prints the first param as `name : <type>` (ALWAYS typed — brick 20 stores
-- untyped params as ty=0, indistinguishable from explicit `: number`), then
-- hands the rest to print_params_rest, then closes. Same bare-first /
-- comma-rest split as print_args / print_args_rest.
rule print_params
  @intention: "Print a rule's parameter list with parens, each parameter explicitly typed"
  @source: vexprparse.intent:53
  input:
    pp : PrintParamsState
  output:
    out : text
  logic:
    out = match pp.params:
      PCons(name_start, name_len, ty, ty_start, ty_len, rest) => concat("(", substring(pp.src, name_start, name_start + name_len), " : ", ty_text(TySpell { ty: ty }), print_params_rest(PrintParamsState { params: rest, src: pp.src }), ")")
      PNil => ""
  proofs:
    purity:
      reads : [pp.params, pp.src]
      calls : [ty_text, print_params_rest]
    termination:
      bound : 4000


rule print_params_rest
  @intention: "Print the remaining parameters, each prefixed with a comma-space and explicitly typed"
  @source: vexprparse.intent:53
  input:
    pp : PrintParamsState
  output:
    out : text
  logic:
    out = match pp.params:
      PCons(name_start, name_len, ty, ty_start, ty_len, rest) => concat(", ", substring(pp.src, name_start, name_start + name_len), " : ", ty_text(TySpell { ty: ty }), print_params_rest(PrintParamsState { params: rest, src: pp.src }))
      PNil => ""
  proofs:
    purity:
      reads : [pp.params, pp.src]
      calls : [ty_text, print_params_rest]
    termination:
      bound : 4000


-- print_binds: one `    let name = expr` line per binding, each terminated by
-- a newline, indentation re-synthesized as the 4-space literal prefix. The
-- value expression goes through brick 34's print_expr (fully parenthesized).
rule print_binds
  @intention: "Print a rule's let bindings, one 4-space-indented line per binding"
  @source: vexprparse.intent:53
  input:
    pb : PrintBindsState
  output:
    out : text
  logic:
    out = match pb.binds:
      BCons(name_start, name_len, value, rest) => concat("    let ", substring(pb.src, name_start, name_start + name_len), " = ", print_expr(PrintState { node: value, src: pb.src }), "\n", print_binds(PrintBindsState { binds: rest, src: pb.src }))
      BNil => ""
  proofs:
    purity:
      reads : [pb.binds, pb.src]
      calls : [print_expr, print_binds]
    termination:
      bound : 4000


-- print_rule: one whole rule declaration — header line (`rule NAME(params)`
-- plus the optional return annotation), the `  logic:` line, the let lines,
-- and the `    out = expr` line, each layer delegated to its printer. The
-- lets build number/group values only (rd_* / block_* accessors — none are
-- text members), so the streaming v1 let constraint holds; the single big
-- concat in the body tail carries every text-SCC call in a direct-element
-- position. A bare final expression prints in the `out = ` form (the parser
-- already normalized it into block_result).
rule print_rule
  @intention: "Print one rule declaration: typed header, logic line, let lines, out line"
  @source: vexprparse.intent:53
  input:
    pr : PrintRuleState
  output:
    out : text
  logic:
    let ns = rd_name_start(pr.rd)
    let nl = rd_name_len(pr.rd)
    let blk = rd_body(pr.rd)
    let binds = block_binds(blk)
    let result = block_result(blk)
    out = concat("rule ", substring(pr.src, ns, ns + nl), print_params(PrintParamsState { params: rd_params(pr.rd), src: pr.src }), ret_text(TySpell { ty: rd_return_type(pr.rd) }), "\n  logic:\n", print_binds(PrintBindsState { binds: binds, src: pr.src }), "    out = ", print_expr(PrintState { node: result, src: pr.src }), "\n")
  proofs:
    purity:
      reads : [pr.rd, pr.src]
      calls : [rd_name_start, rd_name_len, rd_body, block_binds, block_result, rd_params, rd_return_type, print_params, ret_text, print_binds, print_expr]
    termination:
      bound : 4000


-- print_program: the whole RuleList, one printed rule after another in source
-- order (each print_rule output already ends with its own newline, so rules
-- abut directly — exactly the shape parse_program accepts back). RNil is the
-- empty program: empty text.
rule print_program
  @intention: "Print a parsed program: every rule declaration in source order"
  @source: vexprparse.intent:53
  input:
    pg : PrintProgState
  output:
    out : text
  logic:
    out = match pg.rules:
      RCons(head, tail) => concat(print_rule(PrintRuleState { rd: head, src: pg.src }), print_program(PrintProgState { rules: tail, src: pg.src }))
      RNil => ""
  proofs:
    purity:
      reads : [pg.rules, pg.src]
      calls : [print_rule, print_program]
    termination:
      bound : 4000


-- print_program_src: the brick-35 driver. Same front end as check_program /
-- count_rules / eval_main (begin_tokenize — a PROGRAM is multi-line, so the
-- printer must see the same INDENT/DEDENT stream parse_program consumes),
-- then hand the parsed RuleList + the source to the program printer. The lets
-- build group values only; the single text-producing call sits in the body
-- tail, as the streaming v1 grammar requires. Round-trip property (validated
-- externally, two binary invocations): for every program source s,
--   eval_main(print_program_src(s))     == eval_main(s)
--   check_program(print_program_src(s)) == check_program(s)
--   count_rules(print_program_src(s))   == count_rules(s)
rule print_program_src
  @intention: "Tokenize, parse a whole program, and print it back as canonical source"
  @source: vexprparse.intent:53
  input:
    s : ScanState
  output:
    out : text
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    out = print_program(PrintProgState { rules: prog, src: s.source })
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, print_program]
    termination:
      bound : 256


-- R6b money-shot driver: the TYPE CODE of the FIRST rule's body expression. Tokenize
-- + parse the program AND capture its ConceptList (parse_concepts), seed the type env
-- from the head rule's concept-typed INPUT fields (field_concept_tenv, so a `toks :
-- TokenList` input resolves the scrutinee), build the let-binding tenv on top, and
-- type the body via the concept-aware type_of_env. Returns a SCALAR code (0/1/2),
-- ERROR (3), or a CONCEPT code (1000 + index). The R6b soundness gate:
--   body_type("...group Token{Eof}... rule f\n  logic:\n    out = Token::Eof")            >= 1000 (Token, not 0)
--   body_type("... match toks: Cons(h, t) => h  Nil => Token::Eof")                       >= 1000 (h : Token; both arms Token)
--   body_type("... match toks: Cons(h, t) => h + 1  Nil => 0")                            = 3 (h is Token, not a number — UNSOUND case rejected)
--   body_type("... match toks: Cons(h, t) => Token::Eof  Nil => 0")                       = 3 (arms disagree: Token vs number)
-- NATIVE-ONLY (multi-line source). Source is argv arg 1, pos is argv arg 2 (always 0).
rule body_type
  @intention: "Tokenize, parse, and compute the concept-aware type code of the first rule's body expression"
  @source: vexprparse.intent:37
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = begin_tokenize(ScanState { source: s.source, pos: 0 })
    let prog = parse_program(ProgramState { cell: toks, src: s.source })
    let concepts = parse_concepts(ProgramState { cell: toks, src: s.source })
    let body = rl_head_body(prog)
    let binds = block_binds(body)
    let result = block_result(body)
    let start_env = field_concept_tenv(FieldConceptTenvState { fields: rl_head_input(prog), concepts: concepts, src: s.source })
    let tenv = build_tenv(BuildTArg { binds: binds, tenv: start_env, src: s.source, prog: prog, concepts: concepts })
    out = type_of_env(TypeArg { node: result, tenv: tenv, src: s.source, prog: prog, concepts: concepts })
  proofs:
    purity:
      reads : [s.source]
      calls : [begin_tokenize, parse_program, parse_concepts, rl_head_body, block_binds, block_result, field_concept_tenv, rl_head_input, build_tenv, type_of_env]
    termination:
      bound : 256


-- Entry driver: tokenize the source (from argv) and count the cons cells. The
-- money-shot observable for brick 8a: count_cells_src("1 + 2\n3 * 4") = 8
-- (tokens 1 + 2 Newline 3 * 4 then trailing Eof). Newline-bearing sources are
-- NATIVE-ONLY (the interpreter's JSON reader does not decode \n into a real
-- byte 10 — it passes the two bytes backslash-n verbatim), so multi-line counts
-- are checked via argv $'a\nb'; single-line counts cross-check native vs the
-- interpreter through the JSON fixture, exactly like brick 5/7's comma/string
-- cases. count_cells_src takes a ScanState (matching the .json fixture shape),
-- so it is the LAST rule in the file — the conventional "primary" the example
-- sweep test (all_examples_with_json_run_without_panicking) exercises against
-- the JSON records.
rule count_cells_src
  @intention: "Tokenize a source and count its token cons cells (multi-line aware)"
  @source: vexprparse.intent:26
  input:
    s : ScanState
  output:
    out : number
  logic:
    let toks = tokenize(ScanState { source: s.source, pos: 0 })
    out = count_cells(toks)
  proofs:
    purity:
      reads : [s.source]
      calls : [tokenize, count_cells]
    termination:
      bound : 256

