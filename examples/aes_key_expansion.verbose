    let b47 = band(bxor(b31, b43), 255)
    let b48 = band(bxor(bxor(b32, aes_sbox(Byte { b: b45 })), 4), 255)
    let b49 = band(bxor(b33, aes_sbox(Byte { b: b46 })), 255)
    let b50 = band(bxor(b34, aes_sbox(Byte { b: b47 })), 255)
    let b51 = band(bxor(b35, aes_sbox(Byte { b: b44 })), 255)
