@verbose 0.1.0

concept Byte
  @intention: "single byte 0..255"
  @source: aes_key_expansion.intent:1
  fields:
    b : number [0, 255]

concept MasterKey
  @intention: "16-byte AES-128 master key"
  @source: aes_key_expansion.intent:1
  fields:
    k0 : number [0, 255]
    k1 : number [0, 255]
    k2 : number [0, 255]
    k3 : number [0, 255]
    k4 : number [0, 255]
    k5 : number [0, 255]
    k6 : number [0, 255]
    k7 : number [0, 255]
    k8 : number [0, 255]
    k9 : number [0, 255]
    k10 : number [0, 255]
    k11 : number [0, 255]
    k12 : number [0, 255]
    k13 : number [0, 255]
    k14 : number [0, 255]
    k15 : number [0, 255]

concept RoundKeyByte
  @intention: "master key + round (0..10) + byte position (0..15)"
  @source: aes_key_expansion.intent:1
  fields:
    k0 : number [0, 255]
    k1 : number [0, 255]
    k2 : number [0, 255]
    k3 : number [0, 255]
    k4 : number [0, 255]
    k5 : number [0, 255]
