rule round_key
  @intention: "AES-128 KeyExpansion: returns byte `which` of round key `round` (round 0 = master key, 1..10 = expanded)"
  @source: aes_key_expansion.intent:3
  input:
    rk : RoundKeyByte
  output:
    out : number
  logic:
    let b0 = rk.k0
    let b1 = rk.k1
    let b2 = rk.k2
    let b3 = rk.k3
    let b4 = rk.k4
    let b5 = rk.k5
    let b6 = rk.k6
    let b7 = rk.k7
    let b8 = rk.k8
    let b9 = rk.k9
    let b10 = rk.k10
    let b11 = rk.k11
    let b12 = rk.k12
    let b13 = rk.k13
    let b14 = rk.k14
    let b15 = rk.k15
    let b16 = band(bxor(bxor(b0, aes_sbox(Byte { b: b13 })), 1), 255)
    let b17 = band(bxor(b1, aes_sbox(Byte { b: b14 })), 255)
    let b18 = band(bxor(b2, aes_sbox(Byte { b: b15 })), 255)
    let b19 = band(bxor(b3, aes_sbox(Byte { b: b12 })), 255)
    let b20 = band(bxor(b4, b16), 255)
    let b21 = band(bxor(b5, b17), 255)
    let b22 = band(bxor(b6, b18), 255)
    let b23 = band(bxor(b7, b19), 255)
    let b24 = band(bxor(b8, b20), 255)
    let b25 = band(bxor(b9, b21), 255)
    let b26 = band(bxor(b10, b22), 255)
    let b27 = band(bxor(b11, b23), 255)
    let b28 = band(bxor(b12, b24), 255)
    let b29 = band(bxor(b13, b25), 255)
    let b30 = band(bxor(b14, b26), 255)
    let b31 = band(bxor(b15, b27), 255)
    let b32 = band(bxor(bxor(b16, aes_sbox(Byte { b: b29 })), 2), 255)
    let b33 = band(bxor(b17, aes_sbox(Byte { b: b30 })), 255)
    let b34 = band(bxor(b18, aes_sbox(Byte { b: b31 })), 255)
    let b35 = band(bxor(b19, aes_sbox(Byte { b: b28 })), 255)
    let b36 = band(bxor(b20, b32), 255)
    let b37 = band(bxor(b21, b33), 255)
    let b38 = band(bxor(b22, b34), 255)
    let b39 = band(bxor(b23, b35), 255)
    let b40 = band(bxor(b24, b36), 255)
    let b41 = band(bxor(b25, b37), 255)
    let b42 = band(bxor(b26, b38), 255)
    let b43 = band(bxor(b27, b39), 255)
    let b44 = band(bxor(b28, b40), 255)
