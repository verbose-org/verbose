concept Product
  @intention: "A product has a name, a price, and a quantity in stock"
  @source: generated.intent:1

  fields:
    name     : text
    price    : number [0, 100000]
    quantity : number [0, 10000]


rule stock_value
  @intention: "The stock value is the price times the quantity"
  @source: generated.intent:2

  input:
    p : Product

  output:
    value : number

  logic:
    value = p.price * p.quantity

  proofs:
    purity:
      reads   : [p.price, p.quantity]
      calls   : []
      verdict : pure
    termination:
      form  : constant_bound
      bound : 1
    determinism:
      form : total

  hints:
    vectorizable : "pure arithmetic over two fields per record, no calls, no cross-element dependency"
    overflow     : [0, 1000000000]


rule low_stock
  @intention: "A product is low stock when its quantity is less than 10"
  @source: generated.intent:3

  input:
    p : Product

  output:
    is_low : bool

  logic:
    is_low = p.quantity < 10

  proofs:
    purity:
      reads   : [p.quantity]
      calls   : []
      verdict : pure
    termination:
      form  : constant_bound
      bound : 1
    determinism:
      form : total

  hints:
    vectorizable : "single-field threshold comparison; each record independent"


rule needs_reorder
  @intention: "A product needs reorder when it is low stock and its stock value exceeds 500"
  @source: generated.intent:4

  input:
    p : Product

  output:
    reorder : bool

  logic:
    reorder = low_stock(p) and stock_value(p) > 500

  proofs:
    purity:
      reads   : [p]
      calls   : [low_stock, stock_value]
      verdict : pure
    termination:
