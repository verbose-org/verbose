@verbose 0.1.0

concept Byte
  @intention: "single byte 0..255"
  @source: aes_encrypt.intent:1
  fields:
    b : number [0, 255]

concept EncryptInput
  @intention: "16-byte plaintext block + 16-byte AES-128 key + which output byte"
  @source: aes_encrypt.intent:1
  fields:
    p0 : number [0, 255]
    p1 : number [0, 255]
    p2 : number [0, 255]
    p3 : number [0, 255]
